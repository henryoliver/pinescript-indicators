            array.push(id = renderedLines, value = line.new(x1 = bar_index, y1 = prevSessionPoc, x2 = bar_index + extendBarsRight, y2 = prevSessionPoc, xloc = xloc.bar_index, extend = extend.none, color = overallLevelColor, width = 2, style = line.style_solid))
            array.push(id = renderedLines, value = line.new(x1 = bar_index, y1 = prevSessionVah, x2 = bar_index + extendBarsRight, y2 = prevSessionVah, xloc = xloc.bar_index, extend = extend.none, color = overallLevelColor, width = 3, style = line.style_solid))
        if valueAreaPlotVisible and showLevelLabels
            array.push(id = renderedLabels, value = label.new(x = f_labelX(leftX = pivotLabelLeftX, rightX = pivotLabelRightX), y = f_labelY(prevSessionVal), text = "VAL", xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = labelTextColor, color = NORD0, size = f_labelSize(sizeName = labelSizeInput), textalign = f_labelTextAlign()))
            array.push(id = renderedLabels, value = label.new(x = f_labelX(leftX = pivotLabelLeftX, rightX = pivotLabelRightX), y = f_labelY(prevSessionPoc), text = "POC", xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = labelTextColor, color = NORD0, size = f_labelSize(sizeName = labelSizeInput), textalign = f_labelTextAlign()))
