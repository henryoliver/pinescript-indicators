            array.push(id = renderedLabels, value = label.new(x = f_labelX(leftX = bar_index - extendBarsRight, rightX = bar_index + extendBarsRight), y = f_labelY(murreyPlot4), text = "4/8", xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = labelTextColor, color = NORD0, size = f_labelSize(sizeName = labelSizeInput), textalign = f_labelTextAlign()))
            array.push(id = renderedLabels, value = label.new(x = f_labelX(leftX = bar_index - extendBarsRight, rightX = bar_index + extendBarsRight), y = f_labelY(murreyPlot5), text = "5/8", xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = labelTextColor, color = NORD0, size = f_labelSize(sizeName = labelSizeInput), textalign = f_labelTextAlign()))
            array.push(id = renderedLabels, value = label.new(x = f_labelX(leftX = bar_index - extendBarsRight, rightX = bar_index + extendBarsRight), y = f_labelY(murreyPlot6), text = "6/8", xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = labelTextColor, color = NORD0, size = f_labelSize(sizeName = labelSizeInput), textalign = f_labelTextAlign()))
            array.push(id = renderedLabels, value = label.new(x = f_labelX(leftX = bar_index - extendBarsRight, rightX = bar_index + extendBarsRight), y = f_labelY(murreyPlot7), text = "7/8", xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = labelTextColor, color = NORD0, size = f_labelSize(sizeName = labelSizeInput), textalign = f_labelTextAlign()))
            array.push(id = renderedLabels, value = label.new(x = f_labelX(leftX = bar_index - extendBarsRight, rightX = bar_index + extendBarsRight), y = f_labelY(murreyPlot8), text = "8/8", xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = labelTextColor, color = NORD0, size = f_labelSize(sizeName = labelSizeInput), textalign = f_labelTextAlign()))
            array.push(id = renderedLabels, value = label.new(x = f_labelX(leftX = bar_index - extendBarsRight, rightX = bar_index + extendBarsRight), y = f_labelY(murreyExtendedHigh), text = "+4/8", xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = labelTextColor, color = NORD0, size = f_labelSize(sizeName = labelSizeInput), textalign = f_labelTextAlign()))

// 2. 📍 Floor Pivots Plots
plotPivotS4 = plot(series = pivotPlotVisible ? pivotS4 : na, title = "Pivot S4", color = pivotWeight1Color, linewidth = 1, style = plot.style_stepline)
plotPivotS3 = plot(series = pivotPlotVisible ? pivotS3 : na, title = "Pivot S3", color = pivotWeight1Color, linewidth = 1, style = plot.style_stepline)
plotPivotS2 = plot(series = pivotPlotVisible ? pivotS2 : na, title = "Pivot S2", color = pivotWeight1Color, linewidth = 1, style = plot.style_stepline)
plotPivotS1 = plot(series = pivotPlotVisible ? pivotS1 : na, title = "Pivot S1", color = pivotWeight2Color, linewidth = 2, style = plot.style_stepline)
plotPivotPP = plot(series = pivotPlotVisible ? pivotPoint : na, title = "Pivot PP", color = pivotWeight3Color, linewidth = 3, style = plot.style_stepline)
plotPivotR1 = plot(series = pivotPlotVisible ? pivotR1 : na, title = "Pivot R1", color = pivotWeight2Color, linewidth = 2, style = plot.style_stepline)
plotPivotR2 = plot(series = pivotPlotVisible ? pivotR2 : na, title = "Pivot R2", color = pivotWeight1Color, linewidth = 1, style = plot.style_stepline)
plotPivotR3 = plot(series = pivotPlotVisible ? pivotR3 : na, title = "Pivot R3", color = pivotWeight1Color, linewidth = 1, style = plot.style_stepline)
plotPivotR4 = plot(series = pivotPlotVisible ? pivotR4 : na, title = "Pivot R4", color = pivotWeight1Color, linewidth = 1, style = plot.style_stepline)

// 3. 📅 Previous Day Plots
plotPreviousDayHigh = plot(series = previousDayHighPlot, title = "Previous Day High", color = overallLevelColor, linewidth = 3, style = plot.style_stepline)
plotPreviousDayLow = plot(series = previousDayLowPlot, title = "Previous Day Low", color = overallLevelColor, linewidth = 3, style = plot.style_stepline)
