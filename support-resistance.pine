            for murreyPlotIndex = 0 to 8
                float murreyPlotLevelPrice = murreyLower + murreyStep * murreyPlotIndex
                int murreyPlotWeight = murreyPlotIndex == 0 or murreyPlotIndex == 4 or murreyPlotIndex == 8 ? 3 : murreyPlotIndex == 3 or murreyPlotIndex == 5 ? 2 : 1
                murreyPlotStyle = murreyPlotWeight == 3 ? line.style_solid : murreyPlotWeight == 2 ? line.style_dashed : line.style_dotted
