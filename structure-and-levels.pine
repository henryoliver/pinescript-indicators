//@version=6
indicator(title = "Structure & Levels", shorttitle = "🏗️ S&L", overlay = true, max_lines_count = 500, calc_bars_count = 5000)

// ═══════════════════════════════════════════════════════════════════════════════
// 🧱 CONSTANTS
// Shared immutable values used across the indicator, including the Nord palette.
// ═══════════════════════════════════════════════════════════════════════════════
// Nord Theme Colors
// Polar Night
const color NORD0 = #2E3440
const color NORD1 = #3B4252
const color NORD2 = #434C5E
const color NORD3 = #4C566A
// Snow Storm
const color NORD4 = #D8DEE9
const color NORD5 = #E5E9F0
const color NORD6 = #ECEFF4
// Frost
const color NORD7 = #8FBCBB
const color NORD8 = #88C0D0
const color NORD9 = #81A1C1
const color NORD10 = #5E81AC
// Aurora
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

// ═══════════════════════════════════════════════════════════════════════════════
// 🧩 TYPE DEFINITIONS
// Custom types keep related fields together and avoid parallel array drift.
// ═══════════════════════════════════════════════════════════════════════════════
enum LineStyle
    DOTTED = "Dotted"
    DASHED = "Dashed"
    SOLID  = "Solid"

enum LongTermColorMode
    DEFAULT          = "Default"
    AUTO_ZERO_AWARE  = "Auto Zero-Aware"
    FORCE_ZERO_AWARE = "Force Zero-Aware"

type TrendSegment
    int x1
    float y1
    int x2
    float y2

type IntradayLevel
    float price
    int barIndex

type LongTermPivotCandidate
    float price
    int htfBarIndex

type LongTermCluster
    float price
    int count

type KeyLevel
    float price
    int strength

// ═══════════════════════════════════════════════════════════════════════════════
// ⚙️ GENERAL
// Shared chart data, session state, and render orchestration state live here.
// ═══════════════════════════════════════════════════════════════════════════════
float chartClose = close
float chartHigh = high
float chartLow = low

// Running min/max of the chart symbol's own data. Used to decide whether zero is
// genuinely inside this symbol's price scale (true for breadth/cumulative studies
// like the Advance/Decline line or OBV, false for ordinary price symbols). This is
// derived from the chart itself, not the higher-timeframe security request, because
// that request returns na on many index/breadth tickers.
var float chartScaleMin = na
var float chartScaleMax = na
chartScaleMin := na(chartScaleMin) ? chartLow : math.min(chartScaleMin, chartLow)
chartScaleMax := na(chartScaleMax) ? chartHigh : math.max(chartScaleMax, chartHigh)
bool zeroWithinChartScale = not na(chartScaleMin) and not na(chartScaleMax) and chartScaleMin <= 0 and chartScaleMax >= 0

var int sessionStartBarIndex = na
var int latestRegularSessionDayKey = na
var array<line> renderedLines = array.new<line>()

f_clearLines(array<line> lines) =>
    int lineCount = array.size(id = lines)
    if lineCount > 0
        for lineIndex = 0 to lineCount - 1
            line.delete(id = array.get(id = lines, index = lineIndex))
    array.clear(id = lines)

bool inRegularSession = session.ismarket
int regularSessionDayKey = year * 10000 + month * 100 + dayofmonth
int currentTradingDayKey = year(time = timenow) * 10000 + month(time = timenow) * 100 + dayofmonth(time = timenow)
bool isCurrentTradingDay = regularSessionDayKey == currentTradingDayKey
bool isNewTrackedSession = inRegularSession and isCurrentTradingDay and (na(latestRegularSessionDayKey) or regularSessionDayKey != latestRegularSessionDayKey)

if isNewTrackedSession
    latestRegularSessionDayKey := regularSessionDayKey
    sessionStartBarIndex := bar_index

// ═══════════════════════════════════════════════════════════════════════════════
// 🗺️ LONG-TERM S/R
// Higher-timeframe pivot clustering builds the repeated support/resistance map.
// ═══════════════════════════════════════════════════════════════════════════════
const string GROUP_GENERAL = "⚙️ General"
const string GROUP_LONG_TERM = "🗺️ Long-Term Support/Resistance"
const int LONG_TERM_MAX_BARS = 1200
const int LONG_TERM_PIVOT_STRENGTH = 5
// Assumes US equities regular trading hours (09:30–16:00 ET); symbols with a
// different session length scale the bars-per-day estimate proportionally.
const int REGULAR_SESSION_MINUTES = 390
const color LONG_TERM_STRUCTURE_COLOR = color.new(color = NORD3, transp = 60)

bool showLongTermZeroLine = input.bool(defval = false, title = "Show Zero Line", tooltip = "Draws a zero baseline for symbols that oscillate above and below zero, such as cumulative or breadth-style studies.", group = GROUP_GENERAL)
color longTermZeroLineColor = input.color(defval = NORD3, title = "Zero Line Color", tooltip = "Color used for the optional zero baseline.", group = GROUP_GENERAL)
int longTermZeroLineWidth = input.int(defval = 2, title = "Zero Line Width", minval = 1, maxval = 4, tooltip = "Line width for the optional zero baseline.", group = GROUP_GENERAL)
LineStyle longTermZeroLineStyleInput = input.enum(defval = LineStyle.SOLID, title = "Zero Line Style", tooltip = "Style used for the optional zero baseline.", group = GROUP_GENERAL)

bool showLongTermStructure = input.bool(defval = true, title = "Show Long-Term S/R", tooltip = "Draws repeated-pivot support/resistance zones from the current chart symbol using a higher timeframe lookback.", group = GROUP_LONG_TERM)
string longTermTimeframe = input.timeframe(defval = "15", title = "Structure Timeframe", tooltip = "Higher timeframe used to build repeated pivot clusters for long-term support and resistance.", group = GROUP_LONG_TERM)
int longTermLookbackDays = input.int(defval = 22, title = "Lookback (Trading Days)", minval = 10, maxval = 90, tooltip = "How many trading days of higher-timeframe pivots are scanned for repeated levels.", group = GROUP_LONG_TERM)
int longTermLevelsPerSide = input.int(defval = 4, title = "Levels Above/Below Price", minval = 1, maxval = 6, tooltip = "Maximum long-term levels to keep visible above and below the current price.", group = GROUP_LONG_TERM)
LongTermColorMode longTermColorMode = input.enum(defval = LongTermColorMode.AUTO_ZERO_AWARE, title = "Line Color Mode", tooltip = "Default keeps the existing neutral color. Auto Zero-Aware switches to blue above zero and red below zero only when the symbol trades on both sides of zero. Force Zero-Aware applies that split coloring regardless.", group = GROUP_LONG_TERM)

if showLongTermStructure and timeframe.in_seconds() > timeframe.in_seconds(timeframe = longTermTimeframe)
    runtime.error(message = "Structure & Levels: chart timeframe is above the Long-Term S/R structure timeframe (" + longTermTimeframe + "). Raise the Structure Timeframe or disable Long-Term S/R.")

f_longTermLookbackBars(string structureTimeframe, int tradingDays) =>
    int tfSeconds = timeframe.in_seconds(timeframe = structureTimeframe)
    int barsPerDay = tfSeconds < 86400 ? math.max(1, math.ceil(number = REGULAR_SESSION_MINUTES / math.max(tfSeconds / 60.0, 1.0))) : 1
    math.min(LONG_TERM_MAX_BARS, barsPerDay * tradingDays)

f_selectRepeatedKeyLevels(array<LongTermPivotCandidate> candidates, series float tolerance) =>
    array<LongTermCluster> clusters = array.new<LongTermCluster>()
    int candidateCount = array.size(id = candidates)
    if candidateCount > 0
        array<float> sortedPrices = array.new<float>()
        for candidateIndex = 0 to candidateCount - 1
            LongTermPivotCandidate candidate = array.get(id = candidates, index = candidateIndex)
            array.push(id = sortedPrices, value = candidate.price)
        array.sort(id = sortedPrices, order = order.ascending)
        for sortedIndex = 0 to array.size(id = sortedPrices) - 1
            float candidatePrice = array.get(id = sortedPrices, index = sortedIndex)
            int clusterCount = array.size(id = clusters)
            if clusterCount == 0
                array.push(id = clusters, value = LongTermCluster.new(price = candidatePrice, count = 1))
            else
                int lastClusterIndex = clusterCount - 1
                LongTermCluster previousCluster = array.get(id = clusters, index = lastClusterIndex)
                float previousPrice = previousCluster.price
                if candidatePrice - previousPrice > tolerance
                    array.push(id = clusters, value = LongTermCluster.new(price = candidatePrice, count = 1))
                else
                    int updatedCount = previousCluster.count + 1
                    float updatedPrice = (previousPrice * previousCluster.count + candidatePrice) / updatedCount
                    array.set(id = clusters, index = lastClusterIndex, value = LongTermCluster.new(price = updatedPrice, count = updatedCount))
    int sortedClusterCount = array.size(id = clusters)
    if sortedClusterCount > 1
        for outerIndex = 1 to sortedClusterCount - 1
            LongTermCluster sortCluster = array.get(id = clusters, index = outerIndex)
            int innerIndex = outerIndex - 1
            while innerIndex >= 0 and array.get(id = clusters, index = innerIndex).count < sortCluster.count
                array.set(id = clusters, index = innerIndex + 1, value = array.get(id = clusters, index = innerIndex))
                innerIndex -= 1
            array.set(id = clusters, index = innerIndex + 1, value = sortCluster)
    array<KeyLevel> selectedLevels = array.new<KeyLevel>()
    if sortedClusterCount > 0
        for selectedIndex = 0 to sortedClusterCount - 1
            LongTermCluster cluster = array.get(id = clusters, index = selectedIndex)
            if cluster.count >= 2
                array.push(id = selectedLevels, value = KeyLevel.new(price = cluster.price, strength = cluster.count))
    selectedLevels

f_lineWidthFromStrength(int strength) =>
    strength >= 5 ? 4 : strength >= 4 ? 3 : strength >= 3 ? 2 : 1

f_longTermIsZeroAware(LongTermColorMode colorMode, float windowHigh, float windowLow) =>
    colorMode == LongTermColorMode.FORCE_ZERO_AWARE or (colorMode == LongTermColorMode.AUTO_ZERO_AWARE and not na(windowHigh) and not na(windowLow) and windowHigh > 0 and windowLow < 0)

f_longTermLevelColor(bool zeroAwareMode, float levelPrice) =>
    zeroAwareMode ? color.new(color = levelPrice >= 0 ? NORD8 : NORD11, transp = 80) : LONG_TERM_STRUCTURE_COLOR

f_renderLongTermStructure(array<line> lines, array<KeyLevel> keyLevels, int levelsPerSide, float referencePrice, bool zeroAwareMode, float zeroLevelExclusionDistance) =>
    int renderedAboveCount = 0
    int renderedBelowCount = 0
    int keyLevelCount = array.size(id = keyLevels)
    if keyLevelCount > 0
        for keyLevelIndex = 0 to keyLevelCount - 1
            KeyLevel keyLevel = array.get(id = keyLevels, index = keyLevelIndex)
            bool isTooCloseToZero = zeroAwareMode and math.abs(number = keyLevel.price) <= zeroLevelExclusionDistance
            if keyLevel.price >= referencePrice and renderedAboveCount < levelsPerSide and not isTooCloseToZero
                int aboveWidth = f_lineWidthFromStrength(strength = keyLevel.strength)
                color aboveColor = f_longTermLevelColor(zeroAwareMode = zeroAwareMode, levelPrice = keyLevel.price)
                line aboveLine = line.new(x1 = bar_index - 1, y1 = keyLevel.price, x2 = bar_index, y2 = keyLevel.price, xloc = xloc.bar_index, extend = extend.both, color = aboveColor, width = aboveWidth, style = line.style_solid)
                array.push(id = lines, value = aboveLine)
                renderedAboveCount += 1
            if keyLevel.price < referencePrice and renderedBelowCount < levelsPerSide and not isTooCloseToZero
                int belowWidth = f_lineWidthFromStrength(strength = keyLevel.strength)
                color belowColor = f_longTermLevelColor(zeroAwareMode = zeroAwareMode, levelPrice = keyLevel.price)
                line belowLine = line.new(x1 = bar_index - 1, y1 = keyLevel.price, x2 = bar_index, y2 = keyLevel.price, xloc = xloc.bar_index, extend = extend.both, color = belowColor, width = belowWidth, style = line.style_solid)
                array.push(id = lines, value = belowLine)
                renderedBelowCount += 1

int longTermLookbackBars = f_longTermLookbackBars(structureTimeframe = longTermTimeframe, tradingDays = longTermLookbackDays)
bool newLongTermBar = showLongTermStructure ? ta.change(source = time(timeframe = longTermTimeframe)) != 0 : false
float longTermConfirmedPivotHigh = na
float longTermConfirmedPivotLow = na
float longTermWindowHigh = na
float longTermWindowLow = na
float longTermClose = na
var string longTermRegularTicker = ticker.modify(tickerid = syminfo.tickerid, session = session.regular)
[requestedLongTermConfirmedPivotHigh, requestedLongTermConfirmedPivotLow, requestedLongTermWindowHigh, requestedLongTermWindowLow, requestedLongTermClose] = request.security(
     symbol = longTermRegularTicker,
     timeframe = longTermTimeframe,
     expression = [ta.pivothigh(source = high, leftbars = LONG_TERM_PIVOT_STRENGTH, rightbars = LONG_TERM_PIVOT_STRENGTH), ta.pivotlow(source = low, leftbars = LONG_TERM_PIVOT_STRENGTH, rightbars = LONG_TERM_PIVOT_STRENGTH), ta.highest(source = high, length = longTermLookbackBars), ta.lowest(source = low, length = longTermLookbackBars), close],
     lookahead = barmerge.lookahead_off,
     gaps = barmerge.gaps_off,
     ignore_invalid_symbol = true
 )
longTermConfirmedPivotHigh := requestedLongTermConfirmedPivotHigh
longTermConfirmedPivotLow := requestedLongTermConfirmedPivotLow
longTermWindowHigh := requestedLongTermWindowHigh
longTermWindowLow := requestedLongTermWindowLow
longTermClose := requestedLongTermClose

var array<LongTermPivotCandidate> longTermPivotCandidates = array.new<LongTermPivotCandidate>()
var array<KeyLevel> longTermKeyLevels = array.new<KeyLevel>()
var int longTermHTFBarCount = 0
var bool longTermKeysDirty = false
var float longTermClusterTolerance = na

if not showLongTermStructure
    array.clear(id = longTermPivotCandidates)
    array.clear(id = longTermKeyLevels)
    longTermHTFBarCount := 0
    longTermKeysDirty := false
    longTermClusterTolerance := na

// Candidates accumulate on every confirmed HTF bar — including the current trading
// day, so nothing is lost when the chart stays open across a day boundary. Only the
// key-level rebuild is frozen during the live session; the first eligible HTF bar of
// the next day rebuilds the map from the complete candidate set. The window-ready
// guard skips the HTF warmup where ta.highest/ta.lowest are still na and the cluster
// tolerance would degenerate into a single mega-cluster.
bool longTermWindowReady = not na(longTermWindowHigh) and not na(longTermWindowLow)
if showLongTermStructure and newLongTermBar and not na(longTermClose[1]) and longTermWindowReady
    longTermHTFBarCount += 1
    int oldestAllowedPivotBar = math.max(1, longTermHTFBarCount - longTermLookbackBars + 1)

    if not na(longTermConfirmedPivotHigh)
        array.push(id = longTermPivotCandidates, value = LongTermPivotCandidate.new(price = longTermConfirmedPivotHigh, htfBarIndex = math.max(1, longTermHTFBarCount - LONG_TERM_PIVOT_STRENGTH)))
        longTermKeysDirty := true

    if not na(longTermConfirmedPivotLow)
        array.push(id = longTermPivotCandidates, value = LongTermPivotCandidate.new(price = longTermConfirmedPivotLow, htfBarIndex = math.max(1, longTermHTFBarCount - LONG_TERM_PIVOT_STRENGTH)))
        longTermKeysDirty := true

    while array.size(id = longTermPivotCandidates) > 0
        LongTermPivotCandidate oldestCandidate = array.get(id = longTermPivotCandidates, index = 0)
        if oldestCandidate.htfBarIndex < oldestAllowedPivotBar
            array.shift(id = longTermPivotCandidates)
            longTermKeysDirty := true
        else
            break

    if longTermKeysDirty and not isCurrentTradingDay
        if array.size(id = longTermPivotCandidates) > 0
            float longTermRange = math.max(longTermWindowHigh - longTermWindowLow, syminfo.mintick)
            longTermClusterTolerance := math.max(syminfo.mintick * 2.0, longTermRange * 0.025)
            longTermKeyLevels := f_selectRepeatedKeyLevels(candidates = longTermPivotCandidates, tolerance = longTermClusterTolerance)
        else
            array.clear(id = longTermKeyLevels)
            longTermClusterTolerance := na
        longTermKeysDirty := false

// ═══════════════════════════════════════════════════════════════════════════════
// 📍 INTRADAY S/R
// Session pivots become visible support and resistance levels for the current day.
// ═══════════════════════════════════════════════════════════════════════════════
const string GROUP_INTRADAY_SR = "📍 Intraday Support/Resistance"
const int INTRADAY_MAX_LEVELS = 80
const int INTRADAY_DEFAULT_LINE_WIDTH = 2
const color INTRADAY_STRUCTURE_COLOR = NORD3

bool showIntradayStructure = input.bool(defval = true, title = "Show Intraday S/R", tooltip = "Draws intraday support/resistance from confirmed body pivots in the current session.", group = GROUP_INTRADAY_SR)
int intradaySRPivotStrength = input.int(defval = 3, title = "Pivot Strength", minval = 1, maxval = 10, tooltip = "Bars required on each side to confirm an intraday pivot. Higher values reduce noise but react later.", group = GROUP_INTRADAY_SR)
int intradaySRMaxLevels = input.int(defval = 20, title = "Stored Levels", minval = 5, maxval = INTRADAY_MAX_LEVELS, tooltip = "Maximum confirmed intraday pivots kept in memory before selecting the nearest active support and resistance.", group = GROUP_INTRADAY_SR)
int intradaySRForwardBars = input.int(defval = 60, title = "Forward Bars", minval = 1, maxval = 200, tooltip = "Single control for how far each intraday support/resistance line extends forward from its pivot bar. Lines always reach at least the current bar.", group = GROUP_INTRADAY_SR)
int intradaySRLineWidth = input.int(defval = INTRADAY_DEFAULT_LINE_WIDTH, title = "Line Width", minval = 1, maxval = 4, tooltip = "Line width for the nearest intraday support and resistance levels.", group = GROUP_INTRADAY_SR)

f_trimIntradayLevels(array<IntradayLevel> levels, int maxSize) =>
    while array.size(id = levels) > maxSize
        array.shift(id = levels)

f_selectVisibleIntradayLevels(array<IntradayLevel> levels, float referencePrice, int visiblePerSide, bool isResistance) =>
    array<IntradayLevel> visibleLevels = array.new<IntradayLevel>()
    int levelCount = array.size(id = levels)
    if levelCount > 0
        for levelIndex = 0 to levelCount - 1
            IntradayLevel candidateLevel = array.get(id = levels, index = levelIndex)
            bool isOnCorrectSide = isResistance ? candidateLevel.price > referencePrice : candidateLevel.price < referencePrice
            if isOnCorrectSide
                float candidateDistance = math.abs(number = candidateLevel.price - referencePrice)
                int insertIndex = array.size(id = visibleLevels)
                int visibleCount = array.size(id = visibleLevels)
                if visibleCount > 0
                    for visibleIndex = 0 to visibleCount - 1
                        IntradayLevel visibleLevel = array.get(id = visibleLevels, index = visibleIndex)
                        float visibleDistance = math.abs(number = visibleLevel.price - referencePrice)
                        if candidateDistance < visibleDistance
                            insertIndex := visibleIndex
                            break
                if insertIndex < visiblePerSide
                    array.insert(id = visibleLevels, index = insertIndex, value = candidateLevel)
                    if array.size(id = visibleLevels) > visiblePerSide
                        array.pop(id = visibleLevels)
    visibleLevels

f_renderIntradayStructure(array<line> lines, array<IntradayLevel> resistanceLevels, array<IntradayLevel> supportLevels, int sessionStartBar, int forwardBars, int lineWidth, float referencePrice) =>
    array<IntradayLevel> visibleResistanceLevels = f_selectVisibleIntradayLevels(levels = resistanceLevels, referencePrice = referencePrice, visiblePerSide = 1, isResistance = true)
    array<IntradayLevel> visibleSupportLevels = f_selectVisibleIntradayLevels(levels = supportLevels, referencePrice = referencePrice, visiblePerSide = 1, isResistance = false)

    int resistanceCount = array.size(id = visibleResistanceLevels)
    if resistanceCount > 0
        for resistanceIndex = 0 to resistanceCount - 1
            IntradayLevel resistanceLevel = array.get(id = visibleResistanceLevels, index = resistanceIndex)
            if resistanceLevel.barIndex >= sessionStartBar
                int resistanceEndBar = math.max(resistanceLevel.barIndex + forwardBars, bar_index)
                line resistanceLine = line.new(x1 = resistanceLevel.barIndex, y1 = resistanceLevel.price, x2 = resistanceEndBar, y2 = resistanceLevel.price, xloc = xloc.bar_index, extend = extend.none, color = INTRADAY_STRUCTURE_COLOR, width = lineWidth, style = line.style_solid)
                array.push(id = lines, value = resistanceLine)

    int supportCount = array.size(id = visibleSupportLevels)
    if supportCount > 0
        for supportIndex = 0 to supportCount - 1
            IntradayLevel supportLevel = array.get(id = visibleSupportLevels, index = supportIndex)
            if supportLevel.barIndex >= sessionStartBar
                int supportEndBar = math.max(supportLevel.barIndex + forwardBars, bar_index)
                line supportLine = line.new(x1 = supportLevel.barIndex, y1 = supportLevel.price, x2 = supportEndBar, y2 = supportLevel.price, xloc = xloc.bar_index, extend = extend.none, color = INTRADAY_STRUCTURE_COLOR, width = lineWidth, style = line.style_solid)
                array.push(id = lines, value = supportLine)

float intradaySRPivotHigh = showIntradayStructure ? ta.pivothigh(source = chartHigh, leftbars = intradaySRPivotStrength, rightbars = intradaySRPivotStrength) : na
float intradaySRPivotLow = showIntradayStructure ? ta.pivotlow(source = chartLow, leftbars = intradaySRPivotStrength, rightbars = intradaySRPivotStrength) : na
int intradaySRPivotHighBar = not na(intradaySRPivotHigh) ? bar_index - intradaySRPivotStrength : na
int intradaySRPivotLowBar = not na(intradaySRPivotLow) ? bar_index - intradaySRPivotStrength : na

var array<IntradayLevel> intradayResistanceLevels = array.new<IntradayLevel>()
var array<IntradayLevel> intradaySupportLevels = array.new<IntradayLevel>()

if isNewTrackedSession
    array.clear(id = intradayResistanceLevels)
    array.clear(id = intradaySupportLevels)

if not showIntradayStructure
    array.clear(id = intradayResistanceLevels)
    array.clear(id = intradaySupportLevels)

if showIntradayStructure and inRegularSession and isCurrentTradingDay and barstate.isconfirmed and not na(sessionStartBarIndex)
    if not na(intradaySRPivotHigh) and intradaySRPivotHighBar >= sessionStartBarIndex
        array.push(id = intradayResistanceLevels, value = IntradayLevel.new(price = intradaySRPivotHigh, barIndex = intradaySRPivotHighBar))
        f_trimIntradayLevels(levels = intradayResistanceLevels, maxSize = intradaySRMaxLevels)

    if not na(intradaySRPivotLow) and intradaySRPivotLowBar >= sessionStartBarIndex
        array.push(id = intradaySupportLevels, value = IntradayLevel.new(price = intradaySRPivotLow, barIndex = intradaySRPivotLowBar))
        f_trimIntradayLevels(levels = intradaySupportLevels, maxSize = intradaySRMaxLevels)

// ═══════════════════════════════════════════════════════════════════════════════
// 📐 INTRADAY TREND LINES
// Confirmed session pivots define the higher-low and lower-high trend segments; a
// close through a segment retires it.
// ═══════════════════════════════════════════════════════════════════════════════
const string GROUP_TREND = "📐 Intraday Trend Lines"
const int TREND_DEFAULT_LINE_WIDTH = 2

bool showTrendLines = input.bool(defval = true, title = "Show Trend Lines", tooltip = "Draws intraday trend lines from confirmed higher-lows / lower-highs in the current session. Up and down lines can show together as a channel; a line is removed once price closes through it.", group = GROUP_TREND)
int trendLinePivotStrength = input.int(defval = 3, title = "Pivot Strength", minval = 1, maxval = 10, tooltip = "Bars required on each side to confirm a trend pivot. Higher values create fewer, stronger trend lines.", group = GROUP_TREND)
int trendLineWidth = input.int(defval = TREND_DEFAULT_LINE_WIDTH, title = "Line Width", minval = 1, maxval = 4, tooltip = "Line width for the intraday trend lines.", group = GROUP_TREND)
int trendLineLookbackBars = input.int(defval = 60, title = "Lookback (Bars)", minval = 10, maxval = 200, tooltip = "Only trend segments anchored inside this recent window are eligible for display.", group = GROUP_TREND)
int trendLineProjectionBars = input.int(defval = 60, title = "Projection (Bars)", minval = 1, maxval = 200, tooltip = "How far each trend line projects forward.", group = GROUP_TREND)
LineStyle trendLineStyleInput = input.enum(defval = LineStyle.DOTTED, title = "Style", tooltip = "Line style for the intraday trend lines.", group = GROUP_TREND)

f_trendLineStyle(LineStyle styleInput) =>
    styleInput == LineStyle.SOLID ? line.style_solid : styleInput == LineStyle.DASHED ? line.style_dashed : line.style_dotted

f_lineValueAtBar(int x1, float y1, int x2, float y2, int targetBar) =>
    x2 == x1 ? y2 : y1 + (y2 - y1) * (targetBar - x1) / (x2 - x1)

f_isTrendSegmentRelevant(TrendSegment segment, float referencePrice, float recentRange) =>
    float projectedPrice = f_lineValueAtBar(x1 = segment.x1, y1 = segment.y1, x2 = segment.x2, y2 = segment.y2, targetBar = bar_index)
    math.abs(number = projectedPrice - referencePrice) <= recentRange * 0.75

f_renderTrendSegment(array<line> lines, TrendSegment segment, int visibleWindowStart, int projectionBars, int lineWidth, string trendStyle) =>
    int trendVisibleStart = math.max(segment.x1, visibleWindowStart)
    int trendEndBar = bar_index + projectionBars
    if trendEndBar > trendVisibleStart
        float trendVisibleStartY = f_lineValueAtBar(x1 = segment.x1, y1 = segment.y1, x2 = segment.x2, y2 = segment.y2, targetBar = trendVisibleStart)
        float trendVisibleEndY = f_lineValueAtBar(x1 = segment.x1, y1 = segment.y1, x2 = segment.x2, y2 = segment.y2, targetBar = trendEndBar)
        line trendLine = line.new(x1 = trendVisibleStart, y1 = trendVisibleStartY, x2 = trendEndBar, y2 = trendVisibleEndY, xloc = xloc.bar_index, extend = extend.none, color = NORD3, width = lineWidth, style = trendStyle)
        array.push(id = lines, value = trendLine)

f_renderTrendLines(array<line> lines, TrendSegment upTrendSegment, TrendSegment downTrendSegment, int sessionStartBar, int lookbackBars, int projectionBars, int lineWidth, LineStyle styleInput, float referencePrice, float recentRange) =>
    string resolvedTrendStyle = f_trendLineStyle(styleInput = styleInput)
    int trendVisibleWindowStart = math.max(0, bar_index - lookbackBars + 1)

    bool hasDownTrend = not na(downTrendSegment) and downTrendSegment.x1 >= sessionStartBar and downTrendSegment.x2 >= trendVisibleWindowStart and f_isTrendSegmentRelevant(segment = downTrendSegment, referencePrice = referencePrice, recentRange = recentRange)
    bool hasUpTrend = not na(upTrendSegment) and upTrendSegment.x1 >= sessionStartBar and upTrendSegment.x2 >= trendVisibleWindowStart and f_isTrendSegmentRelevant(segment = upTrendSegment, referencePrice = referencePrice, recentRange = recentRange)

    if hasDownTrend
        f_renderTrendSegment(lines = lines, segment = downTrendSegment, visibleWindowStart = trendVisibleWindowStart, projectionBars = projectionBars, lineWidth = lineWidth, trendStyle = resolvedTrendStyle)
    if hasUpTrend
        f_renderTrendSegment(lines = lines, segment = upTrendSegment, visibleWindowStart = trendVisibleWindowStart, projectionBars = projectionBars, lineWidth = lineWidth, trendStyle = resolvedTrendStyle)

float trendPivotHigh = showTrendLines ? ta.pivothigh(source = chartHigh, leftbars = trendLinePivotStrength, rightbars = trendLinePivotStrength) : na
float trendPivotLow = showTrendLines ? ta.pivotlow(source = chartLow, leftbars = trendLinePivotStrength, rightbars = trendLinePivotStrength) : na
float trendRecentRange = showTrendLines ? math.max(ta.highest(source = high, length = trendLineLookbackBars) - ta.lowest(source = low, length = trendLineLookbackBars), syminfo.mintick * 20.0) : na
int trendPivotHighBar = not na(trendPivotHigh) ? bar_index - trendLinePivotStrength : na
int trendPivotLowBar = not na(trendPivotLow) ? bar_index - trendLinePivotStrength : na

var float previousTrendHighLevel = na
var int previousTrendHighBar = na
var float previousTrendLowLevel = na
var int previousTrendLowBar = na
var TrendSegment activeUpTrend = na
var TrendSegment activeDownTrend = na

if isNewTrackedSession
    previousTrendHighLevel := na
    previousTrendHighBar := na
    previousTrendLowLevel := na
    previousTrendLowBar := na
    activeUpTrend := na
    activeDownTrend := na

if not showTrendLines
    previousTrendHighLevel := na
    previousTrendHighBar := na
    previousTrendLowLevel := na
    previousTrendLowBar := na
    activeUpTrend := na
    activeDownTrend := na

if showTrendLines and inRegularSession and isCurrentTradingDay and barstate.isconfirmed and not na(sessionStartBarIndex)
    if not na(trendPivotHigh) and trendPivotHighBar >= sessionStartBarIndex
        if not na(previousTrendHighLevel) and trendPivotHigh < previousTrendHighLevel
            activeDownTrend := TrendSegment.new(x1 = previousTrendHighBar, y1 = previousTrendHighLevel, x2 = trendPivotHighBar, y2 = trendPivotHigh)
        previousTrendHighLevel := trendPivotHigh
        previousTrendHighBar := trendPivotHighBar

    if not na(trendPivotLow) and trendPivotLowBar >= sessionStartBarIndex
        if not na(previousTrendLowLevel) and trendPivotLow > previousTrendLowLevel
            activeUpTrend := TrendSegment.new(x1 = previousTrendLowBar, y1 = previousTrendLowLevel, x2 = trendPivotLowBar, y2 = trendPivotLow)
        previousTrendLowLevel := trendPivotLow
        previousTrendLowBar := trendPivotLowBar

    // Break invalidation: a segment stops being structure once price closes through
    // its projection at the current bar.
    if not na(activeUpTrend) and chartClose < f_lineValueAtBar(x1 = activeUpTrend.x1, y1 = activeUpTrend.y1, x2 = activeUpTrend.x2, y2 = activeUpTrend.y2, targetBar = bar_index)
        activeUpTrend := na

    if not na(activeDownTrend) and chartClose > f_lineValueAtBar(x1 = activeDownTrend.x1, y1 = activeDownTrend.y1, x2 = activeDownTrend.x2, y2 = activeDownTrend.y2, targetBar = bar_index)
        activeDownTrend := na

// ═══════════════════════════════════════════════════════════════════════════════
// 🎨 RENDER ENGINE
// Shared render orchestration clears stale objects and delegates drawing to each feature.
// ═══════════════════════════════════════════════════════════════════════════════
if barstate.islastconfirmedhistory or barstate.islast
    f_clearLines(lines = renderedLines)
    bool showCurrentSessionIntraday = latestRegularSessionDayKey == currentTradingDayKey and not na(sessionStartBarIndex)
    bool longTermZeroAwareMode = f_longTermIsZeroAware(colorMode = longTermColorMode, windowHigh = longTermWindowHigh, windowLow = longTermWindowLow)
    // Reuses the tolerance captured at rebuild time so exclusion and clustering are
    // measured against the same window snapshot.
    float longTermZeroLevelExclusionDistance = longTermZeroAwareMode ? nz(longTermClusterTolerance) : 0.0

    if showIntradayStructure and showCurrentSessionIntraday
        f_renderIntradayStructure(lines = renderedLines, resistanceLevels = intradayResistanceLevels, supportLevels = intradaySupportLevels, sessionStartBar = sessionStartBarIndex, forwardBars = intradaySRForwardBars, lineWidth = intradaySRLineWidth, referencePrice = chartClose)

    if showTrendLines and showCurrentSessionIntraday
        f_renderTrendLines(lines = renderedLines, upTrendSegment = activeUpTrend, downTrendSegment = activeDownTrend, sessionStartBar = sessionStartBarIndex, lookbackBars = trendLineLookbackBars, projectionBars = trendLineProjectionBars, lineWidth = trendLineWidth, styleInput = trendLineStyleInput, referencePrice = chartClose, recentRange = trendRecentRange)

    // Zero baseline is independent of Long-Term S/R: it draws for ANY symbol whose
    // scale contains zero (breadth, cumulative volume), and never forces zero onto a
    // pure price chart where it would distort the scale.
    if showLongTermZeroLine and zeroWithinChartScale
        string resolvedZeroLineStyle = f_trendLineStyle(styleInput = longTermZeroLineStyleInput)
        line zeroLine = line.new(x1 = bar_index - 1, y1 = 0.0, x2 = bar_index, y2 = 0.0, xloc = xloc.bar_index, extend = extend.both, color = longTermZeroLineColor, width = longTermZeroLineWidth, style = resolvedZeroLineStyle)
        array.push(id = renderedLines, value = zeroLine)

    if showLongTermStructure
        f_renderLongTermStructure(lines = renderedLines, keyLevels = longTermKeyLevels, levelsPerSide = longTermLevelsPerSide, referencePrice = chartClose, zeroAwareMode = longTermZeroAwareMode, zeroLevelExclusionDistance = longTermZeroLevelExclusionDistance)
