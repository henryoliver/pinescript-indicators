//@version=6
indicator(title = "Market Up-Down Volume Delta", shorttitle = "📊 Vol Δ", overlay = true)

// ═════════════════════════════════════════════════════════════════════════════
// 🧱 CONSTANTS
// Shared immutable values used by the indicator, including the Nord palette.
// ═════════════════════════════════════════════════════════════════════════════

// 🧩 TYPE DEFINITIONS
enum DisplayMode
    RAW     = "Raw Delta"
    PERCENT = "Delta %"
    RATIO   = "Up/Down Ratio"

enum MAType
    EMA = "EMA"
    SMA = "SMA"

// Nord Theme Color
// Polar Night
const color NORD0 = #2E3440
const color NORD1 = #3B4252
const color NORD2 = #434C5E
const color NORD3 = #4C566A
// Snow Storm
const color NORD4 = #D8DEE9
const color NORD5 = #E5E9F0
const color NORD6 = #ECEFF4
// Frost
const color NORD7 = #8FBCBB
const color NORD8 = #88C0D0
const color NORD9 = #81A1C1
const color NORD10 = #5E81AC
// Aurora
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

// ═════════════════════════════════════════════════════════════════════════════
// 🌐 MARKET
// Manual dropdown over the four major US equity indices. TradingView publishes
// USI breadth feeds with these suffixes only: .NY (NYSE), .NQ (Nasdaq exchange),
// .DJ (Dow 30 — index-specific), .US (combined US). No .SP or .RL suffix
// exists, so S&P 500 routes to NYSE breadth and Russell 2000 routes to the
// US-wide composite as closest proxies.
// ═════════════════════════════════════════════════════════════════════════════
const string GROUP_MARKET = "🌐 Market"

string market = input.string(
     defval = "S&P 500",
     title = "Market (Index)",
     options = ["S&P 500", "NASDAQ 100", "Dow Jones", "Russell 2000"],
     tooltip = "S&P 500 → NYSE breadth (.NY) — closest proxy. NASDAQ 100 → Nasdaq exchange-wide (.NQ). Dow Jones → exact Dow 30 breadth (.DJ). Russell 2000 → US-wide composite (.US) — TradingView has no Russell-specific feed.",
     group = GROUP_MARKET
 )

string upVolSymbol = switch market
    "S&P 500"      => "USI:UPVOL.NY"
    "NASDAQ 100"   => "USI:UPVOL.NQ"
    "Dow Jones"    => "USI:UPVOL.DJ"
    "Russell 2000" => "USI:UPVOL.US"
    => "USI:UPVOL.NY"

string downVolSymbol = switch market
    "S&P 500"      => "USI:DNVOL.NY"
    "NASDAQ 100"   => "USI:DNVOL.NQ"
    "Dow Jones"    => "USI:DNVOL.DJ"
    "Russell 2000" => "USI:DNVOL.US"
    => "USI:DNVOL.NY"

// ═════════════════════════════════════════════════════════════════════════════
// ⚙️ GENERAL
// Shared display controls for the plotted volume delta series.
// ═════════════════════════════════════════════════════════════════════════════
const string GROUP_GENERAL = "⚙️ General"

DisplayMode displayMode = input.enum(
     defval = DisplayMode.RAW,
     title = "Display",
     tooltip = "Raw Delta plots UPVOL − DNVOL in absolute volume units. Delta % normalizes by total volume so the scale is bounded ±100. Up/Down Ratio plots a signed ratio (UPVOL/DNVOL when bullish, −DNVOL/UPVOL when bearish).",
     group = GROUP_GENERAL
 )

bool showSignalLine = input.bool(
     defval = false,
     title = "Show Moving Average",
     tooltip = "Plots a session-reset moving average of the volume delta series. Resets each market open to keep the signal strictly intraday.",
     group = GROUP_GENERAL
 )

MAType signalType = input.enum(
     defval = MAType.EMA,
     title = "Moving Average Type",
     tooltip = "EMA reacts faster to fresh volume bursts; SMA gives a steady average of all bars since the session open.",
     group = GROUP_GENERAL
 )

int signalLength = input.int(
     defval = 15,
     title = "Moving Average Length",
     minval = 1,
     maxval = 100,
     tooltip = "Length for the selected moving average type. On a 5m chart, 15 bars ≈ 75 minutes of intraday smoothing.",
     group = GROUP_GENERAL
 )

bool showZeroLine = input.bool(
     defval = true,
     title = "Show Zero Line",
     tooltip = "Shows the neutral line.",
     group = GROUP_GENERAL
 )

// ═════════════════════════════════════════════════════════════════════════════
// 🧮 VOLUME DELTA
// Raw delta computed manually from UPVOL and DNVOL component feeds. Each new
// market day starts fresh because the USI cumulative feeds reset to ~0 at the
// session open. Signal-line MA is reset on every new session.
// ═════════════════════════════════════════════════════════════════════════════
float upVolume = request.security(
     symbol = upVolSymbol,
     timeframe = timeframe.period,
     expression = close,
     lookahead = barmerge.lookahead_off,
     gaps = barmerge.gaps_off,
     ignore_invalid_symbol = true
 )

float downVolume = request.security(
     symbol = downVolSymbol,
     timeframe = timeframe.period,
     expression = close,
     lookahead = barmerge.lookahead_off,
     gaps = barmerge.gaps_off,
     ignore_invalid_symbol = true
 )

bool isNewSession = ta.change(source = time(timeframe = "D")) != 0

float rawDelta = upVolume - downVolume
float totalVolume = upVolume + downVolume
float deltaPercent = totalVolume > 0 ? rawDelta / totalVolume * 100.0 : na
float signedRatio = upVolume > downVolume ? upVolume / math.max(downVolume, 1.0) : downVolume > upVolume ? -(downVolume / math.max(upVolume, 1.0)) : 0.0

float activeSeries = switch displayMode
    DisplayMode.RAW => rawDelta
    DisplayMode.PERCENT => deltaPercent
    => signedRatio

// Session-reset moving average — never carries yesterday's smoothing into today
var float signalLine = na
var array<float> sessionWindow = array.new<float>()
if isNewSession
    signalLine := na
    array.clear(id = sessionWindow)

if not na(activeSeries)
    if signalType == MAType.EMA
        float alpha = 2.0 / (signalLength + 1.0)
        signalLine := na(signalLine) ? activeSeries : alpha * activeSeries + (1.0 - alpha) * signalLine
    else
        array.push(id = sessionWindow, value = activeSeries)
        if array.size(id = sessionWindow) > signalLength
            array.shift(id = sessionWindow)
        signalLine := array.avg(id = sessionWindow)

bool hasData = not na(upVolume) and not na(downVolume)
bool seriesReady = hasData and not na(activeSeries)
bool isPositive = nz(source = activeSeries, replacement = 0) >= 0
color volumeLineColor = isPositive ? color.new(color = NORD8, transp = 80) : color.new(color = NORD9, transp = 40)
color lineColor = NORD9
if nz(source = activeSeries, replacement = 0) >= nz(source = activeSeries[1], replacement = activeSeries)
    lineColor := NORD8

plot(
     series = seriesReady ? activeSeries : na,
     title = "Volume Delta",
     color = volumeLineColor,
     style = plot.style_line,
     linewidth = 3
 )

plot(
     series = seriesReady and showSignalLine ? signalLine : na,
     title = "Signal",
     color = lineColor,
     style = plot.style_line,
     linewidth = 2
 )

hline(
     price = 0,
     title = "Zero Line",
     color = showZeroLine ? NORD3 : color.new(color = NORD3, transp = 100),
     linestyle = hline.style_solid,
     linewidth = 2
 )
