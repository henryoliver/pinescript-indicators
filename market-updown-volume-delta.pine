//@version=6
indicator(title = "Market Up-Down Volume Delta", shorttitle = "📊 Vol Δ", overlay = false, dynamic_requests = true)

// 🧱 CONSTANTS
const string GROUP_MARKET = "🌐 Market"
const string GROUP_GENERAL = "⚙️ General"

// Nord Theme Colors
const color NORD0 = #2E3440
const color NORD1 = #3B4252
const color NORD2 = #434C5E
const color NORD3 = #4C566A
const color NORD4 = #D8DEE9
const color NORD5 = #E5E9F0
const color NORD6 = #ECEFF4
const color NORD7 = #8FBCBB
const color NORD8 = #88C0D0
const color NORD9 = #81A1C1
const color NORD10 = #5E81AC
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

// 🎛️ USER INPUT SETTINGS
string marketPreset = input.string(
     defval = "Auto",
     title = "Market",
     options = ["Auto", "NASDAQ 100", "NASDAQ Composite", "NYSE / S&P 500", "Dow Jones", "Russell 2000", "Custom"],
     tooltip = "Auto uses NASDAQ breadth for NDX/QQQ/NQ charts and NYSE breadth for SPX/SPY/DIA/IWM/ES/YM/RTY style charts.",
     group = GROUP_MARKET
 )

string customUpVolumeSymbol = input.string(
     defval = "USI:UVOLQ",
     title = "Custom Up-Volume Symbol",
     tooltip = "Used only when Market = Custom.",
     group = GROUP_MARKET
 )

string customDownVolumeSymbol = input.string(
     defval = "USI:DVOLQ",
     title = "Custom Down-Volume Symbol",
     tooltip = "Used only when Market = Custom.",
     group = GROUP_MARKET
 )

bool regularSessionOnly = input.bool(
     defval = true,
     title = "Regular Session Only",
     tooltip = "Uses regular-session data for the breadth symbols when available.",
     group = GROUP_GENERAL
 )

string displayMode = input.string(
     defval = "Delta %",
     title = "Display",
     options = ["Raw Delta", "Delta %", "Up/Down Ratio"],
     tooltip = "Raw Delta plots UVOL - DVOL. Delta % normalizes by total volume. Up/Down Ratio plots a signed ratio around zero.",
     group = GROUP_GENERAL
 )

bool showSignalLine = input.bool(
     defval = true,
     title = "Show Signal Line",
     tooltip = "Plots an EMA of the selected series.",
     group = GROUP_GENERAL
 )

int signalLength = input.int(
     defval = 10,
     title = "Signal Length",
     minval = 1,
     maxval = 100,
     tooltip = "EMA length for the signal line.",
     group = GROUP_GENERAL
 )

bool showZeroLine = input.bool(
     defval = true,
     title = "Show Zero Line",
     tooltip = "Shows the neutral line.",
     group = GROUP_GENERAL
 )

// 🧮 DATA & CALCULATIONS
f_autoUsesNasdaq() =>
    string symbolText = str.upper(syminfo.tickerid + " " + syminfo.ticker + " " + syminfo.root + " " + syminfo.description)
    str.contains(symbolText, "NASDAQ") or
     str.contains(symbolText, "NDX") or
     str.contains(symbolText, "IXIC") or
     str.contains(symbolText, "QQQ") or
     str.contains(symbolText, "NQ1!") or
     str.contains(symbolText, "MNQ1!") or
     str.contains(symbolText, "NQ") or
     str.contains(symbolText, "TQQQ") or
     str.contains(symbolText, "SQQQ")

f_resolveSymbols(string preset, string customUpSymbol, string customDownSymbol) =>
    string resolvedUpSymbol = "USI:UVOL"
    string resolvedDownSymbol = "USI:DVOL"
    string resolvedLabel = "NYSE Breadth"

    if preset == "Custom"
        resolvedUpSymbol := customUpSymbol
        resolvedDownSymbol := customDownSymbol
        resolvedLabel := "Custom"
    else if preset == "NASDAQ 100" or preset == "NASDAQ Composite"
        resolvedUpSymbol := "USI:UVOLQ"
        resolvedDownSymbol := "USI:DVOLQ"
        resolvedLabel := "NASDAQ Breadth"
    else if preset == "NYSE / S&P 500" or preset == "Dow Jones" or preset == "Russell 2000"
        resolvedUpSymbol := "USI:UVOL"
        resolvedDownSymbol := "USI:DVOL"
        resolvedLabel := "NYSE Breadth"
    else
        bool useNasdaqBreadth = f_autoUsesNasdaq()
        resolvedUpSymbol := useNasdaqBreadth ? "USI:UVOLQ" : "USI:UVOL"
        resolvedDownSymbol := useNasdaqBreadth ? "USI:DVOLQ" : "USI:DVOL"
        resolvedLabel := useNasdaqBreadth ? "Auto: NASDAQ Breadth" : "Auto: NYSE Breadth"

    [resolvedUpSymbol, resolvedDownSymbol, resolvedLabel]

[upVolumeSymbol, downVolumeSymbol, sourceLabel] = f_resolveSymbols(
     preset = marketPreset,
     customUpSymbol = customUpVolumeSymbol,
     customDownSymbol = customDownVolumeSymbol
 )

string upVolumeRequestSymbol = regularSessionOnly ? ticker.modify(upVolumeSymbol, session = session.regular) : upVolumeSymbol
string downVolumeRequestSymbol = regularSessionOnly ? ticker.modify(downVolumeSymbol, session = session.regular) : downVolumeSymbol

float upVolume = request.security(
     symbol = upVolumeRequestSymbol,
     timeframe = timeframe.period,
     expression = close,
     lookahead = barmerge.lookahead_off,
     gaps = barmerge.gaps_off,
     ignore_invalid_symbol = true
 )

float downVolume = request.security(
     symbol = downVolumeRequestSymbol,
     timeframe = timeframe.period,
     expression = close,
     lookahead = barmerge.lookahead_off,
     gaps = barmerge.gaps_off,
     ignore_invalid_symbol = true
 )

float rawDelta = upVolume - downVolume
float totalVolume = upVolume + downVolume
float deltaPercent = totalVolume > 0 ? rawDelta / totalVolume * 100.0 : na
float signedRatio = upVolume > downVolume ? upVolume / math.max(downVolume, 1.0) : downVolume > upVolume ? -(downVolume / math.max(upVolume, 1.0)) : 0.0

float activeSeries = displayMode == "Raw Delta" ? rawDelta : displayMode == "Delta %" ? deltaPercent : signedRatio
float signalLine = ta.ema(source = activeSeries, length = signalLength)

bool hasData = not na(upVolume) and not na(downVolume)
bool seriesReady = hasData and not na(activeSeries)
bool isPositive = nz(activeSeries, 0) >= 0
color histogramColor = isPositive ? color.new(color = NORD14, transp = 0) : color.new(color = NORD11, transp = 0)
color lineColor = nz(activeSeries, 0) >= nz(activeSeries[1], activeSeries) ? color.new(color = NORD8, transp = 0) : color.new(color = NORD9, transp = 0)

plot(
     series = seriesReady ? activeSeries : na,
     title = "Volume Delta",
     color = histogramColor,
     style = plot.style_histogram,
     linewidth = 3
 )

plot(
     series = seriesReady and showSignalLine ? signalLine : na,
     title = "Signal",
     color = lineColor,
     style = plot.style_line,
     linewidth = 2
 )

hline(
     price = 0,
     title = "Zero Line",
     color = showZeroLine ? NORD3 : na,
     linestyle = hline.style_solid,
     linewidth = 2
 )

var label statusLabel = na

if barstate.islast
    if not na(statusLabel)
        label.delete(id = statusLabel)

    if seriesReady
        string modeLabel = displayMode == "Raw Delta" ? "Raw" : displayMode == "Delta %" ? "Percent" : "Ratio"
        string statusText = str.format(
             "{0}\nUVOL: {1,number,###,###,###}\nDVOL: {2,number,###,###,###}\nMode: {3}",
             sourceLabel,
             upVolume,
             downVolume,
             modeLabel
         )
        statusLabel := label.new(
             x = bar_index,
             y = nz(activeSeries, 0),
             text = statusText,
             xloc = xloc.bar_index,
             yloc = yloc.price,
             style = label.style_label_left,
             textcolor = NORD6,
             color = color.new(color = NORD1, transp = 15),
             size = size.small
         )
    else
        string errorText = str.format(
             "No breadth data for:\n{0}\n{1}\nSwitch Market or use Custom symbols.",
             upVolumeSymbol,
             downVolumeSymbol
         )
        statusLabel := label.new(
             x = bar_index,
             y = 0,
             text = errorText,
             xloc = xloc.bar_index,
             yloc = yloc.price,
             style = label.style_label_left,
             textcolor = NORD6,
             color = color.new(color = NORD11, transp = 15),
             size = size.small
         )
