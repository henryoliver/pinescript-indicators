//@version=6
indicator(title = "Market Up-Down Volume Delta", shorttitle = "📊 Vol Δ", overlay = false, max_lines_count = 300, calc_bars_count = 5000)

// 🧱 CONSTANTS
const string GROUP_MARKET = "🌐 Market"
const string GROUP_GENERAL = "⚙️ General"
const string GROUP_INTRADAY = "📍 Intraday Support/Resistance"
const string GROUP_LONG_TERM = "🗺️ Long-Term Support/Resistance"

// Nord Theme Colors
const color NORD0 = #2E3440
const color NORD1 = #3B4252
const color NORD2 = #434C5E
const color NORD3 = #4C566A
const color NORD4 = #D8DEE9
const color NORD5 = #E5E9F0
const color NORD6 = #ECEFF4
const color NORD7 = #8FBCBB
const color NORD8 = #88C0D0
const color NORD9 = #81A1C1
const color NORD10 = #5E81AC
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

const int MAX_LONG_TERM_BARS = 1200
const int MAX_INTRADAY_LEVELS = 80
const int INTRADAY_LINE_WIDTH = 2

// 🎛️ USER INPUT SETTINGS
string market = input.string(
     defval = "NASDAQ 100",
     title = "Market (Index)",
     options = ["NASDAQ 100", "S&P 500", "Dow Jones", "Russell 2000"],
     tooltip = "Selects the market-specific up-volume and down-volume symbols used to build the volume-delta index.",
     group = GROUP_MARKET
 )

bool showZeroLine = input.bool(defval = true, title = "Show Zero Line", tooltip = "Shows the zero reference line so you can quickly see whether dominant volume is net positive or net negative.", group = GROUP_GENERAL)
string displayMode = input.string(defval = "Candles", title = "Plot Style", options = ["Candles", "Line"], tooltip = "Displays the volume-delta index as candles or as a single closing-value line.", group = GROUP_GENERAL)

bool showLongTermStructure = input.bool(defval = true, title = "Show Long-Term Support/Resistance", tooltip = "Draws repeated dominant-volume support and resistance levels found from confirmed body pivots in the structure timeframe.", group = GROUP_LONG_TERM)
string longTermTimeframe = input.timeframe(defval = "15", title = "Structure Timeframe", tooltip = "Timeframe used to find the repeated body-based pivot levels that define long-term support and resistance.", group = GROUP_LONG_TERM)
int longTermLookbackDays = input.int(defval = 22, title = "Lookback (Trading Days)", minval = 10, maxval = 90, tooltip = "Approximate amount of trading history used to search for repeated dominant-volume support and resistance levels.", group = GROUP_LONG_TERM)
int longTermLevelsPerSide = input.int(defval = 4, title = "Levels Above/Below Zero", minval = 1, maxval = 6, tooltip = "How many ranked support/resistance levels to keep above zero and below zero.", group = GROUP_LONG_TERM)

bool showIntradayStructure = input.bool(defval = true, title = "Show Intraday Support/Resistance", tooltip = "Draws right-extended intraday support and resistance lines only for the latest regular trading session from confirmed body pivots that set new session highs or lows in the delta index.", group = GROUP_INTRADAY)
int intradayPivotStrengthInput = input.int(defval = 3, title = "Pivot Strength", minval = 1, maxval = 10, tooltip = "Bars required on each side to confirm an intraday body pivot before a support or resistance line can be drawn.", group = GROUP_INTRADAY)
int intradayMaxLevels = input.int(defval = 20, title = "Max Levels", minval = 5, maxval = MAX_INTRADAY_LEVELS, tooltip = "Maximum number of latest-session intraday support and resistance levels to keep on the chart.", group = GROUP_INTRADAY)
int intradayVisibleLevelsPerSide = input.int(defval = 2, title = "Visible Levels Per Side", minval = 1, maxval = 6, tooltip = "Shows only the nearest intraday support levels below and resistance levels above the current delta value.", group = GROUP_INTRADAY)
int intradayLineExtensionBars = input.int(defval = 40, title = "Line Extension (Bars)", minval = 1, maxval = 200, tooltip = "How many bars each intraday support/resistance line should extend forward from its pivot bar.", group = GROUP_INTRADAY)

// 🧮 DATA & CALCULATIONS
f_clearLines(array<line> lines) =>
    int lineCount = array.size(id = lines)
    if lineCount > 0
        for lineIndex = 0 to lineCount - 1
            line.delete(id = array.get(id = lines, index = lineIndex))
    array.clear(id = lines)

f_trimFloatArray(array<float> values, int maxSize) =>
    while array.size(id = values) > maxSize
        array.shift(id = values)

f_isVisibleIntradayLevel(array<float> levels, float referencePrice, float candidateLevel, int visiblePerSide, bool isResistance) =>
    bool isOnCorrectSide = isResistance ? candidateLevel > referencePrice : candidateLevel < referencePrice
    int closerLevels = 0
    int levelCount = array.size(id = levels)
    if isOnCorrectSide and levelCount > 0
        for levelIndex = 0 to levelCount - 1
            float level = array.get(id = levels, index = levelIndex)
            bool countsAsCloser = isResistance ? level > referencePrice and level < candidateLevel : level < referencePrice and level > candidateLevel
            if countsAsCloser
                closerLevels += 1
    isOnCorrectSide and closerLevels < visiblePerSide

f_lookbackBars(string structureTimeframe, int tradingDays) =>
    int tfSeconds = timeframe.in_seconds(structureTimeframe)
    int sessionMinutes = 390
    int barsPerDay = tfSeconds < 86400 ? math.max(1, math.ceil(sessionMinutes / math.max(tfSeconds / 60.0, 1.0))) : 1
    math.min(MAX_LONG_TERM_BARS, barsPerDay * tradingDays)

f_isPivotHigh(array<float> values, int pivotIndex, int strength) =>
    bool isPivot = true
    float pivotValue = array.get(id = values, index = pivotIndex)
    for testIndex = pivotIndex - strength to pivotIndex + strength
        if testIndex != pivotIndex and array.get(id = values, index = testIndex) >= pivotValue
            isPivot := false
            break
    isPivot

f_isPivotLow(array<float> values, int pivotIndex, int strength) =>
    bool isPivot = true
    float pivotValue = array.get(id = values, index = pivotIndex)
    for testIndex = pivotIndex - strength to pivotIndex + strength
        if testIndex != pivotIndex and array.get(id = values, index = testIndex) <= pivotValue
            isPivot := false
            break
    isPivot

f_selectRepeatedLevels(array<float> candidates, int maxLevels, float tolerance) =>
    array<float> clusterPrices = array.new<float>()
    array<int> clusterCounts = array.new<int>()

    int candidateCount = array.size(id = candidates)
    if candidateCount > 0
        for candidateIndex = 0 to candidateCount - 1
            float candidatePrice = array.get(id = candidates, index = candidateIndex)
            int matchingCluster = -1
            float matchingDistance = na
            int clusterCount = array.size(id = clusterPrices)
            if clusterCount > 0
                for clusterIndex = 0 to clusterCount - 1
                    float clusterPrice = array.get(id = clusterPrices, index = clusterIndex)
                    float clusterDistance = math.abs(candidatePrice - clusterPrice)
                    if clusterDistance <= tolerance and (na(matchingDistance) or clusterDistance < matchingDistance)
                        matchingCluster := clusterIndex
                        matchingDistance := clusterDistance
            if matchingCluster == -1
                array.push(id = clusterPrices, value = candidatePrice)
                array.push(id = clusterCounts, value = 1)
            else
                int previousCount = array.get(id = clusterCounts, index = matchingCluster)
                float previousPrice = array.get(id = clusterPrices, index = matchingCluster)
                int updatedCount = previousCount + 1
                float updatedPrice = (previousPrice * previousCount + candidatePrice) / updatedCount
                array.set(id = clusterCounts, index = matchingCluster, value = updatedCount)
                array.set(id = clusterPrices, index = matchingCluster, value = updatedPrice)

    int sortedClusterCount = array.size(id = clusterPrices)
    if sortedClusterCount > 1
        for outerIndex = 1 to sortedClusterCount - 1
            float sortPrice = array.get(id = clusterPrices, index = outerIndex)
            int sortCount = array.get(id = clusterCounts, index = outerIndex)
            int innerIndex = outerIndex - 1
            while innerIndex >= 0 and array.get(id = clusterCounts, index = innerIndex) < sortCount
                array.set(id = clusterPrices, index = innerIndex + 1, value = array.get(id = clusterPrices, index = innerIndex))
                array.set(id = clusterCounts, index = innerIndex + 1, value = array.get(id = clusterCounts, index = innerIndex))
                innerIndex -= 1
            array.set(id = clusterPrices, index = innerIndex + 1, value = sortPrice)
            array.set(id = clusterCounts, index = innerIndex + 1, value = sortCount)

    array<float> selectedLevels = array.new<float>()
    if sortedClusterCount > 0
        for selectedIndex = 0 to sortedClusterCount - 1
            if array.get(id = clusterCounts, index = selectedIndex) >= 2
                array.push(id = selectedLevels, value = array.get(id = clusterPrices, index = selectedIndex))
                if array.size(id = selectedLevels) >= maxLevels
                    break
    selectedLevels

f_inferredPivotStrength(string structureTimeframe) =>
    int tfSeconds = timeframe.in_seconds(structureTimeframe)
    tfSeconds <= 300 ? 3 :
     tfSeconds <= 1800 ? 4 :
     tfSeconds <= 14400 ? 5 :
     tfSeconds <= 86400 ? 6 : 7

string marketSuffix = switch market
    "NASDAQ 100" => "NQ"
    "S&P 500" => "SP"
    "Dow Jones" => "DJ"
    "Russell 2000" => "RL"
    => "NQ"

string upVolSymbol = "USI:UPVOL." + marketSuffix
string downVolSymbol = "USI:DNVOL." + marketSuffix

string upVolRegularSymbol = ticker.modify(upVolSymbol, session = session.regular)
string downVolRegularSymbol = ticker.modify(downVolSymbol, session = session.regular)
[upVolOpen, upVolClose] = request.security(symbol = upVolRegularSymbol, timeframe = timeframe.period, expression = [open, close], lookahead = barmerge.lookahead_off, gaps = barmerge.gaps_off, ignore_invalid_symbol = true)
[downVolOpen, downVolClose] = request.security(symbol = downVolRegularSymbol, timeframe = timeframe.period, expression = [open, close], lookahead = barmerge.lookahead_off, gaps = barmerge.gaps_off, ignore_invalid_symbol = true)

float deltaOpen = upVolOpen - downVolOpen
float deltaClose = upVolClose - downVolClose
float deltaHigh = math.max(deltaOpen, deltaClose)
float deltaLow = math.min(deltaOpen, deltaClose)

[upVolOpenLongTerm, upVolCloseLongTerm] = request.security(symbol = upVolRegularSymbol, timeframe = longTermTimeframe, expression = [open, close], lookahead = barmerge.lookahead_off, gaps = barmerge.gaps_off, ignore_invalid_symbol = true)
[downVolOpenLongTerm, downVolCloseLongTerm] = request.security(symbol = downVolRegularSymbol, timeframe = longTermTimeframe, expression = [open, close], lookahead = barmerge.lookahead_off, gaps = barmerge.gaps_off, ignore_invalid_symbol = true)

float deltaOpenLongTerm = upVolOpenLongTerm - downVolOpenLongTerm
float deltaCloseLongTerm = upVolCloseLongTerm - downVolCloseLongTerm
float deltaHighLongTerm = math.max(deltaOpenLongTerm, deltaCloseLongTerm)
float deltaLowLongTerm = math.min(deltaOpenLongTerm, deltaCloseLongTerm)

bool inRegularSession = session.ismarket
int regularSessionDayKey = year * 10000 + month * 100 + dayofmonth
int currentTradingDayKey = year(timenow) * 10000 + month(timenow) * 100 + dayofmonth(timenow)
bool isCurrentTradingDay = regularSessionDayKey == currentTradingDayKey
bool newLongTermBar = ta.change(time(longTermTimeframe)) != 0

float intradayPivotHigh = ta.pivothigh(source = deltaHigh, leftbars = intradayPivotStrengthInput, rightbars = intradayPivotStrengthInput)
float intradayPivotLow = ta.pivotlow(source = deltaLow, leftbars = intradayPivotStrengthInput, rightbars = intradayPivotStrengthInput)
int intradayPivotHighBar = not na(intradayPivotHigh) ? bar_index - intradayPivotStrengthInput : na
int intradayPivotLowBar = not na(intradayPivotLow) ? bar_index - intradayPivotStrengthInput : na

var int sessionStartBarIndex = na
var int latestRegularSessionDayKey = na
var array<float> intradayResistanceLevels = array.new<float>()
var array<int> intradayResistanceBars = array.new<int>()
var array<float> intradaySupportLevels = array.new<float>()
var array<int> intradaySupportBars = array.new<int>()
var array<float> longTermHighHistory = array.new<float>()
var array<float> longTermLowHistory = array.new<float>()
var array<float> longTermAboveLevels = array.new<float>()
var array<float> longTermBelowLevels = array.new<float>()
var array<line> renderedLines = array.new<line>()
var int longTermLookbackBars = f_lookbackBars(structureTimeframe = longTermTimeframe, tradingDays = longTermLookbackDays)

if inRegularSession and isCurrentTradingDay and (na(latestRegularSessionDayKey) or regularSessionDayKey != latestRegularSessionDayKey)
    latestRegularSessionDayKey := regularSessionDayKey
    sessionStartBarIndex := bar_index
    array.clear(id = intradayResistanceLevels)
    array.clear(id = intradayResistanceBars)
    array.clear(id = intradaySupportLevels)
    array.clear(id = intradaySupportBars)

if showIntradayStructure and inRegularSession and isCurrentTradingDay and barstate.isconfirmed
    if not na(intradayPivotHigh)
        if intradayPivotHighBar >= sessionStartBarIndex
            array.push(id = intradayResistanceLevels, value = intradayPivotHigh)
            array.push(id = intradayResistanceBars, value = intradayPivotHighBar)
            while array.size(id = intradayResistanceLevels) > intradayMaxLevels
                array.shift(id = intradayResistanceLevels)
                array.shift(id = intradayResistanceBars)
    if not na(intradayPivotLow)
        if intradayPivotLowBar >= sessionStartBarIndex
            array.push(id = intradaySupportLevels, value = intradayPivotLow)
            array.push(id = intradaySupportBars, value = intradayPivotLowBar)
            while array.size(id = intradaySupportLevels) > intradayMaxLevels
                array.shift(id = intradaySupportLevels)
                array.shift(id = intradaySupportBars)

if showLongTermStructure and newLongTermBar and not na(deltaCloseLongTerm[1])
    array.push(id = longTermHighHistory, value = deltaHighLongTerm[1])
    array.push(id = longTermLowHistory, value = deltaLowLongTerm[1])
    f_trimFloatArray(values = longTermHighHistory, maxSize = longTermLookbackBars)
    f_trimFloatArray(values = longTermLowHistory, maxSize = longTermLookbackBars)

if showLongTermStructure and (barstate.islastconfirmedhistory or barstate.islast)
    int longTermPivotStrength = f_inferredPivotStrength(structureTimeframe = longTermTimeframe)

    if array.size(id = longTermHighHistory) > longTermPivotStrength * 2
        array<float> aboveCandidates = array.new<float>()
        array<float> belowCandidates = array.new<float>()
        int firstPivotIndex = longTermPivotStrength
        int lastPivotIndex = array.size(id = longTermHighHistory) - longTermPivotStrength - 1
        for pivotIndex = firstPivotIndex to lastPivotIndex
            if f_isPivotHigh(values = longTermHighHistory, pivotIndex = pivotIndex, strength = longTermPivotStrength)
                float pivotHighPrice = array.get(id = longTermHighHistory, index = pivotIndex)
                if pivotHighPrice >= 0
                    array.push(id = aboveCandidates, value = pivotHighPrice)
                else
                    array.push(id = belowCandidates, value = pivotHighPrice)
            if f_isPivotLow(values = longTermLowHistory, pivotIndex = pivotIndex, strength = longTermPivotStrength)
                float pivotLowPrice = array.get(id = longTermLowHistory, index = pivotIndex)
                if pivotLowPrice >= 0
                    array.push(id = aboveCandidates, value = pivotLowPrice)
                else
                    array.push(id = belowCandidates, value = pivotLowPrice)

        float longTermRange = math.max(array.max(id = longTermHighHistory) - array.min(id = longTermLowHistory), 1.0)
        float longTermTolerance = math.max(1.0, longTermRange * 0.025)
        longTermAboveLevels := f_selectRepeatedLevels(candidates = aboveCandidates, maxLevels = longTermLevelsPerSide, tolerance = longTermTolerance)
        longTermBelowLevels := f_selectRepeatedLevels(candidates = belowCandidates, maxLevels = longTermLevelsPerSide, tolerance = longTermTolerance)
    else
        array.clear(id = longTermAboveLevels)
        array.clear(id = longTermBelowLevels)

// 📊 VISUALIZATION
bool useCandles = displayMode == "Candles"
bool isUpCandle = deltaClose >= deltaOpen
// Hollow candles by design so the border and body direction stay readable without obscuring the S/R lines.
color candleBodyColor = isUpCandle ? color.new(color = NORD8, transp = 100) : color.new(color = NORD9, transp = 100)
color candleBorderColor = isUpCandle ? color.new(color = NORD8, transp = 20) : color.new(color = NORD9, transp = 60)
color lineColor = deltaClose >= nz(deltaClose[1], deltaClose) ? color.new(color = NORD8, transp = 20) : color.new(color = NORD9, transp = 60)
color intradayStructureColor = NORD3

plotcandle(
     open = useCandles ? deltaOpen : na,
     high = useCandles ? deltaHigh : na,
     low = useCandles ? deltaLow : na,
     close = useCandles ? deltaClose : na,
     title = "Volume Delta (Candles)",
     color = candleBodyColor,
     wickcolor = candleBodyColor,
     bordercolor = candleBorderColor,
     editable = true
 )

plot(
     series = useCandles ? na : deltaClose,
     title = "Volume Delta (Line)",
     color = lineColor,
     style = plot.style_line,
     linewidth = 3
 )

hline(price = 0, title = "Zero Line", color = showZeroLine ? NORD1 : na, linestyle = hline.style_solid, linewidth = 4, editable = true)

// 🖊️ RENDERING
if barstate.islastconfirmedhistory or barstate.islast
    f_clearLines(lines = renderedLines)
    bool showCurrentSessionIntraday = latestRegularSessionDayKey == currentTradingDayKey

    if showIntradayStructure and showCurrentSessionIntraday
        int resistanceLevelCount = array.size(id = intradayResistanceLevels)
        if resistanceLevelCount > 0
            for resistanceIndex = 0 to resistanceLevelCount - 1
                float resistanceLevel = array.get(id = intradayResistanceLevels, index = resistanceIndex)
                int resistanceBar = array.get(id = intradayResistanceBars, index = resistanceIndex)
                bool showResistanceLevel = f_isVisibleIntradayLevel(levels = intradayResistanceLevels, referencePrice = deltaClose, candidateLevel = resistanceLevel, visiblePerSide = intradayVisibleLevelsPerSide, isResistance = true)
                if showResistanceLevel and not na(sessionStartBarIndex) and resistanceBar >= sessionStartBarIndex
                    int resistanceEndBar = resistanceBar + intradayLineExtensionBars
                    line resistanceLine = line.new(x1 = resistanceBar, y1 = resistanceLevel, x2 = resistanceEndBar, y2 = resistanceLevel, xloc = xloc.bar_index, extend = extend.none, color = intradayStructureColor, width = INTRADAY_LINE_WIDTH, style = line.style_solid)
                    array.push(id = renderedLines, value = resistanceLine)
        int supportLevelCount = array.size(id = intradaySupportLevels)
        if supportLevelCount > 0
            for supportIndex = 0 to supportLevelCount - 1
                float supportLevel = array.get(id = intradaySupportLevels, index = supportIndex)
                int supportBar = array.get(id = intradaySupportBars, index = supportIndex)
                bool showSupportLevel = f_isVisibleIntradayLevel(levels = intradaySupportLevels, referencePrice = deltaClose, candidateLevel = supportLevel, visiblePerSide = intradayVisibleLevelsPerSide, isResistance = false)
                if showSupportLevel and not na(sessionStartBarIndex) and supportBar >= sessionStartBarIndex
                    int supportEndBar = supportBar + intradayLineExtensionBars
                    line supportLine = line.new(x1 = supportBar, y1 = supportLevel, x2 = supportEndBar, y2 = supportLevel, xloc = xloc.bar_index, extend = extend.none, color = intradayStructureColor, width = INTRADAY_LINE_WIDTH, style = line.style_solid)
                    array.push(id = renderedLines, value = supportLine)

    if showLongTermStructure
        int aboveLevelCount = array.size(id = longTermAboveLevels)
        if aboveLevelCount > 0
            for aboveIndex = 0 to aboveLevelCount - 1
                float aboveLevel = array.get(id = longTermAboveLevels, index = aboveIndex)
                int aboveWidth = math.min(aboveLevelCount - aboveIndex, 6)
                line aboveLine = line.new(x1 = bar_index - 1, y1 = aboveLevel, x2 = bar_index, y2 = aboveLevel, xloc = xloc.bar_index, extend = extend.both, color = color.new(color = NORD8, transp = 60), width = aboveWidth, style = line.style_solid)
                array.push(id = renderedLines, value = aboveLine)
        int belowLevelCount = array.size(id = longTermBelowLevels)
        if belowLevelCount > 0
            for belowIndex = 0 to belowLevelCount - 1
                float belowLevel = array.get(id = longTermBelowLevels, index = belowIndex)
                int belowWidth = math.min(belowLevelCount - belowIndex, 6)
                line belowLine = line.new(x1 = bar_index - 1, y1 = belowLevel, x2 = bar_index, y2 = belowLevel, xloc = xloc.bar_index, extend = extend.both, color = color.new(color = NORD11, transp = 60), width = belowWidth, style = line.style_solid)
                array.push(id = renderedLines, value = belowLine)
