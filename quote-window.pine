//@version=6
indicator(title = "Quote Window", shorttitle = "🪟 QW", overlay = true)

// ═════════════════════════════════════════════════════════════════════════════
// 🧱 CONSTANTS
// Shared immutable values used by the indicator, including the Nord palette
// and the commitment thresholds derived from the Quote Window methodology.
// ═════════════════════════════════════════════════════════════════════════════
// Nord Theme Color
// Polar Night
const color NORD0  = #2E3440
const color NORD1  = #3B4252
const color NORD2  = #434C5E
const color NORD3  = #4C566A
// Snow Storm
const color NORD4  = #D8DEE9
const color NORD5  = #E5E9F0
const color NORD6  = #ECEFF4
// Frost
const color NORD7  = #8FBCBB
const color NORD8  = #88C0D0
const color NORD9  = #81A1C1
const color NORD10 = #5E81AC
// Aurora
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

// Commitment tiers — the source methodology has three levels beyond noise:
//   |%| < 0.2 = noise ("not convincing" — treat as neutral)
//   0.2–0.5  = drift; the color starts to count, conviction doesn't
//   ≥ 0.5    = serious ("I take their color more seriously")
//   ≥ 1.0    = committed ("committed to its bullish/bearish posture")
const float QW_NOISE_THRESHOLD       = 0.2
const float QW_SERIOUS_THRESHOLD     = 0.5
const float QW_COMMITTED_THRESHOLD   = 1.0
// Regime fractions, applied to SERIOUS sector counts (source: "look for the
// ones that are over point five and then compare the number of green and
// reds there"): ≥75 % one-sided = committed regime, 50–75 % = mild.
const float QW_COMMITTED_FRACTION    = 0.75
const float QW_MILD_FRACTION         = 0.50
// Bifurcation minority gate — SECTORS ONLY. Source: "the most mixture I'll
// tolerate is for 25% to be one color and 75% to be another color." Counted
// against COLORS beyond the noise floor, not serious/committed counts — a
// sector at −0.4% is red for this rule. Cash and futures indexes get NO
// tolerance: "if they are any mix of red and green, then I consider it a
// bifurcated market. It's that simple." Index bifurcation therefore uses the
// noise threshold with a zero minority gate — one off-color index beyond
// ±0.2% is enough.
const float QW_MINORITY_FRACTION     = 0.25
// Partial-data gap — if an enabled group returns less than this fraction of
// its expected symbols, treat as DATA GAP. Catches degraded feeds where the
// verdict would otherwise quietly run on too few inputs.
const float QW_PARTIAL_GAP_FRACTION  = 0.5

// ═════════════════════════════════════════════════════════════════════════════
// 🧩 TYPE DEFINITIONS
// Compact records used to keep the three symbol groups (cash / futures /
// sectors) iterable from a single rendering loop.
// ═════════════════════════════════════════════════════════════════════════════
// pctChange is the PRIMARY read used by all verdict math and single-baseline
// display: vs prior daily close by default (source: "amateurs watch the open
// and pros watch the close"), vs today's open only when the user selects that
// baseline. In "Both" display mode the primary stays vs-close. pctChangeVsOpen
// and pctChangeVsClose are always populated so the two-column "Both" view is
// free. Cross-group checks (cash↔futures misalignment) must always use
// pctChangeVsClose: cash ETFs open at 09:30 ET but CME futures' daily bar
// opens at globex (~18:00 ET prior day), so vs-open values aren't comparable
// across those groups.
type QwReading
    string label
    float  pctChange
    float  pctChangeVsOpen
    float  pctChangeVsClose
    bool   isCommodity

// ═════════════════════════════════════════════════════════════════════════════
// 🪟 QUOTE WINDOW
// Intermarket commitment monitor. Reads 4 cash indexes, 4 futures indexes,
// and the 11 SPDR sector ETFs to answer: "Is the broad market committed
// enough to one direction today to trust trends?" Companion to CBI — CBI
// gives the direction, this gives the conviction filter.
//
// Live-use intent. Daily data is fetched with lookahead_on so today's
// still-forming daily close is available intraday — the live use case
// requires it. The table renders only on barstate.islast and the rotation
// snapshot is gated to live data (see snapshot section below), but values
// observed during Bar Replay / historical inspection are not reproducible
// diagnostic readings: the leak allows later daily closes to appear on
// earlier intraday bars.
// ═════════════════════════════════════════════════════════════════════════════
const string GROUP_QW_GENERAL = "⚙️ General"
const string GROUP_QW_TABLE   = "📋 Table"
const string GROUP_QW_CASH    = "💵 Cash Indexes"
const string GROUP_QW_FUTURES = "📈 Futures Indexes"
const string GROUP_QW_SECTORS = "🏛️ Sectors"
const string GROUP_QW_REGIME  = "🧭 Regime"

string qwBaselineMode = input.string(
     defval = "Yesterday's Close",
     title = "% Change Baseline",
     options = ["Yesterday's Close", "Today's Open", "Both"],
     tooltip = "Default 'Yesterday's Close' matches the source methodology (amateurs watch the open, pros watch the close). 'Today's Open' is a clean pure-intraday read for cash and sector ETFs (which open at 09:30 ET) — CAVEAT: each CME contract's daily bar opens at globex (~18:00 ET prior day), so 'Today's Open' on the FUTURES rows still includes overnight. 'Both' shows the two baselines side by side, the way the source quote window keeps both columns up; verdict math then runs on the vs-close numbers. The internal cash↔futures misalignment check uses prior-close baseline regardless of this setting to keep cross-group comparisons apples-to-apples.",
     group = GROUP_QW_GENERAL
 )

string qwTablePosition = input.string(
     defval = position.top_right,
     title = "Position",
     options = [position.top_left, position.top_center, position.top_right, position.middle_left, position.middle_right, position.bottom_left, position.bottom_center, position.bottom_right],
     tooltip = "Where the table anchors on the chart. Default top-right keeps it out of the price action's way.",
     group = GROUP_QW_TABLE
 )

int qwTextSize = input.int(
     defval = 10,
     title = "Text Size",
     minval = 0,
     maxval = 36,
     tooltip = "Font size in typographic points; 0 = auto. Equivalents of the old presets: Tiny = 8, Small = 10, Normal = 14, Large = 20.",
     group = GROUP_QW_TABLE
 )

color qwTableBgColor = input.color(
     defval = color.new(color = NORD0, transp = 20),
     title = "Background",
     group = GROUP_QW_TABLE
 )

int qwTableBorderWidth = input.int(
     defval = 1,
     title = "Border Width",
     minval = 0,
     maxval = 5,
     inline = "qw_table_border",
     group = GROUP_QW_TABLE
 )

color qwTableBorderColor = input.color(
     defval = color.new(color = NORD1, transp = 70),
     title = "Border Color",
     inline = "qw_table_border",
     group = GROUP_QW_TABLE
 )

int qwTableFrameWidth = input.int(
     defval = 1,
     title = "Frame Width",
     minval = 0,
     maxval = 5,
     inline = "qw_table_frame",
     group = GROUP_QW_TABLE
 )

color qwTableFrameColor = input.color(
     defval = color.new(color = NORD2, transp = 50),
     title = "Frame Color",
     inline = "qw_table_frame",
     group = GROUP_QW_TABLE
 )

bool qwShowCash = input.bool(
     defval = true,
     title = "Show Cash Indexes",
     tooltip = "SPY, QQQ, DIA, IWM — the four major US cash index ETFs. Bifurcation here = unresolved sentiment. Display only; the regime verdict always considers cash, futures, and sectors regardless of this toggle.",
     group = GROUP_QW_CASH
 )

bool qwShowFutures = input.bool(
     defval = true,
     title = "Show Futures Indexes",
     tooltip = "ES1!, NQ1!, YM1!, RTY1! — the corresponding E-mini front-month continuous futures. Useful as a sentiment check against the cash side. Display only; the regime verdict always considers cash, futures, and sectors regardless of this toggle.",
     group = GROUP_QW_FUTURES
 )

bool qwShowSectors = input.bool(
     defval = true,
     title = "Show Sectors",
     tooltip = "The 11 SPDR Select Sector ETFs. Sector dispersion is the dimension ADD/VOLD can't see — ADD aggregates every stock into one count and hides rotation. Display only; the regime verdict always considers cash, futures, and sectors regardless of this toggle.",
     group = GROUP_QW_SECTORS
 )

bool qwIgnoreCommoditySectors = input.bool(
     defval = true,
     title = "Discount Commodity Sectors (XLE, XLB)",
     tooltip = "Per the source methodology: if the only red sectors on a green day are commodity-linked (energy, materials), don't downgrade the regime — those trade on their own drivers and aren't as threatening to equity sentiment.",
     group = GROUP_QW_SECTORS
 )

bool qwShowRegime = input.bool(
     defval = true,
     title = "Show Regime Verdict",
     tooltip = "Synthesizes five checks (cash bifurcation, futures bifurcation, sector bifurcation, cash↔futures misalignment, data gap) into a single tradability call: COMMITTED / MILD / LOW CONV / BIFURCATED / DATA GAP.",
     group = GROUP_QW_REGIME
 )

bool qwUseTodayOpenBaseline = qwBaselineMode == "Today's Open"
bool qwBothBaselines        = qwBaselineMode == "Both"

// ─────────────────────────────────────────────────────────────────────────────
// Helpers
// ─────────────────────────────────────────────────────────────────────────────
// lookahead_on is intentional here: it makes today's still-forming daily close
// visible intraday, which is required for the live use case. The cost is that
// replay/historical bars receive the eventual daily close — the rotation
// snapshot is gated separately so that leak can't poison var state.
// Single request.security per symbol returns {today's close, yesterday's
// close, today's open}; the helper builds the full QwReading from there.
// Computes BOTH baselines every time (vs-open and vs-close) and selects the
// primary per the baseline mode — see the QwReading type comment.
// The prior layout dispatched between two FromOpen/FromClose helpers via a
// ternary, but Pine evaluates BOTH branches of a ternary containing a
// request.security, so every symbol was firing two security calls. A single
// call returning three fields keeps the request count at one per symbol AND
// gives us both baselines for free — adding fields to an existing
// request.security tuple is free (the daily bar is fetched once regardless).
f_qwMakeReading(string label, string symbolTicker, bool isCommodity, bool useTodayOpenBaseline) =>
    [todayClose, prevClose, todayOpen] = request.security(
         symbol = symbolTicker,
         timeframe = "D",
         expression = [close, close[1], open],
         lookahead = barmerge.lookahead_on,
         ignore_invalid_symbol = true
     )
    float vsOpenPct  = not na(todayClose) and not na(todayOpen) and todayOpen != 0.0 ?
         (todayClose - todayOpen)  / todayOpen  * 100.0 : na
    float vsClosePct = not na(todayClose) and not na(prevClose) and prevClose != 0.0 ?
         (todayClose - prevClose) / prevClose * 100.0 : na
    float primaryPct = useTodayOpenBaseline ? vsOpenPct : vsClosePct
    QwReading.new(label = label, pctChange = primaryPct, pctChangeVsOpen = vsOpenPct, pctChangeVsClose = vsClosePct, isCommodity = isCommodity)

f_qwCellTextColor(float pctChange) =>
    na(pctChange) ? color.new(color = NORD4, transp = 40) : color.new(color = NORD4, transp = 0)

f_qwPctTextColor(float pctChange) =>
    color pctTextColor = color.new(color = NORD4, transp = 40)
    if not na(pctChange)
        if math.abs(pctChange) >= QW_COMMITTED_THRESHOLD
            pctTextColor := color.new(color = pctChange >= 0.0 ? NORD8 : NORD11, transp = 0)
        else if math.abs(pctChange) >= QW_SERIOUS_THRESHOLD
            pctTextColor := color.new(color = pctChange >= 0.0 ? NORD7 : NORD12, transp = 0)
        else if math.abs(pctChange) >= QW_NOISE_THRESHOLD
            pctTextColor := color.new(color = pctChange >= 0.0 ? NORD7 : NORD12, transp = 45)
        else
            pctTextColor := color.new(color = NORD3, transp = 0)
    pctTextColor

f_qwFormatPct(float pctChange) =>
    na(pctChange) ? "—" : str.format("{0,number,+0.00;-0.00}%", pctChange)

// Threshold comparisons are inclusive (>= and <=), matching the methodology
// boundaries: |%| < 0.2 = noise (strict <), >= 0.2 = drift, >= 0.5 = serious,
// >= 1.0 = committed. A value exactly at a boundary belongs to the higher
// tier — and display coloring uses the same inclusive cutoffs, so counting
// and coloring always agree.
f_qwCountAboveThreshold(array<QwReading> readings, float threshold, bool wantPositive, bool excludeCommodity) =>
    int total = 0
    for reading in readings
        if not (excludeCommodity and reading.isCommodity) and not na(reading.pctChange)
            if wantPositive and reading.pctChange >= threshold
                total += 1
            else if not wantPositive and reading.pctChange <= -threshold
                total += 1
    total

f_qwGroupSize(array<QwReading> readings, bool excludeCommodity) =>
    int total = 0
    for reading in readings
        if not (excludeCommodity and reading.isCommodity) and not na(reading.pctChange)
            total += 1
    total

f_qwIsBifurcated(array<QwReading> readings, float threshold, float minorityFraction, bool excludeCommodity) =>
    int greenCount = 0
    int redCount = 0
    int total = 0
    for reading in readings
        if not (excludeCommodity and reading.isCommodity) and not na(reading.pctChange)
            total += 1
            if reading.pctChange >= threshold
                greenCount += 1
            else if reading.pctChange <= -threshold
                redCount += 1
    greenCount > 0 and redCount > 0 and total > 0 and
         math.min(greenCount, redCount) / float(total) > minorityFraction

// Group net means for the header rows. Pine has no field selectors, hence the
// twin helpers; the primary (displayed) net is picked from these two per the
// baseline mode.
f_qwNetMeanVsOpen(array<QwReading> readings) =>
    float pctSum = 0.0
    int total = 0
    for reading in readings
        if not na(reading.pctChangeVsOpen)
            pctSum += reading.pctChangeVsOpen
            total += 1
    total > 0 ? pctSum / total : na

f_qwNetMeanVsClose(array<QwReading> readings) =>
    float pctSum = 0.0
    int total = 0
    for reading in readings
        if not na(reading.pctChangeVsClose)
            pctSum += reading.pctChangeVsClose
            total += 1
    total > 0 ? pctSum / total : na

// ─────────────────────────────────────────────────────────────────────────────
// Build readings for each group using fixed-symbol requests so Pine doesn't
// need dynamic request bookkeeping for the symbol loop on every bar.
// ─────────────────────────────────────────────────────────────────────────────
QwReading qwSpyReading  = f_qwMakeReading(label = "SPY",  symbolTicker = "AMEX:SPY",       isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwQqqReading  = f_qwMakeReading(label = "QQQ",  symbolTicker = "NASDAQ:QQQ",     isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwDiaReading  = f_qwMakeReading(label = "DIA",  symbolTicker = "AMEX:DIA",       isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwIwmReading  = f_qwMakeReading(label = "IWM",  symbolTicker = "AMEX:IWM",       isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)

QwReading qwEsReading   = f_qwMakeReading(label = "ES",   symbolTicker = "CME_MINI:ES1!",  isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwNqReading   = f_qwMakeReading(label = "NQ",   symbolTicker = "CME_MINI:NQ1!",  isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwYmReading   = f_qwMakeReading(label = "YM",   symbolTicker = "CBOT_MINI:YM1!", isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwRtyReading  = f_qwMakeReading(label = "RTY",  symbolTicker = "CME_MINI:RTY1!", isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)

QwReading qwXlcReading  = f_qwMakeReading(label = "XLC",  symbolTicker = "AMEX:XLC",       isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwXlyReading  = f_qwMakeReading(label = "XLY",  symbolTicker = "AMEX:XLY",       isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwXlpReading  = f_qwMakeReading(label = "XLP",  symbolTicker = "AMEX:XLP",       isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwXleReading  = f_qwMakeReading(label = "XLE",  symbolTicker = "AMEX:XLE",       isCommodity = true,  useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwXlfReading  = f_qwMakeReading(label = "XLF",  symbolTicker = "AMEX:XLF",       isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwXlvReading  = f_qwMakeReading(label = "XLV",  symbolTicker = "AMEX:XLV",       isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwXliReading  = f_qwMakeReading(label = "XLI",  symbolTicker = "AMEX:XLI",       isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwXlbReading  = f_qwMakeReading(label = "XLB",  symbolTicker = "AMEX:XLB",       isCommodity = true,  useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwXlreReading = f_qwMakeReading(label = "XLRE", symbolTicker = "AMEX:XLRE",      isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwXlkReading  = f_qwMakeReading(label = "XLK",  symbolTicker = "AMEX:XLK",       isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)
QwReading qwXluReading  = f_qwMakeReading(label = "XLU",  symbolTicker = "AMEX:XLU",       isCommodity = false, useTodayOpenBaseline = qwUseTodayOpenBaseline)

array<QwReading> qwCashReadings = array.from(qwSpyReading, qwQqqReading, qwDiaReading, qwIwmReading)
array<QwReading> qwFuturesReadings = array.from(qwEsReading, qwNqReading, qwYmReading, qwRtyReading)
array<QwReading> qwSectorReadings = array.from(
     qwXlcReading, qwXlyReading, qwXlpReading, qwXleReading, qwXlfReading, qwXlvReading,
     qwXliReading, qwXlbReading, qwXlreReading, qwXlkReading, qwXluReading
 )

// ─────────────────────────────────────────────────────────────────────────────
// Aggregate diagnostics — bifurcation, sector commitment, color rotation.
// Every regime check (bifurcation, misalignment, dominant fraction, data gap)
// runs against the full universe of cash + futures + sectors, regardless of
// which groups the user has elected to display. Show* toggles affect table
// rendering only. Sensitivity is intentionally ASYMMETRIC, per the source
// methodology:
//   • Indexes (cash, futures): ANY mix of red and green beyond the noise
//     floor = bifurcated. Zero tolerance — "It's that simple."
//   • Sectors: mixture is tolerated up to a 25% minority of colors beyond
//     the noise floor.
// ─────────────────────────────────────────────────────────────────────────────
bool qwCashBifurcated    = f_qwIsBifurcated(readings = qwCashReadings,    threshold = QW_NOISE_THRESHOLD, minorityFraction = 0.0, excludeCommodity = false)
bool qwFuturesBifurcated = f_qwIsBifurcated(readings = qwFuturesReadings, threshold = QW_NOISE_THRESHOLD, minorityFraction = 0.0, excludeCommodity = false)

// Group nets for the header rows. The primary follows the baseline mode; the
// "Both" view renders the vs-open and vs-close nets side by side.
float qwCashNetVsOpen     = f_qwNetMeanVsOpen(readings  = qwCashReadings)
float qwCashNetVsClose    = f_qwNetMeanVsClose(readings = qwCashReadings)
float qwFuturesNetVsOpen  = f_qwNetMeanVsOpen(readings  = qwFuturesReadings)
float qwFuturesNetVsClose = f_qwNetMeanVsClose(readings = qwFuturesReadings)
float qwCashNet    = qwUseTodayOpenBaseline ? qwCashNetVsOpen    : qwCashNetVsClose
float qwFuturesNet = qwUseTodayOpenBaseline ? qwFuturesNetVsOpen : qwFuturesNetVsClose

// Cash↔futures misalignment is PER-PAIR, not group-mean — "the S&P is a
// little green, but the ES is a little red … probably a good time to not
// trade that market." Group means can wash out a single split pair (SPY +0.5%
// vs ES −0.3% while the other three pairs align). Pairing relies on the two
// arrays sharing index order: SPY↔ES, QQQ↔NQ, DIA↔YM, IWM↔RTY. Always
// compared on prior-close baseline: cash ETFs open at 09:30 ET but CME
// futures' daily bar opens at globex (~18:00 ET prior day), so vs-open values
// aren't comparable across the pair — comparing them in "Today's Open" mode
// would flag a phantom misalignment any time the overnight gap was meaningful.
bool qwCashFuturesMisaligned = false
for qwPairIndex = 0 to math.min(array.size(qwCashReadings), array.size(qwFuturesReadings)) - 1
    QwReading qwPairCash    = array.get(qwCashReadings,    qwPairIndex)
    QwReading qwPairFutures = array.get(qwFuturesReadings, qwPairIndex)
    if not na(qwPairCash.pctChangeVsClose) and not na(qwPairFutures.pctChangeVsClose) and
         math.abs(qwPairCash.pctChangeVsClose)    >= QW_NOISE_THRESHOLD and
         math.abs(qwPairFutures.pctChangeVsClose) >= QW_NOISE_THRESHOLD and
         ((qwPairCash.pctChangeVsClose > 0.0) != (qwPairFutures.pctChangeVsClose > 0.0))
        qwCashFuturesMisaligned := true

int qwSectorTotal         = f_qwGroupSize(readings = qwSectorReadings, excludeCommodity = qwIgnoreCommoditySectors)
int qwSectorGreensRaw     = f_qwCountAboveThreshold(readings = qwSectorReadings, threshold = QW_NOISE_THRESHOLD,   wantPositive = true,  excludeCommodity = qwIgnoreCommoditySectors)
int qwSectorRedsRaw       = f_qwCountAboveThreshold(readings = qwSectorReadings, threshold = QW_NOISE_THRESHOLD,   wantPositive = false, excludeCommodity = qwIgnoreCommoditySectors)
int qwSectorGreensSerious = f_qwCountAboveThreshold(readings = qwSectorReadings, threshold = QW_SERIOUS_THRESHOLD, wantPositive = true,  excludeCommodity = qwIgnoreCommoditySectors)
int qwSectorRedsSerious   = f_qwCountAboveThreshold(readings = qwSectorReadings, threshold = QW_SERIOUS_THRESHOLD, wantPositive = false, excludeCommodity = qwIgnoreCommoditySectors)

float qwDominantSeriousFraction = qwSectorTotal > 0 ?
     math.max(qwSectorGreensSerious, qwSectorRedsSerious) / float(qwSectorTotal) : 0.0
// Lean uses serious counts; strict > means an exact tie resolves false rather
// than silently biasing green. A tie large enough to reach the MILD fraction
// necessarily trips the sector bifurcation gate first (raw color counts are a
// superset of serious counts, so minority/total ≥ 0.5 > QW_MINORITY_FRACTION),
// meaning the arrow direction here is only consulted when one side is
// genuinely dominant.
bool qwSectorsLeanGreen = qwSectorGreensSerious > qwSectorRedsSerious

// Sector split runs on COLORS beyond noise (raw counts), not serious counts —
// "more than 25% of the sectors are red" counts a −0.4% sector as red.
bool qwSectorsBifurcated = f_qwIsBifurcated(readings = qwSectorReadings, threshold = QW_NOISE_THRESHOLD, minorityFraction = QW_MINORITY_FRACTION, excludeCommodity = qwIgnoreCommoditySectors)

// Data availability — an enabled group must return at least
// QW_PARTIAL_GAP_FRACTION of its expected symbols; otherwise the feed is
// degraded and the verdict can't be trusted. Covers both empty feeds (missing
// permissions, off-hours) AND partial fetches that would otherwise let 1–2
// symbols out of 9+ drive the regime call.
int qwCashExpected       = 4
int qwFuturesExpected    = 4
int qwSectorExpected     = qwIgnoreCommoditySectors ? 9 : 11
int qwCashReceived       = f_qwGroupSize(readings = qwCashReadings,    excludeCommodity = false)
int qwFuturesReceived    = f_qwGroupSize(readings = qwFuturesReadings, excludeCommodity = false)
int qwCashMinReceived    = math.ceil(qwCashExpected    * QW_PARTIAL_GAP_FRACTION)
int qwFuturesMinReceived = math.ceil(qwFuturesExpected * QW_PARTIAL_GAP_FRACTION)
int qwSectorMinReceived  = math.ceil(qwSectorExpected  * QW_PARTIAL_GAP_FRACTION)
bool qwCashDataGap       = qwCashReceived    < qwCashMinReceived
bool qwFuturesDataGap    = qwFuturesReceived < qwFuturesMinReceived
bool qwSectorsDataGap    = qwSectorTotal     < qwSectorMinReceived
bool qwDataGap           = qwCashDataGap or qwFuturesDataGap or qwSectorsDataGap

// Color-rotation tracking: snapshot the sector green/red counts at the US
// cash open and surface the delta so the user can spot sectors flipping
// mid-day — the earliest tell of a regime change per the source methodology.
// US-RTH detection is anchored to America/New_York, NOT to the chart symbol's
// session, so the trigger fires correctly on a futures, FX, or crypto chart.
//
// Snapshot only fires on the actual 09:30 ET transition (qwUsRthJustStarted).
// On a chart loaded mid-session, no snapshot exists yet and the delta is na —
// the UI then renders "·" instead of an arrow, signalling "no open baseline
// yet" rather than passing off load-time counts as the open.
//
// Timeframe caveat: the 09:30 edge fires cleanly on 1m–30m charts (a bar
// boundary lands at the open). On wider timeframes where one bar straddles
// the open (e.g. 1h/4h), the snapshot is taken at the bar's start tick — which
// may be a few minutes before 09:30. Accepted: this script is intended for
// intraday work where the chart is typically ≤15m.
var int qwGreensAtOpen = na
var int qwRedsAtOpen   = na

// NY trading-day rollover reset — without this, the snapshot from yesterday's
// 09:30 ET persists overnight, so this morning's premarket bars compute their
// delta against yesterday's open. Clearing on the date change forces the UI
// back to "no baseline yet" until today's 09:30 snapshot fires. Detect the
// rollover via the NY-tz date so charts that have midnight ET bars (futures,
// FX, crypto) trip the reset at ~midnight, and stock-only charts trip it on
// the first bar of the new RTH session (which is the 09:30 bar itself — the
// reset runs before the snapshot assignment below).
int qwNyDayKey = year(time = time, timezone = "America/New_York") * 10000 + month(time = time, timezone = "America/New_York") * 100 + dayofmonth(time = time, timezone = "America/New_York")
if qwNyDayKey != qwNyDayKey[1]
    qwGreensAtOpen := na
    qwRedsAtOpen   := na

int qwUsRthTime = time(timeframe = timeframe.period, session = "0930-1600:23456", timezone = "America/New_York")
bool qwUsRthJustStarted = not na(qwUsRthTime) and na(qwUsRthTime[1])

// Snapshot gating: lookahead_on can leak future daily closes into historical
// bars, which would poison this var state. Only snapshot once we've reached
// live data (or the last confirmed history bar that immediately precedes it).
bool qwSnapshotAllowed = barstate.isrealtime or barstate.islastconfirmedhistory
if qwUsRthJustStarted and qwSnapshotAllowed
    qwGreensAtOpen := qwSectorGreensRaw
    qwRedsAtOpen   := qwSectorRedsRaw

// Delta is na (not 0) when no snapshot exists or the sector feed is currently
// dead — guards against rendering a phantom "▼9" the moment sectors drop out.
int qwGreensDelta = na(qwGreensAtOpen) or qwSectorTotal == 0 ? na : qwSectorGreensRaw - qwGreensAtOpen
int qwRedsDelta   = na(qwRedsAtOpen)   or qwSectorTotal == 0 ? na : qwSectorRedsRaw   - qwRedsAtOpen

// ─────────────────────────────────────────────────────────────────────────────
// Regime verdict synthesis.
// ─────────────────────────────────────────────────────────────────────────────
int qwCommitTransp = 80 - int(math.min(1.0, qwDominantSeriousFraction) * 55.0)
string qwRegimeText = "· LOW CONV"
color qwRegimeColor = color.new(color = NORD3, transp = qwCommitTransp)
// DATA GAP overrides everything else — never promote partial data to a verdict.
if qwDataGap
    qwRegimeText  := "× DATA GAP"
    qwRegimeColor := color.new(color = NORD12, transp = 20)
else if qwCashBifurcated or qwFuturesBifurcated or qwSectorsBifurcated or qwCashFuturesMisaligned
    qwRegimeText  := "÷ BIFURCATED"
    qwRegimeColor := color.new(color = NORD13, transp = 45)
else if qwDominantSeriousFraction >= QW_COMMITTED_FRACTION
    qwRegimeText  := qwSectorsLeanGreen ? "+ COMMITTED ↑" : "+ COMMITTED ↓"
    qwRegimeColor := qwSectorsLeanGreen ? color.new(color = NORD8, transp = qwCommitTransp) : color.new(color = NORD11, transp = qwCommitTransp)
else if qwDominantSeriousFraction >= QW_MILD_FRACTION
    qwRegimeText  := qwSectorsLeanGreen ? "~ MILD ↑" : "~ MILD ↓"
    qwRegimeColor := qwSectorsLeanGreen ? color.new(color = NORD7, transp = qwCommitTransp) : color.new(color = NORD12, transp = qwCommitTransp)

// ─────────────────────────────────────────────────────────────────────────────
// Render — single table, two columns, sections separated by header rows.
// Pine requires table.new() at the top level, so we declare it here and
// populate inside barstate.islast.
// ─────────────────────────────────────────────────────────────────────────────
var table qwTable = na
var int qwTableRows = na
var int qwTableColumnsState = na
var string qwTablePositionState = ""

// bothColumns renders a third cell (vs-close) so the "Both" baseline mode can
// show the two % columns side by side, the way the source quote window keeps
// both up. In that mode headerValue carries vs-open, headerValue2 vs-close.
f_qwHeaderRow(table tableId, int rowIndex, string headerLabel, string headerValue, bool bothColumns = false, string headerValue2 = "") =>
    table.cell(table_id = tableId, column = 0, row = rowIndex, text = headerLabel,
         text_color = color.new(color = NORD9, transp = 0),
         text_halign = text.align_left,
         text_valign = text.align_center,
         text_size = qwTextSize,
         bgcolor = color.new(color = NORD1, transp = 25))
    table.cell(table_id = tableId, column = 1, row = rowIndex, text = headerValue,
         text_color = color.new(color = NORD4, transp = 30),
         text_halign = text.align_right,
         text_valign = text.align_center,
         text_size = qwTextSize,
         bgcolor = color.new(color = NORD1, transp = 25))
    if bothColumns
        table.cell(table_id = tableId, column = 2, row = rowIndex, text = headerValue2,
             text_color = color.new(color = NORD4, transp = 30),
             text_halign = text.align_right,
             text_valign = text.align_center,
             text_size = qwTextSize,
             bgcolor = color.new(color = NORD1, transp = 25))

f_qwReadingRow(table tableId, int rowIndex, QwReading reading, bool isDimmed, bool bothColumns = false) =>
    color rowBg = color.new(color = NORD0, transp = 100)
    color dimColor = color.new(color = NORD3, transp = 0)
    color rowText = isDimmed ? dimColor : f_qwCellTextColor(pctChange = reading.pctChange)
    table.cell(table_id = tableId, column = 0, row = rowIndex, text = reading.label,
         text_color = rowText,
         text_halign = text.align_left,
         text_valign = text.align_center,
         text_size = qwTextSize,
         bgcolor = rowBg)
    if bothColumns
        color openText  = isDimmed ? dimColor : f_qwPctTextColor(pctChange = reading.pctChangeVsOpen)
        color closeText = isDimmed ? dimColor : f_qwPctTextColor(pctChange = reading.pctChangeVsClose)
        table.cell(table_id = tableId, column = 1, row = rowIndex, text = f_qwFormatPct(pctChange = reading.pctChangeVsOpen),
             text_color = openText,
             text_halign = text.align_right,
             text_valign = text.align_center,
             text_size = qwTextSize,
             bgcolor = rowBg)
        table.cell(table_id = tableId, column = 2, row = rowIndex, text = f_qwFormatPct(pctChange = reading.pctChangeVsClose),
             text_color = closeText,
             text_halign = text.align_right,
             text_valign = text.align_center,
             text_size = qwTextSize,
             bgcolor = rowBg)
    else
        color pctText = isDimmed ? dimColor : f_qwPctTextColor(pctChange = reading.pctChange)
        table.cell(table_id = tableId, column = 1, row = rowIndex, text = f_qwFormatPct(pctChange = reading.pctChange),
             text_color = pctText,
             text_halign = text.align_right,
             text_valign = text.align_center,
             text_size = qwTextSize,
             bgcolor = rowBg)

string qwRegimeTooltip =
     "🧭 REGIME GUIDE\n" +
     "\n" +
     "+ COMMITTED\n" +
     "No index split anywhere, and at least 75% of counted sectors are moving seriously (0.5%+) in one direction.\n" +
     "This is the cleanest trend environment.\n" +
     "\n" +
     "~ MILD\n" +
     "No index split, but only 50-75% of sectors are moving seriously.\n" +
     "There is participation, but not broad enough to treat as a fully confident regime.\n" +
     "\n" +
     "· LOW CONV\n" +
     "Less than half the counted sectors are moving seriously.\n" +
     "Movement may be drift, chop, or weak rotation rather than a trustworthy trend day.\n" +
     "\n" +
     "÷ BIFURCATED\n" +
     "Internal disagreement. Indexes get zero tolerance: any cash index or futures index that is red while the others are green (or vice versa, beyond the 0.2% noise floor) splits the group.\n" +
     "Also fires when more than 25% of counted sectors are the minority color, or when any cash/futures pair of the same market (SPY/ES, QQQ/NQ, DIA/YM, IWM/RTY) points in opposite directions vs prior close.\n" +
     "\n" +
     "× DATA GAP\n" +
     "At least one enabled group returned too few usable readings — zero, or below half of the expected symbol count.\n" +
     "Do not trust the verdict when part of the intermarket picture is missing.\n" +
     "\n" +
     "📐 COMMITMENT RULES\n" +
     "Below 0.2% = noise\n" +
     "0.2-0.5% = drift (color counts, conviction doesn't)\n" +
     "0.5-1% = serious\n" +
     "Above 1% = committed\n" +
     "\n" +
     "📊 DETAIL NUMBER\n" +
     "Normal mode shows seriously-moving (0.5%+) sectors on the dominant side / total counted sectors.\n" +
     "Data-gap mode shows received/expected counts for Cash, Futures, and Sectors."

if barstate.islast
    int qwRow = 0
    bool qwRegimeOnlyView = qwShowRegime and not qwShowCash and not qwShowFutures and not qwShowSectors
    bool qwShowRegimeHeader = qwShowRegime and not qwRegimeOnlyView
    // "Both" baseline mode adds a third column (vs-open | vs-close) plus a
    // column-label row. The regime-only view never needs the split — it shows
    // no per-symbol percentages — so it stays at 2 columns.
    bool qwBothColumns = qwBothBaselines and not qwRegimeOnlyView
    int qwTableColumns = qwBothColumns ? 3 : 2
    int qwVisibleRows = qwRegimeOnlyView ? 1 :
         (qwBothColumns ? 1 : 0) +
         (qwShowCash ? 1 + array.size(qwCashReadings) : 0) +
         (qwShowFutures ? 1 + array.size(qwFuturesReadings) : 0) +
         (qwShowSectors ? 1 + array.size(qwSectorReadings) : 0) +
         (qwShowRegimeHeader ? 2 : 0)

    if na(qwTable) or qwTableRows != qwVisibleRows or qwTableColumnsState != qwTableColumns or qwTablePositionState != qwTablePosition
        if not na(qwTable)
            table.delete(qwTable)
        qwTable := table.new(
             position = qwTablePosition,
             columns = qwTableColumns,
             rows = math.max(1, qwVisibleRows),
             bgcolor = qwTableBgColor,
             border_width = qwTableBorderWidth,
             border_color = qwTableBorderColor,
             frame_width = qwTableFrameWidth,
             frame_color = qwTableFrameColor
         )
        qwTableRows := qwVisibleRows
        qwTableColumnsState := qwTableColumns
        qwTablePositionState := qwTablePosition

    // Column labels — only needed when two % columns are on screen.
    if qwBothColumns
        f_qwHeaderRow(tableId = qwTable, rowIndex = qwRow, headerLabel = "", headerValue = "vs OPEN", bothColumns = true, headerValue2 = "vs CLOSE")
        qwRow += 1

    // Cash block
    if qwShowCash
        f_qwHeaderRow(tableId = qwTable, rowIndex = qwRow, headerLabel = "CASH",
             headerValue = f_qwFormatPct(pctChange = qwBothColumns ? qwCashNetVsOpen : qwCashNet),
             bothColumns = qwBothColumns,
             headerValue2 = f_qwFormatPct(pctChange = qwCashNetVsClose))
        qwRow += 1
        for cashReading in qwCashReadings
            f_qwReadingRow(tableId = qwTable, rowIndex = qwRow, reading = cashReading, isDimmed = false, bothColumns = qwBothColumns)
            qwRow += 1

    // Futures block
    if qwShowFutures
        f_qwHeaderRow(tableId = qwTable, rowIndex = qwRow, headerLabel = "FUTURES",
             headerValue = f_qwFormatPct(pctChange = qwBothColumns ? qwFuturesNetVsOpen : qwFuturesNet),
             bothColumns = qwBothColumns,
             headerValue2 = f_qwFormatPct(pctChange = qwFuturesNetVsClose))
        qwRow += 1
        for futuresReading in qwFuturesReadings
            f_qwReadingRow(tableId = qwTable, rowIndex = qwRow, reading = futuresReading, isDimmed = false, bothColumns = qwBothColumns)
            qwRow += 1

    // Sectors block — header line surfaces the live green/red counts and
    // their since-open delta (the "color rotation" early-warning signal).
    // Uses ● (filled circle, Nord-themed) in place of emoji circles. Delta
    // arrow is "·" when no open snapshot exists yet (chart loaded mid-session
    // or sector feed degraded) so the user can distinguish "we don't know
    // yet" from "no change". Value cell is tinted by the dominant committed
    // lean — NORD8 (green), NORD11 (red), NORD4 (balanced/none). One color
    // covers both ● symbols because Pine table cells are single-color; the
    // numeric counts disambiguate which is greens (first) vs reds (second).
    // Commodity rows (XLE, XLB) are dimmed when "Discount Commodity Sectors"
    // is on, so it's visually obvious they don't contribute to the verdict.
    if qwShowSectors
        string qwGreensArrow = na(qwGreensDelta) ? "·" : qwGreensDelta > 0 ? "▲" : qwGreensDelta < 0 ? "▼" : "→"
        string qwRedsArrow   = na(qwRedsDelta)   ? "·" : qwRedsDelta   > 0 ? "▲" : qwRedsDelta   < 0 ? "▼" : "→"
        string qwGreensDeltaText = na(qwGreensDelta) ? "" : str.tostring(math.abs(qwGreensDelta))
        string qwRedsDeltaText   = na(qwRedsDelta)   ? "" : str.tostring(math.abs(qwRedsDelta))
        string qwSectorHeaderValue = str.format("●{0} {1}{2}  ●{3} {4}{5}",
             qwSectorGreensRaw, qwGreensArrow, qwGreensDeltaText,
             qwSectorRedsRaw,   qwRedsArrow,   qwRedsDeltaText)
        color qwSectorHeaderValueColor = qwSectorGreensSerious > qwSectorRedsSerious ? color.new(color = NORD8, transp = 0) :
             qwSectorGreensSerious < qwSectorRedsSerious ? color.new(color = NORD11, transp = 0) :
             color.new(color = NORD4, transp = 30)
        table.cell(table_id = qwTable, column = 0, row = qwRow, text = "SECTORS",
             text_color = color.new(color = NORD9, transp = 0),
             text_halign = text.align_left,
             text_valign = text.align_center,
             text_size = qwTextSize,
             bgcolor = color.new(color = NORD1, transp = 25))
        // In both-columns mode the counts sit in the rightmost column; the
        // middle cell is filled with header background so the row reads as one
        // continuous band.
        if qwBothColumns
            table.cell(table_id = qwTable, column = 1, row = qwRow, text = "",
                 text_size = qwTextSize,
                 bgcolor = color.new(color = NORD1, transp = 25))
        table.cell(table_id = qwTable, column = qwBothColumns ? 2 : 1, row = qwRow, text = qwSectorHeaderValue,
             text_color = qwSectorHeaderValueColor,
             text_halign = text.align_right,
             text_valign = text.align_center,
             text_size = qwTextSize,
             bgcolor = color.new(color = NORD1, transp = 25))
        qwRow += 1
        for sectorReading in qwSectorReadings
            f_qwReadingRow(tableId = qwTable, rowIndex = qwRow, reading = sectorReading, isDimmed = qwIgnoreCommoditySectors and sectorReading.isCommodity, bothColumns = qwBothColumns)
            qwRow += 1

    // Regime verdict — synthesizes the five bifurcation / commitment / data checks.
    if qwShowRegime
        string qwRegimeDetail = qwDataGap ?
             str.format("C{0}/{1} F{2}/{3} S{4}/{5}",
                  qwCashReceived,    qwCashExpected,
                  qwFuturesReceived, qwFuturesExpected,
                  qwSectorTotal,     qwSectorExpected) :
             str.format("{0}/{1}", math.max(qwSectorGreensSerious, qwSectorRedsSerious), qwSectorTotal)
        if qwRegimeOnlyView
            table.cell(table_id = qwTable, column = 0, row = qwRow, text = qwRegimeText,
                 text_color = color.new(color = NORD6, transp = 0),
                 text_halign = text.align_center,
                 text_valign = text.align_center,
                 text_size = qwTextSize,
                 bgcolor = qwRegimeColor,
                 tooltip = qwRegimeTooltip)
            table.cell(table_id = qwTable, column = 1, row = qwRow, text = qwRegimeDetail,
                 text_color = color.new(color = NORD6, transp = 0),
                 text_halign = text.align_center,
                 text_valign = text.align_center,
                 text_size = qwTextSize,
                 bgcolor = qwRegimeColor,
                 tooltip = qwDataGap ?
                      "Per-group availability when a feed is missing: C=cash, F=futures, S=sectors. Format: received/expected." :
                      "Seriously-moving (0.5%+) sector count on the dominant side / total sectors counted.")
            qwRow += 1
        else
            f_qwHeaderRow(tableId = qwTable, rowIndex = qwRow, headerLabel = "REGIME", headerValue = qwBothColumns ? "" : "Verdict", bothColumns = qwBothColumns, headerValue2 = "Verdict")
            qwRow += 1
            table.cell(table_id = qwTable, column = 0, row = qwRow, text = qwRegimeText,
                 text_color = color.new(color = NORD6, transp = 0),
                 text_halign = text.align_left,
                 text_valign = text.align_center,
                 text_size = qwTextSize,
                 bgcolor = qwRegimeColor,
                 tooltip = qwRegimeTooltip)
            if qwBothColumns
                table.cell(table_id = qwTable, column = 1, row = qwRow, text = "",
                     text_size = qwTextSize,
                     bgcolor = qwRegimeColor)
            table.cell(table_id = qwTable, column = qwBothColumns ? 2 : 1, row = qwRow, text = qwRegimeDetail,
                 text_color = color.new(color = NORD6, transp = 0),
                 text_halign = text.align_right,
                 text_valign = text.align_center,
                 text_size = qwTextSize,
                 bgcolor = qwRegimeColor,
                 tooltip = qwDataGap ?
                      "Per-group availability when a feed is missing: C=cash, F=futures, S=sectors. Format: received/expected." :
                      "Seriously-moving (0.5%+) sector count on the dominant side / total sectors counted.")
            qwRow += 1
