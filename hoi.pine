//@version=6
indicator(title = "Hindenburg Omen Indicator", shorttitle = "⚠️ HOI", overlay = true)

// 🧱 CONSTANTS
const string GROUP_MARKET = "🏛️ Market"
const string GROUP_CONDITIONS = "🧪 Conditions"
const string GROUP_DISPLAY = "🖥️ Display"

// Nord Theme Color Constants
// Polar Night
const color NORD0 = #2E3440
const color NORD1 = #3B4252
const color NORD2 = #434C5E
const color NORD3 = #4C566A
// Snow Storm  
const color NORD4 = #D8DEE9
const color NORD5 = #E5E9F0
const color NORD6 = #ECEFF4
// Frost
const color NORD7 = #8FBCBB
const color NORD8 = #88C0D0
const color NORD9 = #81A1C1
const color NORD10 = #5E81AC
// Aurora
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

// 🎛️ USER INPUT SETTINGS
// Market Selection — unified dropdown across all market-aware indicators.
// TradingView publishes USI breadth feeds with these suffixes only: .NY (NYSE),
// .NQ (Nasdaq exchange), .DJ (Dow 30 — index-specific), .US (combined US).
// No .SP or .RL suffix exists, so S&P 500 routes to NYSE breadth and Russell
// 2000 routes to the US-wide composite as closest proxies.
string market = input.string(
     defval = "S&P 500",
     title = "Market (Index)",
     options = ["S&P 500", "NASDAQ 100", "Dow Jones", "Russell 2000"],
     tooltip = "S&P 500 → NYSE breadth (.NY). NASDAQ 100 → Nasdaq exchange-wide (.NQ). Dow Jones → exact Dow 30 breadth (.DJ). Russell 2000 → US-wide composite (.US). New highs/lows route to NYSE-wide (HIGN/LOWN) for all except NASDAQ 100 which uses NAHO/NALO.",
     group = GROUP_MARKET
 )

string indexSymbol = switch market
    "S&P 500"      => "SP:SPX"
    "NASDAQ 100"   => "NASDAQ:NDX"
    "Dow Jones"    => "DJ:DJI"
    "Russell 2000" => "TVC:RUT"
    => "SP:SPX"

string advSymbol = switch market
    "S&P 500"      => "USI:ADVN.NY"
    "NASDAQ 100"   => "USI:ADVN.NQ"
    "Dow Jones"    => "USI:ADVN.DJ"
    "Russell 2000" => "USI:ADVN.US"
    => "USI:ADVN.NY"

string decSymbol = switch market
    "S&P 500"      => "USI:DECL.NY"
    "NASDAQ 100"   => "USI:DECL.NQ"
    "Dow Jones"    => "USI:DECL.DJ"
    "Russell 2000" => "USI:DECL.US"
    => "USI:DECL.NY"

string uncSymbol = switch market
    "S&P 500"      => "USI:UNCH.NY"
    "NASDAQ 100"   => "USI:UNCH.NQ"
    "Dow Jones"    => "USI:UNCH.DJ"
    "Russell 2000" => "USI:UNCH.US"
    => "USI:UNCH.NY"

string newHighSymbol = market == "NASDAQ 100" ? "INDEX:NAHO" : "INDEX:HIGN"
string newLowSymbol = market == "NASDAQ 100" ? "INDEX:NALO" : "INDEX:LOWN"

// Conditions
int posTrendLookback = input.int(defval = 50, title = "Positive Trend Lookback (Days)",
     minval = 1, maxval = 252, step = 1, tooltip = "Index must be >= its value X days ago",
     group = GROUP_CONDITIONS)
float newLowHighThreshold = input.float(defval = 2.2, title = "New Lows/Highs Threshold (%)",
     minval = 0.1, maxval = 10, step = 0.1, tooltip = "Percentage threshold for new highs and lows",
     group = GROUP_CONDITIONS)
int clusterWindowDays = input.int(defval = 36, title = "Cluster Window (Days)",
     minval = 1, maxval = 120, step = 1, tooltip = "Rolling days to count multiple signals",
     group = GROUP_CONDITIONS)
int clusterMinSignals = input.int(defval = 2, title = "Cluster Min Signals",
     minval = 1, maxval = 10, step = 1, tooltip = "Signals required within the window to confirm",
     group = GROUP_CONDITIONS)

// Display
int signalPeriod = input.int(defval = 10, title = "Signal Period (Days)",
     minval = 1, maxval = 90, step = 1, tooltip = "Background highlight period after signal",
     group = GROUP_DISPLAY)
bool showBackground = input.bool(defval = true, title = "Show Background",
     tooltip = "Show background color during signal period", group = GROUP_DISPLAY)
color backgroundColor = input.color(defval = color.new(color = NORD11, transp = 90), title = "Background Color",
     tooltip = "Background highlight color shown while the signal window is active.", group = GROUP_DISPLAY)

// 🧮 DATA & CALCULATIONS
// Get breadth and index data (daily)
float advIssues = request.security(symbol = advSymbol, timeframe = "D", expression = close,
     gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
float decIssues = request.security(symbol = decSymbol, timeframe = "D", expression = close,
     gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
float uncIssues = request.security(symbol = uncSymbol, timeframe = "D", expression = close,
     gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
float newHighs = request.security(symbol = newHighSymbol, timeframe = "D", expression = close,
     gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
float newLows = request.security(symbol = newLowSymbol, timeframe = "D", expression = close,
     gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
float marketIndexValue = request.security(symbol = indexSymbol, timeframe = "D", expression = close,
     gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)

// Calculations
// Total number of issues (like the reference codes)
float total = advIssues + decIssues + uncIssues
float nhPct = not na(total) and total > 0 ? (newHighs / total * 100) : na
float nlPct = not na(total) and total > 0 ? (newLows / total * 100) : na

// Condition 1: % of issues hitting new 52W highs and 52W lows >= threshold
bool isNewHighLowThresholdMet = not na(nhPct) and not na(nlPct) and
     nhPct >= newLowHighThreshold and
     nlPct >= newLowHighThreshold and
     math.min(nhPct, nlPct) >= newLowHighThreshold

// Condition 2: Index is higher or equal in value than when it was X days ago
bool isPositiveTrend = not na(marketIndexValue) and not na(marketIndexValue[posTrendLookback]) and
     marketIndexValue >= marketIndexValue[posTrendLookback]

// Condition 3: McClellan Oscillator must be negative
float mcclellanRatio = not na(advIssues) and not na(decIssues) and (advIssues + decIssues) > 0 ?
     1000 * ((advIssues - decIssues) / (advIssues + decIssues)) : na
float mcclellanFastEma = ta.ema(source = mcclellanRatio, length = 19)
float mcclellanSlowEma = ta.ema(source = mcclellanRatio, length = 39)
float mcclellanOscillator = mcclellanFastEma - mcclellanSlowEma
bool isMcclellanNegative = not na(mcclellanOscillator) and mcclellanOscillator < 0

// Condition 4: Ratio of new 52W highs to new 52W lows < 2
bool isHighLowRatioValid = not na(newHighs) and not na(newLows) and newLows > 0 and
     (newHighs / newLows) < 2

// Confirmed daily bar flag (daily time)
bool dailyConfirmed = request.security(symbol = indexSymbol, timeframe = "D", expression = barstate.isconfirmed, gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)

// Hindenburg Omen Signal (confirmed daily bars only)
bool homenSignalRaw = dailyConfirmed and isNewHighLowThresholdMet and isPositiveTrend and isMcclellanNegative and isHighLowRatioValid

// Cluster confirmation: require multiple signals within a rolling 36-day window.
var array<int> signalWindow = array.new<int>()
var int clusterCount = 0

if dailyConfirmed and barstate.isconfirmed
    array.push(signalWindow, homenSignalRaw ? 1 : 0)
    if array.size(signalWindow) > clusterWindowDays
        array.shift(signalWindow)
    clusterCount := int(array.sum(signalWindow))

bool homenSignal = homenSignalRaw and clusterCount >= clusterMinSignals

// Track days since last signal using confirmed daily bars (not chart bars)
var int daysSinceSignal = na
if dailyConfirmed and barstate.isconfirmed
    if homenSignal
        daysSinceSignal := 0
    else if not na(daysSinceSignal)
        daysSinceSignal += 1

// Background Color for Signal Period (days)
bool inSignalWindow = not na(daysSinceSignal) and daysSinceSignal >= 0 and daysSinceSignal <= signalPeriod
bgcolor(showBackground and inSignalWindow ? backgroundColor : na, title = "Signal Period Background")
