// © henry_oliver
// MACD & Waves — Top Dog Trading momentum waves (Barry Burns)
// MOM = MACD line (5/20 EMA), DAD = signal line (30 EMA). Each momentum wave is timed by
// the cycle indicator (Stochastic 5,2,3); MOM supplies the level. Trend & wave count come
// from HH/HL (up) vs LL/LH (down) on the registered MOM extremes — not from MACD pivots,
// zero crosses, or the signal line angle.

//@version=6
indicator(title = "MACD & Waves", shorttitle = "📉 MACD&W", max_labels_count = 500)

// ═════════════════════════════════════════════════════════════════════════════
// 🧱 CONSTANTS
// Shared immutable values used by the indicator, including the Nord palette.
// ═════════════════════════════════════════════════════════════════════════════
// Nord Theme Color
// Polar Night
const color NORD0 = #2E3440
const color NORD1 = #3B4252
const color NORD2 = #434C5E
const color NORD3 = #4C566A
// Snow Storm
const color NORD4 = #D8DEE9
const color NORD5 = #E5E9F0
const color NORD6 = #ECEFF4
// Frost
const color NORD7 = #8FBCBB
const color NORD8 = #88C0D0
const color NORD9 = #81A1C1
const color NORD10 = #5E81AC
// Aurora
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

// Shared trend colors — consumed by both the MACD signal line and the wave labels.
const color TREND_UP_COLOR = color.new(color = NORD8, transp = 20)
const color TREND_DOWN_COLOR = color.new(color = NORD9, transp = 60)

// ═════════════════════════════════════════════════════════════════════════════
// 📈 MACD
// MOM/DAD engine: MACD line, signal line, histogram, and their plot colors.
// Signal line color reads the slope (visual only — never used for wave counting).
// ═════════════════════════════════════════════════════════════════════════════
const string GROUP_MACD = "📈 MACD"

macdSource = input.source(defval = close, title = "Source", group = GROUP_MACD)
macdFastLength = input.int(defval = 5, title = "Fast Length", minval = 1, group = GROUP_MACD)
macdSlowLength = input.int(defval = 20, title = "Slow Length", minval = 1, group = GROUP_MACD)
macdSignalLength = input.int(defval = 30, title = "Signal Length", minval = 1, group = GROUP_MACD)
macdOscMAType = input.string(defval = "EMA", title = "Oscillator MA Type", options = ["EMA", "SMA"], group = GROUP_MACD, display = display.none)
macdSignalMAType = input.string(defval = "EMA", title = "Signal MA Type", options = ["EMA", "SMA"], group = GROUP_MACD, display = display.none)

// Helper function to calculate an EMA or SMA of a source series.
f_ma(float maSource, int maLength, simple string maType) =>
    maType == "EMA" ? ta.ema(source = maSource, length = maLength) : ta.sma(source = maSource, length = maLength)

float macd = f_ma(macdSource, macdFastLength, macdOscMAType) - f_ma(macdSource, macdSlowLength, macdOscMAType)
float signal = f_ma(macd, macdSignalLength, macdSignalMAType)
float hist = macd - signal

color histColor = hist >= 0 ?
     (hist > hist[1] ? NORD9 : color.new(color = NORD9, transp = 60)) :
     (hist > hist[1] ? color.new(color = NORD10, transp = 60) : NORD10)
color signalColor = signal > signal[1] ? TREND_UP_COLOR : TREND_DOWN_COLOR

// ═════════════════════════════════════════════════════════════════════════════
// 🌊 WAVES
// Momentum wave counting. MOM high = highest MACD value while %D holds the
// cycle-high zone (≥ upper band, held through the mid-band); MOM low = lowest
// MACD while %D holds the cycle-low zone. A wave registers when %D crosses
// through the band to the opposite zone. Trend is read off the registered
// extremes: HH → up impulse, HL → up retrace, LL → down impulse, LH → down
// retrace. The count resets to 1 when an impulse flips the structure; the
// newest wave is provisional until the next swing confirms it.
// ═════════════════════════════════════════════════════════════════════════════
const string GROUP_WAVES = "🌊 Waves"

showWaveCount = input.bool(defval = true, title = "Show Wave Count", group = GROUP_WAVES)
cycleKLength = input.int(defval = 5, title = "Cycle %K Length", minval = 1, group = GROUP_WAVES,
     tooltip = "Stochastic %K length. Barry's cycle indicator uses 5.")
cycleKSmoothing = input.int(defval = 2, title = "Cycle %K Smoothing", minval = 1, group = GROUP_WAVES)
cycleDSmoothing = input.int(defval = 3, title = "Cycle %D Smoothing", minval = 1, group = GROUP_WAVES)
cycleBandHalfWidth = input.float(defval = 5, title = "Cycle Band (± around 50)", minval = 0, maxval = 25, group = GROUP_WAVES,
     tooltip = "Barry's 45/55 band = 5. A wave registers when %D crosses through the band to the opposite zone. Set 0 for a single 50 line; widen to reduce whipsaw.")

float cycleD = ta.sma(source = ta.sma(source = ta.stoch(source = close, high = high, low = low, length = cycleKLength), length = cycleKSmoothing), length = cycleDSmoothing)
float cycleUpperBand = 50 + cycleBandHalfWidth
float cycleLowerBand = 50 - cycleBandHalfWidth

var int cycleZone = 0        // 1 = cycle-high zone, -1 = cycle-low zone, 0 = unseeded
var int waveTrend = 0        // 1 = up (HH/HL), -1 = down (LL/LH)
var int waveNumber = 0
var float waveRunMax = na    // running MOM max during the current high zone
var int waveRunMaxBar = na
var float waveRunMin = na    // running MOM min during the current low zone
var int waveRunMinBar = na
var float waveLastHigh = na  // last registered MOM high
var float waveLastLow = na   // last registered MOM low

// Helper function to draw a wave count label at a registered MOM extreme.
f_drawWave(int waveBar, float waveValue, int waveIndex, bool isHigh, color waveTextColor) =>
    if showWaveCount
        label.new(x = waveBar, y = waveValue, text = str.tostring(waveIndex),
             style = isHigh ? label.style_label_down : label.style_label_up,
             color = color.new(color = color.gray, transp = 100),
             textcolor = waveTextColor, size = 14)

// The engine runs on every realtime tick so the count moves intrabar. Pine's
// rollback keeps it honest: var state and intrabar-created labels revert on
// each update, so intrabar registrations stay provisional until the bar's
// closing tick commits them.

// Zone with hysteresis: %D must reach a band edge to claim a zone and holds it
// through the mid-band. The MOM extreme is tracked across the whole zone hold.
int cycleNewZone = cycleD >= cycleUpperBand ? 1 : cycleD <= cycleLowerBand ? -1 : cycleZone

if cycleNewZone == 1 and (na(waveRunMax) or macd > waveRunMax)
    waveRunMax := macd
    waveRunMaxBar := bar_index
if cycleNewZone == -1 and (na(waveRunMin) or macd < waveRunMin)
    waveRunMin := macd
    waveRunMinBar := bar_index

// The high zone completes when %D crosses through the band to the low zone —
// register the MOM high.
if cycleZone == 1 and cycleNewZone == -1 and not na(waveRunMax)
    if not na(waveLastHigh)
        if waveRunMax > waveLastHigh
            // Higher High — up impulse. Resets the count to 1 on a structure flip.
            waveNumber := waveTrend == 1 ? waveNumber + 1 : 1
            waveTrend := 1
            f_drawWave(waveRunMaxBar, waveRunMax, waveNumber, true, TREND_UP_COLOR)
        else if waveTrend == -1
            // Lower High — down retrace, counted only while the trend is down.
            waveNumber += 1
            f_drawWave(waveRunMaxBar, waveRunMax, waveNumber, true, TREND_DOWN_COLOR)
    waveLastHigh := waveRunMax
    waveRunMax := na

// The low zone completes when %D crosses through the band to the high zone —
// register the MOM low.
if cycleZone == -1 and cycleNewZone == 1 and not na(waveRunMin)
    if not na(waveLastLow)
        if waveRunMin < waveLastLow
            // Lower Low — down impulse. Resets the count to 1 on a structure flip.
            waveNumber := waveTrend == -1 ? waveNumber + 1 : 1
            waveTrend := -1
            f_drawWave(waveRunMinBar, waveRunMin, waveNumber, false, TREND_DOWN_COLOR)
        else if waveTrend == 1
            // Higher Low — up retrace, counted only while the trend is up.
            waveNumber += 1
            f_drawWave(waveRunMinBar, waveRunMin, waveNumber, false, TREND_UP_COLOR)
    waveLastLow := waveRunMin
    waveRunMin := na

cycleZone := cycleNewZone

// ═════════════════════════════════════════════════════════════════════════════
// 🎨 PLOTS
// Final plot, hline, and alert statements only — all series and colors are
// computed in their owning sections above.
// ═════════════════════════════════════════════════════════════════════════════
hline(price = 0, title = "Zero Line", color = color.new(color = NORD3, transp = 50), linestyle = hline.style_dashed)
plot(series = hist, title = "Histogram", color = histColor, style = plot.style_columns, display = display.none)
plot(series = macd, title = "MACD", color = NORD3, linewidth = 2)
plot(series = signal, title = "Signal", color = signalColor, linewidth = 4)
plot(series = cycleD, title = "Cycle %D", color = NORD9, display = display.data_window)

alertcondition(condition = hist[1] >= 0 and hist < 0, title = "Rising to falling", message = "MACD histogram switched from a rising to falling state")
alertcondition(condition = hist[1] <= 0 and hist > 0, title = "Falling to rising", message = "MACD histogram switched from a falling to rising state")
