//@version=6
indicator(title = "Stochastic", shorttitle = "🎲 Stoch", format = format.price, precision = 2, timeframe = "", timeframe_gaps = false)

// 🧱 CONSTANTS
const string GROUP_STOCH = "📈 Cycle (Setup Chart)"

// Nord Theme Color
// Polar Night
const color NORD0 = #2E3440
const color NORD1 = #3B4252
const color NORD2 = #434C5E
const color NORD3 = #4C566A
// Snow Storm
const color NORD4 = #D8DEE9
const color NORD5 = #E5E9F0
const color NORD6 = #ECEFF4
// Frost
const color NORD7 = #8FBCBB
const color NORD8 = #88C0D0
const color NORD9 = #81A1C1
const color NORD10 = #5E81AC
// Aurora
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

// Direction colors (same pair as the trend coloring in macd-waves)
const color UP_COLOR = color.new(color = NORD8, transp = 20)
const color DOWN_COLOR = color.new(color = NORD9, transp = 60)

// 🎛️ USER INPUT SETTINGS

// Stochastic Input Settings (Barry's cycle defaults: %K Length 5, %K Smoothing 2, %D Smoothing 3)
int periodK = input.int(defval = 5, title = "%K Length", minval = 1, group = GROUP_STOCH)
int smoothK = input.int(defval = 2, title = "%K Smoothing", minval = 1, group = GROUP_STOCH)
int periodD = input.int(defval = 3, title = "%D Smoothing", minval = 1, group = GROUP_STOCH)

// 🧮 CALCULATIONS
float k = ta.sma(source = ta.stoch(source = close, high = high, low = low, length = periodK), length = smoothK)
float d = ta.sma(source = k, length = periodD)

// Direction of %D — hold the last direction on flat bars so the color doesn't flicker.
var bool dRising = true
dRising := d > d[1] ? true : d < d[1] ? false : dRising

// 📊 PLOT
// %D first so %K draws on top of it. Widths/colors are Style-tab editable.
plot(series = d, title = "%D", color = dRising ? UP_COLOR : DOWN_COLOR, linewidth = 4)
plot(series = k, title = "%K", color = NORD3, linewidth = 2)

// Bands — fixed prices; color/width/style/visibility are Style-tab editable.
hline(price = 80, title = "Upper Band", color = NORD3, linewidth = 1, linestyle = hline.style_dashed)
hline(price = 55, title = "Upper Mid Band", color = NORD3, linewidth = 1, linestyle = hline.style_dashed)
hline(price = 50, title = "Middle Band", color = color.new(color = NORD3, transp = 50), linewidth = 1, display = display.none)
hline(price = 45, title = "Lower Mid Band", color = NORD3, linewidth = 1, linestyle = hline.style_dashed)
hline(price = 20, title = "Lower Band", color = NORD3, linewidth = 1, linestyle = hline.style_dashed)
