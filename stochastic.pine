// Stochastic — Top Dog Trading "Energy of Cycles".
// Serves two roles in one indicator:
//   1. CYCLE indicator on the setup chart        → 5/2/3 stochastic, 80/20 + 55/45 bands.
//   2. LONG TERM CYCLE CONFIRMATION on the 3× HTF → same cycle settings pulled from the
//      confirmation chart (Barry's 3:1 fractal ratio). Read %D direction to confirm the trade.

//@version=6
indicator(title = "Stochastic", shorttitle = "🎲 Stoch", format = format.price, precision = 2, timeframe = "", timeframe_gaps = true)

// 🧱 CONSTANTS
const string GROUP_STOCH = "📈 Cycle (Setup Chart)"
const string GROUP_STYLE = "🎨 Style"
const string GROUP_BANDS = "📏 Bands"
const string GROUP_CONFIRM = "🔭 Long Term Cycle Confirmation"

// Nord Theme Color
// Polar Night
const color NORD0 = #2E3440
const color NORD1 = #3B4252
const color NORD2 = #434C5E
const color NORD3 = #4C566A
// Snow Storm
const color NORD4 = #D8DEE9
const color NORD5 = #E5E9F0
const color NORD6 = #ECEFF4
// Frost
const color NORD7 = #8FBCBB
const color NORD8 = #88C0D0
const color NORD9 = #81A1C1
const color NORD10 = #5E81AC
// Aurora
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

// 🎛️ USER INPUT SETTINGS

// Stochastic Input Settings (Barry's cycle defaults: %K 5, %K Smoothing 2, %D 3)
int periodK = input.int(defval = 5, title = "%K Length", minval = 1, group = GROUP_STOCH)
int smoothK = input.int(defval = 2, title = "%K Smoothing", minval = 1, group = GROUP_STOCH)
int periodD = input.int(defval = 3, title = "%D Smoothing", minval = 1, group = GROUP_STOCH)

// Stochastic Colors & Width
color colorK = input.color(defval = NORD3, title = "%K Color", group = GROUP_STYLE)
int widthK = input.int(defval = 2, title = "%K Width", minval = 1, maxval = 10, group = GROUP_STYLE)
color colorD = input.color(defval = color.new(color = NORD2, transp = 60), title = "%D Color", group = GROUP_STYLE)
int widthD = input.int(defval = 4, title = "%D Width", minval = 1, maxval = 10, group = GROUP_STYLE)

// Band Settings
bool showUpperBand = input.bool(defval = true, title = "Show Upper Band", group = GROUP_BANDS)
float upperBand = input.float(defval = 80, title = "Upper Band", minval = 50, maxval = 100, group = GROUP_BANDS)
bool showUpperMidBand = input.bool(defval = true, title = "Show Upper Mid Band", group = GROUP_BANDS)
float upperMidBand = input.float(defval = 55, title = "Upper Mid Band", minval = 50, maxval = 100, group = GROUP_BANDS)
bool showMiddleBand = input.bool(defval = false, title = "Show Middle Band", group = GROUP_BANDS)
float middleBand = input.float(defval = 50, title = "Middle Band", minval = 0, maxval = 100, group = GROUP_BANDS)
bool showLowerMidBand = input.bool(defval = true, title = "Show Lower Mid Band", group = GROUP_BANDS)
float lowerMidBand = input.float(defval = 45, title = "Lower Mid Band", minval = 0, maxval = 50, group = GROUP_BANDS)
bool showLowerBand = input.bool(defval = true, title = "Show Lower Band", group = GROUP_BANDS)
float lowerBand = input.float(defval = 20, title = "Lower Band", minval = 0, maxval = 50, group = GROUP_BANDS)
color bandColor = input.color(defval = NORD3, title = "Band Color", group = GROUP_BANDS)
int bandWidth = input.int(defval = 1, title = "Band Width", minval = 1, maxval = 10, group = GROUP_BANDS)

// Long Term Cycle Confirmation Settings
// The confirmation chart is the higher timeframe in Barry's 3:1 fractal. Same cycle settings,
// bigger scale. Confirm the trade by the direction/position of the confirmation %D.
bool showConfirm = input.bool(defval = false, title = "Show Long Term Cycle", group = GROUP_CONFIRM,
     tooltip = "Plots the cycle stochastic from the confirmation (higher) timeframe using the same %K/%D settings.")
bool confirmAuto = input.bool(defval = true, title = "Auto Confirmation Timeframe (Fractal Ratio)", group = GROUP_CONFIRM,
     tooltip = "When on, the confirmation timeframe is the chart timeframe × the ratio below (Barry's 3:1 rule).")
int confirmRatio = input.int(defval = 3, title = "Fractal Ratio", minval = 2, maxval = 12, group = GROUP_CONFIRM,
     tooltip = "Barry's standard is 3 (setup : confirmation = 1 : 3).")
string confirmTimeframe = input.timeframe(defval = "", title = "Manual Confirmation Timeframe", group = GROUP_CONFIRM,
     tooltip = "Used only when Auto is off. Leave blank to fall back to the chart timeframe.")
bool confirmShowK = input.bool(defval = false, title = "Show Confirmation %K", group = GROUP_CONFIRM)
bool confirmShowD = input.bool(defval = true, title = "Show Confirmation %D", group = GROUP_CONFIRM,
     tooltip = "%D is the line Barry reads on the confirmation chart to confirm direction.")
color colorConfirmK = input.color(defval = color.new(color = NORD8, transp = 40), title = "Confirmation %K Color", group = GROUP_CONFIRM)
int widthConfirmK = input.int(defval = 1, title = "Confirmation %K Width", minval = 1, maxval = 10, group = GROUP_CONFIRM)
color colorConfirmD = input.color(defval = NORD10, title = "Confirmation %D Color", group = GROUP_CONFIRM)
int widthConfirmD = input.int(defval = 3, title = "Confirmation %D Width", minval = 1, maxval = 10, group = GROUP_CONFIRM)

// 🧮 CALCULATIONS
// Stochastic %K/%D (reused for both the local cycle and the HTF confirmation so the
// confirmation is a true fractal of the setup — same indicator, bigger scale).
f_stoch(simple int lenK, simple int smoothingK, simple int lenD) =>
    float kk = ta.sma(source = ta.stoch(source = close, high = high, low = low, length = lenK), length = smoothingK)
    float dd = ta.sma(source = kk, length = lenD)
    [kk, dd]

// Local cycle (setup chart)
[k, d] = f_stoch(lenK = periodK, smoothingK = smoothK, lenD = periodD)

// Resolve the confirmation timeframe
int chartSeconds = timeframe.in_seconds()
string resolvedConfirmTimeframe = confirmAuto ? timeframe.from_seconds(seconds = chartSeconds * confirmRatio) : (confirmTimeframe == "" ? timeframe.period : confirmTimeframe)

// Long term cycle (confirmation chart) — same settings, pulled from the higher timeframe.
[confirmKRaw, confirmDRaw] = request.security(
     symbol = syminfo.tickerid,
     timeframe = resolvedConfirmTimeframe,
     expression = f_stoch(lenK = periodK, smoothingK = smoothK, lenD = periodD),
     lookahead = barmerge.lookahead_off,
     gaps = barmerge.gaps_off)

float confirmK = showConfirm and confirmShowK ? confirmKRaw : na
float confirmD = showConfirm and confirmShowD ? confirmDRaw : na

// 📊 PLOT
// Plot Stochastic Lines (setup chart cycle)
plot(series = d, title = "%D", color = colorD, linewidth = widthD)
plot(series = k, title = "%K", color = colorK, linewidth = widthK)

// Plot Long Term Cycle Confirmation (higher timeframe)
plot(series = confirmD, title = "LT %D", color = colorConfirmD, linewidth = widthConfirmD)
plot(series = confirmK, title = "LT %K", color = colorConfirmK, linewidth = widthConfirmK)

// Plot Bands
h0 = hline(price = showUpperBand ? upperBand : na, title = "Upper Band", color = bandColor, linewidth = bandWidth, linestyle = hline.style_dashed)
hline(price = showUpperMidBand ? upperMidBand : na, title = "Upper Mid Band", color = bandColor, linewidth = bandWidth, linestyle = hline.style_dashed)
hline(price = showMiddleBand ? middleBand : na, title = "Middle Band", color = color.new(color = bandColor, transp = 50), linewidth = bandWidth)
hline(price = showLowerMidBand ? lowerMidBand : na, title = "Lower Mid Band", color = bandColor, linewidth = bandWidth, linestyle = hline.style_dashed)
h1 = hline(price = showLowerBand ? lowerBand : na, title = "Lower Band", color = bandColor, linewidth = bandWidth, linestyle = hline.style_dashed)
