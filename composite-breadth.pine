//@version=6
indicator(title = "Composite Breadth Indicator", shorttitle = "📊 CBI", format = format.price, precision = 2)

// ═════════════════════════════════════════════════════════════════════════════
// 🧱 CONSTANTS
// Nord palette plus shared composite-scale and strip-layout values.
// ═════════════════════════════════════════════════════════════════════════════
// Polar Night
const color NORD0  = #2E3440
const color NORD1  = #3B4252
const color NORD2  = #434C5E
const color NORD3  = #4C566A
// Snow Storm
const color NORD4  = #D8DEE9
const color NORD5  = #E5E9F0
const color NORD6  = #ECEFF4
// Frost
const color NORD7  = #8FBCBB
const color NORD8  = #88C0D0
const color NORD9  = #81A1C1
const color NORD10 = #5E81AC
// Aurora
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

// Composite scale and reference levels (bounded by translator clipping)
const float SCALE_MAX  = 100.0
const float REF_STRONG = 75.0
const float REF_SOLID  = 50.0
const float REF_MILD   = 25.0

// Component strip layout, anchored below the composite zone
const float STRIP_VOLD_TOP  = -105.0
const float STRIP_VOLD_BASE = -109.0
const float STRIP_ADD_TOP   = -111.0
const float STRIP_ADD_BASE  = -115.0
const float STRIP_TICK_TOP  = -117.0
const float STRIP_TICK_BASE = -121.0

// Internal tuning
const float TICK_FIXED_SCALE              = 500.0
const float DIVERGENCE_DEADBAND           = 0.10
const int   REGIME_WARMUP_BARS            = 5
const float REGIME_CHOP_MAX_ABS           = 15.0
const float REGIME_TREND_MIN_ABS          = 30.0
const float REGIME_TREND_MIN_PCT          = 0.70
const int   RESOLUTION_MIN_BARS           = 3
const int   RESOLUTION_HOLD_BARS          = 8
const int   RESOLUTION_TIMEOUT            = 18
const float RESOLUTION_REVERSAL_THRESHOLD = 500.0
const float RESOLUTION_CONTINUATION_BAND  = 200.0

// ═════════════════════════════════════════════════════════════════════════════
// 🏛️ MARKET SELECTION
// Market selection inputs and symbol resolution.
// ═════════════════════════════════════════════════════════════════════════════
const string GROUP_MARKET = "🏛️ Market Selection"
const string GROUP_CUSTOM = "🔧 Custom Symbols"

const string MARKET_AUTO        = "Auto"
const string MARKET_NDX         = "Nasdaq 100"
const string MARKET_NDX_QQQ     = "Nasdaq 100 / QQQ"
const string MARKET_NDX_FUTURES = "Nasdaq 100 / NQ"
const string MARKET_IXIC        = "Nasdaq Composite"
const string MARKET_SPX         = "S&P 500"
const string MARKET_SPX_SPY     = "S&P 500 / SPY"
const string MARKET_SPX_FUTURES = "S&P 500 / ES"
const string MARKET_DJI         = "Dow Jones"
const string MARKET_DJI_DIA     = "Dow Jones / DIA"
const string MARKET_DJI_FUTURES = "Dow Jones / YM"
const string MARKET_RUT         = "Russell 2000"
const string MARKET_RUT_IWM     = "Russell 2000 / IWM"
const string MARKET_RUT_FUTURES = "Russell 2000 / RTY"
const string MARKET_CUSTOM      = "Custom"

const string TICK_NY = "USI:TICK"
const string ADD_NY  = "USI:ADD"
const string VOLD_NY = "USI:VOLD"

const string TICK_NQ = "USI:TICKQ"
const string ADD_NQ  = "USI:ADDQ"
const string VOLD_NQ = "USI:VOLDQ"

f_isNasdaqChart() =>
    bool isNasdaqChart = str.contains(source = str.upper(source = syminfo.prefix), str = "NASDAQ")
    isNasdaqChart := isNasdaqChart or syminfo.ticker == "QQQ"
    isNasdaqChart := isNasdaqChart or syminfo.ticker == "TQQQ"
    isNasdaqChart := isNasdaqChart or syminfo.ticker == "SQQQ"
    isNasdaqChart := isNasdaqChart or syminfo.ticker == "NDX"
    isNasdaqChart := isNasdaqChart or syminfo.ticker == "IXIC"
    isNasdaqChart := isNasdaqChart or str.startswith(source = syminfo.ticker, str = "NQ")
    isNasdaqChart

string marketSelection = input.string(defval = MARKET_AUTO, title = "Market",
     options = [MARKET_AUTO, MARKET_NDX, MARKET_NDX_QQQ, MARKET_NDX_FUTURES, MARKET_IXIC, MARKET_SPX, MARKET_SPX_SPY, MARKET_SPX_FUTURES, MARKET_DJI, MARKET_DJI_DIA, MARKET_DJI_FUTURES, MARKET_RUT, MARKET_RUT_IWM, MARKET_RUT_FUTURES, MARKET_CUSTOM],
     tooltip = "Select the market for breadth data. Auto detects based on the current chart symbol.",
     group = GROUP_MARKET)

string customTickSymbol = input.symbol(defval = "USI:TICKQ", title = "TICK Symbol",
     tooltip = "Custom TICK index symbol.", group = GROUP_CUSTOM)
string customAddSymbol = input.symbol(defval = "USI:ADDQ", title = "ADD Symbol",
     tooltip = "Custom Advance-Decline symbol.", group = GROUP_CUSTOM)
string customVoldSymbol = input.symbol(defval = "USI:VOLDQ", title = "VOLD Symbol",
     tooltip = "Custom Up/Down Volume symbol.", group = GROUP_CUSTOM)

bool marketIsNasdaq = f_isNasdaqChart()

string marketTickSymbol = TICK_NY
string marketAddSymbol = ADD_NY
string marketVoldSymbol = VOLD_NY

if marketSelection == MARKET_AUTO
    if marketIsNasdaq
        marketTickSymbol := TICK_NQ
        marketAddSymbol := ADD_NQ
        marketVoldSymbol := VOLD_NQ
else if marketSelection == MARKET_NDX or marketSelection == MARKET_NDX_QQQ or marketSelection == MARKET_NDX_FUTURES or marketSelection == MARKET_IXIC
    marketTickSymbol := TICK_NQ
    marketAddSymbol := ADD_NQ
    marketVoldSymbol := VOLD_NQ
else if marketSelection == MARKET_CUSTOM
    marketTickSymbol := customTickSymbol
    marketAddSymbol := customAddSymbol
    marketVoldSymbol := customVoldSymbol

// ═════════════════════════════════════════════════════════════════════════════
// ⚖️ COMPONENT WEIGHTS
// ═════════════════════════════════════════════════════════════════════════════
const string GROUP_WEIGHTS = "⚖️ Component Weights"

float weightVold = input.float(defval = 40, title = "VOLD Weight", minval = 0, maxval = 100, step = 5,
     tooltip = "Volume trend — regime filter. The slow, dominant-energy reading.", group = GROUP_WEIGHTS)
float weightAdd = input.float(defval = 35, title = "ADD Weight", minval = 0, maxval = 100, step = 5,
     tooltip = "Advance-Decline — leading sentiment. Turns before VOLD does.", group = GROUP_WEIGHTS)
float weightTick = input.float(defval = 25, title = "TICK Weight", minval = 0, maxval = 100, step = 5,
     tooltip = "TICK — sustained momentum (smoothed). Instant ±985 extremes are tracked separately as exhaustion alerts.", group = GROUP_WEIGHTS)

// ═════════════════════════════════════════════════════════════════════════════
// 🧮 CALCULATION
// ═════════════════════════════════════════════════════════════════════════════
const string GROUP_CALC = "🧮 Calculation"

int signalLength = input.int(defval = 13, title = "Signal EMA Length", minval = 1, maxval = 100, step = 1,
     tooltip = "EMA period for the signal line (primary visual).", group = GROUP_CALC)
int tickSmoothLength = input.int(defval = 5, title = "TICK Smoothing", minval = 1, maxval = 20, step = 1,
     tooltip = "EMA smoothing for sustained TICK direction. Raw TICK still feeds instant-extreme detection.", group = GROUP_CALC)
int historySessions = input.int(defval = 20, title = "History Sessions", minval = 5, maxval = 60, step = 1,
     tooltip = "Prior-session count used to normalize anchored VOLD and ADD against their typical daily extremes.", group = GROUP_CALC)
int tickExtremeLevel = input.int(defval = 985, title = "TICK Extreme Threshold", minval = 500, maxval = 1200, step = 5,
     tooltip = "Raw |TICK| level that fires an exhaustion alert.", group = GROUP_CALC)
int divergenceBars = input.int(defval = 5, title = "Divergence Bars", minval = 2, maxval = 20, step = 1,
     tooltip = "Consecutive bars VOLD and ADD must disagree to fire a divergence flag.", group = GROUP_CALC)

// ═════════════════════════════════════════════════════════════════════════════
// 📋 DISPLAY TOGGLES
// ═════════════════════════════════════════════════════════════════════════════
const string GROUP_DISPLAY = "📋 Display"

bool showSignalLine = input.bool(defval = true, title = "Signal Line",
     tooltip = "Primary visual. NORD8 cyan above zero, NORD11 red below.", group = GROUP_DISPLAY)
bool showHistogram = input.bool(defval = true, title = "Histogram Underlay",
     tooltip = "Quiet bars behind the signal line. Bar physically shrinks when components disagree.", group = GROUP_DISPLAY)
bool showRegimeBg = input.bool(defval = true, title = "Regime Background",
     tooltip = "Live session-level tint: Trend ↑ / Trend ↓ / Chop / Exhaustion / Mixed.", group = GROUP_DISPLAY)
bool showStrip = input.bool(defval = true, title = "Component Strip",
     tooltip = "Three thin colored rows below the composite — one per component.", group = GROUP_DISPLAY)
bool showExhaustionMarkers = input.bool(defval = true, title = "TICK Exhaustion Markers",
     tooltip = "Yellow dots when raw |TICK| breaches the extreme threshold; triangles classify each event as continuation or reversal.", group = GROUP_DISPLAY)
bool showDivergenceFlag = input.bool(defval = true, title = "VOLD/ADD Divergence",
     tooltip = "Flag bars where ADD and VOLD have disagreed in direction for N consecutive bars.", group = GROUP_DISPLAY)
bool showReferenceLines = input.bool(defval = true, title = "Reference Lines",
     tooltip = "Zero line plus ±25 / ±50 / ±75 alignment-strength bands.", group = GROUP_DISPLAY)

// ═════════════════════════════════════════════════════════════════════════════
// 📡 DATA REQUESTS
// ═════════════════════════════════════════════════════════════════════════════
float tickValue = request.security(symbol = marketTickSymbol, timeframe = timeframe.period, expression = close,
     gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off, ignore_invalid_symbol = true)
float addValue = request.security(symbol = marketAddSymbol, timeframe = timeframe.period, expression = close,
     gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off, ignore_invalid_symbol = true)
float voldValue = request.security(symbol = marketVoldSymbol, timeframe = timeframe.period, expression = close,
     gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off, ignore_invalid_symbol = true)

bool isNewSession = ta.change(source = time(timeframe = "D")) != 0

// ═════════════════════════════════════════════════════════════════════════════
// 🔀 COMPONENT TRANSLATORS
// Each native series → directional confidence in [-1, +1] using a method that
// respects its behavior:
//   VOLD → anchored cumulative from session open, scaled by N-session typical daily max
//   ADD  → anchored relative to session open, scaled by N-session typical daily max
//   TICK → smoothed EMA divided by 500 (the fixed regime boundary, never normalized)
// Raw TICK extremes are intentionally NOT in the composite — they feed a
// separate overlay so a single ±1000 spike cannot flood the score.
// ═════════════════════════════════════════════════════════════════════════════
float emaAlpha = 2.0 / (historySessions + 1.0)

// --- VOLD: anchor to session open (handles feeds that don't reset cum to zero)
var float sessionOpenVold = na
if isNewSession
    sessionOpenVold := na
if na(sessionOpenVold) and not na(voldValue)
    sessionOpenVold := voldValue
float anchoredVold = not na(voldValue) and not na(sessionOpenVold) ? voldValue - sessionOpenVold : na

// --- VOLD: track session max of |anchoredVold|, EMA across sessions
var float sessionMaxVold = 0.0
var float typicalVoldMax = na
if isNewSession
    if sessionMaxVold > 0.0
        typicalVoldMax := na(typicalVoldMax) ? sessionMaxVold : emaAlpha * sessionMaxVold + (1.0 - emaAlpha) * typicalVoldMax
    sessionMaxVold := 0.0
if not na(anchoredVold)
    sessionMaxVold := math.max(sessionMaxVold, math.abs(anchoredVold))

float voldConfidence = na
if not na(anchoredVold) and not na(typicalVoldMax) and typicalVoldMax > 0.0
    voldConfidence := math.max(-1.0, math.min(1.0, anchoredVold / typicalVoldMax))

// --- ADD: anchor to session open
var float sessionOpenAdd = na
if isNewSession
    sessionOpenAdd := na
if na(sessionOpenAdd) and not na(addValue)
    sessionOpenAdd := addValue
float anchoredAdd = not na(addValue) and not na(sessionOpenAdd) ? addValue - sessionOpenAdd : na

// --- ADD: track session max, EMA across sessions
var float sessionMaxAdd = 0.0
var float typicalAddMax = na
if isNewSession
    if sessionMaxAdd > 0.0
        typicalAddMax := na(typicalAddMax) ? sessionMaxAdd : emaAlpha * sessionMaxAdd + (1.0 - emaAlpha) * typicalAddMax
    sessionMaxAdd := 0.0
if not na(anchoredAdd)
    sessionMaxAdd := math.max(sessionMaxAdd, math.abs(anchoredAdd))

float addConfidence = na
if not na(anchoredAdd) and not na(typicalAddMax) and typicalAddMax > 0.0
    addConfidence := math.max(-1.0, math.min(1.0, anchoredAdd / typicalAddMax))

// --- TICK: smoothed EMA, fixed scale by 500
float tickSmoothed = ta.ema(source = tickValue, length = tickSmoothLength)
float tickConfidence = na
if not na(tickSmoothed)
    tickConfidence := math.max(-1.0, math.min(1.0, tickSmoothed / TICK_FIXED_SCALE))

// ═════════════════════════════════════════════════════════════════════════════
// 🎯 COMPOSITE
// directional = weighted average of active confidences   ∈ [-1, +1]
// consensus   = 1 − (stdev of active confidences) / max-possible-stdev  ∈ [0, 1]
// composite   = directional × consensus × 100   ∈ [-100, +100]
// When components disagree the bar physically shrinks toward zero.
// ═════════════════════════════════════════════════════════════════════════════
int activeCount = (na(voldConfidence) ? 0 : 1) + (na(addConfidence) ? 0 : 1) + (na(tickConfidence) ? 0 : 1)

float weightedSum = 0.0
float weightTotal = 0.0
if not na(voldConfidence)
    weightedSum += weightVold * voldConfidence
    weightTotal += weightVold
if not na(addConfidence)
    weightedSum += weightAdd * addConfidence
    weightTotal += weightAdd
if not na(tickConfidence)
    weightedSum += weightTick * tickConfidence
    weightTotal += weightTick

float directional = weightTotal > 0.0 ? weightedSum / weightTotal : na

float sumConf = (na(voldConfidence) ? 0.0 : voldConfidence) + (na(addConfidence) ? 0.0 : addConfidence) + (na(tickConfidence) ? 0.0 : tickConfidence)
float meanConf = activeCount > 0 ? sumConf / activeCount : 0.0
float devSumSquared = (na(voldConfidence) ? 0.0 : math.pow(voldConfidence - meanConf, 2)) + (na(addConfidence) ? 0.0 : math.pow(addConfidence - meanConf, 2)) + (na(tickConfidence) ? 0.0 : math.pow(tickConfidence - meanConf, 2))
float stdevConf = activeCount > 0 ? math.sqrt(devSumSquared / activeCount) : 0.0
float maxStdev = activeCount >= 3 ? 0.9428 : 1.0
float consensus = activeCount <= 1 ? 1.0 : math.max(0.0, 1.0 - stdevConf / maxStdev)

float composite = na(directional) ? na : directional * consensus * SCALE_MAX
float signalLine = ta.ema(source = composite, length = signalLength)

// ═════════════════════════════════════════════════════════════════════════════
// 🚨 TICK EXHAUSTION STATE MACHINE
// On a raw |TICK| extreme print, enter pending state. Watch smoothed TICK for:
//   reversal     → crosses to opposite side beyond ±500
//   continuation → returns to and holds within neutral band
// Times out after RESOLUTION_TIMEOUT bars.
// ═════════════════════════════════════════════════════════════════════════════
bool tickExtremeUp = not na(tickValue) and tickValue >= tickExtremeLevel
bool tickExtremeDown = not na(tickValue) and tickValue <= -tickExtremeLevel

var int exhaustionState = 0
var int barsInState = 0

bool markContinuationUp = false
bool markReversalUp = false
bool markContinuationDown = false
bool markReversalDown = false

if exhaustionState == 0
    if tickExtremeUp
        exhaustionState := 1
        barsInState := 0
    else if tickExtremeDown
        exhaustionState := -1
        barsInState := 0
else
    barsInState += 1
    if exhaustionState == 1
        if barsInState >= RESOLUTION_MIN_BARS and not na(tickSmoothed) and tickSmoothed <= -RESOLUTION_REVERSAL_THRESHOLD
            markReversalUp := true
            exhaustionState := 0
        else if barsInState >= RESOLUTION_HOLD_BARS and not na(tickSmoothed) and tickSmoothed >= -RESOLUTION_CONTINUATION_BAND and tickSmoothed <= RESOLUTION_REVERSAL_THRESHOLD
            markContinuationUp := true
            exhaustionState := 0
        else if barsInState >= RESOLUTION_TIMEOUT
            exhaustionState := 0
    else if exhaustionState == -1
        if barsInState >= RESOLUTION_MIN_BARS and not na(tickSmoothed) and tickSmoothed >= RESOLUTION_REVERSAL_THRESHOLD
            markReversalDown := true
            exhaustionState := 0
        else if barsInState >= RESOLUTION_HOLD_BARS and not na(tickSmoothed) and tickSmoothed <= RESOLUTION_CONTINUATION_BAND and tickSmoothed >= -RESOLUTION_REVERSAL_THRESHOLD
            markContinuationDown := true
            exhaustionState := 0
        else if barsInState >= RESOLUTION_TIMEOUT
            exhaustionState := 0

bool exhaustionActive = exhaustionState != 0

// ═════════════════════════════════════════════════════════════════════════════
// ↔️ VOLD–ADD DIVERGENCE
// Streak counter on bars where ADD and VOLD point opposite directions
// (outside a deadband). Triggers once when the streak crosses the threshold.
// ═════════════════════════════════════════════════════════════════════════════
bool voldBull = not na(voldConfidence) and voldConfidence > DIVERGENCE_DEADBAND
bool voldBear = not na(voldConfidence) and voldConfidence < -DIVERGENCE_DEADBAND
bool addBull = not na(addConfidence) and addConfidence > DIVERGENCE_DEADBAND
bool addBear = not na(addConfidence) and addConfidence < -DIVERGENCE_DEADBAND
bool currentlyDiverging = (voldBull and addBear) or (voldBear and addBull)

var int divergeStreak = 0
if currentlyDiverging
    divergeStreak += 1
else
    divergeStreak := 0

bool divergenceTriggered = divergeStreak == divergenceBars

// ═════════════════════════════════════════════════════════════════════════════
// 🌅 SESSION REGIME CLASSIFIER
// Live tallies since session open: bars-above-zero, bars-below-zero,
// average |composite|. Yields one of TREND ↑ / TREND ↓ / CHOP / EXHAUSTION / MIXED.
// ═════════════════════════════════════════════════════════════════════════════
var int barsSinceOpen = 0
var int barsAboveZero = 0
var int barsBelowZero = 0
var float sumAbsComposite = 0.0

if isNewSession
    barsSinceOpen := 0
    barsAboveZero := 0
    barsBelowZero := 0
    sumAbsComposite := 0.0

if not na(composite)
    barsSinceOpen += 1
    if composite > 0.0
        barsAboveZero += 1
    else if composite < 0.0
        barsBelowZero += 1
    sumAbsComposite += math.abs(composite)

float pctAbove = barsSinceOpen > 0 ? barsAboveZero / barsSinceOpen : 0.0
float pctBelow = barsSinceOpen > 0 ? barsBelowZero / barsSinceOpen : 0.0
float avgAbs = barsSinceOpen > 0 ? sumAbsComposite / barsSinceOpen : 0.0

int regimeCode = 0
if barsSinceOpen >= REGIME_WARMUP_BARS
    if exhaustionActive
        regimeCode := 3
    else if avgAbs < REGIME_CHOP_MAX_ABS
        regimeCode := 2
    else if pctAbove > REGIME_TREND_MIN_PCT and avgAbs > REGIME_TREND_MIN_ABS
        regimeCode := 1
    else if pctBelow > REGIME_TREND_MIN_PCT and avgAbs > REGIME_TREND_MIN_ABS
        regimeCode := -1

// ═════════════════════════════════════════════════════════════════════════════
// 🎨 COLOR DERIVATION
// Signal line and exhaustion dots are loudest; everything else recedes via
// opacity. NORD8 bull, NORD11 bear, NORD13 exhaustion, NORD3 grid.
// ═════════════════════════════════════════════════════════════════════════════
color signalColor = na
if not na(signalLine)
    signalColor := signalLine >= 0.0 ? NORD8 : NORD11

color histogramColor = na
if not na(composite)
    histogramColor := composite >= 0.0 ? color.new(color = NORD8, transp = 60) : color.new(color = NORD11, transp = 60)

f_stripColor(float confidence) =>
    color result = na
    if not na(confidence)
        float magnitude = math.abs(confidence)
        int transparency = int(90.0 - 70.0 * magnitude)
        color baseColor = confidence >= 0.0 ? NORD8 : NORD11
        result := color.new(color = baseColor, transp = transparency)
    result

color voldStripColor = f_stripColor(confidence = voldConfidence)
color addStripColor = f_stripColor(confidence = addConfidence)
color tickStripColor = f_stripColor(confidence = tickConfidence)

color regimeBgColor = na
if regimeCode == 1
    regimeBgColor := color.new(color = NORD8, transp = 92)
else if regimeCode == -1
    regimeBgColor := color.new(color = NORD11, transp = 92)
else if regimeCode == 2
    regimeBgColor := color.new(color = NORD3, transp = 94)
else if regimeCode == 3
    regimeBgColor := color.new(color = NORD13, transp = 90)

// ═════════════════════════════════════════════════════════════════════════════
// 📊 PLOTS
// Render order: background → reference grid → strips → histogram → signal → markers.
// ═════════════════════════════════════════════════════════════════════════════
bgcolor(color = showRegimeBg ? regimeBgColor : na, title = "Regime Tint")

hline(price = 0,            title = "Zero", color = showReferenceLines ? color.new(color = NORD3, transp = 30) : na, linestyle = hline.style_solid,  linewidth = 1)
hline(price = REF_MILD,     title = "+25",  color = showReferenceLines ? color.new(color = NORD3, transp = 60) : na, linestyle = hline.style_dashed, linewidth = 1)
hline(price = -REF_MILD,    title = "-25",  color = showReferenceLines ? color.new(color = NORD3, transp = 60) : na, linestyle = hline.style_dashed, linewidth = 1)
hline(price = REF_SOLID,    title = "+50",  color = showReferenceLines ? color.new(color = NORD3, transp = 60) : na, linestyle = hline.style_dashed, linewidth = 1)
hline(price = -REF_SOLID,   title = "-50",  color = showReferenceLines ? color.new(color = NORD3, transp = 60) : na, linestyle = hline.style_dashed, linewidth = 1)
hline(price = REF_STRONG,   title = "+75",  color = showReferenceLines ? color.new(color = NORD3, transp = 60) : na, linestyle = hline.style_dashed, linewidth = 1)
hline(price = -REF_STRONG,  title = "-75",  color = showReferenceLines ? color.new(color = NORD3, transp = 60) : na, linestyle = hline.style_dashed, linewidth = 1)

plot(series = showStrip ? STRIP_VOLD_TOP : na, title = "VOLD Strip", color = voldStripColor, style = plot.style_columns, histbase = STRIP_VOLD_BASE)
plot(series = showStrip ? STRIP_ADD_TOP  : na, title = "ADD Strip",  color = addStripColor,  style = plot.style_columns, histbase = STRIP_ADD_BASE)
plot(series = showStrip ? STRIP_TICK_TOP : na, title = "TICK Strip", color = tickStripColor, style = plot.style_columns, histbase = STRIP_TICK_BASE)

plot(series = showHistogram  ? composite  : na, title = "Composite", style = plot.style_histogram, color = histogramColor, linewidth = 2)
plot(series = showSignalLine ? signalLine : na, title = "Signal",    color = signalColor, linewidth = 3)

plotshape(series = showExhaustionMarkers and tickExtremeUp ? REF_STRONG + 10.0 : na,
     title = "TICK Up Exhaustion", style = shape.circle, location = location.absolute,
     color = color.new(color = NORD13, transp = 10), size = size.tiny)
plotshape(series = showExhaustionMarkers and tickExtremeDown ? -REF_STRONG - 10.0 : na,
     title = "TICK Down Exhaustion", style = shape.circle, location = location.absolute,
     color = color.new(color = NORD13, transp = 10), size = size.tiny)
plotshape(series = showExhaustionMarkers and markContinuationUp ? REF_STRONG + 5.0 : na,
     title = "Up Continuation", style = shape.triangleup, location = location.absolute,
     color = color.new(color = NORD8, transp = 25), size = size.tiny)
plotshape(series = showExhaustionMarkers and markReversalUp ? REF_STRONG + 5.0 : na,
     title = "Up Reversal", style = shape.triangledown, location = location.absolute,
     color = color.new(color = NORD11, transp = 25), size = size.tiny)
plotshape(series = showExhaustionMarkers and markContinuationDown ? -REF_STRONG - 5.0 : na,
     title = "Down Continuation", style = shape.triangledown, location = location.absolute,
     color = color.new(color = NORD11, transp = 25), size = size.tiny)
plotshape(series = showExhaustionMarkers and markReversalDown ? -REF_STRONG - 5.0 : na,
     title = "Down Reversal", style = shape.triangleup, location = location.absolute,
     color = color.new(color = NORD8, transp = 25), size = size.tiny)

plotshape(series = showDivergenceFlag and divergenceTriggered ? 0.0 : na,
     title = "VOLD/ADD Divergence", style = shape.diamond, location = location.absolute,
     color = color.new(color = NORD15, transp = 40), size = size.tiny)
