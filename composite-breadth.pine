//@version=6
indicator(title = "Composite Breadth Indicator", shorttitle = "📊 CBI", format = format.price, precision = 2)

// ═════════════════════════════════════════════════════════════════════════════
// 🧱 CONSTANTS
// Shared immutable values used by the indicator, including the Nord palette.
// ═════════════════════════════════════════════════════════════════════════════
// Nord Theme Color
// Polar Night
const color NORD0  = #2E3440
const color NORD1  = #3B4252
const color NORD2  = #434C5E
const color NORD3  = #4C566A
// Snow Storm
const color NORD4  = #D8DEE9
const color NORD5  = #E5E9F0
const color NORD6  = #ECEFF4
// Frost
const color NORD7  = #8FBCBB
const color NORD8  = #88C0D0
const color NORD9  = #81A1C1
const color NORD10 = #5E81AC
// Aurora
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

// ═════════════════════════════════════════════════════════════════════════════
// 📊 COMPOSITE BREADTH
// Market breadth composite built from VOLD, ADD, PCTABOVEVWAP, and CUMTICK
// (session-cumulative TICK slope). Raw TICK is kept as context only (extreme
// markers) — it doesn't enter the weighted sum because its raw per-bar value
// is too noisy; the cumulative slope captures the same information with
// persistence baked in. The composite is a CONFIRMATION instrument: price
// discovery happens in the futures, breadth answers "did the cash basket
// ratify the move". On top of it sit two alert-grade context layers:
// intrabar TICK extreme markers (exhaustion — Barry's ±1000 zones) and
// alert-only VOLD session-extreme events. This section owns its inputs,
// data requests, calculations, color prep, and plot-ready outputs.
// ═════════════════════════════════════════════════════════════════════════════
const string GROUP_COMPOSITE_BREADTH_MARKET     = "🏛️ Market"
const string GROUP_COMPOSITE_BREADTH_WEIGHTS    = "⚖️ Weights"
const string GROUP_COMPOSITE_BREADTH_SIGNAL     = "🧮 Signal"
const string GROUP_COMPOSITE_BREADTH_TICK       = "⚡ TICK Context"
const string GROUP_COMPOSITE_BREADTH_DISPLAY    = "📋 Display"

const float CBI_SCALE_MAX               = 100.0
const float CBI_TICK_FIXED_SCALE        = 500.0
const int   CBI_SIGNAL_WARMUP_BARS      = 5        // bars to seed display before first signal value — slightly longer than legacy 3 so the EMA isn't dominated by the seed at session open
const int   CBI_DISPLAY_SMOOTH_LENGTH   = 3        // light EMA on composite for the plot only — reduces visual noise without affecting calc
const float CBI_OPACITY_ANCHOR          = 35.0
const float CBI_EXTENDED_LEVEL          = 60.0     // dotted reference at ±60 — Barry's manual "30-day VOLD support/resistance" equivalent, marks abnormally extended breadth
const int   CBI_SIGNAL_MIN_TRANSP       = 40
const float CBI_THREE_WAY_MAX_STDEV     = 0.9428
const float CBI_PCTVWAP_BAND            = 15.0     // ±band around 50 mapped to full ±1 confidence. Practitioner rails are 40/60 (>60 = don't short, <40 = don't long) — ±15 saturates right where the tape treats the reading as extreme. The legacy ±25 band left the component chronically under-scaled (a 65 print — a strong directional session — scored only 0.6)
const float CBI_SIGNAL_ALERT_GATE_MINUTES = 30.0   // post-open window in MINUTES during which composite-vs-signal CROSS alerts stay muted (bar count derived from the chart timeframe). The 09:30–10:00 window is auction-seeding noise for the internals — ADD's early print largely encodes overnight gap direction, and a freshly reseeded signal EMA makes crosses there mostly artifacts. LEVEL alerts (±50 impulse, VOLD extremes, TICK extremes) are NOT gated: extreme levels at the open are real information (early breadth thrust = trend-day tell); it's specifically the crosses that are noise

const float CBI_CUMTICK_SLOPE_MINUTES   = 10.0     // cumulative-TICK slope lookback in MINUTES — bar count derived from the chart timeframe (5 bars on 2-min) so the window keeps its meaning on 1m/2m/5m charts. Short enough to catch real-time inflections, long enough to filter single-bar noise
const float CBI_TICKQ_SCALE_FACTOR      = 1.5      // cumTICK slope SATURATION only: TICKQ covers more issues and its per-bar values run wider, so "averaged a full scale across the window" widens by this factor. Deliberately NOT applied to the extreme threshold — practitioner TICKQ extreme levels (~1000 extreme / ~1200 climax) sit near the NYSE levels; the old 1.5× auto-widening (~±1478) suppressed TICKQ extremes almost entirely
const float CBI_TICK_BIAS_DAYS          = 20.0     // Steenbarger Adjusted-TICK trailing-mean window in trading days — raw TICK carries a persistent positive bias; subtracting a ~20-day mean before cumulating recenters the cumTICK slope
const int   CBI_FEED_HEALTH_GRACE_BARS  = 5        // bars after session open before a missing required feed triggers the log.warning — gives the USI feeds time to deliver their first non-na bar
const int   CBI_VOLD_EXTREME_REARM_BARS = 10       // a VOLD-delta new session high/low only fires as an event when the prior extreme stood for at least this many bars — suppresses the every-bar "new extreme" spam of a steady trend leg
const int   CBI_TIME_DIM_EXTRA_TRANSP   = 35       // extra transparency added to the composite line during the lunch trough and MOC window when time-of-day dimming is on
// NYSE RTH session windows (ET, Mon–Fri). RTH_OPEN anchors every session-wide
// state reset; LUNCH is the documented intraday volume/volatility trough
// (low-information breadth); MOC is the market-on-close rebalancing window
// where TICK is contaminated by index-rebalance program spikes.
const string CBI_SESSION_RTH_OPEN       = "0930-0935:23456"
const string CBI_SESSION_LUNCH          = "1200-1330:23456"
const string CBI_SESSION_MOC            = "1545-1600:23456"

// ─── Market ───────────────────────────────────────────────────────────────────
string compositeBreadthMarket = input.string(
     defval = "NASDAQ 100",
     title = "Market (Index)",
     options = ["S&P 500", "NASDAQ 100", "Dow Jones", "Russell 2000"],
     tooltip = "S&P 500 → NYSE breadth (.NY). NASDAQ 100 → Nasdaq exchange-wide (.NQ) for ADVN/DECL/UPVOL/DNVOL/PCTABOVEVWAP. Dow Jones → exact Dow 30 breadth (.DJ) where available. Russell 2000 → US-wide composite (.US) — TradingView has no Russell-specific breadth feed.",
     group = GROUP_COMPOSITE_BREADTH_MARKET
 )

// ─── Weights (30/25/20/25 = VOLD/ADD/PCTABOVEVWAP/CUMTICK) ────────────────────
// Research synthesis: TRIN is a non-independent transformation of VOLD+ADD so
// adding it would double-count. VOLD and ADD are correlated siblings (net
// breadth measured in volume vs issues — their DISAGREEMENT is the
// information, and the consensus multiplier already extracts it), so their
// combined weight is capped at 55% instead of the legacy 70%; VOLD keeps the
// edge over ADD as the higher-conviction leg and the cleanest trend-day
// identifier in practitioner use. PCTABOVEVWAP captures positioning vs the
// dominant institutional execution benchmark and is independent of the
// volume/issue dimensions. CUMTICK (cumulative intraday TICK,
// slope-normalized) is the only component with a documented LEADING use case
// — Steenbarger's cumulative-TICK divergence read — so it carries 25%
// instead of the legacy 15%. Raw TICK remains context-only (extreme
// markers): the per-bar value is too noisy to be a weighted signal.
//
// Weight-optimality check (2026-07-08): no published correlation matrix,
// intraday predictive decomposition, or consensus composite weighting exists
// for this stack — every published composite's weights are folklore. The one
// rigorous, replicated literature (forecast-combination puzzle, DeMiguel's
// 1/N, Grinold's signal-weighting) says: with correlated noisy signals and
// no out-of-sample estimation, stay near equal weights with at most mild
// conviction tilts, and give a correlated pair a shared capped budget.
// 30/25/20/25 is exactly that construction (max 5-point tilt from equal,
// VOLD+ADD capped at 55%) — re-tuning it without a proper out-of-sample
// sweep would be worse than leaving it alone.
float compositeBreadthVoldWeight = input.float(
     defval = 30,
     title = "VOLD Weight",
     minval = 0,
     maxval = 100,
     step = 5,
     tooltip = "Volume trend — conviction. Barry's primary intraday breadth read on NDX (\"up/down volume difference\") and the strongest trend-day identifier in practitioner use.",
     group = GROUP_COMPOSITE_BREADTH_WEIGHTS
 )

float compositeBreadthAddWeight = input.float(
     defval = 25,
     title = "ADD Weight",
     minval = 0,
     maxval = 100,
     step = 5,
     tooltip = "Advance-Decline — direction (how many stocks). Distinct from VOLD which measures conviction (how much volume). Weighted slightly below VOLD: the two are correlated siblings and VOLD is the higher-conviction of the pair.",
     group = GROUP_COMPOSITE_BREADTH_WEIGHTS
 )

float compositeBreadthPctVwapWeight = input.float(
     defval = 20,
     title = "PCTABOVEVWAP Weight",
     minval = 0,
     maxval = 100,
     step = 5,
     tooltip = "Percent of stocks trading above their intraday VWAP — independent breadth dimension capturing real-time positioning vs the institutional execution benchmark (VWAP-pegged algos are the single largest execution style). The slowest-turning component: reads as the composite's stance, not its trigger. Per-instrument routing: SPX → .NY, NDX → .NQ, Dow → .DJ, RUT → .US.",
     group = GROUP_COMPOSITE_BREADTH_WEIGHTS
 )

float compositeBreadthCumTickWeight = input.float(
     defval = 25,
     title = "CUMTICK Weight",
     minval = 0,
     maxval = 100,
     step = 5,
     tooltip = "Cumulative session TICK, slope-normalized. Confidence is the 10-minute (timeframe-derived bar count) rate-of-change of the running session sum of (optionally bias-adjusted) TICK, saturating at ±1 when TICK averaged ±500 (NYSE; ±750 on TICKQ) across the window. Positive = breadth strengthening on the bid; negative = weakening. This is the divergence-grade breadth series — the only component with a documented LEADING use case (Steenbarger) — hence its 25% weight. Frozen during the 15:45–16:00 MOC window (rebalancing spikes aren't directional information). Resets at each NYSE RTH open.",
     group = GROUP_COMPOSITE_BREADTH_WEIGHTS
 )

// ─── Signal / smoothing ───────────────────────────────────────────────────────
int compositeBreadthSignalLength = input.int(
     defval = 20,
     title = "Signal EMA Length",
     minval = 1,
     maxval = 100,
     step = 1,
     tooltip = "EMA period for the signal line (smoothed reference). Fed from the smoothed display line so signal vs composite is internally consistent. Reseeds at every session open after a brief warmup (time-anchored, so it works on RTH-only and extended-hours charts alike) — crosses read against fresh state rather than carrying over from the prior session. Default 20 follows Ehlers' half-cycle rule for crossover pairs: the 3-EMA display vs a 20-EMA signal is tuned to ~40-minute directional legs on a 2-min chart, squarely inside the 30–120 min swings this composite is meant to ratify (the old 15 was tuned to ~24-min legs — the very fastest edge of that target). Lag ≈ 19 minutes on 2-min — under a third of a one-hour move, the right trade for a CONFIRMATION line. Drop toward 15 to lead faster at the cost of more whipsaw crosses; don't go far above 25 — a 195-bar RTH session can't converge much more EMA.",
     group = GROUP_COMPOSITE_BREADTH_SIGNAL
 )

// ─── TICK context (Barry-aligned) ─────────────────────────────────────────────
bool compositeBreadthTickNyseOnly = input.bool(
     defval = false,
     title = "Use NYSE TICK only (Barry's preference)",
     tooltip = "OFF (default): TICK routes to the market-matching feed — USI:TICK for S&P/Dow/Russell, USI:TICKQ for NASDAQ. ON: forces USI:TICK regardless of selected market. Barry Burns explicitly prefers NYSE TICK for all markets — \"the technique that I use for the tick indicator works best with the New York Stock Exchange tick … I just use the New York Stock Exchange tick\", and on TICKQ/Dow tick: \"they just don't reach the extremes as much.\" Asked about trading the NQ: \"I would still use the tick index.\" Turn on to follow his approach.",
     group = GROUP_COMPOSITE_BREADTH_TICK
 )

bool compositeBreadthTickShowExtremes = input.bool(
     defval = true,
     title = "Show TICK Extreme Markers",
     tooltip = "Plot a small NORD13 triangle above/below the composite line on the bar where the TICK feed's intrabar HIGH/LOW first reaches the configured extreme threshold (±985 default). Detection reads the raw bar high/low, not the close — Barry's ±1000 zones are momentary touches that a 2-min close routinely misses by hundreds of points. Up-triangle = TICK extreme high, down-triangle = TICK extreme low. Per Barry's method: extremes signal exhaustion, NOT continuation — wait for the next cycle high/low on price after an extreme appears. Suppressed 15:45–16:00 (MOC rebalancing spikes). Matching alertconditions fire whether or not the markers are shown.",
     group = GROUP_COMPOSITE_BREADTH_TICK
 )

float compositeBreadthTickExtremeThreshold = input.float(
     defval = 985.0,
     title = "TICK Extreme Threshold",
     minval = 400.0,
     maxval = 1400.0,
     step = 25,
     tooltip = "Intrabar TICK high/low threshold for extreme markers, applied as-is to whichever TICK feed is resolved. Barry draws horizontal lines at ±1000 with audio alert at ±985 (just inside the extreme so you don't miss the trigger) — 985 is the default here for the same reason. No TICKQ auto-widening: practitioner TICKQ extreme levels (~1000 extreme / ~1200 climax) sit near the NYSE levels, and the old 1.5× auto-scale (~±1478) suppressed TICKQ extremes almost entirely. Regime note: fixed thresholds go stale — in a quiet tape ±800 is already extreme, in a fast one ±1400 is the better reference; adjust here when the tape changes character.",
     group = GROUP_COMPOSITE_BREADTH_TICK
 )

float compositeBreadthTickExtremeOffset = input.float(
     defval = 4.0,
     title = "TICK Extreme Marker Offset",
     minval = 0.0,
     maxval = 30.0,
     step = 0.5,
     tooltip = "Y-axis distance above/below the composite line for the extreme triangles. 0 places the triangle directly on the line; default 4 clears the 4px-thick line so the shape isn't absorbed.",
     group = GROUP_COMPOSITE_BREADTH_TICK
 )

bool compositeBreadthCumTickBiasAdjust = input.bool(
     defval = true,
     title = "Bias-Adjust CUMTICK (Steenbarger)",
     tooltip = "Subtract a trailing ~20-trading-day mean of per-bar TICK before cumulating (Steenbarger's Adjusted TICK construction). Raw TICK carries a persistent positive bias, which tilts the cumulative slope bullish and makes negative saturation structurally rarer than positive — consistent with the backtest record where fading negative TICK extremes worked and fading positive ones didn't. OFF cumulates raw TICK (legacy behavior). Applies to the CUMTICK composite component only; the extreme markers always read the raw intrabar high/low.",
     group = GROUP_COMPOSITE_BREADTH_TICK
 )

// ─── Display ──────────────────────────────────────────────────────────────────
bool compositeBreadthShowSignalLine = input.bool(
     defval = true,
     title = "Signal Line",
     tooltip = "Smoothed reference line — EMA of the smoothed composite (fed from the same series that's plotted, so divergences read true). Composite above signal = upward momentum building; composite below signal = downward.",
     group = GROUP_COMPOSITE_BREADTH_DISPLAY
 )

bool compositeBreadthShowTimeOfDayDim = input.bool(
     defval = true,
     title = "Time-of-Day Dimming",
     tooltip = "Dim the composite line during the two structurally low-information windows: the lunch trough (12:00–13:30 ET — intraday volume/volatility minimum, VWAP-algo autopilot) and the MOC window (15:45–16:00 ET — market-on-close rebalancing contaminates the internals; CUMTICK is frozen and TICK extremes are suppressed there regardless of this toggle). Visual only: the composite math is unchanged, the dimmer line just reads as \"lower confidence now\".",
     group = GROUP_COMPOSITE_BREADTH_DISPLAY
 )

bool compositeBreadthShowZeroLine = input.bool(
     defval = true,
     title = "Zero Line",
     tooltip = "Solid neutral guide at zero — the only fixed reference. Above zero = net bullish breadth, below = net bearish.",
     group = GROUP_COMPOSITE_BREADTH_DISPLAY
 )

bool compositeBreadthShowExtendedLevels = input.bool(
     defval = false,
     title = "Show Extended Levels (±60)",
     tooltip = "Dotted reference lines at ±CBI_EXTENDED_LEVEL (60 by default). Beyond visual saturation the composite would otherwise look identical from ±35 to ±100; the dotted lines mark the \"extended for this market\" zone — Barry's equivalent of his manually-drawn 30-day VOLD support/resistance levels. Breadth pushing past ±60 is an extended directional reading, not a normal-range one. OFF by default because the ±60 hlines pin TradingView's auto-scale to at least [−60, +60], which can compress the composite's actual swing. Turn on if you want fixed visual reference levels at the cost of some auto-scale flexibility.",
     group = GROUP_COMPOSITE_BREADTH_DISPLAY
 )

bool compositeBreadthShowSessionDivider = input.bool(
     defval = true,
     title = "Session Divider",
     tooltip = "Tint the first bar of each NYSE RTH session so day boundaries are obvious at a glance — without it, back-to-back sessions blur together and you can't tell where one day ends and the next begins. Anchored to the same time-anchored 09:30 edge that resets every piece of session state (EMAs, cumTick, VOLD extremes, feed-health counters), so the divider lands exactly where the indicator resets.",
     group = GROUP_COMPOSITE_BREADTH_DISPLAY
 )

// ═════════════════════════════════════════════════════════════════════════════
// 🔗 SYMBOL ROUTING
// ═════════════════════════════════════════════════════════════════════════════
string compositeBreadthAdvSymbol = switch compositeBreadthMarket
    "S&P 500"      => "USI:ADVN.NY"
    "NASDAQ 100"   => "USI:ADVN.NQ"
    "Dow Jones"    => "USI:ADVN.DJ"
    "Russell 2000" => "USI:ADVN.US"
    => "USI:ADVN.NY"

string compositeBreadthDeclSymbol = switch compositeBreadthMarket
    "S&P 500"      => "USI:DECL.NY"
    "NASDAQ 100"   => "USI:DECL.NQ"
    "Dow Jones"    => "USI:DECL.DJ"
    "Russell 2000" => "USI:DECL.US"
    => "USI:DECL.NY"

string compositeBreadthUpVolSymbol = switch compositeBreadthMarket
    "S&P 500"      => "USI:UPVOL.NY"
    "NASDAQ 100"   => "USI:UPVOL.NQ"
    "Dow Jones"    => "USI:UPVOL.DJ"
    "Russell 2000" => "USI:UPVOL.US"
    => "USI:UPVOL.NY"

string compositeBreadthDownVolSymbol = switch compositeBreadthMarket
    "S&P 500"      => "USI:DNVOL.NY"
    "NASDAQ 100"   => "USI:DNVOL.NQ"
    "Dow Jones"    => "USI:DNVOL.DJ"
    "Russell 2000" => "USI:DNVOL.US"
    => "USI:DNVOL.NY"

// PCTABOVEVWAP: .NY/.NQ/.DJ/.US all confirmed live on TradingView symbol
// pages. NDX uses .NQ (NASDAQ-100 specific intraday VWAP breadth) — earlier
// versions fell back to .US because .NQ was unverified at the time; this is
// now corrected and the routing is exchange-exact per instrument.
string compositeBreadthPctVwapSymbol = switch compositeBreadthMarket
    "S&P 500"      => "USI:PCTABOVEVWAP.NY"
    "NASDAQ 100"   => "USI:PCTABOVEVWAP.NQ"
    "Dow Jones"    => "USI:PCTABOVEVWAP.DJ"
    "Russell 2000" => "USI:PCTABOVEVWAP.US"
    => "USI:PCTABOVEVWAP.NY"

// TICK: routed to the legacy feeds USI:TICK (NYSE) and USI:TICKQ (NASDAQ).
// Symbol-catalog notes (verified against TradingView's symbol-search API,
// provider ICE): a Dow tick DOES exist — legacy USI:TICKI (±30 scale, 30
// stocks) and dotted USI:TICK.DJ — and a dotted per-exchange TICK family
// (USI:TICK.NY/.NQ/.DJ/.US) exists too. Dow still deliberately routes to
// NYSE TICK: TICKI's ±30 range is incompatible with the ±1000-calibrated
// extreme levels this indicator is built around. Russell has no specific
// tick feed. Both fallbacks match Barry's stated practice ("I just use the
// New York Stock Exchange tick").
string compositeBreadthTickPerMarketSymbol = switch compositeBreadthMarket
    "S&P 500"      => "USI:TICK"
    "NASDAQ 100"   => "USI:TICKQ"
    "Dow Jones"    => "USI:TICK"
    "Russell 2000" => "USI:TICK"
    => "USI:TICK"

string compositeBreadthTickSymbol = compositeBreadthTickNyseOnly ?
     "USI:TICK" : compositeBreadthTickPerMarketSymbol

// ═════════════════════════════════════════════════════════════════════════════
// 🎛️ DERIVED CALIBRATION
// Timeframe- and feed-aware scaling so the calibration constants keep their
// MEANING when the chart interval or the TICK feed changes.
//
// Windows are specified in minutes and converted to a bar count from the
// chart timeframe — a "10-minute slope" is 5 bars on 2-min, 10 bars on 1-min,
// 2 bars on 5-min, instead of silently becoming a 50-minute slope on a 10-min
// chart. Floors keep degenerate timeframes (daily+) from producing 0-bar
// windows; the breadth feeds are intraday-only anyway.
//
// TICK scaling: the cumTICK slope saturation is calibrated to NYSE TICK and
// widens by CBI_TICKQ_SCALE_FACTOR when the resolved feed is TICKQ (its
// per-bar values run wider — without the factor, cumTICK confidence pegs at
// ±1 on ordinary Nasdaq sessions). The slope scale generalizes the old
// hard-coded 2500 (= 5 bars × 500): saturation always means "TICK averaged
// ±1 full scale for the entire slope window". The EXTREME threshold is NOT
// feed-scaled — practitioner TICKQ extreme levels sit near the NYSE ones
// (see the threshold input tooltip).
//
// The bias window (~20 trading days of chart bars, 390 RTH minutes per day)
// drives the Steenbarger trailing-mean adjustment on the cumTICK input.
// ═════════════════════════════════════════════════════════════════════════════
int compositeBreadthCumTickSlopeWindow  = math.max(2, math.round(number = CBI_CUMTICK_SLOPE_MINUTES * 60.0 / timeframe.in_seconds()))
int compositeBreadthSignalAlertGateBars = math.max(1, math.round(number = CBI_SIGNAL_ALERT_GATE_MINUTES * 60.0 / timeframe.in_seconds()))
int compositeBreadthTickBiasWindowBars  = math.max(10, math.round(number = CBI_TICK_BIAS_DAYS * 390.0 * 60.0 / timeframe.in_seconds()))
float compositeBreadthTickScaleFactor  = compositeBreadthTickSymbol == "USI:TICKQ" ? CBI_TICKQ_SCALE_FACTOR : 1.0
float compositeBreadthTickScale        = CBI_TICK_FIXED_SCALE * compositeBreadthTickScaleFactor
float compositeBreadthCumTickSlopeScale = compositeBreadthCumTickSlopeWindow * compositeBreadthTickScale

// ═════════════════════════════════════════════════════════════════════════════
// 📡 DATA REQUESTS
// ═════════════════════════════════════════════════════════════════════════════
// Why ADVN/DECL and UPVOL/DNVOL instead of TradingView's pre-computed nets
// (USI:ADVDEC.x = advancers − decliners, USI:ADVDECV.x = up-vol − down-vol,
// both verified live for all four suffixes): the confidence math is the
// RATIO delta/total, so the denominator is needed too — the nets would save
// nothing (total would still require ACTV−UNCH / TVOL−UNCHVOL requests).
// Four component calls yield delta AND total exactly, well inside the
// request budget.
//
// All breadth feeds use gaps_on so out-of-session bars come back as na rather
// than being forward-filled with the last RTH value. On a futures or extended-
// hours chart, gaps_off would keep plotting Friday's last RTH breadth all
// weekend; gaps_on lets the composite blank when the feeds aren't live (paired
// with explicit na-clearing of the display/signal state below). For TICK
// specifically, the session-reset detector also relies on a real na→value
// transition to reseed the EMA at each NYSE RTH open.
//
// lookahead = barmerge.lookahead_off is intentional and correct here, NOT an
// oversight against the repo's "use lookahead_on for real-time accuracy" note
// (that guidance applies to HIGHER-timeframe requests). Every request below
// uses timeframe = timeframe.period — the chart's own timeframe — so there is
// no higher-timeframe bar to look ahead into and lookahead has no effect on the
// returned series. lookahead_off is also the non-repainting default; flipping
// to lookahead_on with `close` would leak future data on HTF requests, so off
// stays the safe choice if these are ever pointed at a higher timeframe.
float compositeBreadthAdvValue = request.security(
     symbol = compositeBreadthAdvSymbol,
     timeframe = timeframe.period,
     expression = close,
     gaps = barmerge.gaps_on,
     lookahead = barmerge.lookahead_off,
     ignore_invalid_symbol = true
 )

float compositeBreadthDeclValue = request.security(
     symbol = compositeBreadthDeclSymbol,
     timeframe = timeframe.period,
     expression = close,
     gaps = barmerge.gaps_on,
     lookahead = barmerge.lookahead_off,
     ignore_invalid_symbol = true
 )

float compositeBreadthUpVolValue = request.security(
     symbol = compositeBreadthUpVolSymbol,
     timeframe = timeframe.period,
     expression = close,
     gaps = barmerge.gaps_on,
     lookahead = barmerge.lookahead_off,
     ignore_invalid_symbol = true
 )

float compositeBreadthDownVolValue = request.security(
     symbol = compositeBreadthDownVolSymbol,
     timeframe = timeframe.period,
     expression = close,
     gaps = barmerge.gaps_on,
     lookahead = barmerge.lookahead_off,
     ignore_invalid_symbol = true
 )

float compositeBreadthPctVwapValue = request.security(
     symbol = compositeBreadthPctVwapSymbol,
     timeframe = timeframe.period,
     expression = close,
     gaps = barmerge.gaps_on,
     lookahead = barmerge.lookahead_off,
     ignore_invalid_symbol = true
 )

// TICK close/high/low in ONE tuple request — same symbol and timeframe, and
// TradingView does NOT deduplicate distinct expressions, so three separate
// calls would cost three of the 40-request budget for one data pull. `close`
// feeds cumTICK (and its bias mean), where per-bar settlement is the right
// series. HIGH/LOW feed the extreme markers: Barry's ±1000 zones are
// momentary touches — a TICK spike to +1200 that mean-reverts inside the bar
// can close the 2-min TICK bar at +400, so extreme detection built on
// `close` (let alone a smoothed close) misses most real extremes.
[compositeBreadthTickValue, compositeBreadthTickHighValue, compositeBreadthTickLowValue] = request.security(
     symbol = compositeBreadthTickSymbol,
     timeframe = timeframe.period,
     expression = [close, high, low],
     gaps = barmerge.gaps_on,
     lookahead = barmerge.lookahead_off,
     ignore_invalid_symbol = true
 )

// ═════════════════════════════════════════════════════════════════════════════
// 🔔 SESSION DETECTION
// AnyFeedLive = at least one of the six breadth feeds is non-na this bar.
// SessionJustOpened = the 09:30 ET time-anchored session-open edge — the
// canonical trigger for ALL session-wide state resets (display/signal EMAs,
// cumTick, pending TICK-extreme flags, VOLD extremes, feed-health counters).
// One mechanism for every reset: earlier versions split
// resets between this edge and na→value feed edges, and the feed edges never
// fire on an RTH-only chart (no dark bars between sessions), which silently
// disabled the daily reseeds after day one.
//
// BarsSinceSessionOpen counts chart bars since the most recent session-open
// transition, increments only while at least one feed is live (so the
// off-RTH gap doesn't bloat the count). Used to gate cumTick slope
// computation against the cross-session lookback leak, to arm the
// composite-vs-signal cross alerts after the opening noise window, and to
// mature the feed-health warning even when TICK is the missing feed.
//
// InLunchWindow / InMocWindow mark the two structurally low-information
// windows: the midday volume/volatility trough (visual dimming only) and the
// market-on-close rebalancing window (CUMTICK frozen, TICK extremes
// suppressed, plus dimming).
// ═════════════════════════════════════════════════════════════════════════════
bool compositeBreadthAnyFeedLive =
     not na(compositeBreadthTickValue)    or
     not na(compositeBreadthAdvValue)     or
     not na(compositeBreadthDeclValue)    or
     not na(compositeBreadthUpVolValue)   or
     not na(compositeBreadthDownVolValue) or
     not na(compositeBreadthPctVwapValue)

// Session-open edge is TIME-anchored, not feed-presence-anchored. The earlier
// "AnyFeedLive false→true" approach relied on a real off-session bar existing
// between sessions to create the na→value transition. That holds on futures /
// extended-hours charts (overnight bars come back na), but on an RTH-only chart
// there are NO dark bars between sessions: the bar before 09:30 is yesterday's
// 16:00, whose feeds were live, so AnyFeedLive[1] is true and the edge never
// fires — silently skipping the daily reset of the EMAs, cumTick, VOLD
// extremes, feed-health flags, and the session divider. Pinning to the NYSE RTH
// open window (09:30–09:35 ET, weekdays) fires reliably on BOTH chart types and
// decouples the reset from feed health — a session still opens at 09:30 even if
// a feed is dead, which is more correct than gating on whether data arrived.
bool compositeBreadthInRthOpen = not na(time(timeframe = timeframe.period, session = CBI_SESSION_RTH_OPEN, timezone = "America/New_York"))
bool compositeBreadthSessionJustOpened = compositeBreadthInRthOpen and not compositeBreadthInRthOpen[1]
bool compositeBreadthInLunchWindow = not na(time(timeframe = timeframe.period, session = CBI_SESSION_LUNCH, timezone = "America/New_York"))
bool compositeBreadthInMocWindow   = not na(time(timeframe = timeframe.period, session = CBI_SESSION_MOC,   timezone = "America/New_York"))

var int compositeBreadthBarsSinceSessionOpen = 0
if compositeBreadthSessionJustOpened
    compositeBreadthBarsSinceSessionOpen := 1
else if compositeBreadthAnyFeedLive
    compositeBreadthBarsSinceSessionOpen += 1

// ═════════════════════════════════════════════════════════════════════════════
// 🧮 HELPERS
// ═════════════════════════════════════════════════════════════════════════════
f_compositeBreadthClampedRatio(float numerator, float denominator) =>
    float compositeBreadthRatio = na
    if not na(numerator) and not na(denominator) and denominator > 0.0
        compositeBreadthRatio := math.max(-1.0, math.min(1.0, numerator / denominator))
    compositeBreadthRatio

f_compositeBreadthProgressiveColor(float value, float scale, int minTransp) =>
    color compositeBreadthResultColor = na
    if not na(value)
        // Two-stage gradient — NORD11 → NORD3 (neutral grey at zero) → NORD8 — produces
        // a continuous hue walk through neutral instead of the abrupt cyan↔red flip at
        // zero that previously left visible bright bars at color transitions.
        color compositeBreadthBaseColor = value >= 0.0 ?
             color.from_gradient(value = value, bottom_value = 0.0,    top_value = scale, bottom_color = NORD3,  top_color = NORD8) :
             color.from_gradient(value = value, bottom_value = -scale, top_value = 0.0,   bottom_color = NORD11, top_color = NORD3)
        // Magnitude-based transparency: faded near zero, vivid at |value| ≥ scale.
        float compositeBreadthMagnitude = math.min(1.0, math.abs(number = value) / scale)
        int compositeBreadthTransparency = int(minTransp - minTransp * compositeBreadthMagnitude)
        compositeBreadthResultColor := color.new(color = compositeBreadthBaseColor, transp = compositeBreadthTransparency)
    compositeBreadthResultColor

// ═════════════════════════════════════════════════════════════════════════════
// 🎯 PER-COMPONENT CONFIDENCE
// VOLD, ADD, PCTABOVEVWAP, and CUMTICK feed the weighted composite. Raw
// per-bar TICK only feeds the extreme markers — never the weighted sum.
// ═════════════════════════════════════════════════════════════════════════════
float compositeBreadthVoldDelta = not na(compositeBreadthUpVolValue) and not na(compositeBreadthDownVolValue) ?
     compositeBreadthUpVolValue - compositeBreadthDownVolValue : na
float compositeBreadthVoldTotal = not na(compositeBreadthUpVolValue) and not na(compositeBreadthDownVolValue) ?
     compositeBreadthUpVolValue + compositeBreadthDownVolValue : na
float compositeBreadthVoldConfidence = f_compositeBreadthClampedRatio(
     numerator = compositeBreadthVoldDelta,
     denominator = compositeBreadthVoldTotal
 )

float compositeBreadthAddDelta = not na(compositeBreadthAdvValue) and not na(compositeBreadthDeclValue) ?
     compositeBreadthAdvValue - compositeBreadthDeclValue : na
float compositeBreadthAddTotal = not na(compositeBreadthAdvValue) and not na(compositeBreadthDeclValue) ?
     compositeBreadthAdvValue + compositeBreadthDeclValue : na
float compositeBreadthAddConfidence = f_compositeBreadthClampedRatio(
     numerator = compositeBreadthAddDelta,
     denominator = compositeBreadthAddTotal
 )

// PCTABOVEVWAP is published as a 0..100 percentage. Center on 50 (true neutral
// positioning) and map to the same -1..+1 confidence scale as VOLD/ADD over a
// ±CBI_PCTVWAP_BAND band. Practitioner rails are 40/60 — above 60% is a
// "don't short" tape, below 40% a "don't long" one — so ±15 saturates the
// component right where the tape actually treats the reading as extreme:
// 65 = +1 (full bullish), 35 = −1 (full bearish), anything past clamps. The
// earlier ±25 band left the component chronically under-scaled (a strong
// 65-70 directional session scored only ~0.6-0.8), which structurally
// under-delivered its weight.
float compositeBreadthPctVwapConfidence = not na(compositeBreadthPctVwapValue) ?
     math.max(-1.0, math.min(1.0, (compositeBreadthPctVwapValue - 50.0) / CBI_PCTVWAP_BAND)) : na

// TICK bias mean (Steenbarger adjustment). Raw TICK carries a persistent
// positive bias — Steenbarger's Adjusted TICK subtracts a trailing ~20-day
// mean of the per-bar TICK before cumulating, and without that recentering
// the cumTICK slope tilts bullish (negative saturation becomes structurally
// rarer than positive). Approximated here as a long EMA (~20 trading days of
// chart bars, timeframe-derived) that only updates on live TICK bars, so
// off-RTH na gaps neither decay nor pollute it. Seeded from the first live
// TICK value — early-history adjusted values start near zero and converge as
// the window fills, which only affects the oldest loaded bars.
var float compositeBreadthTickBiasMean = na
if not na(compositeBreadthTickValue)
    float compositeBreadthTickBiasAlpha = 2.0 / (compositeBreadthTickBiasWindowBars + 1.0)
    compositeBreadthTickBiasMean := na(compositeBreadthTickBiasMean) ? compositeBreadthTickValue :
         compositeBreadthTickBiasAlpha * compositeBreadthTickValue + (1.0 - compositeBreadthTickBiasAlpha) * compositeBreadthTickBiasMean

float compositeBreadthTickAdjustedValue = na(compositeBreadthTickValue) ? na :
     compositeBreadthCumTickBiasAdjust and not na(compositeBreadthTickBiasMean) ?
     compositeBreadthTickValue - compositeBreadthTickBiasMean : compositeBreadthTickValue

// CUMTICK (cumulative session TICK, slope-normalized)
// Sum of (bias-adjusted) TICK across the session, reset at
// compositeBreadthSessionJustOpened (the time-anchored 09:30 edge). The LEVEL
// of CUMTICK grows with session length, so it's not directly comparable
// across bars; the SLOPE (CBI_CUMTICK_SLOPE_MINUTES of rate-of-change, bar
// count derived from the chart timeframe — 5 bars on 2-min) is what carries
// the signal: positive slope = breadth strengthening on the bid right now,
// negative = weakening. Normalize slope by the derived slope scale so
// confidence saturates at ±1 when TICK has averaged a full scale
// (±500 NYSE, ±750 TICKQ) across the slope window — a strong directional
// regime.
//
// Cross-session leak guard: the slope lookback compositeBreadthCumTickValue[
// compositeBreadthCumTickSlopeWindow] would otherwise reach back across the
// off-RTH gap into the PRIOR session's accumulated value, making the first
// few bars of every new session register a bogus full-magnitude slope
// (this-session reset value minus yesterday's huge cumulative). The slope is
// therefore gated on compositeBreadthBarsSinceSessionOpen >
// compositeBreadthCumTickSlopeWindow — only computed when the entire
// lookback window is provably in-session.
//
// This is the divergence-grade breadth series. Raw TICK is too jagged to
// spot pivot-style turns; PCTABOVEVWAP plateaus mid-session. CUMTICK slope
// captures the inflections that price reversals actually pivot against.
var float compositeBreadthCumTickValue = na
if compositeBreadthSessionJustOpened or na(compositeBreadthCumTickValue)
    compositeBreadthCumTickValue := compositeBreadthTickAdjustedValue
else if not na(compositeBreadthTickAdjustedValue)
    compositeBreadthCumTickValue := compositeBreadthCumTickValue + compositeBreadthTickAdjustedValue
// When TICK is na (off-RTH gap), leave cumTick at its last value — the next
// session-open edge will reseed it via compositeBreadthSessionJustOpened.

bool compositeBreadthCumTickSlopeReady = compositeBreadthBarsSinceSessionOpen > compositeBreadthCumTickSlopeWindow and
     not na(compositeBreadthCumTickValue) and not na(compositeBreadthCumTickValue[compositeBreadthCumTickSlopeWindow])
float compositeBreadthCumTickSlope = compositeBreadthCumTickSlopeReady ?
     compositeBreadthCumTickValue - compositeBreadthCumTickValue[compositeBreadthCumTickSlopeWindow] : na

float compositeBreadthCumTickConfidenceLive = not na(compositeBreadthCumTickSlope) ?
     math.max(-1.0, math.min(1.0, compositeBreadthCumTickSlope / compositeBreadthCumTickSlopeScale)) : na

// MOC freeze — TICK after 15:45 ET is dominated by market-on-close
// rebalancing program spikes and is ignored for directional analysis by
// practitioner consensus. Rather than dropping the component to na (which
// would renormalize the weights and jolt the composite), CUMTICK confidence
// HOLDS its last pre-15:45 value through the close: the component keeps its
// weight and its stance, it just stops reacting to contaminated prints.
var float compositeBreadthCumTickHeldConfidence = na
if not compositeBreadthInMocWindow
    compositeBreadthCumTickHeldConfidence := compositeBreadthCumTickConfidenceLive
float compositeBreadthCumTickConfidence = compositeBreadthInMocWindow ?
     compositeBreadthCumTickHeldConfidence : compositeBreadthCumTickConfidenceLive

// ═════════════════════════════════════════════════════════════════════════════
// 🩺 FEED HEALTH MONITORING
// All six request.security calls use ignore_invalid_symbol = true so an
// invalid feed silently returns na — the composite would then run with
// degraded inputs and no obvious signal that something is wrong. Track each
// feed's "ever delivered in current session" state, emit a one-time
// log.warning after a grace window if any feed is still missing, and render
// a status badge on the last bar listing the unhealthy feeds.
//
// All counters and reset edges are tied to compositeBreadthSessionJustOpened
// (the time-anchored 09:30 edge). Earlier versions anchored to a TICK-feed
// na→value edge, but that meant a missing TICK feed would prevent BOTH the
// counter from incrementing AND the warning path from ever maturing — the
// badge would show TICK as missing but nothing else would ever fire. The
// time edge is independent of feed health entirely: a session opens at 09:30
// whether or not data arrived, and a perpetually-missing TICK is just one
// more entry in the missing-feeds list, not a circuit-breaker.
// ═════════════════════════════════════════════════════════════════════════════
var bool compositeBreadthAdvFeedLive        = false
var bool compositeBreadthDeclFeedLive       = false
var bool compositeBreadthUpVolFeedLive      = false
var bool compositeBreadthDownVolFeedLive    = false
var bool compositeBreadthPctVwapFeedLive    = false
var bool compositeBreadthTickFeedLive       = false
var bool compositeBreadthFeedWarningEmitted = false

if compositeBreadthSessionJustOpened
    compositeBreadthAdvFeedLive        := false
    compositeBreadthDeclFeedLive       := false
    compositeBreadthUpVolFeedLive      := false
    compositeBreadthDownVolFeedLive    := false
    compositeBreadthPctVwapFeedLive    := false
    compositeBreadthTickFeedLive       := false
    compositeBreadthFeedWarningEmitted := false

if not na(compositeBreadthTickValue)
    compositeBreadthTickFeedLive       := true
if not na(compositeBreadthAdvValue)
    compositeBreadthAdvFeedLive        := true
if not na(compositeBreadthDeclValue)
    compositeBreadthDeclFeedLive       := true
if not na(compositeBreadthUpVolValue)
    compositeBreadthUpVolFeedLive      := true
if not na(compositeBreadthDownVolValue)
    compositeBreadthDownVolFeedLive    := true
if not na(compositeBreadthPctVwapValue)
    compositeBreadthPctVwapFeedLive    := true

// One boolean drives every per-bar consumer (warning gate, alert condition,
// badge visibility). The human-readable missing-feeds list is only needed on
// the rare paths that actually display it (one-time log warning, last-bar
// badge), so it's built on demand by the helper below instead of concatenating
// strings on every historical bar.
bool compositeBreadthAnyFeedMissing = not (compositeBreadthAdvFeedLive and compositeBreadthDeclFeedLive and
     compositeBreadthUpVolFeedLive and compositeBreadthDownVolFeedLive and
     compositeBreadthPctVwapFeedLive and compositeBreadthTickFeedLive)

f_compositeBreadthMissingFeedsText() =>
    string compositeBreadthMissingText = ""
    if not compositeBreadthAdvFeedLive
        compositeBreadthMissingText += "ADVN "
    if not compositeBreadthDeclFeedLive
        compositeBreadthMissingText += "DECL "
    if not compositeBreadthUpVolFeedLive
        compositeBreadthMissingText += "UPVOL "
    if not compositeBreadthDownVolFeedLive
        compositeBreadthMissingText += "DNVOL "
    if not compositeBreadthPctVwapFeedLive
        compositeBreadthMissingText += "PCTVWAP "
    if not compositeBreadthTickFeedLive
        compositeBreadthMissingText += "TICK "
    compositeBreadthMissingText

// Emit a one-time log.warning per session once we're past the grace window.
// Pine v6 routes this to the Pine logs panel (View → Pine Logs) so the user
// can see which feed(s) failed without checking the chart. Uses
// compositeBreadthBarsSinceSessionOpen (independent of TICK) so a missing
// TICK feed doesn't suppress the warning.
// Gated to barstate.isrealtime: this is a LIVE health check, not a backtest
// signal. The emitted-flag resets every session, so without this
// guard a multi-day historical load would fire one warning per historical
// session with a missing feed and flood the Pine Logs panel on every load.
if barstate.isrealtime and compositeBreadthBarsSinceSessionOpen >= CBI_FEED_HEALTH_GRACE_BARS and not compositeBreadthFeedWarningEmitted and compositeBreadthAnyFeedMissing
    log.warning("CBI: feed(s) not delivering after {0} bars post-open — {1}(market = {2})", CBI_FEED_HEALTH_GRACE_BARS, f_compositeBreadthMissingFeedsText(), compositeBreadthMarket)
    compositeBreadthFeedWarningEmitted := true

// ═════════════════════════════════════════════════════════════════════════════
// 🧬 COMPOSITE SCORE
// Weighted sum × consensus multiplier × CBI_SCALE_MAX, using FOUR weighted
// components: VOLD, ADD, PCTABOVEVWAP, CUMTICK. Consensus measures cross-
// component agreement: when the four move together, the line is allowed to
// reach its full magnitude; when they disagree, it's squeezed toward zero
// (a squeezed line reads "uncertain breadth", not "neutral breadth"). Raw
// per-bar TICK is NOT a weighted component — it only drives the extreme
// triangle markers and their alerts.
// ═════════════════════════════════════════════════════════════════════════════
// A component is "active" only when both its data is present AND its weight is
// non-zero. Setting a weight to 0 must fully remove that component from BOTH
// the directional weighted sum AND the consensus calculation — otherwise a
// disabled component's disagreement still squeezes the composite toward zero.
bool compositeBreadthVoldActive    = not na(compositeBreadthVoldConfidence)    and compositeBreadthVoldWeight    > 0.0
bool compositeBreadthAddActive     = not na(compositeBreadthAddConfidence)     and compositeBreadthAddWeight     > 0.0
bool compositeBreadthPctVwapActive = not na(compositeBreadthPctVwapConfidence) and compositeBreadthPctVwapWeight > 0.0
bool compositeBreadthCumTickActive = not na(compositeBreadthCumTickConfidence) and compositeBreadthCumTickWeight > 0.0

int compositeBreadthActiveCount = (compositeBreadthVoldActive ? 1 : 0) +
     (compositeBreadthAddActive     ? 1 : 0) +
     (compositeBreadthPctVwapActive ? 1 : 0) +
     (compositeBreadthCumTickActive ? 1 : 0)

float compositeBreadthWeightedSum = 0.0
float compositeBreadthWeightTotal = 0.0
if compositeBreadthVoldActive
    compositeBreadthWeightedSum += compositeBreadthVoldWeight * compositeBreadthVoldConfidence
    compositeBreadthWeightTotal += compositeBreadthVoldWeight
if compositeBreadthAddActive
    compositeBreadthWeightedSum += compositeBreadthAddWeight * compositeBreadthAddConfidence
    compositeBreadthWeightTotal += compositeBreadthAddWeight
if compositeBreadthPctVwapActive
    compositeBreadthWeightedSum += compositeBreadthPctVwapWeight * compositeBreadthPctVwapConfidence
    compositeBreadthWeightTotal += compositeBreadthPctVwapWeight
if compositeBreadthCumTickActive
    compositeBreadthWeightedSum += compositeBreadthCumTickWeight * compositeBreadthCumTickConfidence
    compositeBreadthWeightTotal += compositeBreadthCumTickWeight

float compositeBreadthDirectional = compositeBreadthWeightTotal > 0.0 ?
     compositeBreadthWeightedSum / compositeBreadthWeightTotal : na

float compositeBreadthConfidenceSum = (compositeBreadthVoldActive    ? compositeBreadthVoldConfidence    : 0.0) +
     (compositeBreadthAddActive     ? compositeBreadthAddConfidence     : 0.0) +
     (compositeBreadthPctVwapActive ? compositeBreadthPctVwapConfidence : 0.0) +
     (compositeBreadthCumTickActive ? compositeBreadthCumTickConfidence : 0.0)
float compositeBreadthMeanConfidence = compositeBreadthActiveCount > 0 ?
     compositeBreadthConfidenceSum / compositeBreadthActiveCount : 0.0
float compositeBreadthVoldDeviation    = compositeBreadthVoldConfidence    - compositeBreadthMeanConfidence
float compositeBreadthAddDeviation     = compositeBreadthAddConfidence     - compositeBreadthMeanConfidence
float compositeBreadthPctVwapDeviation = compositeBreadthPctVwapConfidence - compositeBreadthMeanConfidence
float compositeBreadthCumTickDeviation = compositeBreadthCumTickConfidence - compositeBreadthMeanConfidence
float compositeBreadthDeviationSumSquared = (compositeBreadthVoldActive    ? compositeBreadthVoldDeviation    * compositeBreadthVoldDeviation    : 0.0) +
     (compositeBreadthAddActive     ? compositeBreadthAddDeviation     * compositeBreadthAddDeviation     : 0.0) +
     (compositeBreadthPctVwapActive ? compositeBreadthPctVwapDeviation * compositeBreadthPctVwapDeviation : 0.0) +
     (compositeBreadthCumTickActive ? compositeBreadthCumTickDeviation * compositeBreadthCumTickDeviation : 0.0)
float compositeBreadthStdevConfidence = compositeBreadthActiveCount > 0 ?
     math.sqrt(number = compositeBreadthDeviationSumSquared / compositeBreadthActiveCount) : 0.0
// Max stdev varies by active count: 3 active = sqrt(8/9) ≈ 0.9428 (two at +1,
// one at -1 or vice versa); 2 and 4 active both max at 1.0 (perfect split).
// 1 or 0 active falls through to the consensus = 1.0 fast-path below.
float compositeBreadthMaxStdev = compositeBreadthActiveCount == 3 ? CBI_THREE_WAY_MAX_STDEV : 1.0
float compositeBreadthMagnitudeConsensus = math.max(0.0, 1.0 - compositeBreadthStdevConfidence / compositeBreadthMaxStdev)

// Sign-aware consensus (the only mode — the legacy stdev-only squeeze was
// removed: it over-suppressed clean trending sessions where PCTABOVEVWAP
// migrates more slowly than VOLD/ADD even though all components point the
// same way). Agreement splits into two questions: (1) team — how many
// components share the sign of the mean? (2) magnitude — within the team,
// how tightly do they cluster?
//
// When all components share sign (full team agreement: 3/3 or 4/4), the line
// expresses its directional value — consensus floors at 0.85 even if
// magnitudes disagree, because magnitude divergence in the same direction is
// sensitivity, not disagreement.
//
// At ~2/3 or 3/4 agreement (ratio ≥ 0.666), the sign penalty (0.7×) and the
// magnitude penalty stack — there's a real dissenter and the line should
// squeeze. At ~half (ratio ≥ 0.333), full squeeze (0.3×). Below that, the
// components are fighting (0.1×) — "uncertain breadth" is the right read.
// Practitioner logic is categorical (all-align = full size, one dissents =
// reduce, split = stand down); these tiers are that logic made continuous.
bool compositeBreadthMeanIsPositive = compositeBreadthMeanConfidence >= 0.0
int compositeBreadthSignAlignedCount =
     (compositeBreadthVoldActive    and ((compositeBreadthVoldConfidence    >= 0.0) == compositeBreadthMeanIsPositive) ? 1 : 0) +
     (compositeBreadthAddActive     and ((compositeBreadthAddConfidence     >= 0.0) == compositeBreadthMeanIsPositive) ? 1 : 0) +
     (compositeBreadthPctVwapActive and ((compositeBreadthPctVwapConfidence >= 0.0) == compositeBreadthMeanIsPositive) ? 1 : 0) +
     (compositeBreadthCumTickActive and ((compositeBreadthCumTickConfidence >= 0.0) == compositeBreadthMeanIsPositive) ? 1 : 0)
float compositeBreadthSignAlignmentRatio = compositeBreadthActiveCount > 0 ?
     compositeBreadthSignAlignedCount / float(compositeBreadthActiveCount) : 1.0
float compositeBreadthSignFactor = compositeBreadthSignAlignmentRatio >= 0.999 ? 1.0 :
     compositeBreadthSignAlignmentRatio >= 0.666 ? 0.7 :
     compositeBreadthSignAlignmentRatio >= 0.333 ? 0.3 : 0.1

float compositeBreadthConsensus = 1.0
if compositeBreadthActiveCount > 1
    compositeBreadthConsensus := compositeBreadthSignAlignmentRatio >= 0.999 ?
         math.max(0.85, compositeBreadthMagnitudeConsensus) :
         compositeBreadthSignFactor * compositeBreadthMagnitudeConsensus

float compositeBreadthLineValue = na(compositeBreadthDirectional) ? na :
     compositeBreadthDirectional * compositeBreadthConsensus * CBI_SCALE_MAX

// ═════════════════════════════════════════════════════════════════════════════
// 🌊 DISPLAY + SIGNAL EMA
// Display EMA is short (3) and tames per-bar jitter so intraday swings on the
// composite read cleanly. The signal EMA is fed FROM the display line (not
// from the raw composite) so the visible composite-vs-signal relationship is
// internally consistent — divergences read true rather than reflecting two
// different lag profiles.
//
// Two reset paths, both required. (1) na blanking: when the upstream
// composite is unavailable (off-RTH on futures/extended charts, paired with
// gaps_on) the lines blank instead of freezing into a stale flat line.
// (2) The time-anchored session-open edge: on an RTH-only chart there ARE no
// na bars between sessions, so without this reset the EMAs would carry
// yesterday's smoothed state into today's open and the warmup would only
// ever run on the first loaded session. Reseeding at each open is
// structurally required here: the internals themselves are session-scoped
// series that discontinuously reset at 09:30 — a continuous EMA would smooth
// yesterday's closing regime into today's gap.
// ═════════════════════════════════════════════════════════════════════════════
var float compositeBreadthDisplayLine = na
if compositeBreadthSessionJustOpened
    compositeBreadthDisplayLine := na
if not na(compositeBreadthLineValue)
    float compositeBreadthDisplayAlpha = 2.0 / (CBI_DISPLAY_SMOOTH_LENGTH + 1.0)
    compositeBreadthDisplayLine := na(compositeBreadthDisplayLine) ? compositeBreadthLineValue :
         compositeBreadthDisplayAlpha * compositeBreadthLineValue + (1.0 - compositeBreadthDisplayAlpha) * compositeBreadthDisplayLine
else
    compositeBreadthDisplayLine := na

// Single fixed signal length all session. The old "adaptive (faster at
// open)" feature — length 8 for the first hour — was removed on research:
// clock-scheduled EMA speed-ups have no precedent anywhere in the adaptive-MA
// literature (KAMA/VIDYA/MAMA all adapt to measured market properties, never
// to the clock), and the 09:30–10:00 window is exactly where a FASTER signal
// does the most damage — the internals are still seeding off the opening
// auction, so extra crosses there are artifacts, not information. The
// event-time insight the feature was reaching for ("an opening bar carries
// more information than a lunch bar") is real, but the correct response for
// a confirmation instrument is to gate the cross ALERTS at the open (below),
// not to speed the EMA up into the noise.
var float compositeBreadthSignalLineValue = na
var int compositeBreadthSignalSeedCount = 0
if compositeBreadthSessionJustOpened
    compositeBreadthSignalLineValue := na
    compositeBreadthSignalSeedCount := 0
if not na(compositeBreadthDisplayLine)
    compositeBreadthSignalSeedCount += 1
    if compositeBreadthSignalSeedCount > CBI_SIGNAL_WARMUP_BARS
        float compositeBreadthSignalAlpha = 2.0 / (compositeBreadthSignalLength + 1.0)
        compositeBreadthSignalLineValue := na(compositeBreadthSignalLineValue) ? compositeBreadthDisplayLine :
             compositeBreadthSignalAlpha * compositeBreadthDisplayLine + (1.0 - compositeBreadthSignalAlpha) * compositeBreadthSignalLineValue
else
    compositeBreadthSignalLineValue := na
    compositeBreadthSignalSeedCount := 0

// Cross-alert gate: composite-vs-signal cross alerts stay muted for the
// first CBI_SIGNAL_ALERT_GATE_MINUTES of each session (30 min default) —
// auction-seeding noise plus a freshly reseeded 20-EMA make early crosses
// mostly artifacts, and the gate window doubles as proper convergence time
// for the signal EMA (the 5-bar warmup alone under-seeds a 20-length EMA).
// Level-based alerts (±50 impulse, VOLD extremes, TICK extremes) are NOT
// gated — extreme LEVELS at the open are genuine trend-day information;
// it's specifically the crosses that are noise there.
bool compositeBreadthSignalCrossArmed = compositeBreadthBarsSinceSessionOpen > compositeBreadthSignalAlertGateBars

// ═════════════════════════════════════════════════════════════════════════════
// 📈 VOLD SESSION EXTREMES
// Barry reads the up/down volume-difference line making fresh session
// extremes as commitment. The ratio form fed to the composite
// (delta / total) goes numerically inert in the afternoon — total session
// volume keeps growing, so a real late-day reversal barely moves it. The raw
// DELTA making a new session high/low is the responsive event.
//
// Rearm gate: in a steady trend leg every bar prints a "new extreme", which
// is trend confirmation but useless as an event. The event only fires when
// the prior extreme stood for at least CBI_VOLD_EXTREME_REARM_BARS bars —
// i.e. VOLD breaking out of a range after a pause. With the composite's
// sign it reads as fresh commitment (confirmation); against it, as an early
// warning that volume is rotating before the composite shows it.
// ═════════════════════════════════════════════════════════════════════════════
var float compositeBreadthVoldSessionMax   = na
var float compositeBreadthVoldSessionMin   = na
var int   compositeBreadthVoldBarsSinceHigh = 0
var int   compositeBreadthVoldBarsSinceLow  = 0
bool compositeBreadthVoldNewSessionHigh = false
bool compositeBreadthVoldNewSessionLow  = false

if compositeBreadthSessionJustOpened
    compositeBreadthVoldSessionMax    := na
    compositeBreadthVoldSessionMin    := na
    compositeBreadthVoldBarsSinceHigh := 0
    compositeBreadthVoldBarsSinceLow  := 0

if barstate.isconfirmed and not na(compositeBreadthVoldDelta)
    if na(compositeBreadthVoldSessionMax) or compositeBreadthVoldDelta > compositeBreadthVoldSessionMax
        compositeBreadthVoldNewSessionHigh := compositeBreadthVoldBarsSinceHigh >= CBI_VOLD_EXTREME_REARM_BARS
        compositeBreadthVoldSessionMax     := compositeBreadthVoldDelta
        compositeBreadthVoldBarsSinceHigh  := 0
    else
        compositeBreadthVoldBarsSinceHigh += 1
    if na(compositeBreadthVoldSessionMin) or compositeBreadthVoldDelta < compositeBreadthVoldSessionMin
        compositeBreadthVoldNewSessionLow := compositeBreadthVoldBarsSinceLow >= CBI_VOLD_EXTREME_REARM_BARS
        compositeBreadthVoldSessionMin    := compositeBreadthVoldDelta
        compositeBreadthVoldBarsSinceLow  := 0
    else
        compositeBreadthVoldBarsSinceLow += 1

// ═════════════════════════════════════════════════════════════════════════════
// ⚡ TICK EXTREMES (Barry's method)
// Barry treats ±1000 as exhaustion zones — extremes signal that the current
// move is overextended, NOT that it will continue. After an extreme appears,
// his workflow is to wait for the next cycle high/low on the price chart.
// Detection reads the TICK feed's raw intrabar HIGH/LOW (not a smoothed
// close — extremes are momentary touches the 2-min close routinely misses),
// against the threshold input applied as-is to the resolved feed (no TICKQ
// widening — see the input tooltip). Suppressed inside the 15:45–16:00 MOC
// window: rebalancing program spikes routinely print extreme TICKs that
// carry no exhaustion information. Rising-edge bools feed the triangle
// markers and the extreme alertconditions.
//
// Regime caveat (research): exhaustion-fading is a POSITIVE-gamma-regime
// read. On negative-gamma trend days (expanding range, breakouts following
// through, one-sided VOLD from the open) the same extreme print is
// continuation fuel — weigh the marker against the VOLD session-extreme
// events before fading anything.
// ═════════════════════════════════════════════════════════════════════════════
bool compositeBreadthTickExtremeUp   = not compositeBreadthInMocWindow and not na(compositeBreadthTickHighValue) and compositeBreadthTickHighValue >=  compositeBreadthTickExtremeThreshold
bool compositeBreadthTickExtremeDown = not compositeBreadthInMocWindow and not na(compositeBreadthTickLowValue)  and compositeBreadthTickLowValue  <= -compositeBreadthTickExtremeThreshold

// Rising-edge detection is decoupled from the actual plot fire so a TICK
// extreme that lands on a bar with na displayLine (rare: TICK is live but
// all four weighted breadth feeds gapped simultaneously) doesn't get
// consumed silently. The edge arms a pending flag; the marker fires on
// the first subsequent bar where displayLine is valid. Pending is cleared
// at the next session open so a stale arm from yesterday can't fire today.
bool compositeBreadthTickExtremeUpEdge   = compositeBreadthTickExtremeUp   and not compositeBreadthTickExtremeUp[1]
bool compositeBreadthTickExtremeDownEdge = compositeBreadthTickExtremeDown and not compositeBreadthTickExtremeDown[1]

var bool compositeBreadthTickExtremeUpPending   = false
var bool compositeBreadthTickExtremeDownPending = false

if compositeBreadthSessionJustOpened
    compositeBreadthTickExtremeUpPending   := false
    compositeBreadthTickExtremeDownPending := false

if compositeBreadthTickExtremeUpEdge
    compositeBreadthTickExtremeUpPending := true
if compositeBreadthTickExtremeDownEdge
    compositeBreadthTickExtremeDownPending := true

bool compositeBreadthTickExtremeUpNew   = compositeBreadthTickExtremeUpPending   and not na(compositeBreadthDisplayLine)
bool compositeBreadthTickExtremeDownNew = compositeBreadthTickExtremeDownPending and not na(compositeBreadthDisplayLine)

if compositeBreadthTickExtremeUpNew
    compositeBreadthTickExtremeUpPending := false
if compositeBreadthTickExtremeDownNew
    compositeBreadthTickExtremeDownPending := false

// ═════════════════════════════════════════════════════════════════════════════
// 🎨 COLORS
// ═════════════════════════════════════════════════════════════════════════════
// Time-of-day dimming: extra transparency on the composite line during the
// lunch trough and the MOC window — the two structurally low-information
// stretches of the session. Visual only; the math is untouched.
color compositeBreadthLineBaseColor = f_compositeBreadthProgressiveColor(
     value = compositeBreadthDisplayLine,
     scale = CBI_OPACITY_ANCHOR,
     minTransp = CBI_SIGNAL_MIN_TRANSP
 )
bool compositeBreadthInLowInfoWindow = compositeBreadthInLunchWindow or compositeBreadthInMocWindow
color compositeBreadthLineColor = compositeBreadthShowTimeOfDayDim and compositeBreadthInLowInfoWindow and not na(compositeBreadthLineBaseColor) ?
     color.new(color = compositeBreadthLineBaseColor, transp = math.min(95.0, color.t(compositeBreadthLineBaseColor) + CBI_TIME_DIM_EXTRA_TRANSP)) :
     compositeBreadthLineBaseColor

// Zero hline color stays solid; the display toggle handles show/hide. Using
// transparency alone would leave the line invisible but still pinning the
// y-axis to include 0 (which is usually fine for the composite, but consistent
// behaviour across all hlines is cleaner — every togglable hline uses
// display.none when off).
color compositeBreadthZeroLineColor = NORD3

// ═════════════════════════════════════════════════════════════════════════════
// 📊 PLOTS
// Final plot calls stay here due to Pine placement constraints. All series and
// styling inputs are prepared inside the owning Composite Breadth section.
// ═════════════════════════════════════════════════════════════════════════════
hline(price = 0, title = "Zero", color = compositeBreadthZeroLineColor, linestyle = hline.style_solid, linewidth = 3, display = compositeBreadthShowZeroLine ? display.all : display.none)

// Extended-level reference lines at ±CBI_EXTENDED_LEVEL. Dotted, dim NORD3.
// Past visual saturation the composite line looks the same from ±35 onward
// — these lines re-introduce a "this is extended for this market" cue,
// equivalent to Barry's manually drawn 30-day VOLD support/resistance levels.
// Toggling off uses display.none rather than alpha=100: an hline with alpha=100
// is invisible but its `price` parameter still pins TradingView's auto-scale
// to include ±60, which compresses the composite's natural swing around zero.
// display.none removes the hline from the scale calculation entirely.
color compositeBreadthExtendedLineColor = color.new(color = NORD3, transp = 60)
hline(price =  CBI_EXTENDED_LEVEL, title = "Extended Up",   color = compositeBreadthExtendedLineColor, linestyle = hline.style_dotted, linewidth = 1, display = compositeBreadthShowExtendedLevels ? display.all : display.none)
hline(price = -CBI_EXTENDED_LEVEL, title = "Extended Down", color = compositeBreadthExtendedLineColor, linestyle = hline.style_dotted, linewidth = 1, display = compositeBreadthShowExtendedLevels ? display.all : display.none)

// Session divider — vertical column tint on the session-open bar so each new
// RTH day is visually separated from the prior one. Same time-anchored edge
// that drives every session-wide reset.
bgcolor(color = compositeBreadthShowSessionDivider and compositeBreadthSessionJustOpened ? color.new(color = NORD3, transp = 70) : na, title = "Session Divider")

plot(series = compositeBreadthDisplayLine, title = "Composite", color = compositeBreadthLineColor, linewidth = 4)
plot(series = compositeBreadthShowSignalLine ? compositeBreadthSignalLineValue : na, title = "Signal", color = NORD3, linewidth = 2)

// TICK extreme markers — Barry's exhaustion zones. NORD13 triangles at 50%
// transparency, sitting above/below the composite line: up-triangle above on
// extreme high, down-triangle below on extreme low. Read as "watch next cycle
// on price" cues, not entries.
color compositeBreadthTickExtremeColor = color.new(color = NORD13, transp = 50)
plotshape(series = compositeBreadthTickShowExtremes and compositeBreadthTickExtremeUpNew   ? compositeBreadthDisplayLine + compositeBreadthTickExtremeOffset : na, title = "TICK Extreme Up",   style = shape.triangleup,   location = location.absolute, color = compositeBreadthTickExtremeColor, size = size.tiny, display = compositeBreadthTickShowExtremes ? display.all : display.none)
plotshape(series = compositeBreadthTickShowExtremes and compositeBreadthTickExtremeDownNew ? compositeBreadthDisplayLine - compositeBreadthTickExtremeOffset : na, title = "TICK Extreme Down", style = shape.triangledown, location = location.absolute, color = compositeBreadthTickExtremeColor, size = size.tiny, display = compositeBreadthTickShowExtremes ? display.all : display.none)

// Feed-health badge — one persistent label updated in-place each bar via
// label.set_*() (more efficient than the delete+recreate pattern; TradingView
// docs recommend this when the label persists across the whole chart life).
// Created once on the first bar where any feed is missing; hidden by setting
// transparency to 100 when everything is healthy so we don't churn handles.
var label compositeBreadthFeedHealthLabel = na
if barstate.islast
    if compositeBreadthAnyFeedMissing
        string compositeBreadthFeedHealthRenderText = "⚠ CBI feeds missing: " + f_compositeBreadthMissingFeedsText()
        color compositeBreadthFeedHealthLabelColor = color.new(color = NORD11, transp = 20)
        if na(compositeBreadthFeedHealthLabel)
            compositeBreadthFeedHealthLabel := label.new(
                 x = bar_index,
                 y = CBI_SCALE_MAX * 0.95,
                 text = compositeBreadthFeedHealthRenderText,
                 xloc = xloc.bar_index,
                 yloc = yloc.price,
                 color = compositeBreadthFeedHealthLabelColor,
                 textcolor = NORD6,
                 style = label.style_label_left,
                 size = size.normal
             )
        else
            label.set_xy       (id = compositeBreadthFeedHealthLabel, x = bar_index, y = CBI_SCALE_MAX * 0.95)
            label.set_text     (id = compositeBreadthFeedHealthLabel, text = compositeBreadthFeedHealthRenderText)
            label.set_color    (id = compositeBreadthFeedHealthLabel, color = compositeBreadthFeedHealthLabelColor)
            label.set_textcolor(id = compositeBreadthFeedHealthLabel, textcolor = NORD6)
    else if not na(compositeBreadthFeedHealthLabel)
        // All feeds healthy — hide via full transparency instead of
        // deleting+recreating each render.
        label.set_color    (id = compositeBreadthFeedHealthLabel, color = color.new(color = NORD11, transp = 100))
        label.set_textcolor(id = compositeBreadthFeedHealthLabel, textcolor = color.new(color = NORD6, transp = 100))

// Additional alerts on the smoothed composite line. The ±50 impulse alerts
// sit intentionally INSIDE the ±60 extended level: ±50 is "strong directional
// breadth engaged" (confirmation of strength), ±60 is "abnormally extended"
// (exhaustion context) — two different reads, two different levels.
alertcondition(condition = ta.crossover (source1 = compositeBreadthDisplayLine, source2 = compositeBreadthSignalLineValue) and compositeBreadthSignalCrossArmed, title = "Composite crosses above Signal", message = "Composite breadth crossed above signal — upward momentum building.")
alertcondition(condition = ta.crossunder(source1 = compositeBreadthDisplayLine, source2 = compositeBreadthSignalLineValue) and compositeBreadthSignalCrossArmed, title = "Composite crosses below Signal", message = "Composite breadth crossed below signal — downward momentum building.")
alertcondition(condition = ta.crossover (source1 = compositeBreadthDisplayLine, source2 =  50.0), title = "Composite crosses +50 (impulse up)",   message = "Composite breadth crossed above +50 — bullish breadth impulse.")
alertcondition(condition = ta.crossunder(source1 = compositeBreadthDisplayLine, source2 = -50.0), title = "Composite crosses −50 (impulse down)", message = "Composite breadth crossed below −50 — bearish breadth impulse.")
alertcondition(condition = compositeBreadthAnyFeedMissing and compositeBreadthBarsSinceSessionOpen >= CBI_FEED_HEALTH_GRACE_BARS, title = "CBI: Feed(s) missing", message = "One or more required breadth feeds have not delivered after the post-open grace window. Check the Pine logs panel and the feed-health badge for details.")

// TICK extreme alerts — Barry's ±985 audio-alert workflow (the threshold
// input exists FOR this alert: 985 sits just inside his ±1000 lines so the
// trigger isn't missed). Exhaustion context, not entries.
alertcondition(condition = compositeBreadthTickExtremeUpNew,   title = "TICK extreme HIGH", message = "TICK touched the extreme high threshold — exhaustion zone, not continuation. Watch the next cycle high on price.")
alertcondition(condition = compositeBreadthTickExtremeDownNew, title = "TICK extreme LOW",  message = "TICK touched the extreme low threshold — exhaustion zone, not continuation. Watch the next cycle low on price.")

// VOLD session-extreme alerts — raw volume-difference breaking its session
// range after a pause (Barry's fresh-commitment read on the up/down volume
// difference line).
alertcondition(condition = compositeBreadthVoldNewSessionHigh, title = "VOLD new session high (after pause)", message = "Up/down volume difference broke to a fresh session high after holding a range — fresh volume commitment on the buy side.")
alertcondition(condition = compositeBreadthVoldNewSessionLow,  title = "VOLD new session low (after pause)",  message = "Up/down volume difference broke to a fresh session low after holding a range — fresh volume commitment on the sell side.")
