//@version=6
indicator(title = "Composite Breadth Indicator", shorttitle = "📊 CBI", format = format.price, precision = 2, max_labels_count = 500)

// ═════════════════════════════════════════════════════════════════════════════
// 🧱 CONSTANTS
// Shared immutable values used by the indicator, including the Nord palette.
// ═════════════════════════════════════════════════════════════════════════════
// Nord Theme Color
// Polar Night
const color NORD0  = #2E3440
const color NORD1  = #3B4252
const color NORD2  = #434C5E
const color NORD3  = #4C566A
// Snow Storm
const color NORD4  = #D8DEE9
const color NORD5  = #E5E9F0
const color NORD6  = #ECEFF4
// Frost
const color NORD7  = #8FBCBB
const color NORD8  = #88C0D0
const color NORD9  = #81A1C1
const color NORD10 = #5E81AC
// Aurora
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

// ═════════════════════════════════════════════════════════════════════════════
// 📊 COMPOSITE BREADTH
// Market breadth composite built from VOLD, ADD, PCTABOVEVWAP, and CUMTICK
// (session-cumulative TICK slope). Raw TICK is kept as context only (strip
// + extreme markers) — it doesn't enter the weighted sum because its raw
// per-bar value is too noisy; the cumulative slope captures the same
// information with persistence baked in. This section owns its inputs, data
// requests, calculations, color prep, and plot-ready outputs.
// ═════════════════════════════════════════════════════════════════════════════
const string GROUP_COMPOSITE_BREADTH_MARKET     = "🏛️ Market"
const string GROUP_COMPOSITE_BREADTH_WEIGHTS    = "⚖️ Weights"
const string GROUP_COMPOSITE_BREADTH_SIGNAL     = "🧮 Signal"
const string GROUP_COMPOSITE_BREADTH_TICK       = "⚡ TICK Context"
const string GROUP_COMPOSITE_BREADTH_PIVOTS     = "🪜 Structure (HH/HL/LH/LL)"
const string GROUP_COMPOSITE_BREADTH_DISPLAY    = "📋 Display"

const float CBI_SCALE_MAX               = 100.0
const float CBI_TICK_FIXED_SCALE        = 500.0
const int   CBI_SIGNAL_WARMUP_BARS      = 5        // bars to seed display before first signal value — slightly longer than legacy 3 so the EMA isn't dominated by the seed at session open
const int   CBI_DISPLAY_SMOOTH_LENGTH   = 3        // light EMA on composite for the plot only — reduces visual noise without affecting calc
const float CBI_OPACITY_ANCHOR          = 35.0
const float CBI_EXTENDED_LEVEL          = 60.0     // dotted reference at ±60 — Barry's manual "30-day VOLD support/resistance" equivalent, marks abnormally extended breadth
const float CBI_STRIP_OPACITY_ANCHOR    = 0.5
const int   CBI_SIGNAL_MIN_TRANSP       = 40
const int   CBI_STRIP_MIN_TRANSP        = 65
const int   CBI_STRIP_MIN_TRANSP_TICK   = 75       // TICK row reads as secondary — slightly more transparent than the weighted components
const float CBI_THREE_WAY_MAX_STDEV     = 0.9428
const int   CBI_PIVOT_LEFT_LEGS         = 2        // left-side noise filter — pivot bar must exceed this many prior bars
const int   CBI_PIVOT_RIGHT_LEGS        = 1        // right-side confirmation lag in bars — minimum-latency pivot detection
const float CBI_PIVOT_CONSENSUS_GATE    = 0.5      // consensus floor: pivots below this are likely artifacts of disagreement, suppressed
const float CBI_PIVOT_EQUAL_TOLERANCE   = 1.0      // % of CBI_SCALE_MAX — pivots within this band of the prior same-type pivot are non-events (neither HH/LH nor HL/LL). Quiets the flat-consolidation false-flip case where strict <= would otherwise tag every flat retest as a fresh LH.
const int   CBI_TICK_SMOOTH_LENGTH      = 5        // EMA smoothing length applied to raw TICK for the strip color and extreme detection
const int   CBI_ADAPTIVE_SIGNAL_BARS    = 30       // number of post-open bars during which the shorter "open" signal EMA is used when adaptive signal length is enabled
const int   CBI_CUMTICK_SLOPE_WINDOW    = 5        // bars used to compute the cumulative TICK slope (5 bars × 2-min = 10 min) — short enough to catch real-time inflections, long enough to filter single-bar noise
const float CBI_CUMTICK_SLOPE_SCALE     = 2500.0   // scale (= 5 × CBI_TICK_FIXED_SCALE) at which the CUMTICK slope confidence saturates at ±1. A 5-bar swing of ±2500 means raw TICK averaged ±500 for the entire window — strong directional pressure
const int   CBI_FEED_HEALTH_GRACE_BARS  = 5        // bars after TICK first opens before a missing required feed triggers the log.warning — gives the USI feeds time to deliver their first non-na bar

// ─── Market ───────────────────────────────────────────────────────────────────
string compositeBreadthMarket = input.string(
     defval = "NASDAQ 100",
     title = "Market (Index)",
     options = ["S&P 500", "NASDAQ 100", "Dow Jones", "Russell 2000"],
     tooltip = "S&P 500 → NYSE breadth (.NY). NASDAQ 100 → Nasdaq exchange-wide (.NQ) for ADVN/DECL/UPVOL/DNVOL/PCTABOVEVWAP. Dow Jones → exact Dow 30 breadth (.DJ) where available. Russell 2000 → US-wide composite (.US) — TradingView has no Russell-specific breadth feed.",
     group = GROUP_COMPOSITE_BREADTH_MARKET
 )

// ─── Weights (35/35/15/15 = VOLD/ADD/PCTABOVEVWAP/CUMTICK) ────────────────────
// Research synthesis: TRIN is a non-independent transformation of VOLD+ADD so
// adding it would double-count; PCTABOVEVWAP captures intraday positioning vs
// the institutional execution benchmark and is independent of the volume/issue
// dimensions; CUMTICK (cumulative intraday TICK, slope-normalized) captures
// session-persistent bid/offer pressure that raw TICK can't carry — it's the
// canonical intraday divergence series used by professional desks against the
// S&P/NDX index futures. Raw TICK remains context-only (strip + extremes);
// practitioner consensus is that the raw per-bar value is too noisy to
// function as a weighted signal — the cumulative slope encodes the same
// pressure with persistence baked in.
float compositeBreadthVoldWeight = input.float(
     defval = 35,
     title = "VOLD Weight",
     minval = 0,
     maxval = 100,
     step = 5,
     tooltip = "Volume trend — conviction. Barry's primary intraday breadth read on NDX (\"up/down volume difference\").",
     group = GROUP_COMPOSITE_BREADTH_WEIGHTS
 )

float compositeBreadthAddWeight = input.float(
     defval = 35,
     title = "ADD Weight",
     minval = 0,
     maxval = 100,
     step = 5,
     tooltip = "Advance-Decline — direction (how many stocks). Distinct from VOLD which measures conviction (how much volume).",
     group = GROUP_COMPOSITE_BREADTH_WEIGHTS
 )

float compositeBreadthPctVwapWeight = input.float(
     defval = 15,
     title = "PCTABOVEVWAP Weight",
     minval = 0,
     maxval = 100,
     step = 5,
     tooltip = "Percent of stocks trading above their intraday VWAP — independent breadth dimension capturing real-time positioning vs the institutional execution benchmark. Per-instrument routing: SPX → .NY, NDX → .NQ, Dow → .DJ, RUT → .US.",
     group = GROUP_COMPOSITE_BREADTH_WEIGHTS
 )

float compositeBreadthCumTickWeight = input.float(
     defval = 15,
     title = "CUMTICK Weight",
     minval = 0,
     maxval = 100,
     step = 5,
     tooltip = "Cumulative session TICK, slope-normalized. Confidence is the 5-bar (10-minute on 2-min charts) rate-of-change of the running session sum of raw TICK, divided by CBI_CUMTICK_SLOPE_SCALE (2500). Positive = breadth strengthening on the bid; negative = weakening. This is the divergence-grade breadth series — raw TICK is too jagged to spot turns, raw level drifts with session length; the slope of the cumulative captures \"pressure right now\" with persistence baked in. Resets at each NYSE RTH open along with the TICK feed.",
     group = GROUP_COMPOSITE_BREADTH_WEIGHTS
 )

// ─── Signal / smoothing ───────────────────────────────────────────────────────
int compositeBreadthSignalLength = input.int(
     defval = 15,
     title = "Signal EMA Length",
     minval = 1,
     maxval = 100,
     step = 1,
     tooltip = "EMA period for the signal line (smoothed reference). Fed from the smoothed display line so signal vs composite is internally consistent. Blanks off-RTH when the breadth feeds aren't live and reseeds at the next session open after a brief warmup, so divergences read against fresh state rather than carrying over from the prior session. Recommended 13–15 for 2m intraday: 13 = faster lead, 15 (default) = cleaner HH/HL pivot structure.",
     group = GROUP_COMPOSITE_BREADTH_SIGNAL
 )

bool compositeBreadthAdaptiveSignal = input.bool(
     defval = true,
     title = "Adaptive Signal Length (faster at open)",
     tooltip = "When ON, the signal EMA uses the shorter \"Open Length\" for the first ~30 bars after each session open, then transitions to the main Signal EMA Length. Tracks Barry's observation that the morning commitment window benefits from a faster read while midday/afternoon prefers a smoother line. OFF behaves as before — single fixed length all session.",
     group = GROUP_COMPOSITE_BREADTH_SIGNAL
 )

int compositeBreadthSignalLengthOpen = input.int(
     defval = 8,
     title = "Signal EMA Length (Open)",
     minval = 1,
     maxval = 50,
     step = 1,
     tooltip = "Shorter EMA period used at the session open when Adaptive Signal Length is ON. Default 8 on 2-min ≈ 16 minutes of memory — fast enough to pick up the morning commitment move without lagging into the first cycle reversal.",
     group = GROUP_COMPOSITE_BREADTH_SIGNAL
 )

bool compositeBreadthSignAwareConsensus = input.bool(
     defval = true,
     title = "Sign-aware Consensus",
     tooltip = "When ON, the consensus multiplier first checks how many active components share the sign of the mean. 3/3 sign-aligned components are \"same-team\" — magnitude differences are sensitivity, not disagreement — so the squeeze toward zero is relaxed (minimum 0.85). When only 2/3 or 1/3 agree, both the sign penalty and the stdev penalty stack. OFF reverts to the original stdev-only squeeze, which can over-suppress clean trending sessions where PCTABOVEVWAP lags VOLD/ADD in magnitude.",
     group = GROUP_COMPOSITE_BREADTH_SIGNAL
 )

// ─── TICK context (Barry-aligned) ─────────────────────────────────────────────
bool compositeBreadthTickNyseOnly = input.bool(
     defval = false,
     title = "Use NYSE TICK only (Barry's preference)",
     tooltip = "OFF (default): TICK routes to the market-matching feed — USI:TICK for S&P/Dow/Russell, USI:TICKQ for NASDAQ. ON: forces USI:TICK regardless of selected market. Barry Burns explicitly prefers NYSE TICK for all markets (quote: \"there is a tick index for the NASDAQ, and there's also a tick index for the Dow. I don't find them to be as reliable or as helpful. So I just use the tick no matter what I'm trading.\") — turn on if you want to follow his approach.",
     group = GROUP_COMPOSITE_BREADTH_TICK
 )

bool compositeBreadthTickShowExtremes = input.bool(
     defval = true,
     title = "Show TICK Extreme Markers",
     tooltip = "Plot a small NORD13 triangle on the composite line (same placement style as the HH/HL/LH/LL pivot circles) on the bar where smoothed TICK first reaches the configured extreme threshold (±800 default). Up-triangle = TICK extreme high, down-triangle = TICK extreme low. Per Barry's method: extremes signal exhaustion, NOT continuation — wait for the next cycle high/low on price after an extreme appears.",
     group = GROUP_COMPOSITE_BREADTH_TICK
 )

float compositeBreadthTickExtremeThreshold = input.float(
     defval = 800.0,
     title = "TICK Extreme Threshold",
     minval = 400.0,
     maxval = 1200.0,
     step = 25,
     tooltip = "Smoothed TICK threshold for extreme markers. Barry draws horizontal lines at ±1000 with audio alert at ±985 (just inside the extreme so you don't miss the trigger). Default 800 fires slightly earlier — adjust toward 985 for closer-to-extreme triggers.",
     group = GROUP_COMPOSITE_BREADTH_TICK
 )

float compositeBreadthTickExtremeOffset = input.float(
     defval = 4.0,
     title = "TICK Extreme Marker Offset",
     minval = 0.0,
     maxval = 30.0,
     step = 0.5,
     tooltip = "Y-axis distance above/below the composite line for the extreme triangles. 0 places the triangle directly on the line; default 4 clears the 4px-thick line so the shape isn't absorbed.",
     group = GROUP_COMPOSITE_BREADTH_TICK
 )

// ─── Pivot structure ──────────────────────────────────────────────────────────
bool compositeBreadthShowPivots = input.bool(
     defval = false,
     title = "Show Trend Structure Markers",
     tooltip = "Detect pivots on the smoothed composite line, classify each new pivot as HH/HL/LH/LL relative to the prior same-type pivot, and color by TREND STATE: NORD8 cyan in bull, NORD11 red in bear. State flips the moment the bullish sequence breaks — a fresh HH sets bull, an LH OR an LL sets bear. HL is treated as a non-event (a bounce in a downtrend, a continuation in an uptrend) — it does NOT reclaim bull from bear. This is asymmetric on purpose: the bullish sequence breaks the moment a high fails to extend (LH alone is enough), but reclaiming bull requires a fresh HH. HL only seeds initial bull if no classification has set state yet. Per-event alerts (HH/HL/LH/LL) still fire individually whether or not the markers are visible. Pivots confirm CBI_PIVOT_RIGHT_LEGS bar(s) after they form — minimum lag in Pine (a turning point can't be known without one bar to the right). Baselines and trend state reset at each session open. OFF by default to keep the composite line uncluttered.",
     group = GROUP_COMPOSITE_BREADTH_PIVOTS
 )

bool compositeBreadthPivotGateByConsensus = input.bool(
     defval = true,
     title = "Suppress Pivots When Consensus Low",
     tooltip = "When the four weighted components disagree, the consensus multiplier squeezes the composite line toward zero — which can manufacture pivots that aren't structural. Default ON suppresses pivot markers when consensus at the pivot bar was below 0.5. Turn off to see all pivots regardless of agreement.",
     group = GROUP_COMPOSITE_BREADTH_PIVOTS
 )

bool compositeBreadthPivotUseTolerance = input.bool(
     defval = true,
     title = "Pivot Tolerance Band",
     tooltip = "When ON, a new pivot must exceed the prior same-type pivot by more than CBI_PIVOT_EQUAL_TOLERANCE (1% of scale) to register as HH/LH/HL/LL. Pivots inside that tolerance band are non-events — neither HH nor LH (and neither HL nor LL) — and don't flip trend state. Stops flat consolidation re-tests from being tagged LH and instantly flipping bull→bear. OFF reverts to strict <= / >= comparison.",
     group = GROUP_COMPOSITE_BREADTH_PIVOTS
 )

float compositeBreadthPivotOffset = input.float(
     defval = 0.5,
     title = "Pivot Marker Offset",
     minval = 0.0,
     maxval = 30.0,
     step = 0.5,
     tooltip = "Y-axis distance for pivot circles: highs offset above the line, lows below. 0 places them directly on the composite line.",
     group = GROUP_COMPOSITE_BREADTH_PIVOTS
 )

int compositeBreadthPivotSize = input.int(
     defval = 5,
     title = "Pivot Marker Size",
     minval = 0,
     maxval = 10,
     step = 1,
     tooltip = "Pivot circle size in typographic points. 0 hides the marker; 5 is roughly size.tiny; 10 is small. Pine v6 accepts numeric size directly so the slider value is passed through as-is.",
     group = GROUP_COMPOSITE_BREADTH_PIVOTS
 )

// ─── Display ──────────────────────────────────────────────────────────────────
bool compositeBreadthShowSignalLine = input.bool(
     defval = true,
     title = "Signal Line",
     tooltip = "Smoothed reference line — EMA of the smoothed composite (fed from the same series that's plotted, so divergences read true). Composite above signal = upward momentum building; composite below signal = downward.",
     group = GROUP_COMPOSITE_BREADTH_DISPLAY
 )

bool compositeBreadthShowLine = input.bool(
     defval = true,
     title = "Composite Line",
     tooltip = "Primary directional indicator: the smoothed composite breadth score. Color saturates (NORD8 cyan up, NORD11 red down) with magnitude, dulls toward grey near zero. Blanks off-RTH (when the underlying breadth feeds aren't live) instead of freezing at the last RTH value — absence of a line communicates 'feed not active'.",
     group = GROUP_COMPOSITE_BREADTH_DISPLAY
 )

bool compositeBreadthShowStrip = input.bool(
     defval = false,
     title = "Component Strip",
     tooltip = "Five thin colored rows showing each component's directional confidence: VOLD (top), ADD, PCTABOVEVWAP, CUMTICK, TICK (bottom). The top four are the weighted components and their row heights are proportional to their weights — alignment = breadth speaking with one voice. TICK row is context-only (thinner + lighter intensity to read as secondary): it does NOT contribute to the composite math, only to the visual read. OFF by default so the composite line gets the full vertical height of the indicator panel — turn on when you want to verify which component is driving the composite.",
     group = GROUP_COMPOSITE_BREADTH_DISPLAY
 )

float compositeBreadthStripTopY = input.float(
     defval = -85,
     title = "Strip Position (Y)",
     minval = -120,
     maxval = -10,
     step = 5,
     tooltip = "Y-coordinate where the strip's top edge sits. Five rows (VOLD, ADD, PCTABOVEVWAP, CUMTICK, TICK context) extend downward from here, rows touching with no gap. Default −85 tucks the strip at the very bottom of the panel so the composite line gets the full ±100 height to breathe. Move closer to zero (e.g. −30) to put the strip nearer the composite, but the composite will visually compress as TradingView's auto-scaler extends the y-axis to include the strip footprint.",
     group = GROUP_COMPOSITE_BREADTH_DISPLAY
 )

float compositeBreadthStripRowHeight = input.float(
     defval = 3.0,
     title = "Strip Row Height",
     minval = 1.0,
     maxval = 10.0,
     step = 0.5,
     tooltip = "Y-axis unit anchoring the total strip span. The five rows together occupy 4 × this value (preserved from the legacy 4-row layout — adding CUMTICK didn't grow the strip). The four weighted rows split a portion proportional to their weights; the TICK context row is fixed at 60% of one legacy row. Default 3.0 → 12-unit total strip.",
     group = GROUP_COMPOSITE_BREADTH_DISPLAY
 )

bool compositeBreadthShowZeroLine = input.bool(
     defval = true,
     title = "Zero Line",
     tooltip = "Solid neutral guide at zero — the only fixed reference. Above zero = net bullish breadth, below = net bearish.",
     group = GROUP_COMPOSITE_BREADTH_DISPLAY
 )

bool compositeBreadthShowExtendedLevels = input.bool(
     defval = false,
     title = "Show Extended Levels (±60)",
     tooltip = "Dotted reference lines at ±CBI_EXTENDED_LEVEL (60 by default). Beyond visual saturation the composite would otherwise look identical from ±35 to ±100; the dotted lines mark the \"extended for this market\" zone — Barry's equivalent of his manually-drawn 30-day VOLD support/resistance levels. Breadth pushing past ±60 is an extended directional reading, not a normal-range one. OFF by default because the ±60 hlines pin TradingView's auto-scale to at least [−60, +60], which can compress the composite's actual swing. Turn on if you want fixed visual reference levels at the cost of some auto-scale flexibility.",
     group = GROUP_COMPOSITE_BREADTH_DISPLAY
 )

bool compositeBreadthShowSessionDivider = input.bool(
     defval = true,
     title = "Session Divider",
     tooltip = "Tint the first bar of each NYSE RTH session so day boundaries are obvious at a glance — without it, back-to-back sessions blur together and you can't tell where one day ends and the next begins. Anchored to the same any-feed session-open edge that resets the cumTick, pivot baselines, and feed-health counters, so the divider lands exactly where the indicator's state resets.",
     group = GROUP_COMPOSITE_BREADTH_DISPLAY
 )

// ═════════════════════════════════════════════════════════════════════════════
// 🔗 SYMBOL ROUTING
// ═════════════════════════════════════════════════════════════════════════════
string compositeBreadthAdvSymbol = switch compositeBreadthMarket
    "S&P 500"      => "USI:ADVN.NY"
    "NASDAQ 100"   => "USI:ADVN.NQ"
    "Dow Jones"    => "USI:ADVN.DJ"
    "Russell 2000" => "USI:ADVN.US"
    => "USI:ADVN.NY"

string compositeBreadthDeclSymbol = switch compositeBreadthMarket
    "S&P 500"      => "USI:DECL.NY"
    "NASDAQ 100"   => "USI:DECL.NQ"
    "Dow Jones"    => "USI:DECL.DJ"
    "Russell 2000" => "USI:DECL.US"
    => "USI:DECL.NY"

string compositeBreadthUpVolSymbol = switch compositeBreadthMarket
    "S&P 500"      => "USI:UPVOL.NY"
    "NASDAQ 100"   => "USI:UPVOL.NQ"
    "Dow Jones"    => "USI:UPVOL.DJ"
    "Russell 2000" => "USI:UPVOL.US"
    => "USI:UPVOL.NY"

string compositeBreadthDownVolSymbol = switch compositeBreadthMarket
    "S&P 500"      => "USI:DNVOL.NY"
    "NASDAQ 100"   => "USI:DNVOL.NQ"
    "Dow Jones"    => "USI:DNVOL.DJ"
    "Russell 2000" => "USI:DNVOL.US"
    => "USI:DNVOL.NY"

// PCTABOVEVWAP: .NY/.NQ/.DJ/.US all confirmed live on TradingView symbol
// pages. NDX uses .NQ (NASDAQ-100 specific intraday VWAP breadth) — earlier
// versions fell back to .US because .NQ was unverified at the time; this is
// now corrected and the routing is exchange-exact per instrument.
string compositeBreadthPctVwapSymbol = switch compositeBreadthMarket
    "S&P 500"      => "USI:PCTABOVEVWAP.NY"
    "NASDAQ 100"   => "USI:PCTABOVEVWAP.NQ"
    "Dow Jones"    => "USI:PCTABOVEVWAP.DJ"
    "Russell 2000" => "USI:PCTABOVEVWAP.US"
    => "USI:PCTABOVEVWAP.NY"

// TICK: TradingView's TICK feeds do NOT follow the .NY/.NQ/.US suffix convention
// used by ADVN/DECL/UPVOL/DNVOL/PCTABOVEVWAP. The real tickers are USI:TICK
// (NYSE) and USI:TICKQ (NASDAQ). There is no reliable per-exchange TICK feed
// for Dow Industrials or Russell — those fall back to NYSE TICK, which also
// matches Barry's explicit preference ("I just use the tick no matter what
// I'm trading"). Earlier versions used USI:TICK.NQ etc; with
// ignore_invalid_symbol = true those silently returned na and no extremes
// ever fired, which is why the triangles never plotted.
string compositeBreadthTickPerMarketSymbol = switch compositeBreadthMarket
    "S&P 500"      => "USI:TICK"
    "NASDAQ 100"   => "USI:TICKQ"
    "Dow Jones"    => "USI:TICK"
    "Russell 2000" => "USI:TICK"
    => "USI:TICK"

string compositeBreadthTickSymbol = compositeBreadthTickNyseOnly ?
     "USI:TICK" : compositeBreadthTickPerMarketSymbol

// ═════════════════════════════════════════════════════════════════════════════
// 📡 DATA REQUESTS
// ═════════════════════════════════════════════════════════════════════════════
// All breadth feeds use gaps_on so out-of-session bars come back as na rather
// than being forward-filled with the last RTH value. On a futures or extended-
// hours chart, gaps_off would keep plotting Friday's last RTH breadth all
// weekend; gaps_on lets the composite blank when the feeds aren't live (paired
// with explicit na-clearing of the display/signal state below). For TICK
// specifically, the session-reset detector also relies on a real na→value
// transition to reseed the EMA at each NYSE RTH open.
//
// lookahead = barmerge.lookahead_off is intentional and correct here, NOT an
// oversight against the repo's "use lookahead_on for real-time accuracy" note
// (that guidance applies to HIGHER-timeframe requests). Every request below
// uses timeframe = timeframe.period — the chart's own timeframe — so there is
// no higher-timeframe bar to look ahead into and lookahead has no effect on the
// returned series. lookahead_off is also the non-repainting default; flipping
// to lookahead_on with `close` would leak future data on HTF requests, so off
// stays the safe choice if these are ever pointed at a higher timeframe.
float compositeBreadthAdvValue = request.security(
     symbol = compositeBreadthAdvSymbol,
     timeframe = timeframe.period,
     expression = close,
     gaps = barmerge.gaps_on,
     lookahead = barmerge.lookahead_off,
     ignore_invalid_symbol = true
 )

float compositeBreadthDeclValue = request.security(
     symbol = compositeBreadthDeclSymbol,
     timeframe = timeframe.period,
     expression = close,
     gaps = barmerge.gaps_on,
     lookahead = barmerge.lookahead_off,
     ignore_invalid_symbol = true
 )

float compositeBreadthUpVolValue = request.security(
     symbol = compositeBreadthUpVolSymbol,
     timeframe = timeframe.period,
     expression = close,
     gaps = barmerge.gaps_on,
     lookahead = barmerge.lookahead_off,
     ignore_invalid_symbol = true
 )

float compositeBreadthDownVolValue = request.security(
     symbol = compositeBreadthDownVolSymbol,
     timeframe = timeframe.period,
     expression = close,
     gaps = barmerge.gaps_on,
     lookahead = barmerge.lookahead_off,
     ignore_invalid_symbol = true
 )

float compositeBreadthPctVwapValue = request.security(
     symbol = compositeBreadthPctVwapSymbol,
     timeframe = timeframe.period,
     expression = close,
     gaps = barmerge.gaps_on,
     lookahead = barmerge.lookahead_off,
     ignore_invalid_symbol = true
 )

float compositeBreadthTickValue = request.security(
     symbol = compositeBreadthTickSymbol,
     timeframe = timeframe.period,
     expression = close,
     gaps = barmerge.gaps_on,
     lookahead = barmerge.lookahead_off,
     ignore_invalid_symbol = true
 )

// ═════════════════════════════════════════════════════════════════════════════
// 🔔 SESSION DETECTION
// AnyFeedLive = at least one of the six breadth feeds is non-na this bar.
// SessionJustOpened = the first bar of a transition from "all feeds dark" to
// "at least one feed live" — used as the canonical session-open edge for ALL
// session-wide resets (pivot baselines, feed-health counters, cumTick).
// Independent of TICK specifically, so a missing TICK feed doesn't suppress
// session detection. The existing TICK-feed-only edge stays for TICK-EMA-
// specific resets that genuinely require TICK to be live.
//
// BarsSinceSessionOpen counts chart bars since the most recent session-open
// transition, increments only while at least one feed is live (so the
// off-RTH gap doesn't bloat the count). Used to gate cumTick slope
// computation against the cross-session lookback leak and to mature the
// feed-health warning even when TICK is the missing feed.
// ═════════════════════════════════════════════════════════════════════════════
bool compositeBreadthAnyFeedLive =
     not na(compositeBreadthTickValue)    or
     not na(compositeBreadthAdvValue)     or
     not na(compositeBreadthDeclValue)    or
     not na(compositeBreadthUpVolValue)   or
     not na(compositeBreadthDownVolValue) or
     not na(compositeBreadthPctVwapValue)

// Session-open edge is TIME-anchored, not feed-presence-anchored. The earlier
// "AnyFeedLive false→true" approach relied on a real off-session bar existing
// between sessions to create the na→value transition. That holds on futures /
// extended-hours charts (overnight bars come back na), but on an RTH-only chart
// there are NO dark bars between sessions: the bar before 09:30 is yesterday's
// 16:00, whose feeds were live, so AnyFeedLive[1] is true and the edge never
// fires — silently skipping the daily reset of cumTick, signal seed, pivot
// state, feed-health flags, and the session divider. Pinning to the NYSE RTH
// open window (09:30–09:35 ET, weekdays) fires reliably on BOTH chart types and
// decouples the reset from feed health — a session still opens at 09:30 even if
// a feed is dead, which is more correct than gating on whether data arrived.
bool compositeBreadthInRthOpen = not na(time(timeframe.period, "0930-0935:23456", "America/New_York"))
bool compositeBreadthSessionJustOpened = compositeBreadthInRthOpen and not compositeBreadthInRthOpen[1]

var int compositeBreadthBarsSinceSessionOpen = 0
if compositeBreadthSessionJustOpened
    compositeBreadthBarsSinceSessionOpen := 1
else if compositeBreadthAnyFeedLive
    compositeBreadthBarsSinceSessionOpen += 1

// ═════════════════════════════════════════════════════════════════════════════
// 🧮 HELPERS
// ═════════════════════════════════════════════════════════════════════════════
f_compositeBreadthClampedRatio(float numerator, float denominator) =>
    float compositeBreadthRatio = na
    if not na(numerator) and not na(denominator) and denominator > 0.0
        compositeBreadthRatio := math.max(-1.0, math.min(1.0, numerator / denominator))
    compositeBreadthRatio

f_compositeBreadthProgressiveColor(float value, float scale, int minTransp) =>
    color compositeBreadthResultColor = na
    if not na(value)
        // Two-stage gradient — NORD11 → NORD3 (neutral grey at zero) → NORD8 — produces
        // a continuous hue walk through neutral instead of the abrupt cyan↔red flip at
        // zero that previously left visible bright bars at color transitions.
        color compositeBreadthBaseColor = value >= 0.0 ?
             color.from_gradient(value = value, bottom_value = 0.0,    top_value = scale, bottom_color = NORD3,  top_color = NORD8) :
             color.from_gradient(value = value, bottom_value = -scale, top_value = 0.0,   bottom_color = NORD11, top_color = NORD3)
        // Magnitude-based transparency: faded near zero, vivid at |value| ≥ scale.
        float compositeBreadthMagnitude = math.min(1.0, math.abs(number = value) / scale)
        int compositeBreadthTransparency = int(minTransp - minTransp * compositeBreadthMagnitude)
        compositeBreadthResultColor := color.new(color = compositeBreadthBaseColor, transp = compositeBreadthTransparency)
    compositeBreadthResultColor

// ═════════════════════════════════════════════════════════════════════════════
// 🎯 PER-COMPONENT CONFIDENCE
// VOLD, ADD, PCTABOVEVWAP feed the weighted composite. TICK is computed for the
// context strip + extreme markers only — NOT included in the weighted sum.
// ═════════════════════════════════════════════════════════════════════════════
float compositeBreadthVoldDelta = not na(compositeBreadthUpVolValue) and not na(compositeBreadthDownVolValue) ?
     compositeBreadthUpVolValue - compositeBreadthDownVolValue : na
float compositeBreadthVoldTotal = not na(compositeBreadthUpVolValue) and not na(compositeBreadthDownVolValue) ?
     compositeBreadthUpVolValue + compositeBreadthDownVolValue : na
float compositeBreadthVoldConfidence = f_compositeBreadthClampedRatio(
     numerator = compositeBreadthVoldDelta,
     denominator = compositeBreadthVoldTotal
 )

float compositeBreadthAddDelta = not na(compositeBreadthAdvValue) and not na(compositeBreadthDeclValue) ?
     compositeBreadthAdvValue - compositeBreadthDeclValue : na
float compositeBreadthAddTotal = not na(compositeBreadthAdvValue) and not na(compositeBreadthDeclValue) ?
     compositeBreadthAdvValue + compositeBreadthDeclValue : na
float compositeBreadthAddConfidence = f_compositeBreadthClampedRatio(
     numerator = compositeBreadthAddDelta,
     denominator = compositeBreadthAddTotal
 )

// PCTABOVEVWAP is published as a 0..100 percentage. Center on 50 (true neutral
// positioning) and map to the same -1..+1 confidence scale as VOLD/ADD — but
// using a TIGHTER ±25 band rather than the full ±50 range. In live US sessions
// PCTABOVEVWAP almost never leaves ~25..75 — a 70 reading is a strong bull day
// on the tape, not a "0.4 confidence" half-signal. The full-range divisor of
// 50 structurally under-contributed PCTABOVEVWAP to the weighted composite even
// at its real-world extremes. Mapping (pct − 50) / 25 means 75 = +1 (full
// bullish), 25 = −1 (full bearish), and anything past clamps to ±1. The 20%
// weight then actually delivers a 20% influence rather than a 10% one.
float compositeBreadthPctVwapConfidence = not na(compositeBreadthPctVwapValue) ?
     math.max(-1.0, math.min(1.0, (compositeBreadthPctVwapValue - 50.0) / 25.0)) : na

// TICK smoothing — session-resetting EMA. Confidence used for the strip color
// and extreme detection only (not the composite math).
//
// Session-start detection uses the TICK feed's own data presence (na → value)
// rather than the chart symbol's session.ismarket. On a futures chart (ES/NQ,
// near-24h session), session.ismarket would fire at globex open while TICK
// only has data during NYSE RTH — the reset would happen on the wrong bar.
// Using "TICK first appears after na" anchors the reset to NYSE RTH regardless
// of chart symbol.
var float compositeBreadthTickSmoothed = na
bool compositeBreadthTickFeedJustOpened = not na(compositeBreadthTickValue) and na(compositeBreadthTickValue[1])
if na(compositeBreadthTickValue)
    // Out-of-session: clear the smoothed value so the strip goes dark, the
    // TICK confidence reads as na, and the rising-edge logic on extreme
    // detection sees a real "false" during the gap. Without this, a session
    // that ended at an extreme would keep extremeUp = true through the gap
    // and suppress a same-direction extreme marker at the next session open.
    compositeBreadthTickSmoothed := na
else
    float compositeBreadthTickAlpha = 2.0 / (CBI_TICK_SMOOTH_LENGTH + 1.0)
    compositeBreadthTickSmoothed := compositeBreadthTickFeedJustOpened or na(compositeBreadthTickSmoothed) ? compositeBreadthTickValue :
         compositeBreadthTickAlpha * compositeBreadthTickValue + (1.0 - compositeBreadthTickAlpha) * compositeBreadthTickSmoothed

float compositeBreadthTickConfidence = not na(compositeBreadthTickSmoothed) ?
     math.max(-1.0, math.min(1.0, compositeBreadthTickSmoothed / CBI_TICK_FIXED_SCALE)) : na

// CUMTICK (cumulative session TICK, slope-normalized)
// Sum of raw TICK across the session, reset at compositeBreadthSessionJustOpened
// (any-feed session-open edge — broader than TICK-only so cumTick resets even
// if TICK comes online slightly later than the other feeds). The LEVEL of
// CUMTICK grows with session length, so it's not directly comparable across
// bars; the SLOPE (CBI_CUMTICK_SLOPE_WINDOW-bar rate of change, default 5
// bars = 10 min on 2-min) is what carries the signal: positive slope =
// breadth strengthening on the bid right now, negative = weakening.
// Normalize slope by CBI_CUMTICK_SLOPE_SCALE so confidence saturates at ±1
// when raw TICK has averaged ±500 across the slope window — a strong
// directional regime.
//
// Cross-session leak guard: the slope lookback compositeBreadthCumTickValue[
// CBI_CUMTICK_SLOPE_WINDOW] would otherwise reach back across the off-RTH
// gap into the PRIOR session's accumulated value, making the first ~5 bars
// of every new session register a bogus full-magnitude slope (this-session
// reset value minus yesterday's huge cumulative). The slope is therefore
// gated on compositeBreadthBarsSinceSessionOpen > CBI_CUMTICK_SLOPE_WINDOW —
// only computed when the entire lookback window is provably in-session.
//
// This is the divergence-grade breadth series. Raw TICK is too jagged to
// spot pivot-style turns; PCTABOVEVWAP plateaus mid-session. CUMTICK slope
// captures the inflections that price reversals actually pivot against.
var float compositeBreadthCumTickValue = na
if compositeBreadthSessionJustOpened or na(compositeBreadthCumTickValue)
    compositeBreadthCumTickValue := compositeBreadthTickValue
else if not na(compositeBreadthTickValue)
    compositeBreadthCumTickValue := compositeBreadthCumTickValue + compositeBreadthTickValue
// When TICK is na (off-RTH gap), leave cumTick at its last value — the next
// session-open edge will reseed it via compositeBreadthSessionJustOpened.

bool compositeBreadthCumTickSlopeReady = compositeBreadthBarsSinceSessionOpen > CBI_CUMTICK_SLOPE_WINDOW and
     not na(compositeBreadthCumTickValue) and not na(compositeBreadthCumTickValue[CBI_CUMTICK_SLOPE_WINDOW])
float compositeBreadthCumTickSlope = compositeBreadthCumTickSlopeReady ?
     compositeBreadthCumTickValue - compositeBreadthCumTickValue[CBI_CUMTICK_SLOPE_WINDOW] : na

float compositeBreadthCumTickConfidence = not na(compositeBreadthCumTickSlope) ?
     math.max(-1.0, math.min(1.0, compositeBreadthCumTickSlope / CBI_CUMTICK_SLOPE_SCALE)) : na

// ═════════════════════════════════════════════════════════════════════════════
// 🩺 FEED HEALTH MONITORING
// All six request.security calls use ignore_invalid_symbol = true so an
// invalid feed silently returns na — the composite would then run with
// degraded inputs and no obvious signal that something is wrong. Track each
// feed's "ever delivered in current session" state, emit a one-time
// log.warning after a grace window if any feed is still missing, and render
// a status badge on the last bar listing the unhealthy feeds.
//
// All counters and reset edges are tied to compositeBreadthSessionJustOpened
// (any-feed session-open edge) rather than the TICK-only edge. Earlier
// versions used compositeBreadthTickFeedJustOpened as the anchor, but that
// meant a missing TICK feed would prevent BOTH the counter from incrementing
// AND the warning path from ever maturing — the badge would show TICK as
// missing but nothing else would ever fire. Using the broader edge fixes
// that: any feed coming online opens the session for health-tracking
// purposes, and a perpetually-missing TICK is just one more entry in the
// missing-feeds list, not a circuit-breaker.
// ═════════════════════════════════════════════════════════════════════════════
var bool compositeBreadthAdvFeedLive        = false
var bool compositeBreadthDeclFeedLive       = false
var bool compositeBreadthUpVolFeedLive      = false
var bool compositeBreadthDownVolFeedLive    = false
var bool compositeBreadthPctVwapFeedLive    = false
var bool compositeBreadthTickFeedLive       = false
var bool compositeBreadthFeedWarningEmitted = false

if compositeBreadthSessionJustOpened
    compositeBreadthAdvFeedLive        := false
    compositeBreadthDeclFeedLive       := false
    compositeBreadthUpVolFeedLive      := false
    compositeBreadthDownVolFeedLive    := false
    compositeBreadthPctVwapFeedLive    := false
    compositeBreadthTickFeedLive       := false
    compositeBreadthFeedWarningEmitted := false

if not na(compositeBreadthTickValue)
    compositeBreadthTickFeedLive       := true
if not na(compositeBreadthAdvValue)
    compositeBreadthAdvFeedLive        := true
if not na(compositeBreadthDeclValue)
    compositeBreadthDeclFeedLive       := true
if not na(compositeBreadthUpVolValue)
    compositeBreadthUpVolFeedLive      := true
if not na(compositeBreadthDownVolValue)
    compositeBreadthDownVolFeedLive    := true
if not na(compositeBreadthPctVwapValue)
    compositeBreadthPctVwapFeedLive    := true

// Build the list of missing feeds (label-rendering and log-warning use the
// same source of truth).
string compositeBreadthMissingFeedsText = ""
if not compositeBreadthAdvFeedLive
    compositeBreadthMissingFeedsText := compositeBreadthMissingFeedsText + "ADVN "
if not compositeBreadthDeclFeedLive
    compositeBreadthMissingFeedsText := compositeBreadthMissingFeedsText + "DECL "
if not compositeBreadthUpVolFeedLive
    compositeBreadthMissingFeedsText := compositeBreadthMissingFeedsText + "UPVOL "
if not compositeBreadthDownVolFeedLive
    compositeBreadthMissingFeedsText := compositeBreadthMissingFeedsText + "DNVOL "
if not compositeBreadthPctVwapFeedLive
    compositeBreadthMissingFeedsText := compositeBreadthMissingFeedsText + "PCTVWAP "
if not compositeBreadthTickFeedLive
    compositeBreadthMissingFeedsText := compositeBreadthMissingFeedsText + "TICK "

// Emit a one-time log.warning per session once we're past the grace window.
// Pine v6 routes this to the Pine logs panel (View → Pine Logs) so the user
// can see which feed(s) failed without checking the chart. Uses
// compositeBreadthBarsSinceSessionOpen (independent of TICK) so a missing
// TICK feed doesn't suppress the warning.
// Gated to barstate.isrealtime: this is a LIVE health check, not a backtest
// signal. The emitted-flag resets every session, so without this
// guard a multi-day historical load would fire one warning per historical
// session with a missing feed and flood the Pine Logs panel on every load.
if barstate.isrealtime and compositeBreadthBarsSinceSessionOpen >= CBI_FEED_HEALTH_GRACE_BARS and not compositeBreadthFeedWarningEmitted and str.length(compositeBreadthMissingFeedsText) > 0
    log.warning("CBI: feed(s) not delivering after " + str.tostring(value = CBI_FEED_HEALTH_GRACE_BARS) + " bars post-open — " + compositeBreadthMissingFeedsText + "(market = " + compositeBreadthMarket + ")")
    compositeBreadthFeedWarningEmitted := true

// ═════════════════════════════════════════════════════════════════════════════
// 🧬 COMPOSITE SCORE
// Weighted sum × consensus multiplier × CBI_SCALE_MAX, using FOUR weighted
// components: VOLD, ADD, PCTABOVEVWAP, CUMTICK. Consensus measures cross-
// component agreement: when the four move together, the line is allowed to
// reach its full magnitude; when they disagree, it's squeezed toward zero
// (the line and the strip together then read "uncertain breadth", not
// "neutral breadth"). Raw TICK confidence is NOT a weighted component — it
// only drives the context strip color and the extreme triangle markers.
// ═════════════════════════════════════════════════════════════════════════════
// A component is "active" only when both its data is present AND its weight is
// non-zero. Setting a weight to 0 must fully remove that component from BOTH
// the directional weighted sum AND the consensus calculation — otherwise a
// disabled component's disagreement still squeezes the composite toward zero.
bool compositeBreadthVoldActive    = not na(compositeBreadthVoldConfidence)    and compositeBreadthVoldWeight    > 0.0
bool compositeBreadthAddActive     = not na(compositeBreadthAddConfidence)     and compositeBreadthAddWeight     > 0.0
bool compositeBreadthPctVwapActive = not na(compositeBreadthPctVwapConfidence) and compositeBreadthPctVwapWeight > 0.0
bool compositeBreadthCumTickActive = not na(compositeBreadthCumTickConfidence) and compositeBreadthCumTickWeight > 0.0

int compositeBreadthActiveCount = (compositeBreadthVoldActive ? 1 : 0) +
     (compositeBreadthAddActive     ? 1 : 0) +
     (compositeBreadthPctVwapActive ? 1 : 0) +
     (compositeBreadthCumTickActive ? 1 : 0)

float compositeBreadthWeightedSum = 0.0
float compositeBreadthWeightTotal = 0.0
if compositeBreadthVoldActive
    compositeBreadthWeightedSum += compositeBreadthVoldWeight * compositeBreadthVoldConfidence
    compositeBreadthWeightTotal += compositeBreadthVoldWeight
if compositeBreadthAddActive
    compositeBreadthWeightedSum += compositeBreadthAddWeight * compositeBreadthAddConfidence
    compositeBreadthWeightTotal += compositeBreadthAddWeight
if compositeBreadthPctVwapActive
    compositeBreadthWeightedSum += compositeBreadthPctVwapWeight * compositeBreadthPctVwapConfidence
    compositeBreadthWeightTotal += compositeBreadthPctVwapWeight
if compositeBreadthCumTickActive
    compositeBreadthWeightedSum += compositeBreadthCumTickWeight * compositeBreadthCumTickConfidence
    compositeBreadthWeightTotal += compositeBreadthCumTickWeight

float compositeBreadthDirectional = compositeBreadthWeightTotal > 0.0 ?
     compositeBreadthWeightedSum / compositeBreadthWeightTotal : na

float compositeBreadthConfidenceSum = (compositeBreadthVoldActive    ? compositeBreadthVoldConfidence    : 0.0) +
     (compositeBreadthAddActive     ? compositeBreadthAddConfidence     : 0.0) +
     (compositeBreadthPctVwapActive ? compositeBreadthPctVwapConfidence : 0.0) +
     (compositeBreadthCumTickActive ? compositeBreadthCumTickConfidence : 0.0)
float compositeBreadthMeanConfidence = compositeBreadthActiveCount > 0 ?
     compositeBreadthConfidenceSum / compositeBreadthActiveCount : 0.0
float compositeBreadthDeviationSumSquared = (compositeBreadthVoldActive    ? math.pow(base = compositeBreadthVoldConfidence    - compositeBreadthMeanConfidence, exponent = 2) : 0.0) +
     (compositeBreadthAddActive     ? math.pow(base = compositeBreadthAddConfidence     - compositeBreadthMeanConfidence, exponent = 2) : 0.0) +
     (compositeBreadthPctVwapActive ? math.pow(base = compositeBreadthPctVwapConfidence - compositeBreadthMeanConfidence, exponent = 2) : 0.0) +
     (compositeBreadthCumTickActive ? math.pow(base = compositeBreadthCumTickConfidence - compositeBreadthMeanConfidence, exponent = 2) : 0.0)
float compositeBreadthStdevConfidence = compositeBreadthActiveCount > 0 ?
     math.sqrt(number = compositeBreadthDeviationSumSquared / compositeBreadthActiveCount) : 0.0
// Max stdev varies by active count: 3 active = sqrt(8/9) ≈ 0.9428 (two at +1,
// one at -1 or vice versa); 2 and 4 active both max at 1.0 (perfect split).
// 1 or 0 active falls through to the consensus = 1.0 fast-path below.
float compositeBreadthMaxStdev = compositeBreadthActiveCount == 3 ? CBI_THREE_WAY_MAX_STDEV : 1.0
float compositeBreadthMagnitudeConsensus = math.max(0.0, 1.0 - compositeBreadthStdevConfidence / compositeBreadthMaxStdev)

// Sign-aware consensus. The original stdev-only squeeze can over-suppress clean
// trending sessions where PCTABOVEVWAP migrates more slowly than VOLD/ADD —
// even though all components point the same direction. The fix splits
// agreement into two questions: (1) team — how many components share the sign
// of the mean? (2) magnitude — within the team, how tightly do they cluster?
//
// When all components share sign (full team agreement: 3/3 or 4/4), the line
// expresses its directional value — we floor the consensus at 0.85 even if
// magnitudes disagree, because magnitude divergence in the same direction is
// sensitivity, not disagreement.
//
// At ~2/3 or 3/4 agreement (ratio ≥ 0.666), the sign penalty (0.7×) and the
// magnitude penalty stack — there's a real dissenter and the line should
// squeeze. At ~half (ratio ≥ 0.333), full squeeze (0.3×). Below that, the
// components are fighting (0.1×) — "uncertain breadth" is the right read.
bool compositeBreadthMeanIsPositive = compositeBreadthMeanConfidence >= 0.0
int compositeBreadthSignAlignedCount =
     (compositeBreadthVoldActive    and ((compositeBreadthVoldConfidence    >= 0.0) == compositeBreadthMeanIsPositive) ? 1 : 0) +
     (compositeBreadthAddActive     and ((compositeBreadthAddConfidence     >= 0.0) == compositeBreadthMeanIsPositive) ? 1 : 0) +
     (compositeBreadthPctVwapActive and ((compositeBreadthPctVwapConfidence >= 0.0) == compositeBreadthMeanIsPositive) ? 1 : 0) +
     (compositeBreadthCumTickActive and ((compositeBreadthCumTickConfidence >= 0.0) == compositeBreadthMeanIsPositive) ? 1 : 0)
float compositeBreadthSignAlignmentRatio = compositeBreadthActiveCount > 0 ?
     compositeBreadthSignAlignedCount / float(compositeBreadthActiveCount) : 1.0
float compositeBreadthSignFactor = compositeBreadthSignAlignmentRatio >= 0.999 ? 1.0 :
     compositeBreadthSignAlignmentRatio >= 0.666 ? 0.7 :
     compositeBreadthSignAlignmentRatio >= 0.333 ? 0.3 : 0.1

float compositeBreadthConsensus = 1.0
if compositeBreadthActiveCount > 1
    if compositeBreadthSignAwareConsensus
        if compositeBreadthSignAlignmentRatio >= 0.999
            compositeBreadthConsensus := math.max(0.85, compositeBreadthMagnitudeConsensus)
        else
            compositeBreadthConsensus := compositeBreadthSignFactor * compositeBreadthMagnitudeConsensus
    else
        compositeBreadthConsensus := compositeBreadthMagnitudeConsensus

float compositeBreadthLineValue = na(compositeBreadthDirectional) ? na :
     compositeBreadthDirectional * compositeBreadthConsensus * CBI_SCALE_MAX

// ═════════════════════════════════════════════════════════════════════════════
// 🌊 DISPLAY + SIGNAL EMA
// Display EMA is short (3) and tames per-bar jitter so the visible HH/HL/LH/LL
// pivot structure reads cleanly. The signal EMA is fed FROM the display line
// (not from the raw composite) so the visible composite-vs-signal relationship
// is internally consistent — divergences read true rather than reflecting two
// different lag profiles.
//
// Both lines blank to na when the upstream composite is unavailable (paired
// with gaps_on on the breadth feeds). Without the else branches, the var would
// freeze at the last RTH value and the plot would draw a stale flat line
// across overnight/weekend bars. The signal warmup counter resets on the same
// edge so the seed re-runs cleanly at the next session open instead of
// snapping from last Friday's smoothed value to Monday's first bar.
// ═════════════════════════════════════════════════════════════════════════════
var float compositeBreadthDisplayLine = na
if not na(compositeBreadthLineValue)
    float compositeBreadthDisplayAlpha = 2.0 / (CBI_DISPLAY_SMOOTH_LENGTH + 1.0)
    compositeBreadthDisplayLine := na(compositeBreadthDisplayLine) ? compositeBreadthLineValue :
         compositeBreadthDisplayAlpha * compositeBreadthLineValue + (1.0 - compositeBreadthDisplayAlpha) * compositeBreadthDisplayLine
else
    compositeBreadthDisplayLine := na

// Adaptive signal length: while bars-since-open ≤ CBI_ADAPTIVE_SIGNAL_BARS (and
// the adaptive toggle is on), use the shorter compositeBreadthSignalLengthOpen
// so the line picks up the morning commitment move quickly. After the
// transition bar it uses the main compositeBreadthSignalLength for a smoother
// midday/afternoon read. Same EMA series throughout — the alpha just changes,
// so the transition is a brief one-bar adjustment rather than a discontinuity.
var float compositeBreadthSignalLineValue = na
var int compositeBreadthSignalSeedCount = 0
if not na(compositeBreadthDisplayLine)
    compositeBreadthSignalSeedCount += 1
    if compositeBreadthSignalSeedCount > CBI_SIGNAL_WARMUP_BARS
        int compositeBreadthEffectiveSignalLength = compositeBreadthAdaptiveSignal and compositeBreadthSignalSeedCount <= CBI_ADAPTIVE_SIGNAL_BARS ?
             compositeBreadthSignalLengthOpen : compositeBreadthSignalLength
        float compositeBreadthSignalAlpha = 2.0 / (compositeBreadthEffectiveSignalLength + 1.0)
        compositeBreadthSignalLineValue := na(compositeBreadthSignalLineValue) ? compositeBreadthDisplayLine :
             compositeBreadthSignalAlpha * compositeBreadthDisplayLine + (1.0 - compositeBreadthSignalAlpha) * compositeBreadthSignalLineValue
else
    compositeBreadthSignalLineValue := na
    compositeBreadthSignalSeedCount := 0

// ═════════════════════════════════════════════════════════════════════════════
// ⚡ TICK EXTREMES (Barry's method)
// Barry treats ±1000 as exhaustion zones — extremes signal that the current
// move is overextended, NOT that it will continue. After an extreme appears,
// his workflow is to wait for the next cycle high/low on the price chart.
// Rising-edge bools below feed the visual triangle marker only.
// ═════════════════════════════════════════════════════════════════════════════
bool compositeBreadthTickExtremeUp   = not na(compositeBreadthTickSmoothed) and compositeBreadthTickSmoothed >=  compositeBreadthTickExtremeThreshold
bool compositeBreadthTickExtremeDown = not na(compositeBreadthTickSmoothed) and compositeBreadthTickSmoothed <= -compositeBreadthTickExtremeThreshold

// Rising-edge detection is decoupled from the actual plot fire so a TICK
// extreme that lands on a bar with na displayLine (rare: TICK is live but
// all four weighted breadth feeds gapped simultaneously) doesn't get
// consumed silently. The edge arms a pending flag; the marker fires on
// the first subsequent bar where displayLine is valid. Pending is cleared
// at the next session open so a stale arm from yesterday can't fire today.
bool compositeBreadthTickExtremeUpEdge   = compositeBreadthTickExtremeUp   and not compositeBreadthTickExtremeUp[1]
bool compositeBreadthTickExtremeDownEdge = compositeBreadthTickExtremeDown and not compositeBreadthTickExtremeDown[1]

var bool compositeBreadthTickExtremeUpPending   = false
var bool compositeBreadthTickExtremeDownPending = false

if compositeBreadthTickFeedJustOpened
    compositeBreadthTickExtremeUpPending   := false
    compositeBreadthTickExtremeDownPending := false

if compositeBreadthTickExtremeUpEdge
    compositeBreadthTickExtremeUpPending := true
if compositeBreadthTickExtremeDownEdge
    compositeBreadthTickExtremeDownPending := true

bool compositeBreadthTickExtremeUpNew   = compositeBreadthTickExtremeUpPending   and not na(compositeBreadthDisplayLine)
bool compositeBreadthTickExtremeDownNew = compositeBreadthTickExtremeDownPending and not na(compositeBreadthDisplayLine)

if compositeBreadthTickExtremeUpNew
    compositeBreadthTickExtremeUpPending := false
if compositeBreadthTickExtremeDownNew
    compositeBreadthTickExtremeDownPending := false

// ═════════════════════════════════════════════════════════════════════════════
// 🪜 PIVOT STRUCTURE (HH / HL / LH / LL)
// Detect pivots on the smoothed composite line and classify each new pivot
// against the prior same-type pivot. Asymmetric legs (LEFT=noise filter,
// RIGHT=confirmation lag) — markers appear RIGHT_LEGS bars after the pivot
// forms, which is the minimum lag Pine permits (a turning point can't be
// known without at least one bar to the right). Color is by TREND STATE: a
// fresh HH sets bull (cyan), an LH OR an LL sets bear (red), an HL is a
// non-event for state (continuation/bounce). The bullish sequence breaks the
// moment a high fails to extend, so an LH alone is enough — reclaiming bull
// then requires a fresh HH. Optional consensus gating uses the consensus
// value AT THE PIVOT BAR (not now) to decide whether to show the marker, so
// disagreement-driven artifacts are suppressed without retroactively hiding
// real structure when consensus recovers later.
// ═════════════════════════════════════════════════════════════════════════════
float compositeBreadthPivotHighValue = ta.pivothigh(source = compositeBreadthDisplayLine, leftbars = CBI_PIVOT_LEFT_LEGS, rightbars = CBI_PIVOT_RIGHT_LEGS)
float compositeBreadthPivotLowValue  = ta.pivotlow (source = compositeBreadthDisplayLine, leftbars = CBI_PIVOT_LEFT_LEGS, rightbars = CBI_PIVOT_RIGHT_LEGS)

// Consensus AT the pivot bar (RIGHT_LEGS bars ago) — not current consensus.
// Evaluated BEFORE the last-pivot baseline updates so a suppressed pivot can't
// become the comparison baseline for the next one (which would corrupt the
// HH/LH/HL/LL classification visible to the trader).
float compositeBreadthConsensusAtPivot = compositeBreadthConsensus[CBI_PIVOT_RIGHT_LEGS]
bool compositeBreadthPivotAllowed = not compositeBreadthPivotGateByConsensus or
     (not na(compositeBreadthConsensusAtPivot) and compositeBreadthConsensusAtPivot >= CBI_PIVOT_CONSENSUS_GATE)

// Tolerance band — pivots within ±CBI_PIVOT_EQUAL_TOLERANCE percent of
// CBI_SCALE_MAX of the prior same-type pivot are non-events. Stops flat
// consolidation re-tests from being tagged LH (and instantly flipping bull→bear)
// just because the value happened to equal or fractionally undercut the prior
// pivot. When the toggle is off, falls back to the legacy strict-comparison
// behaviour with tolerance = 0.
float compositeBreadthPivotTolerance = compositeBreadthPivotUseTolerance ?
     CBI_PIVOT_EQUAL_TOLERANCE / 100.0 * CBI_SCALE_MAX : 0.0

var float compositeBreadthLastPivotHigh = na
var float compositeBreadthLastPivotLow  = na
var int   compositeBreadthTrendState    = 0
var label compositeBreadthLastHighLabel = na
var label compositeBreadthLastLowLabel  = na
var int   compositeBreadthLastPivotType = 0   // 1 = last rendered pivot was a high, -1 = low, 0 = none yet

// Session-open reset — pivot baselines, trend state, and the alternation
// tracker are intraday-only. Anchored to compositeBreadthSessionJustOpened
// (any-feed
// first non-na bar at NYSE RTH open) rather than the displayLine na->value
// edge. The displayLine can blank mid-session if all four weighted breadth
// feeds gap on the same bar (rare but possible during a USI outage); using
// that edge would falsely wipe pivot history on every such hiccup. The
// session-open edge is a clean US-RTH boundary regardless of chart symbol
// or which specific feeds are live. Label refs are intentionally NOT
// cleared here; yesterday's pivot markers stay visible as historical
// context.
if compositeBreadthSessionJustOpened
    compositeBreadthLastPivotHigh := na
    compositeBreadthLastPivotLow  := na
    compositeBreadthTrendState    := 0
    compositeBreadthLastPivotType := 0

bool compositeBreadthIsHH = false
bool compositeBreadthIsLH = false
bool compositeBreadthIsHL = false
bool compositeBreadthIsLL = false

// Gate pivot processing on barstate.isconfirmed so realtime intrabar ticks
// can't fire the pivot block before the confirmation bar has closed. Without
// this, ta.pivothigh / ta.pivotlow can return a value early in the
// confirmation bar that the bar's eventual final high/low then invalidates —
// causing the pivot label and alert to print and then repaint. The gate
// adds at most one bar of cosmetic lag in realtime (historical bars are
// always confirmed) and makes the indicator behave identically to its
// "once per bar close" alert-config counterpart.
if not na(compositeBreadthPivotHighValue) and barstate.isconfirmed
    if not na(compositeBreadthLastPivotHigh)
        float compositeBreadthHighDelta = compositeBreadthPivotHighValue - compositeBreadthLastPivotHigh
        compositeBreadthIsHH := compositeBreadthHighDelta >  compositeBreadthPivotTolerance
        compositeBreadthIsLH := compositeBreadthHighDelta < -compositeBreadthPivotTolerance
    // Only accept the pivot as the new baseline when (a) the consensus gate
    // passes AND (b) the pivot is either the FIRST pivot of the session
    // (nothing to compare against) or has been CLASSIFIED as HH/LH (outside
    // the tolerance band). Within-tolerance pivots must NOT become the new
    // baseline — if they did, repeated within-tolerance pivots would silently
    // drift the baseline through the tolerance band and slow trends would
    // never classify as structure. Suppressed (low-consensus) pivots are
    // also treated as if they didn't happen, preserving structural continuity.
    bool compositeBreadthHighIsFirstPivot = na(compositeBreadthLastPivotHigh)
    bool compositeBreadthHighIsClassified = compositeBreadthIsHH or compositeBreadthIsLH
    if compositeBreadthPivotAllowed and (compositeBreadthHighIsFirstPivot or compositeBreadthHighIsClassified)
        compositeBreadthLastPivotHigh := compositeBreadthPivotHighValue

if not na(compositeBreadthPivotLowValue) and barstate.isconfirmed
    if not na(compositeBreadthLastPivotLow)
        float compositeBreadthLowDelta = compositeBreadthPivotLowValue - compositeBreadthLastPivotLow
        compositeBreadthIsHL := compositeBreadthLowDelta >  compositeBreadthPivotTolerance
        compositeBreadthIsLL := compositeBreadthLowDelta < -compositeBreadthPivotTolerance
    bool compositeBreadthLowIsFirstPivot = na(compositeBreadthLastPivotLow)
    bool compositeBreadthLowIsClassified = compositeBreadthIsHL or compositeBreadthIsLL
    if compositeBreadthPivotAllowed and (compositeBreadthLowIsFirstPivot or compositeBreadthLowIsClassified)
        compositeBreadthLastPivotLow := compositeBreadthPivotLowValue

// Trend state — the "bullish sequence is broken" rule. Bull state requires a
// fresh HH (the strong continuation/reclamation signal). Bear state can be
// entered by either LH (weakness — bullish structure failed to extend) or LL
// (decisive break). HL is treated as a non-event for state: it's a bounce in
// a downtrend (doesn't reclaim bull) and a continuation in an uptrend
// (doesn't flip bull). HL only seeds an initial bull state when no prior
// classification has set one yet — that prevents the very first low pivot of
// a session, classified as HL against the running pivot baseline, from
// staying uncolored.
//
// Soft-warn HL counter: while bear state is active, count consecutive HL
// pivots (each higher low is a structural improvement). After
// Gated on barstate.isconfirmed — without the gate, the isHH/isLH/HL/LL bools
// could be true mid-bar from a pre-confirmation pivot, flipping the trend
// state and then un-flipping when the bar's final extremes invalidate the
// pivot. Confined to the confirmed-bar path so state transitions are
// monotonic and non-repainting.
if compositeBreadthPivotAllowed and barstate.isconfirmed
    if compositeBreadthIsHH
        compositeBreadthTrendState := 1
    else if compositeBreadthIsLH or compositeBreadthIsLL
        compositeBreadthTrendState := -1
    else if compositeBreadthIsHL and compositeBreadthTrendState == 0
        compositeBreadthTrendState := 1

alertcondition(condition = compositeBreadthIsHH and compositeBreadthPivotAllowed, title = "Composite HH", message = "Composite breadth made a higher high — bullish continuation structure.")
alertcondition(condition = compositeBreadthIsLH and compositeBreadthPivotAllowed, title = "Composite LH", message = "Composite breadth made a lower high — bullish structure broken, watch for confirmation.")
alertcondition(condition = compositeBreadthIsHL and compositeBreadthPivotAllowed, title = "Composite HL", message = "Composite breadth made a higher low — bullish retrace held.")
alertcondition(condition = compositeBreadthIsLL and compositeBreadthPivotAllowed, title = "Composite LL", message = "Composite breadth made a lower low — bearish confirmation.")

// ═════════════════════════════════════════════════════════════════════════════
// 🎨 COLORS + STRIP COORDINATES
// ═════════════════════════════════════════════════════════════════════════════
color compositeBreadthLineColor = f_compositeBreadthProgressiveColor(
     value = compositeBreadthDisplayLine,
     scale = CBI_OPACITY_ANCHOR,
     minTransp = CBI_SIGNAL_MIN_TRANSP
 )

color compositeBreadthVoldStripColor = f_compositeBreadthProgressiveColor(
     value = compositeBreadthVoldConfidence,
     scale = CBI_STRIP_OPACITY_ANCHOR,
     minTransp = CBI_STRIP_MIN_TRANSP
 )

color compositeBreadthAddStripColor = f_compositeBreadthProgressiveColor(
     value = compositeBreadthAddConfidence,
     scale = CBI_STRIP_OPACITY_ANCHOR,
     minTransp = CBI_STRIP_MIN_TRANSP
 )

color compositeBreadthPctVwapStripColor = f_compositeBreadthProgressiveColor(
     value = compositeBreadthPctVwapConfidence,
     scale = CBI_STRIP_OPACITY_ANCHOR,
     minTransp = CBI_STRIP_MIN_TRANSP
 )

color compositeBreadthCumTickStripColor = f_compositeBreadthProgressiveColor(
     value = compositeBreadthCumTickConfidence,
     scale = CBI_STRIP_OPACITY_ANCHOR,
     minTransp = CBI_STRIP_MIN_TRANSP
 )

color compositeBreadthTickStripColor = f_compositeBreadthProgressiveColor(
     value = compositeBreadthTickConfidence,
     scale = CBI_STRIP_OPACITY_ANCHOR,
     minTransp = CBI_STRIP_MIN_TRANSP_TICK
 )

// Strip row heights proportional to component weight. The four weighted rows
// (VOLD / ADD / PCTABOVEVWAP / CUMTICK) are sized by their share of the
// configured weights, so visual importance matches the math — a 35/35/15/15
// split renders VOLD and ADD twice as tall as PCTABOVEVWAP or CUMTICK. TICK is
// context-only so it gets a thinner fixed-fraction row (60% of one legacy row)
// that reads as secondary at a glance. Total strip span is preserved at
// 4 × stripRowHeight so the existing Y-coordinate input still controls the
// same screen real estate even though there are now 5 rows. If all four
// weights are zero (degenerate config), fall back to an even four-way split.
float compositeBreadthTotalRowWeight       = compositeBreadthVoldWeight + compositeBreadthAddWeight + compositeBreadthPctVwapWeight + compositeBreadthCumTickWeight
float compositeBreadthStripTotalHeight     = 4.0 * compositeBreadthStripRowHeight
float compositeBreadthTickRowHeight        = 0.6 * compositeBreadthStripRowHeight
float compositeBreadthWeightedRowsHeight   = compositeBreadthStripTotalHeight - compositeBreadthTickRowHeight
float compositeBreadthVoldRowHeight        = compositeBreadthTotalRowWeight > 0.0 ?
     compositeBreadthWeightedRowsHeight * compositeBreadthVoldWeight    / compositeBreadthTotalRowWeight :
     compositeBreadthWeightedRowsHeight / 4.0
float compositeBreadthAddRowHeight         = compositeBreadthTotalRowWeight > 0.0 ?
     compositeBreadthWeightedRowsHeight * compositeBreadthAddWeight     / compositeBreadthTotalRowWeight :
     compositeBreadthWeightedRowsHeight / 4.0
float compositeBreadthPctVwapRowHeight     = compositeBreadthTotalRowWeight > 0.0 ?
     compositeBreadthWeightedRowsHeight * compositeBreadthPctVwapWeight / compositeBreadthTotalRowWeight :
     compositeBreadthWeightedRowsHeight / 4.0
float compositeBreadthCumTickRowHeight     = compositeBreadthTotalRowWeight > 0.0 ?
     compositeBreadthWeightedRowsHeight * compositeBreadthCumTickWeight / compositeBreadthTotalRowWeight :
     compositeBreadthWeightedRowsHeight / 4.0

float compositeBreadthVoldRowTop     = compositeBreadthStripTopY
float compositeBreadthVoldRowBase    = compositeBreadthVoldRowTop    - compositeBreadthVoldRowHeight
float compositeBreadthAddRowTop      = compositeBreadthVoldRowBase
float compositeBreadthAddRowBase     = compositeBreadthAddRowTop     - compositeBreadthAddRowHeight
float compositeBreadthPctVwapRowTop  = compositeBreadthAddRowBase
float compositeBreadthPctVwapRowBase = compositeBreadthPctVwapRowTop - compositeBreadthPctVwapRowHeight
float compositeBreadthCumTickRowTop  = compositeBreadthPctVwapRowBase
float compositeBreadthCumTickRowBase = compositeBreadthCumTickRowTop - compositeBreadthCumTickRowHeight
float compositeBreadthTickRowTop     = compositeBreadthCumTickRowBase
float compositeBreadthTickRowBase    = compositeBreadthTickRowTop    - compositeBreadthTickRowHeight

// Zero hline color stays solid; the display toggle handles show/hide. Using
// transparency alone would leave the line invisible but still pinning the
// y-axis to include 0 (which is usually fine for the composite, but consistent
// behaviour across all hlines is cleaner — every togglable hline uses
// display.none when off).
color compositeBreadthZeroLineColor = NORD3

// ═════════════════════════════════════════════════════════════════════════════
// 📊 PLOTS
// Final plot calls stay here due to Pine placement constraints. All series and
// styling inputs are prepared inside the owning Composite Breadth section.
// ═════════════════════════════════════════════════════════════════════════════
hline(price = 0, title = "Zero", color = compositeBreadthZeroLineColor, linestyle = hline.style_solid, linewidth = 3, display = compositeBreadthShowZeroLine ? display.all : display.none)

// Extended-level reference lines at ±CBI_EXTENDED_LEVEL. Dotted, dim NORD3.
// Past visual saturation the composite line looks the same from ±35 onward
// — these lines re-introduce a "this is extended for this market" cue,
// equivalent to Barry's manually drawn 30-day VOLD support/resistance levels.
// Toggling off uses display.none rather than alpha=100: an hline with alpha=100
// is invisible but its `price` parameter still pins TradingView's auto-scale
// to include ±60, which compresses the composite's natural swing around zero.
// display.none removes the hline from the scale calculation entirely.
color compositeBreadthExtendedLineColor = color.new(color = NORD3, transp = 60)
hline(price =  CBI_EXTENDED_LEVEL, title = "Extended Up",   color = compositeBreadthExtendedLineColor, linestyle = hline.style_dotted, linewidth = 1, display = compositeBreadthShowExtendedLevels ? display.all : display.none)
hline(price = -CBI_EXTENDED_LEVEL, title = "Extended Down", color = compositeBreadthExtendedLineColor, linestyle = hline.style_dotted, linewidth = 1, display = compositeBreadthShowExtendedLevels ? display.all : display.none)

// Strip plots use display.none when off, NOT just na series. plot.style_columns
// with na series still passes histbase (around -85 to -97) into TradingView's
// auto-scale calculation, which pins the y-axis lower bound to ~-97 even when
// nothing visible is drawn — that's what made the composite hover near zero.
// display.none excludes the plot from scale entirely; na series + display.none
// is the canonical "fully hidden toggle" pattern in Pine v6.
plot(series = compositeBreadthShowStrip ? compositeBreadthVoldRowTop     : na, title = "VOLD Strip",         color = compositeBreadthVoldStripColor,    style = plot.style_columns, histbase = compositeBreadthVoldRowBase,    display = compositeBreadthShowStrip ? display.all : display.none)
plot(series = compositeBreadthShowStrip ? compositeBreadthAddRowTop      : na, title = "ADD Strip",          color = compositeBreadthAddStripColor,     style = plot.style_columns, histbase = compositeBreadthAddRowBase,     display = compositeBreadthShowStrip ? display.all : display.none)
plot(series = compositeBreadthShowStrip ? compositeBreadthPctVwapRowTop  : na, title = "PCTABOVEVWAP Strip", color = compositeBreadthPctVwapStripColor, style = plot.style_columns, histbase = compositeBreadthPctVwapRowBase, display = compositeBreadthShowStrip ? display.all : display.none)
plot(series = compositeBreadthShowStrip ? compositeBreadthCumTickRowTop  : na, title = "CUMTICK Strip",      color = compositeBreadthCumTickStripColor, style = plot.style_columns, histbase = compositeBreadthCumTickRowBase, display = compositeBreadthShowStrip ? display.all : display.none)
plot(series = compositeBreadthShowStrip ? compositeBreadthTickRowTop     : na, title = "TICK Strip (context)", color = compositeBreadthTickStripColor,  style = plot.style_columns, histbase = compositeBreadthTickRowBase,    display = compositeBreadthShowStrip ? display.all : display.none)

// Session divider — vertical column tint on the session-open bar so each new
// RTH day is visually separated from the prior one. Same any-feed edge that
// drives every other session-wide reset.
bgcolor(color = compositeBreadthShowSessionDivider and compositeBreadthSessionJustOpened ? color.new(color = NORD3, transp = 70) : na, title = "Session Divider")

plot(series = compositeBreadthShowLine       ? compositeBreadthDisplayLine    : na, title = "Composite", color = compositeBreadthLineColor, linewidth = 4)
plot(series = compositeBreadthShowSignalLine ? compositeBreadthSignalLineValue : na, title = "Signal",    color = NORD3,                     linewidth = 2)

// TICK extreme markers — Barry's exhaustion zones. NORD13 triangles at 50%
// transparency, sitting above/below the composite line: up-triangle above on
// extreme high, down-triangle below on extreme low. Read as "watch next cycle
// on price" cues, not entries.
color compositeBreadthTickExtremeColor = color.new(color = NORD13, transp = 50)
plotshape(series = compositeBreadthTickShowExtremes and compositeBreadthTickExtremeUpNew   ? compositeBreadthDisplayLine + compositeBreadthTickExtremeOffset : na, title = "TICK Extreme Up",   style = shape.triangleup,   location = location.absolute, color = compositeBreadthTickExtremeColor, size = size.tiny, display = compositeBreadthTickShowExtremes ? display.all : display.none)
plotshape(series = compositeBreadthTickShowExtremes and compositeBreadthTickExtremeDownNew ? compositeBreadthDisplayLine - compositeBreadthTickExtremeOffset : na, title = "TICK Extreme Down", style = shape.triangledown, location = location.absolute, color = compositeBreadthTickExtremeColor, size = size.tiny, display = compositeBreadthTickShowExtremes ? display.all : display.none)

// Pivot structure markers on the composite. Color is by TREND STATE (set by
// the most recent decisive classification), not per-pivot type. This means
// an HL inside an established bear state stays red — a bounce, not a
// reclamation — and only a fresh HH flips back to bullish cyan. Conversely,
// an LH alone is enough to flip bull → bear (the bullish sequence is broken
// the moment a high fails to extend). HL is a non-event for state changes;
// it just seeds bull on the very first pivot of a session when nothing else
// has set state yet.
//
// Rendered as deletable labels (not plotshape) so the strict zig-zag rule
// can be enforced: between two same-type pivots there MUST be an
// opposite-type pivot. If a new pivot's type matches the previous rendered
// pivot's type, the prior label is deleted and the new one takes its place
// — HH then another HH renders only the latest, an LH after an HH replaces
// the HH, etc. Placed at the pivot bar via x = bar_index - RIGHT_LEGS so
// the circle sits at the actual turning point (RIGHT_LEGS bars left of the
// confirmation bar). Highs offset above the line, lows offset below.
color compositeBreadthTrendColor = compositeBreadthTrendState ==  1 ? color.new(color = NORD8,  transp = 70) :
     compositeBreadthTrendState == -1 ? color.new(color = NORD11, transp = 70) : na
if compositeBreadthShowPivots and compositeBreadthPivotAllowed
    int compositeBreadthPivotBarIndex = bar_index - CBI_PIVOT_RIGHT_LEGS
    if compositeBreadthIsHH or compositeBreadthIsLH
        if compositeBreadthLastPivotType == 1 and not na(compositeBreadthLastHighLabel)
            label.delete(id = compositeBreadthLastHighLabel)
        compositeBreadthLastHighLabel := label.new(
             x = compositeBreadthPivotBarIndex,
             y = compositeBreadthPivotHighValue + compositeBreadthPivotOffset,
             text = "",
             xloc = xloc.bar_index,
             yloc = yloc.price,
             color = compositeBreadthTrendColor,
             style = label.style_circle,
             size = compositeBreadthPivotSize
         )
        compositeBreadthLastPivotType := 1
    if compositeBreadthIsHL or compositeBreadthIsLL
        if compositeBreadthLastPivotType == -1 and not na(compositeBreadthLastLowLabel)
            label.delete(id = compositeBreadthLastLowLabel)
        compositeBreadthLastLowLabel := label.new(
             x = compositeBreadthPivotBarIndex,
             y = compositeBreadthPivotLowValue - compositeBreadthPivotOffset,
             text = "",
             xloc = xloc.bar_index,
             yloc = yloc.price,
             color = compositeBreadthTrendColor,
             style = label.style_circle,
             size = compositeBreadthPivotSize
         )
        compositeBreadthLastPivotType := -1

// Feed-health badge — one persistent label updated in-place each bar via
// label.set_*() (more efficient than the delete+recreate pattern; TradingView
// docs recommend this when the label persists across the whole chart life).
// Created once on the first bar where any feed is missing; hidden by setting
// transparency to 100 when everything is healthy so we don't churn handles.
var label compositeBreadthFeedHealthLabel = na
if barstate.islast
    bool compositeBreadthAnyFeedMissing = str.length(compositeBreadthMissingFeedsText) > 0
    if compositeBreadthAnyFeedMissing
        string compositeBreadthFeedHealthRenderText = "⚠ CBI feeds missing: " + compositeBreadthMissingFeedsText
        color compositeBreadthFeedHealthLabelColor = color.new(color = NORD11, transp = 20)
        if na(compositeBreadthFeedHealthLabel)
            compositeBreadthFeedHealthLabel := label.new(
                 x = bar_index,
                 y = CBI_SCALE_MAX * 0.95,
                 text = compositeBreadthFeedHealthRenderText,
                 xloc = xloc.bar_index,
                 yloc = yloc.price,
                 color = compositeBreadthFeedHealthLabelColor,
                 textcolor = NORD6,
                 style = label.style_label_left,
                 size = size.normal
             )
        else
            label.set_xy       (id = compositeBreadthFeedHealthLabel, x = bar_index, y = CBI_SCALE_MAX * 0.95)
            label.set_text     (id = compositeBreadthFeedHealthLabel, text = compositeBreadthFeedHealthRenderText)
            label.set_color    (id = compositeBreadthFeedHealthLabel, color = compositeBreadthFeedHealthLabelColor)
            label.set_textcolor(id = compositeBreadthFeedHealthLabel, textcolor = NORD6)
    else if not na(compositeBreadthFeedHealthLabel)
        // All feeds healthy — hide via full transparency instead of
        // deleting+recreating each render.
        label.set_color    (id = compositeBreadthFeedHealthLabel, color = color.new(color = NORD11, transp = 100))
        label.set_textcolor(id = compositeBreadthFeedHealthLabel, textcolor = color.new(color = NORD6, transp = 100))

// Additional alerts on the smoothed composite line.
alertcondition(condition = ta.crossover (source1 = compositeBreadthDisplayLine, source2 = compositeBreadthSignalLineValue), title = "Composite crosses above Signal", message = "Composite breadth crossed above signal — upward momentum building.")
alertcondition(condition = ta.crossunder(source1 = compositeBreadthDisplayLine, source2 = compositeBreadthSignalLineValue), title = "Composite crosses below Signal", message = "Composite breadth crossed below signal — downward momentum building.")
alertcondition(condition = ta.crossover (source1 = compositeBreadthDisplayLine, source2 =  50.0), title = "Composite crosses +50 (impulse up)",   message = "Composite breadth crossed above +50 — bullish breadth impulse.")
alertcondition(condition = ta.crossunder(source1 = compositeBreadthDisplayLine, source2 = -50.0), title = "Composite crosses −50 (impulse down)", message = "Composite breadth crossed below −50 — bearish breadth impulse.")
alertcondition(condition = str.length(compositeBreadthMissingFeedsText) > 0 and compositeBreadthBarsSinceSessionOpen >= CBI_FEED_HEALTH_GRACE_BARS, title = "CBI: Feed(s) missing", message = "One or more required breadth feeds have not delivered after the post-open grace window. Check the Pine logs panel and the feed-health badge for details.")
