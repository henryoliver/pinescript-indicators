// Moving Average with Trend Indicator

//@version=6
indicator(title = "MAs & Waves", shorttitle = "MA&W", overlay = true, calc_bars_count = 300)

// ===================================================================
// SECTION 1: CONSTANTS & THEME
// ===================================================================

// Nord Theme Colors (Complete Palette)
const color NORD0  = #2E3440
const color NORD1  = #3B4252
const color NORD2  = #434C5E
const color NORD3  = #4C566A
const color NORD4  = #D8DEE9
const color NORD5  = #E5E9F0
const color NORD6  = #ECEFF4
const color NORD7  = #8FBCBB
const color NORD8  = #88C0D0
const color NORD9  = #81A1C1
const color NORD10 = #5E81AC
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

// Trend States
const string TREND_UP   = "up"
const string TREND_DOWN = "down"
const string TREND_FLAT = "flat"

// Alphabet for cycle letters
const string CYCLE_ALPHABET = "abcdefghijklmnopqrstuvwxyz"

// ===================================================================
// SECTION 2: TYPE DEFINITIONS
// ===================================================================

// Custom type to store cycle extremes
type CyclePoint
    float open
    float close
    float high
    float low
    int barIndex

// Enum for cycle zone states
enum CycleZone
    NONE
    HIGH
    LOW

// Custom type to store pending retracement cycle info
type PendingCycle
    float high
    float low
    int barIndex

// ===================================================================
// SECTION 3: USER INPUTS
// ===================================================================

const string GROUP_GENERAL = "⚙️ General Settings"
const string GROUP_TREND = "📈 Trend Detection"
const string GROUP_STOCH = "📉 Stochastic Cycles"
const string GROUP_LABELS = "🏷️ Labels"

// General Settings
src = input.source(defval = close, title = "Source", group = GROUP_GENERAL)
smaLength = input.int(defval = 50, title = "Length", minval = 1, group = GROUP_GENERAL)
smaOffset = input.int(defval = 0, title = "Offset", minval = -500, maxval = 500, display = display.none, group = GROUP_GENERAL)
// Line width fixed to maintain consistency across indicators

// Trend Detection Settings
trendLookback = input.int(defval = 1, title = "Lookback Period (Bars)", minval = 1, maxval = 20,
     tooltip = "Number of bars to look back when calculating the slope", group = GROUP_TREND)
flatThreshold = input.float(defval = 0.001, title = "Flat Threshold", minval = 0.0001, maxval = 10.0, step = 0.0001,
     tooltip = "Slope values between -threshold and +threshold are considered flat/neutral", group = GROUP_TREND)

// Trend Colors (fixed defaults)
colorUp = color.new(color = NORD8, transp = 20)
colorFlat = NORD2
colorDown = color.new(color = NORD9, transp = 60)

// Stochastic Settings (for cycle detection)
stochLength = input.int(defval = 5, title = "K Length", minval = 1, group = GROUP_STOCH)
stochSmooth = input.int(defval = 2, title = "K Smooth", minval = 1, group = GROUP_STOCH)
stochDLength = input.int(defval = 3, title = "D Length", minval = 1, group = GROUP_STOCH)

// Label Settings
labelColor = input.color(defval = color.new(color = NORD4, transp = 40), title = "Label Color", group = GROUP_LABELS)
waveLabelSizeOpt = input.string(defval = "Normal", title = "Wave Label Size", options = ["Tiny", "Small", "Normal", "Large", "Huge"], group = GROUP_LABELS)
showCycleLetters = input.bool(defval = false, title = "Show Cycle Letters", group = GROUP_LABELS)
cycleLabelSizeOpt = input.string(defval = "Normal", title = "Cycle Label Size (Letters)", options = ["Tiny", "Small", "Normal", "Large", "Huge"], group = GROUP_LABELS)

waveLabelSize = switch waveLabelSizeOpt
    "Tiny" => size.tiny
    "Small" => size.small
    "Normal" => size.normal
    "Large" => size.large
    => size.huge

cycleLabelSize = switch cycleLabelSizeOpt
    "Tiny" => size.tiny
    "Small" => size.small
    "Normal" => size.normal
    "Large" => size.large
    => size.huge

// Array size limit to prevent performance issues
const int MAX_PENDING_RETRACEMENTS = 20

// ===================================================================
// SECTION 4: CALCULATIONS
// ===================================================================
// Calculate the Simple Moving Average
sma = ta.sma(source = src, length = smaLength)

// Calculate Slope (Direct comparison - no trigonometric functions for better performance)
// Slope = change in SMA value over the lookback period
smaSlope = ta.change(source = sma, length = trendLookback)

// Determine Trend Direction
// If absolute slope is less than threshold: FLAT
// If slope is positive: UPTREND
// If slope is negative: DOWNTREND
trend = math.abs(number = smaSlope) < flatThreshold ? TREND_FLAT : smaSlope > 0 ? TREND_UP : TREND_DOWN

// Select Color Based on Trend
smaColor = switch trend
    TREND_UP => colorUp
    TREND_DOWN => colorDown
    => colorFlat

// === STOCHASTIC CYCLES ===
// Calculate Stochastic %K and %D
stochK = ta.stoch(source = close, high = high, low = low, length = stochLength)
stochKSmoothed = ta.sma(source = stochK, length = stochSmooth)
stochD = ta.sma(source = stochKSmoothed, length = stochDLength)
bool dCrossAbove45 = ta.crossover(stochD, 45)
bool dCrossBelow55 = ta.crossunder(stochD, 55)

// Track previous trend for reset detection
var string previousTrend = TREND_FLAT
bool trendChanged = trend != previousTrend

// Cycle state variables
var CycleZone cycleZone = CycleZone.NONE
var CycleZone previousCycleZone = CycleZone.NONE
var CycleZone priorZone = CycleZone.NONE
var string currentCycleTrend = TREND_FLAT
var string previousCycleTrend = TREND_FLAT
var bool trendResetPending = false

// Current cycle tracking (winner = highest/lowest CLOSE, but store both open and close)
var CyclePoint currentCycleHigh = CyclePoint.new(na, na, na, na, na)
var CyclePoint currentCycleLow = CyclePoint.new(na, na, na, na, na)

// Previous cycle tracking (in same trend only)
var CyclePoint previousCycleHigh = CyclePoint.new(na, na, na, na, na)
var CyclePoint previousCycleLow = CyclePoint.new(na, na, na, na, na)

// === WAVE COUNTING ===
// Wave state tracking
var bool wave1Anchored = false
var int currentImpulseNumber = 0  // 1, 3, 5, 7, 9...
var CyclePoint lastImpulseCandle = CyclePoint.new(na, na, na, na, na)

// Pending retracements (waiting for next impulse to confirm)
var array<PendingCycle> pendingRetracements = array.new<PendingCycle>()
var int cycleLetterIdx = 0
float labelOffset = syminfo.mintick * 10.0
float letterExtraOffset = syminfo.mintick * 16.0
log.info("Init: offsets set | labelOffset=" + str.tostring(labelOffset) + " | letterExtraOffset=" + str.tostring(letterExtraOffset))

// Reset ALL cycle and wave variables when trend changes
if trendChanged
    if cycleZone == CycleZone.NONE
        cycleZone := CycleZone.NONE
        previousCycleZone := CycleZone.NONE
        priorZone := CycleZone.NONE
        currentCycleTrend := TREND_FLAT
        previousCycleTrend := TREND_FLAT
        currentCycleHigh := CyclePoint.new(na, na, na, na, na)
        currentCycleLow := CyclePoint.new(na, na, na, na, na)
        previousCycleHigh := CyclePoint.new(na, na, na, na, na)
        previousCycleLow := CyclePoint.new(na, na, na, na, na)
        wave1Anchored := false
        currentImpulseNumber := 0
        lastImpulseCandle := CyclePoint.new(na, na, na, na, na)
        pendingRetracements.clear()
        cycleLetterIdx := 0
        previousTrend := trend
        trendResetPending := false
        log.info("Reset: trendChanged -> full reset (no active cycle) | trend=" + trend)
    else
        trendResetPending := true
        previousTrend := trend
        log.info("Reset: trendChanged during active cycle -> defer reset | trend=" + trend)

// === CYCLE STATE ===
// Detect when cycles complete and assign wave labels (confirmed bars only)
bool completedCycleLow = false
bool completedCycleHigh = false
log.info("CycleState: flags init | completedHigh=" + str.tostring(completedCycleHigh) + " | completedLow=" + str.tostring(completedCycleLow))

if barstate.isconfirmed
    priorZone := cycleZone
    log.info("CycleState: enter | Zone=" + str.tostring(cycleZone) + " | D=" + str.tostring(stochD))

    switch cycleZone
        CycleZone.NONE =>
            if dCrossAbove45 or stochD > 55
                cycleZone := CycleZone.HIGH
                currentCycleHigh := CyclePoint.new(open, close, high, low, bar_index)
                currentCycleTrend := trend
                log.info("CycleState: NONE->HIGH | idx=" + str.tostring(bar_index))
            else if dCrossBelow55 or stochD < 45
                cycleZone := CycleZone.LOW
                currentCycleLow := CyclePoint.new(open, close, high, low, bar_index)
                currentCycleTrend := trend
                log.info("CycleState: NONE->LOW | idx=" + str.tostring(bar_index))

        CycleZone.HIGH =>
            if stochD < 55
                cycleZone := CycleZone.LOW
                previousCycleHigh := currentCycleHigh
                previousCycleTrend := currentCycleTrend
                currentCycleHigh := CyclePoint.new(na, na, na, na, na)
                currentCycleLow := CyclePoint.new(open, close, high, low, bar_index)
                currentCycleTrend := trend
                log.info("CycleState: HIGH->LOW | prevHighIdx=" + str.tostring(previousCycleHigh.barIndex))
            else
                if na(currentCycleHigh.high) or high > currentCycleHigh.high
                    currentCycleHigh := CyclePoint.new(open, close, high, low, bar_index)
                    log.info("CycleState: HIGH update extreme | idx=" + str.tostring(bar_index))

        CycleZone.LOW =>
            if stochD > 45
                cycleZone := CycleZone.HIGH
                previousCycleLow := currentCycleLow
                previousCycleTrend := currentCycleTrend
                currentCycleLow := CyclePoint.new(na, na, na, na, na)
                currentCycleHigh := CyclePoint.new(open, close, high, low, bar_index)
                currentCycleTrend := trend
                log.info("CycleState: LOW->HIGH | prevLowIdx=" + str.tostring(previousCycleLow.barIndex))
            else
                if na(currentCycleLow.low) or low < currentCycleLow.low
                    currentCycleLow := CyclePoint.new(open, close, high, low, bar_index)
                    log.info("CycleState: LOW update extreme | idx=" + str.tostring(bar_index))

    completedCycleLow := cycleZone == CycleZone.HIGH and priorZone == CycleZone.LOW
    completedCycleHigh := cycleZone == CycleZone.LOW and priorZone == CycleZone.HIGH


// === WAVE LOGIC ===
// Only execute wave logic on confirmed bars (bar close, not every tick)
if barstate.isconfirmed
    bool resetLettersThisCycle = false
    log.info("WaveLogic: enter | Trend=" + trend + " | CompletedHigh=" + str.tostring(completedCycleHigh) + " | CompletedLow=" + str.tostring(completedCycleLow))

    // DOWNTREND wave logic
    if previousCycleTrend == TREND_DOWN
        // Completed a cycle LOW → check for impulse wave (1, 3, 5, 7...)
        if completedCycleLow
            if not wave1Anchored
                wave1Anchored := true
                currentImpulseNumber := 1
                lastImpulseCandle := previousCycleLow
                pendingRetracements.clear()
                resetLettersThisCycle := true
                label.new(x = previousCycleLow.barIndex, y = previousCycleLow.low - labelOffset, text = "1", style = label.style_none, color = na, textcolor = labelColor, size = waveLabelSize)
                log.info("WaveLogic: DOWN anchor wave1 @ " + str.tostring(previousCycleLow.barIndex))
            else
                float previousLow = lastImpulseCandle.low
                float currentClose = previousCycleLow.close
                float currentOpen = previousCycleLow.open
                bool qualifiesAsImpulse = currentClose < previousLow and currentOpen <= previousLow
                log.info("WaveLogic: DOWN impulse check | qualifies=" + str.tostring(qualifiesAsImpulse))

                if qualifiesAsImpulse
                    currentImpulseNumber += 2
                    lastImpulseCandle := previousCycleLow
                    resetLettersThisCycle := true
                    label.new(x = previousCycleLow.barIndex, y = previousCycleLow.low - labelOffset, text = str.tostring(value = currentImpulseNumber), style = label.style_none, color = na, textcolor = labelColor, size = waveLabelSize)
                    log.info("WaveLogic: DOWN impulse " + str.tostring(currentImpulseNumber) + " @ " + str.tostring(previousCycleLow.barIndex))

                    if pendingRetracements.size() > 0
                        int highestIndex = 0
                        float highestHigh = pendingRetracements.get(0).high
                        if pendingRetracements.size() > 1
                            for i = 1 to pendingRetracements.size() - 1
                                if pendingRetracements.get(i).high > highestHigh
                                    highestHigh := pendingRetracements.get(i).high
                                    highestIndex := i

                        PendingCycle winner = pendingRetracements.get(highestIndex)
                        int evenNumber = currentImpulseNumber - 1
                        label.new(x = winner.barIndex, y = winner.high, text = str.tostring(value = evenNumber), style = label.style_none, color = na, textcolor = labelColor, size = waveLabelSize)

                        pendingRetracements.clear()
                else
                    int failedNumber = currentImpulseNumber + 2
                    label.new(x = previousCycleLow.barIndex, y = previousCycleLow.low - labelOffset, text = "F" + str.tostring(value = failedNumber), style = label.style_none, color = na, textcolor = labelColor, size = waveLabelSize)
                    log.info("WaveLogic: DOWN failed " + str.tostring(failedNumber) + " @ " + str.tostring(previousCycleLow.barIndex))

        if wave1Anchored and completedCycleHigh and pendingRetracements.size() < MAX_PENDING_RETRACEMENTS
            PendingCycle pendingRetracement = PendingCycle.new(high = previousCycleHigh.high, low = previousCycleHigh.low, barIndex = previousCycleHigh.barIndex)
            pendingRetracements.push(pendingRetracement)

    // UPTREND wave logic (inverted from downtrend)
    if previousCycleTrend == TREND_UP
        if completedCycleHigh
            if not wave1Anchored
                wave1Anchored := true
                currentImpulseNumber := 1
                lastImpulseCandle := previousCycleHigh
                pendingRetracements.clear()
                resetLettersThisCycle := true
                label.new(x = previousCycleHigh.barIndex, y = previousCycleHigh.high + labelOffset, text = "1", style = label.style_none, color = na, textcolor = labelColor, size = waveLabelSize)
                log.info("WaveLogic: UP anchor wave1 @ " + str.tostring(previousCycleHigh.barIndex))
            else
                float previousHigh = lastImpulseCandle.high
                float currentClose = previousCycleHigh.close
                float currentOpen = previousCycleHigh.open
                bool qualifiesAsImpulse = currentClose > previousHigh and currentOpen >= previousHigh
                log.info("WaveLogic: UP impulse check | qualifies=" + str.tostring(qualifiesAsImpulse))

                if qualifiesAsImpulse
                    currentImpulseNumber += 2
                    lastImpulseCandle := previousCycleHigh
                    resetLettersThisCycle := true
                    label.new(x = previousCycleHigh.barIndex, y = previousCycleHigh.high + labelOffset, text = str.tostring(value = currentImpulseNumber), style = label.style_none, color = na, textcolor = labelColor, size = waveLabelSize)
                    log.info("WaveLogic: UP impulse " + str.tostring(currentImpulseNumber) + " @ " + str.tostring(previousCycleHigh.barIndex))

                    if pendingRetracements.size() > 0
                        int lowestIndex = 0
                        float lowestLow = pendingRetracements.get(0).low
                        if pendingRetracements.size() > 1
                            for i = 1 to pendingRetracements.size() - 1
                                if pendingRetracements.get(i).low < lowestLow
                                    lowestLow := pendingRetracements.get(i).low
                                    lowestIndex := i

                        PendingCycle winner = pendingRetracements.get(lowestIndex)
                        int evenNumber = currentImpulseNumber - 1
                        label.new(x = winner.barIndex, y = winner.low, text = str.tostring(value = evenNumber), style = label.style_none, color = na, textcolor = labelColor, size = waveLabelSize)

                        pendingRetracements.clear()
                else
                    int failedNumber = currentImpulseNumber + 2
                    label.new(x = previousCycleHigh.barIndex, y = previousCycleHigh.high + labelOffset, text = "F" + str.tostring(value = failedNumber), style = label.style_none, color = na, textcolor = labelColor, size = waveLabelSize)
                    log.info("WaveLogic: UP failed " + str.tostring(failedNumber) + " @ " + str.tostring(previousCycleHigh.barIndex))

        if wave1Anchored and completedCycleLow and pendingRetracements.size() < MAX_PENDING_RETRACEMENTS
            PendingCycle pendingRetracement = PendingCycle.new(high = previousCycleLow.high, low = previousCycleLow.low, barIndex = previousCycleLow.barIndex)
            pendingRetracements.push(pendingRetracement)

    if resetLettersThisCycle
        cycleLetterIdx := 0

    // Label cycle letters for every completed cycle
    if showCycleLetters and completedCycleHigh
        string letter = str.substring(source = CYCLE_ALPHABET, begin_pos = cycleLetterIdx, end_pos = cycleLetterIdx + 1)
        label.new(x = previousCycleHigh.barIndex, y = previousCycleHigh.high + letterExtraOffset, text = letter, style = label.style_none, color = na, textcolor = labelColor, size = cycleLabelSize)
        cycleLetterIdx := math.min(cycleLetterIdx + 1, str.length(CYCLE_ALPHABET) - 1)

    if showCycleLetters and completedCycleLow
        string letter = str.substring(source = CYCLE_ALPHABET, begin_pos = cycleLetterIdx, end_pos = cycleLetterIdx + 1)
        label.new(x = previousCycleLow.barIndex, y = previousCycleLow.low - letterExtraOffset, text = letter, style = label.style_none, color = na, textcolor = labelColor, size = cycleLabelSize)
        cycleLetterIdx := math.min(cycleLetterIdx + 1, str.length(CYCLE_ALPHABET) - 1)

    if trendResetPending and (completedCycleHigh or completedCycleLow)
        wave1Anchored := false
        currentImpulseNumber := 0
        lastImpulseCandle := CyclePoint.new(na, na, na, na, na)
        pendingRetracements.clear()
        cycleLetterIdx := 0
        trendResetPending := false
        log.info("Reset: applied deferred reset after cycle completion")

// === PLOT ===
plot(series = sma, title = "SMA", color = smaColor, linewidth = 3, offset = smaOffset)

// === DEBUG LOGGING ===
log.info("=== MAs & Waves Debug Summary ===")
log.info("Trend: " + trend + " | Slope: " + str.tostring(smaSlope))
log.info("StochD: " + str.tostring(stochD) + " | D>45=" + str.tostring(dCrossAbove45) + " | D<55=" + str.tostring(dCrossBelow55))
log.info("Zone: " + str.tostring(cycleZone) + " | Prior: " + str.tostring(priorZone))
log.info("Completed High: " + str.tostring(completedCycleHigh) + " | Completed Low: " + str.tostring(completedCycleLow))
log.info("Wave1 Anchored: " + str.tostring(wave1Anchored) + " | Impulse#: " + str.tostring(currentImpulseNumber))
log.info("Pending Retracements: " + str.tostring(pendingRetracements.size()))
