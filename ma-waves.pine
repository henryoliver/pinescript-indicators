// Moving Average with Trend Indicator
// Concepts:
// - Trend: Determined by SMA slope over lookback; used to classify waves.
// - Wave: A label assigned at cycle transitions; odd waves are impulses, even waves are retraces.
// - Impulse (odd): Must progress beyond the prior impulse in the trend direction.
// - Retrace (even): No progression rule relative to prior retrace.
// - Cycle: Complete cycle is HIGH→LOW→HIGH or LOW→HIGH→LOW; a half-cycle is HIGH→LOW or LOW→HIGH.

//@version=6
indicator(title = "MAs & Waves", shorttitle = "MA&W", overlay = true, calc_bars_count = 300, max_labels_count = 500)

// ===================================================================
// SECTION 1: CONSTANTS & THEME
// ===================================================================

// Nord Theme Colors (Complete Palette)
const color NORD0  = #2E3440
const color NORD1  = #3B4252
const color NORD2  = #434C5E
const color NORD3  = #4C566A
const color NORD4  = #D8DEE9
const color NORD5  = #E5E9F0
const color NORD6  = #ECEFF4
const color NORD7  = #8FBCBB
const color NORD8  = #88C0D0
const color NORD9  = #81A1C1
const color NORD10 = #5E81AC
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

// Trend States
enum Trend
    UP
    DOWN
    FLAT

// Alphabet for cycle letters
const string CYCLE_ALPHABET = "abcdefghijklmnopqrstuvwxyz"

// ===================================================================
// SECTION 2: TYPE DEFINITIONS
// ===================================================================

// Custom type to store cycle extremes
type CyclePoint
    float open
    float close
    float high
    float low
    float sma
    int barIndex

// Enum for cycle zone states
enum CycleZone
    NONE
    HIGH
    LOW

// ===================================================================
// SECTION 3: USER INPUTS
// ===================================================================

const string GROUP_GENERAL = "⚙️ General Settings"
const string GROUP_TREND = "📈 Trend Detection"
const string GROUP_STOCH = "📉 Stochastic Cycles"
const string GROUP_LABELS = "🏷️ Labels"

// General Settings
src = input.source(defval = close, title = "Source", group = GROUP_GENERAL)
smaLength = input.int(defval = 50, title = "Length", minval = 1, group = GROUP_GENERAL)
smaOffset = input.int(defval = 0, title = "Offset", minval = -500, maxval = 500, display = display.none, group = GROUP_GENERAL)
// Line width fixed to maintain consistency across indicators

// Trend Detection Settings
trendLookback = input.int(defval = 1, title = "Lookback Period (Bars)", minval = 1, maxval = 20,
     tooltip = "Number of bars to look back when calculating the slope", group = GROUP_TREND)
flatThreshold = input.float(defval = 0.0001, title = "Flat Threshold", minval = 0.0001, maxval = 10.0, step = 0.0001,
     tooltip = "Per-bar SMA slope threshold; values between -threshold and +threshold are flat", group = GROUP_TREND)

// Trend Colors (fixed defaults)
colorTrendUp = color.new(color = NORD8, transp = 20)
colorTrendFlat = NORD2
colorTrendDown = color.new(color = NORD9, transp = 60)

// Stochastic Settings (for cycle detection)
stochLength = input.int(defval = 5, title = "K Length", minval = 1, group = GROUP_STOCH)
stochSmooth = input.int(defval = 2, title = "K Smooth", minval = 1, group = GROUP_STOCH)
stochDLength = input.int(defval = 3, title = "D Length", minval = 1, group = GROUP_STOCH)

// Label Settings
waveLabelColor = input.color(defval = color.new(color = NORD4, transp = 40), title = "Wave Label Color", group = GROUP_LABELS)
waveLabelSizeOpt = input.string(defval = "Normal", title = "Wave Label Size", options = ["Tiny", "Small", "Normal", "Large", "Huge"], group = GROUP_LABELS)
cycleShowLetters = input.bool(defval = false, title = "Show Cycle Letters", group = GROUP_LABELS)
cycleLabelColor = input.color(defval = color.new(color = NORD4, transp = 40), title = "Cycle Label Color", group = GROUP_LABELS)
cycleLabelSizeOpt = input.string(defval = "Normal", title = "Cycle Label Size (Letters)", options = ["Tiny", "Small", "Normal", "Large", "Huge"], group = GROUP_LABELS)
waveLabelOffset = input.float(defval = 10.0, title = "Wave Label Offset (Ticks)", minval = 0.0, step = 1.0, group = GROUP_LABELS)
waveLabelProvisionalColor = input.color(defval = color.new(color = NORD4, transp = 70), title = "Wave Label Provisional Color", group = GROUP_LABELS)

waveLabelSize = switch waveLabelSizeOpt
    "Tiny" => size.tiny
    "Small" => size.small
    "Normal" => size.normal
    "Large" => size.large
    => size.huge

cycleLabelSize = switch cycleLabelSizeOpt
    "Tiny" => size.tiny
    "Small" => size.small
    "Normal" => size.normal
    "Large" => size.large
    => size.huge

// ===================================================================
// SECTION 4: CALCULATIONS
// ===================================================================
// Calculate the Simple Moving Average
sma = ta.sma(source = src, length = smaLength)

// Calculate Slope (Direct comparison - no trigonometric functions for better performance)
// Slope = per-bar change in SMA over the lookback period
smaSlope = (sma - sma[trendLookback]) / trendLookback

// Determine Trend Direction
// If absolute slope is less than threshold: FLAT
// If slope is positive: UPTREND
// If slope is negative: DOWNTREND
Trend trend = math.abs(number = smaSlope) < flatThreshold ? Trend.FLAT : smaSlope > 0 ? Trend.UP : Trend.DOWN

// Select Color Based on Trend
smaColor = switch trend
    Trend.UP => colorTrendUp
    Trend.DOWN => colorTrendDown
    => colorTrendFlat

// === SCaffolded State (types in use; wave logic to follow) ===
var CycleZone cycleZone = CycleZone.NONE
var CyclePoint lastCyclePoint = CyclePoint.new(na, na, na, na, na, na)

// === STOCHASTIC CYCLES ===
// Calculate Stochastic %K and %D
stochK = ta.stoch(source = close, high = high, low = low, length = stochLength)
stochKSmoothed = ta.sma(source = stochK, length = stochSmooth)
stochD = ta.sma(source = stochKSmoothed, length = stochDLength)
bool dCrossAbove45 = ta.crossover(stochD, 45)
bool dCrossBelow55 = ta.crossunder(stochD, 55)

// === FIRST IMPULSE WAVE ONLY ===
var Trend previousTrend = Trend.FLAT
var bool firstImpulseArmed = false
var bool firstImpulsePlotted = false
var label firstImpulseLabel = na
var CyclePoint currentCycleHigh = CyclePoint.new(na, na, na, na, na, na)
var CyclePoint currentCycleLow = CyclePoint.new(na, na, na, na, na, na)
float waveLabelOffsetPrice = syminfo.mintick * waveLabelOffset

// Trend-change interface
f_onTrendChange(Trend newTrend) =>
    firstImpulseArmed := newTrend == Trend.UP or newTrend == Trend.DOWN
    firstImpulsePlotted := false
    previousTrend := newTrend

if trend != previousTrend
    f_onTrendChange(trend)

// Track half-cycles and place the first impulse wave at the first cycle extreme after trend turns
// Extreme bar: bar that sets the cycle high/low.
// Half-cycle confirmation bar: bar that ends the half-cycle (D crosses back through 45/55).
switch cycleZone
    CycleZone.NONE =>
        if dCrossAbove45 or stochD > 55
            cycleZone := CycleZone.HIGH
            currentCycleHigh := CyclePoint.new(open, close, high, low, sma, bar_index)
        else if dCrossBelow55 or stochD < 45
            cycleZone := CycleZone.LOW
            currentCycleLow := CyclePoint.new(open, close, high, low, sma, bar_index)
    CycleZone.HIGH =>
        if stochD < 55
            // Cycle high completes here
            bool highBarAboveSma = currentCycleHigh.low > currentCycleHigh.sma
            if firstImpulseArmed and not firstImpulsePlotted and trend == Trend.UP and highBarAboveSma
                if na(firstImpulseLabel)
                    firstImpulseLabel := label.new(x = currentCycleHigh.barIndex, y = currentCycleHigh.high + waveLabelOffsetPrice, text = "1", style = label.style_none, color = na, textcolor = waveLabelProvisionalColor, size = waveLabelSize)
                label.set_textcolor(firstImpulseLabel, waveLabelColor)
                firstImpulsePlotted := true
                firstImpulseArmed := false
            cycleZone := CycleZone.LOW
            currentCycleLow := CyclePoint.new(open, close, high, low, sma, bar_index)
        else
            if na(currentCycleHigh.high) or high > currentCycleHigh.high
                currentCycleHigh := CyclePoint.new(open, close, high, low, sma, bar_index)
            if firstImpulseArmed and trend == Trend.UP
                bool highBarAboveSma = currentCycleHigh.low > currentCycleHigh.sma
                if highBarAboveSma
                    if na(firstImpulseLabel)
                        firstImpulseLabel := label.new(x = currentCycleHigh.barIndex, y = currentCycleHigh.high + waveLabelOffsetPrice, text = "1", style = label.style_none, color = na, textcolor = waveLabelProvisionalColor, size = waveLabelSize)
                    label.set_xy(firstImpulseLabel, currentCycleHigh.barIndex, currentCycleHigh.high + waveLabelOffsetPrice)
    CycleZone.LOW =>
        if stochD > 45
            // Cycle low completes here
            bool lowBarBelowSma = currentCycleLow.high < currentCycleLow.sma
            if firstImpulseArmed and not firstImpulsePlotted and trend == Trend.DOWN and lowBarBelowSma
                if na(firstImpulseLabel)
                    firstImpulseLabel := label.new(x = currentCycleLow.barIndex, y = currentCycleLow.low - waveLabelOffsetPrice, text = "1", style = label.style_none, color = na, textcolor = waveLabelProvisionalColor, size = waveLabelSize)
                label.set_textcolor(firstImpulseLabel, waveLabelColor)
                firstImpulsePlotted := true
                firstImpulseArmed := false
            cycleZone := CycleZone.HIGH
            currentCycleHigh := CyclePoint.new(open, close, high, low, sma, bar_index)
        else
            if na(currentCycleLow.low) or low < currentCycleLow.low
                currentCycleLow := CyclePoint.new(open, close, high, low, sma, bar_index)
            if firstImpulseArmed and trend == Trend.DOWN
                bool lowBarBelowSma = currentCycleLow.high < currentCycleLow.sma
                if lowBarBelowSma
                    if na(firstImpulseLabel)
                        firstImpulseLabel := label.new(x = currentCycleLow.barIndex, y = currentCycleLow.low - waveLabelOffsetPrice, text = "1", style = label.style_none, color = na, textcolor = waveLabelProvisionalColor, size = waveLabelSize)
                    label.set_xy(firstImpulseLabel, currentCycleLow.barIndex, currentCycleLow.low - waveLabelOffsetPrice)

// === PLOT ===
plot(series = sma, title = "SMA", color = smaColor, linewidth = 3, offset = smaOffset)
