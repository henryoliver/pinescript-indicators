// Moving Average with Trend Indicator

//@version=6
indicator(title = "MAs & Waves", shorttitle = "🌊 MA&W", overlay = true, max_labels_count = 500)

// ═════════════════════════════════════════════════════════════════════════════
// 🧱 CONSTANTS
// Shared immutable values used by the indicator, including the Nord palette.
// ═════════════════════════════════════════════════════════════════════════════
// Nord Theme Color
// Polar Night
const color NORD0 = #2E3440
const color NORD1 = #3B4252
const color NORD2 = #434C5E
const color NORD3 = #4C566A
// Snow Storm
const color NORD4 = #D8DEE9
const color NORD5 = #E5E9F0
const color NORD6 = #ECEFF4
// Frost
const color NORD7 = #8FBCBB
const color NORD8 = #88C0D0
const color NORD9 = #81A1C1
const color NORD10 = #5E81AC
// Aurora
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

// ═════════════════════════════════════════════════════════════════════════════
// 🧩 TYPE DEFINITIONS
// Custom Pine types live here when a file needs them.
// ═════════════════════════════════════════════════════════════════════════════
enum TrendDir
    UP
    DOWN
    FLAT

// ═════════════════════════════════════════════════════════════════════════════
// 🎛️ USER INPUT SETTINGS
// All input groups are declared together so the settings dialog keeps the
// built-in ordering — Trend, Cycle, Waves, then Calculation last. Pine's
// top-to-bottom declaration rule would otherwise force the Calculation inputs
// above the sections that consume them, moving the group to the top.
// ═════════════════════════════════════════════════════════════════════════════
const string GROUP_TREND = "📈 Trend"
const string GROUP_CYCLE = "🔄 Cycle"
const string GROUP_WAVES = "🌊 Waves"
const string GROUP_CALC = "🧮 Calculation"

// Trend Settings
trendSource = input.source(defval = close, title = "Source", group = GROUP_TREND)
trendSmaLength = input.int(defval = 50, title = "SMA Length", minval = 1, group = GROUP_TREND)
trendSmaOffset = input.int(defval = 0, title = "SMA Offset", minval = -500, maxval = 500, display = display.none, group = GROUP_TREND)
trendFlatWindow = input.int(defval = 10, title = "Flat Window", minval = 1, maxval = 200,
     tooltip = "Bars over which the SMA's net movement is measured for the flat-regime test (only used when Flat ATR Fraction > 0). On a sideways MA the one-bar slope keeps alternating sign with real magnitude, so single bars never read flat — this window is what catches the neutral stretch the eye sees. A flat regime colors the line gray and ends the wave count.", group = GROUP_TREND)
trendFlatAtrFraction = input.float(defval = 0.0, title = "Flat ATR Fraction", minval = 0.0, maxval = 5.0, step = 0.05,
     tooltip = "Flat-regime sensitivity: the MA is flat when its net movement over the Flat Window is at most this fraction of ATR(14). A flat stretch ends the count like a direction change, so up > flat > up resets and re-anchors wave 1 after the resume. 0 (default) disables the regime — strictly UP/DOWN, the count then resets only on a direction change. Try 0.25 to enable flat detection.", group = GROUP_TREND)

// Cycle Settings (Barry's cycle defaults: %K Length 5, %K Smoothing 2, %D Smoothing 3)
cycleKLength = input.int(defval = 5, title = "%K Length", minval = 1, group = GROUP_CYCLE)
cycleKSmoothing = input.int(defval = 2, title = "%K Smoothing", minval = 1, group = GROUP_CYCLE)
cycleDSmoothing = input.int(defval = 3, title = "%D Smoothing", minval = 1, group = GROUP_CYCLE)

// Wave Settings
// Wave label colors match macd-waves' wave count colors.
waveUpColor = input.color(defval = color.new(color = NORD8, transp = 20), title = "Up Trend Wave Color", group = GROUP_WAVES)
waveDownColor = input.color(defval = color.new(color = NORD11, transp = 10), title = "Down Trend Wave Color", group = GROUP_WAVES)
waveLabelSize = input.int(defval = 14, title = "Wave Label Size", minval = 8, maxval = 40, group = GROUP_WAVES)

// Calculation Settings (manual equivalent of the built-in section — the
// indicator() `timeframe` parameter can't be used in scripts that create drawings)
calcTimeframe = input.timeframe(defval = "", title = "Timeframe",
     tooltip = "Timeframe the SMA is calculated on. Leave on Chart to follow the chart's timeframe. Note: an HTF SMA with chart-timeframe cycles is a hybrid — Barry's multi-timeframe handling uses separate charts at 3:1, so the wave count is no longer his pure system.", group = GROUP_CALC)
calcWaitForClose = input.bool(defval = true, title = "Wait for timeframe closes",
     tooltip = "On a higher timeframe, only show values once that timeframe's bar closes (gaps between closes). Off updates the line with the forming bar.", group = GROUP_CALC)

// ═════════════════════════════════════════════════════════════════════════════
// 📈 TREND
// SMA engine and trend state. The SMA and its one-bar slope are computed inside
// the requested timeframe, so on an HTF setting the slope reads HTF bars, not
// chart bars. Exports `trendSma`, `trendDir`, and `trendColor`.
// ═════════════════════════════════════════════════════════════════════════════
const color TREND_UP_COLOR = color.new(color = NORD8, transp = 20)
const color TREND_DOWN_COLOR = color.new(color = NORD9, transp = 60)
const color TREND_FLAT_COLOR = NORD2

// Inputs to signal — "Wait for timeframe closes" maps to gaps: na between HTF
// closes when on. lookahead stays off so historical HTF values never leak early.
// The flat regime is computed inside the engine so an HTF setting measures it
// in HTF bars against HTF ATR; it crosses request.security as a 1/0 float.
f_trendEngine() =>
    float smaValue = ta.sma(source = trendSource, length = trendSmaLength)
    float atrValue = ta.atr(length = 14)
    float netChange = smaValue - smaValue[trendFlatWindow]
    bool isFlatRegime = trendFlatAtrFraction > 0 and not na(netChange) and not na(atrValue) and
         math.abs(netChange) <= trendFlatAtrFraction * atrValue
    [smaValue, smaValue - smaValue[1], isFlatRegime ? 1.0 : 0.0]

[trendSma, trendSlopePerBar, trendFlatRegimeRaw] = request.security(symbol = syminfo.tickerid, timeframe = calcTimeframe,
     expression = f_trendEngine(), gaps = calcWaitForClose ? barmerge.gaps_on : barmerge.gaps_off,
     lookahead = barmerge.lookahead_off)

// Signal to state — the slope's sign classifies the bar; FLAT exists only
// through the regime test, because a per-bar reading can't catch neutral: on
// a sideways MA the one-bar slope keeps real magnitude with alternating sign,
// while the MA's NET movement over the window collapses toward zero. With
// the regime enabled a plateau breaks the count like a direction change —
// up > flat > up resets and re-anchors wave 1. With the regime disabled
// (fraction 0, the default) the state is strictly UP or DOWN — the count
// resets only on a direction change. An na slope (SMA warm-up, HTF gap bar)
// or an exactly-zero slope holds the last state. The gray line, the
// extreme-bar classification, and the wave count's flat break all read this
// same state.
bool trendFlatRegime = nz(source = trendFlatRegimeRaw, replacement = 0) > 0.5
var TrendDir trendDir = TrendDir.FLAT
trendDir := trendFlatRegime ? TrendDir.FLAT :
     trendSlopePerBar > 0 ? TrendDir.UP :
     trendSlopePerBar < 0 ? TrendDir.DOWN : trendDir
color trendColor = switch trendDir
    TrendDir.UP => TREND_UP_COLOR
    TrendDir.DOWN => TREND_DOWN_COLOR
    TrendDir.FLAT => TREND_FLAT_COLOR

// ═════════════════════════════════════════════════════════════════════════════
// 🔄 CYCLES
// Cycle engine (same as stochastic/macd-waves): %D 5/2/3 against the 45/55 band.
// Crossing above 45 starts a high half-cycle, crossing below 55 starts a low
// half-cycle (plus the band-skip variants). Each half-cycle tracks its extreme
// price live (highest high / lowest low) plus the extreme bar's open/close and
// trend state (wave qualification and classification are judged on that bar),
// and exports them with the just-ended half-cycle's final values, for the
// WAVES and PLOT layers. Each bar belongs to the half-cycle
// matching its own %D state (Barry's window rule), so the boundary bar is the
// NEW half-cycle's first bar: the ended cycle's extreme freezes on the bar
// before the cross, and a wave can never pin on a bar of the next half-cycle
// — a stop-run wick on the crossing bar seeds the new cycle instead of
// handing the ended cycle a phantom extreme. The new half-cycle still seeds
// from every bar since the ended extreme — the %D cross lags the price turn
// by a varying number of bars, and any of them may hold the new extreme.
// One wave point per bar: a bar that anchored a half-cycle's extreme is
// consumed, so consecutive wave points (1 then 2, 2 then 3, a then b) never
// share a bar — the seed scan stops one bar short of the ended extreme.
// ═════════════════════════════════════════════════════════════════════════════
// %D above 55 = high zone, below 45 = low zone.
const float CYCLE_LOW_BOUNDARY = 45.0
const float CYCLE_HIGH_BOUNDARY = 55.0
// Longest boundary-seed scan back to the ended cycle's extreme bar.
const int CYCLE_SEED_MAX_LOOKBACK = 200

// Boundary seeding indexes history with a runtime offset — declare the
// buffers so the auto-sized ones (measured on the short early cycles) never
// overflow on a later, longer half-cycle.
max_bars_back(high, CYCLE_SEED_MAX_LOOKBACK)
max_bars_back(low, CYCLE_SEED_MAX_LOOKBACK)
max_bars_back(open, CYCLE_SEED_MAX_LOOKBACK)
max_bars_back(close, CYCLE_SEED_MAX_LOOKBACK)
// The trend state mirrored as ints so the seed scan can index it too
// (max_bars_back needs a simple-type series, which an enum is not).
int trendDirState = trendDir == TrendDir.UP ? 1 : trendDir == TrendDir.DOWN ? -1 : 0
max_bars_back(trendDirState, CYCLE_SEED_MAX_LOOKBACK)

float cycleK = ta.sma(source = ta.stoch(source = close, high = high, low = low, length = cycleKLength), length = cycleKSmoothing)
float cycleD = ta.sma(source = cycleK, length = cycleDSmoothing)
bool crossedAbove45 = ta.crossover(source1 = cycleD, source2 = CYCLE_LOW_BOUNDARY)
bool crossedAbove55 = ta.crossover(source1 = cycleD, source2 = CYCLE_HIGH_BOUNDARY)
bool crossedBelow55 = ta.crossunder(source1 = cycleD, source2 = CYCLE_HIGH_BOUNDARY)
bool crossedBelow45 = ta.crossunder(source1 = cycleD, source2 = CYCLE_LOW_BOUNDARY)

var int cycleZone = 0  // 1 = high half-cycle, -1 = low half-cycle, 0 = unseeded
bool startedHighCycle = crossedAbove45 or (crossedAbove55 and cycleZone == -1)
bool startedLowCycle = crossedBelow55 or (crossedBelow45 and cycleZone == 1)
bool cycleStartedThisBar = startedHighCycle or startedLowCycle

// The open half-cycle's extreme price and its bar, plus the just-ended
// half-cycle's final extreme (na unless a new half-cycle started this bar).
var float cycleExtreme = na
var int cycleExtremeBar = na
var float cycleExtremeOpen = na
var float cycleExtremeClose = na
var TrendDir cycleExtremeTrendDir = TrendDir.FLAT
float endedCycleExtreme = na
int endedCycleExtremeBar = na
float endedCycleExtremeOpen = na
float endedCycleExtremeClose = na
TrendDir endedCycleExtremeTrendDir = TrendDir.FLAT

// Track the open half-cycle's extreme. Skipped on boundary bars: the crossing
// bar's %D already reads the other zone, so the bar belongs to the NEW
// half-cycle and must never move the ended cycle's extreme — it enters
// through the new cycle's seed scan below instead. Ties go to the most
// recent bar (>=/<=), so an equal high/low moves the dot forward.
if cycleZone != 0 and not cycleStartedThisBar and
     ((cycleZone == 1 and high >= cycleExtreme) or (cycleZone == -1 and low <= cycleExtreme))
    cycleExtreme := cycleZone == 1 ? high : low
    cycleExtremeBar := bar_index
    cycleExtremeOpen := open
    cycleExtremeClose := close
    cycleExtremeTrendDir := trendDir

if cycleStartedThisBar
    endedCycleExtreme := cycleExtreme
    endedCycleExtremeBar := cycleExtremeBar
    endedCycleExtremeOpen := cycleExtremeOpen
    endedCycleExtremeClose := cycleExtremeClose
    endedCycleExtremeTrendDir := cycleExtremeTrendDir
    cycleZone := startedHighCycle ? 1 : -1
    // Seed the new half-cycle: scan every eligible bar since the ended
    // extreme — the %D cross lags the price turn by a varying number of bars,
    // and any of them may already hold the new cycle's extreme — plus this
    // boundary bar itself (offset 0), the new cycle's first bar. The ended
    // extreme bar is consumed — one wave point per bar, so consecutive points
    // (1 then 2, 2 then 3, a then b) never share a bar — and the scan stops
    // one bar short of it. Ties keep the most recent bar, like the tracker.
    int cycleSeedLookback = na(endedCycleExtremeBar) ? 1 : math.min(bar_index - endedCycleExtremeBar - 1, CYCLE_SEED_MAX_LOOKBACK)
    float cycleSeedExtreme = startedHighCycle ? high : low
    int cycleSeedOffset = 0
    if cycleSeedLookback > 0
        for barOffset = 1 to cycleSeedLookback
            float seedCandidate = startedHighCycle ? high[barOffset] : low[barOffset]
            if startedHighCycle ? seedCandidate > cycleSeedExtreme : seedCandidate < cycleSeedExtreme
                cycleSeedExtreme := seedCandidate
                cycleSeedOffset := barOffset
    cycleExtreme := cycleSeedExtreme
    cycleExtremeBar := bar_index - cycleSeedOffset
    cycleExtremeOpen := open[cycleSeedOffset]
    cycleExtremeClose := close[cycleSeedOffset]
    cycleExtremeTrendDir := trendDirState[cycleSeedOffset] == 1 ? TrendDir.UP :
         trendDirState[cycleSeedOffset] == -1 ? TrendDir.DOWN : TrendDir.FLAT

// ═════════════════════════════════════════════════════════════════════════════
// 🌊 WAVES
// Wave structure on top of the cycle extremes (Barry Burns rules).
//
// Trend: read at each half-cycle's extreme bar — Barry judges the MA angle at
// the cycle high/low itself — so same-direction wiggles never reset the count
// (Part 3), and at a trend birth the first cycle low after the MA rolls over
// is already wave 1. A changed reading ends the old count on the spot. The
// live layer samples the same bar, so a mid-cycle change previews the reset
// (wave 1 on the new impulse side, owner downgraded to its letter) ahead of
// the pin.
// Exception — direction break: an OPPOSITE reading on ANY bar of a half-cycle
// also ends the count (Part 5: the count ends as soon as the 50 MA changes
// direction), because the rollover bars usually sit mid-cycle (the MA lags
// price) and the slope can recover by the extreme bar — extreme-bar sampling
// alone then reads the count's trend on both sides of a real top (QQQ 1m
// 2026-07-08 09:00: a two-bar down dip bottomed one bar before the cycle low
// and the up count ran straight from 5 into a 6-owner across the rollover).
// One agreement rule resolves the break: a wave pins only where the extreme
// bar's reading and the boundary bar's reading AGREE. Disagreement (rollover,
// or a lone opposite-slope extreme bar) pins nothing — the count resets and
// takes the boundary's reading, and wave 1 anchors at the next extreme whose
// bar agrees. Full agreement with the old trend after a mid-cycle break
// (dip-and-resume) re-anchors wave 1 of a reborn same-direction count. The
// live layer applies the same rule with the current reading standing in for
// the boundary bar, so no wave ever previews into the other side's trend.
// Exception — flat break: a FLAT reading on ANY bar of a half-cycle ends the
// count at the boundary (Part 5: "as soon as you get the 50 MA going flat,
// the wave count would end"), because the flat stretch usually falls between
// two extreme bars and extreme-bar sampling alone never sees it. After a
// flat break the ended extreme re-anchors wave 1 only if it printed after
// the MA resumed; an extreme from before the flat belongs to the dead count
// and is discarded via a FLAT classification.
//
// Impulse side: qualifies when the cycle's EXTREME bar commits a real body
// past the last CONFIRMED wave extreme — never a failed wave's or a letter
// cycle's — with the open allowed to touch it and the close required to clear
// it. An extreme beyond the baseline without that body commit is a failed
// wave ("F" + number, always bare — a cycle is a failed wave OR a lettered
// retrace cycle, never both; corpus F3s pin inside open zones): it pins,
// advances nothing, and restarts the letters AND the zone's complexity
// count. Wave 1 auto-qualifies. Confirmed impulses move the baseline,
// advance the count by 2, and close the retrace zone.
//
// Retrace zone (between confirmed impulses): every cycle consumes a letter in
// order, and every non-owner cycle shows its letter (Barry: letters mark
// cycles). Letters restart after every wave point — confirmed AND failed. A
// lone "a" is meaningless, so it only plots once the very next cycle shows its
// "b" — live: the "a" previews as soon as the live bare-letter "b" draws, and
// pins with the "b"; a failed wave, confirmed impulse, or trend reset drops it
// (and its preview) instead.
// The most extreme completed retrace owns the even number, stacked with its
// letter once the zone is complex (2+ retraces, live included) and the letter
// is confirmed — the letter on the candle side, the number at the outer edge. Ownership is provisional — a deeper retrace takes the number
// and downgrades the old owner to its letter (an owner "a" that never got its
// "b" is deleted instead); a trend reset does the same when the closing
// impulse never confirmed. Impulse numbers are final once their half-cycle
// ends.
// ═════════════════════════════════════════════════════════════════════════════
const string WAVE_ALPHABET = "abcdefghijklmnopqrstuvwxyz"

// Trend + count state (reset when the boundary-sampled trend changes)
var TrendDir waveTrendDir = TrendDir.FLAT  // the count's trend — the reading at the last classified cycle extreme
var float waveLastImpulseExtreme = na      // last CONFIRMED impulse extreme — the only qualification baseline
var int waveNextImpulseNumber = 1          // number the next impulse attempt is targeting (1, 3, 5, ...)

// Retrace-zone state (between two confirmed impulses)
var int waveZoneNextLetterIndex = 0        // next letter consumed by a cycle inside the zone
var int waveZoneRetraceCount = 0           // completed retrace-side cycles in the zone
var float waveZoneBestExtreme = na         // most extreme completed retrace price — owns the even number
var int waveZoneBestLetterIndex = -1       // the owner's letter (stacked under its number when complex)
var bool waveZoneOwnerAConfirmed = true    // an owner "a" displays only after its "b" confirms
var bool waveZoneOwnerAPending = false     // owner "a" awaiting the very next cycle's verdict

// A lone letter-"a" pin is held here until the very next cycle shows its "b"
// (previewed live, made permanent on the pin); a failed wave, confirmed
// impulse, or trend reset drops it instead.
var float wavePendingAPrice = na
var int wavePendingABar = na
var bool wavePendingAIsHighSide = false

// Per-open-cycle state
var int waveCycleLetterIndex = -1          // letter consumed by the open cycle (-1 = outside a zone)

// Flat-break latch — a FLAT trend reading anywhere in the open half-cycle
// (boundary bar included) breaks the count at the next boundary. Consumed and
// cleared there.
var bool waveCycleSawFlat = false
var int waveLastFlatBar = na
if trendDir == TrendDir.FLAT
    waveCycleSawFlat := true
    waveLastFlatBar := bar_index

// Direction-break latch — a reading OPPOSITE to the count's trend anywhere in
// the open half-cycle (boundary bar included) breaks the count at the next
// boundary even when the extreme bar reads the count's trend again. Consumed
// and cleared there, like the flat latch.
var bool waveCycleSawOpposite = false
if waveTrendDir != TrendDir.FLAT and trendDir != TrendDir.FLAT and trendDir != waveTrendDir
    waveCycleSawOpposite := true

// Helper function to look up a zone letter (wraps past 'z').
f_waveLetterAt(int letterIndex) =>
    int wrappedIndex = letterIndex % 26
    str.substring(source = WAVE_ALPHABET, begin_pos = wrappedIndex, end_pos = wrappedIndex + 1)

// Helper function building a retrace label: plain number while the zone is
// simple, number stacked with the letter once it is complex. The letter always
// sits on the candle side and the number at the outer edge — above the candle
// the number is the top line, below the candle it is the bottom line.
f_waveRetraceText(int retraceNumber, int letterIndex, bool zoneIsComplex, bool isHighSide) =>
    string numberText = str.tostring(value = retraceNumber)
    if zoneIsComplex and letterIndex >= 0
        string letterText = f_waveLetterAt(letterIndex = letterIndex)
        isHighSide ? numberText + "\n" + letterText : letterText + "\n" + numberText
    else
        numberText

// ── Cycle boundary processing — classify the ended half-cycle, then seed the
// new one. Exports for PLOT: the ended cycle's pin text ("" = drop its live
// label), whether the pinned label takes retrace-number ownership, a one-shot
// downgrade text or delete flag for the old owner (deeper takeover or trend
// reset), an owner-ref clear flag, and a released held-"a" to draw.
string waveEndedLabelText = ""
bool waveEndedBecomesOwner = false
string waveEndedOwnerDowngradeText = ""
bool waveEndedOwnerDelete = false
bool waveOwnerClear = false
float wavePendingAReleasePrice = na
int wavePendingAReleaseBar = na
bool wavePendingAReleaseIsHighSide = false

if cycleStartedThisBar
    bool hadPendingA = not na(wavePendingAPrice)
    bool hadOwnerAPending = waveZoneOwnerAPending
    bool endedPinnedBareLetter = false
    // The ended cycle is classified by the trend on its own extreme bar; an
    // unseeded first cycle (na extreme) falls back to the boundary reading.
    TrendDir endedCycleTrendDir = na(endedCycleExtreme) ? trendDir : endedCycleExtremeTrendDir
    // Flat break: a FLAT stretch inside the ended half-cycle ends the count
    // even when the extreme bar itself reads the count's trend. An extreme
    // from before the flat belongs to the dead count — classify it FLAT so it
    // pins nothing; one printed after the MA resumed re-anchors wave 1 below.
    bool endedCycleFlatBroke = waveCycleSawFlat and waveTrendDir != TrendDir.FLAT
    // One agreement rule resolves every direction case: a wave pins only
    // where the extreme bar's reading and the boundary bar's reading AGREE —
    // a bar can never receive a wave from a trend that wasn't standing at
    // both ends of the verdict. Disagreement (a rollover whose extreme
    // closed in the old trend — QQQ 2m 2026-07-10 08:44 — or a lone
    // opposite-slope extreme bar inside a standing trend) pins NOTHING: the
    // count resets, takes the boundary's reading, and wave 1 anchors at the
    // next extreme whose bar agrees. Full agreement with the OLD trend after
    // a mid-cycle break (dip-and-resume, QQQ 2m 2026-07-09 09:58) re-anchors
    // wave 1 of a reborn same-direction count. A flat break supersedes both:
    // the MA stalled rather than turned, and the flat rules below own it.
    bool endedCycleRebirth = waveCycleSawOpposite and not endedCycleFlatBroke and waveTrendDir != TrendDir.FLAT and
         endedCycleTrendDir == waveTrendDir and trendDir == waveTrendDir
    bool endedCycleBarMismatch = not endedCycleFlatBroke and endedCycleTrendDir != TrendDir.FLAT and
         trendDir != TrendDir.FLAT and endedCycleTrendDir != trendDir
    if endedCycleBarMismatch
        endedCycleTrendDir := trendDir
    if endedCycleFlatBroke and not na(endedCycleExtremeBar) and endedCycleExtremeBar <= waveLastFlatBar
        endedCycleTrendDir := TrendDir.FLAT
    if endedCycleTrendDir != waveTrendDir or endedCycleFlatBroke or endedCycleRebirth or endedCycleBarMismatch
        // The old count ended. An owner whose closing impulse never confirmed
        // was only ever a cycle — it keeps its letter, not the even number;
        // an owner "a" that never got its "b" disappears instead.
        if not na(waveZoneBestExtreme) and waveZoneBestLetterIndex >= 0
            if waveZoneBestLetterIndex == 0 and not waveZoneOwnerAConfirmed
                waveEndedOwnerDelete := true
            else
                waveEndedOwnerDowngradeText := f_waveLetterAt(letterIndex = waveZoneBestLetterIndex)
        waveLastImpulseExtreme := na
        waveNextImpulseNumber := 1
        waveZoneNextLetterIndex := 0
        waveZoneRetraceCount := 0
        waveZoneBestExtreme := na
        waveZoneBestLetterIndex := -1
        waveOwnerClear := true
    waveTrendDir := endedCycleTrendDir
    // Falls through after a reset too, so a low whose extreme printed under
    // the newborn trend anchors wave 1 immediately — no discarded cycle.
    // Exception: a rollover-flipped extreme (bar mismatch) is discarded — its
    // bar closed in the old trend and can't receive the newborn count's wave.
    if waveTrendDir != TrendDir.FLAT and not na(endedCycleExtreme) and not endedCycleBarMismatch
        bool endedIsImpulseSide = (waveTrendDir == TrendDir.UP) == startedLowCycle
        if endedIsImpulseSide
            // Qualification is judged on the ended cycle's extreme bar against
            // the last CONFIRMED wave extreme only.
            bool endedWickBeyond = not na(waveLastImpulseExtreme) and
                 (waveTrendDir == TrendDir.UP ? endedCycleExtreme > waveLastImpulseExtreme : endedCycleExtreme < waveLastImpulseExtreme)
            bool endedBodyCommits = not na(waveLastImpulseExtreme) and
                 (waveTrendDir == TrendDir.UP ?
                     endedCycleExtremeOpen >= waveLastImpulseExtreme and endedCycleExtremeClose > waveLastImpulseExtreme :
                     endedCycleExtremeOpen <= waveLastImpulseExtreme and endedCycleExtremeClose < waveLastImpulseExtreme)
            if waveNextImpulseNumber == 1 or endedBodyCommits
                // Confirmed impulse — advance the count, move the baseline, close the zone.
                waveEndedLabelText := str.tostring(value = waveNextImpulseNumber)
                waveLastImpulseExtreme := endedCycleExtreme
                waveNextImpulseNumber := waveNextImpulseNumber + 2
                waveZoneNextLetterIndex := 0
                waveZoneRetraceCount := 0
                waveZoneBestExtreme := na
                waveZoneBestLetterIndex := -1
                waveOwnerClear := true
            else if endedWickBeyond
                // Failed wave — wick passed the baseline, no real body did. It
                // pins bare and advances nothing: a cycle is a failed wave OR
                // a lettered retrace cycle, never both (corpus F3s pin inside
                // open zones; F labels always print bare). The letters and the
                // zone's complexity count restart after it just like after a
                // real wave. Ownership survives: the even number is still the
                // extreme between the confirmed impulses ("the 8 goes over
                // here because it's still looking for a full 9").
                waveEndedLabelText := "F" + str.tostring(value = waveNextImpulseNumber)
                waveZoneNextLetterIndex := 0
                waveZoneRetraceCount := 0
            else if waveCycleLetterIndex >= 0
                // No break at all — just a lettered cycle inside the open zone.
                waveEndedLabelText := f_waveLetterAt(letterIndex = waveCycleLetterIndex)
                endedPinnedBareLetter := true
        else if waveNextImpulseNumber > 1
            // Retrace-side cycle completed inside the open zone.
            waveZoneRetraceCount := waveZoneRetraceCount + 1
            bool zoneIsComplex = waveZoneRetraceCount >= 2
            bool takesOwnership = na(waveZoneBestExtreme) or
                 (waveTrendDir == TrendDir.UP ? endedCycleExtreme < waveZoneBestExtreme : endedCycleExtreme > waveZoneBestExtreme)
            int waveRetraceNumber = waveNextImpulseNumber - 1
            if takesOwnership
                if not na(waveZoneBestExtreme) and waveZoneBestLetterIndex >= 0
                    if waveZoneBestLetterIndex == 0 and not waveZoneOwnerAConfirmed
                        waveEndedOwnerDelete := true
                    else
                        waveEndedOwnerDowngradeText := f_waveLetterAt(letterIndex = waveZoneBestLetterIndex)
                waveZoneBestExtreme := endedCycleExtreme
                waveZoneBestLetterIndex := waveCycleLetterIndex
                // A new owner's "a" stays hidden (plain number, no stack)
                // until the very next cycle confirms its "b".
                waveZoneOwnerAConfirmed := waveCycleLetterIndex != 0
                waveZoneOwnerAPending := waveCycleLetterIndex == 0
                waveEndedLabelText := f_waveRetraceText(retraceNumber = waveRetraceNumber, letterIndex = waveCycleLetterIndex == 0 ? -1 : waveCycleLetterIndex, zoneIsComplex = zoneIsComplex, isHighSide = waveTrendDir == TrendDir.DOWN)
                waveEndedBecomesOwner := true
            else if zoneIsComplex and waveCycleLetterIndex >= 1
                waveEndedLabelText := f_waveLetterAt(letterIndex = waveCycleLetterIndex)
                endedPinnedBareLetter := true
            else if waveCycleLetterIndex == 0
                // A lone "a" — hold it until the next cycle confirms its "b".
                wavePendingAPrice := endedCycleExtreme
                wavePendingABar := endedCycleExtremeBar
                wavePendingAIsHighSide := startedLowCycle
    // Seed the new cycle — consume a letter while a zone is open.
    waveCycleLetterIndex := -1
    if waveTrendDir != TrendDir.FLAT and waveNextImpulseNumber > 1
        waveCycleLetterIndex := waveZoneNextLetterIndex
        waveZoneNextLetterIndex := waveZoneNextLetterIndex + 1
    // Resolve held "a"s from the previous boundary: only a plain-letter pin by
    // the very next cycle (its "b") confirms them — a failed wave, confirmed
    // impulse, or trend reset drops them for good.
    if hadPendingA
        if endedPinnedBareLetter
            wavePendingAReleasePrice := wavePendingAPrice
            wavePendingAReleaseBar := wavePendingABar
            wavePendingAReleaseIsHighSide := wavePendingAIsHighSide
        wavePendingAPrice := na
        wavePendingABar := na
    if hadOwnerAPending
        waveZoneOwnerAConfirmed := endedPinnedBareLetter
        waveZoneOwnerAPending := false
    waveCycleSawFlat := false  // the flat break was consumed with the ended cycle
    waveCycleSawOpposite := false  // and so was the direction break

// ── Live trend, sampled where the boundary will sample it: the open cycle's
// own extreme bar. When that reading differs from the count's trend, the
// boundary is going to reset — so the live layer previews the reset (count
// restarts at 1, owner downgrades to its letter) instead of extending the old
// count. Preview only; the boundary owns all state, and the preview reverts
// if a new extreme bar reads the old trend again.
TrendDir waveLiveTrendDir = na(cycleExtreme) ? waveTrendDir : cycleExtremeTrendDir
bool waveLiveFlatBroke = waveCycleSawFlat and waveTrendDir != TrendDir.FLAT
// Direction-break preview — mirrors the boundary's agreement rule with the
// CURRENT trend reading standing in for the boundary bar: the label only
// previews while the extreme bar's reading matches it, so a wave can never
// preview into the other side's standing trend — a lone opposite-slope
// extreme bar, or a new-trend extreme while the MA has already flipped back,
// previews nothing (FLAT = "label dropped", like the flat-break preview). A
// mid-cycle break with full agreement on the old trend previews the
// same-direction rebirth (wave 1).
bool waveLivePreviewsRebirth = waveCycleSawOpposite and not waveLiveFlatBroke and waveTrendDir != TrendDir.FLAT and
     waveLiveTrendDir == waveTrendDir and trendDir == waveTrendDir and not na(cycleExtreme)
if waveLiveTrendDir != TrendDir.FLAT and trendDir != TrendDir.FLAT and waveLiveTrendDir != trendDir
    waveLiveTrendDir := TrendDir.FLAT
// Flat-break preview — mirrors the boundary: an extreme from before the flat
// reads FLAT (its label will be dropped), one after it previews the re-anchor.
if waveLiveFlatBroke and not na(cycleExtremeBar) and cycleExtremeBar <= waveLastFlatBar
    waveLiveTrendDir := TrendDir.FLAT
bool waveLivePreviewsReset = cycleZone != 0 and (waveLiveTrendDir != waveTrendDir or waveLiveFlatBroke or waveLivePreviewsRebirth)

// ── Live qualification of the open impulse-side half-cycle, judged on the
// current extreme bar and re-evaluated as the extreme moves. The open may
// equal the last confirmed wave extreme; the close must clear it, whatever
// the bar's color ("a green bar closing equal to the low of wave one is not
// a wave three"). An extreme beyond the baseline without the body = failed.
bool waveCycleIsImpulseSide = cycleZone != 0 and waveLiveTrendDir != TrendDir.FLAT and (waveLiveTrendDir == TrendDir.UP) == (cycleZone == 1)
bool waveLiveWickBeyond = false
bool waveLiveBodyCommits = false
if waveCycleIsImpulseSide and not waveLivePreviewsReset and not na(waveLastImpulseExtreme) and not na(cycleExtreme)
    waveLiveWickBeyond := waveTrendDir == TrendDir.UP ? cycleExtreme > waveLastImpulseExtreme : cycleExtreme < waveLastImpulseExtreme
    waveLiveBodyCommits := waveTrendDir == TrendDir.UP ?
         cycleExtremeOpen >= waveLastImpulseExtreme and cycleExtremeClose > waveLastImpulseExtreme :
         cycleExtremeOpen <= waveLastImpulseExtreme and cycleExtremeClose < waveLastImpulseExtreme

// ── Live classification of the open half-cycle, re-evaluated every bar. A
// failed wave upgrades to its full number in place if a deeper extreme bar
// commits the body — and downgrades back if a wick-only bar takes the extreme.
string waveLiveLabelText = ""
bool waveLiveShowsLetter = false  // the live label is the cycle's bare letter
if cycleZone != 0 and waveLiveTrendDir != TrendDir.FLAT
    int waveLiveImpulseNumber = waveLivePreviewsReset ? 1 : waveNextImpulseNumber
    if waveCycleIsImpulseSide
        if waveLiveImpulseNumber == 1 or waveLiveBodyCommits
            waveLiveLabelText := str.tostring(value = waveLiveImpulseNumber)
        else if waveLiveWickBeyond
            waveLiveLabelText := "F" + str.tostring(value = waveLiveImpulseNumber)
        else if waveCycleLetterIndex >= 0
            waveLiveLabelText := f_waveLetterAt(letterIndex = waveCycleLetterIndex)
            waveLiveShowsLetter := true
    else if not waveLivePreviewsReset and waveNextImpulseNumber > 1
        bool liveTakesOwnership = na(waveZoneBestExtreme) or
             (waveTrendDir == TrendDir.UP ? cycleExtreme < waveZoneBestExtreme : cycleExtreme > waveZoneBestExtreme)
        bool zoneIsComplexLive = waveZoneRetraceCount + 1 >= 2  // the live retrace counts toward complexity
        if liveTakesOwnership
            // A live "a" can never be confirmed yet — preview the plain number.
            waveLiveLabelText := f_waveRetraceText(retraceNumber = waveNextImpulseNumber - 1, letterIndex = waveCycleLetterIndex == 0 ? -1 : waveCycleLetterIndex, zoneIsComplex = zoneIsComplexLive, isHighSide = waveTrendDir == TrendDir.DOWN)
        else if zoneIsComplexLive and waveCycleLetterIndex >= 1
            waveLiveLabelText := f_waveLetterAt(letterIndex = waveCycleLetterIndex)
            waveLiveShowsLetter := true

// ── Authoritative owner text, recomputed every bar: while a live retrace is
// provisionally deeper than the owner, the owner previews its letter; it
// reverts to its number (stacked when complex) otherwise.
string waveOwnerText = ""
bool waveOwnerHasZone = not na(waveZoneBestExtreme)
if waveOwnerHasZone
    // The owner's letter only displays once confirmed — an "a" without its
    // "b" keeps the plain number (or an empty preview while a live retrace is
    // provisionally deeper or a trend reset is being previewed).
    bool ownerLetterShowable = waveZoneBestLetterIndex >= 1 or (waveZoneBestLetterIndex == 0 and waveZoneOwnerAConfirmed)
    if waveLivePreviewsReset
        // Trend changed on the live extreme bar — preview the boundary's owner
        // downgrade: bare letter, blank for an unconfirmed "a".
        waveOwnerText := ownerLetterShowable ? f_waveLetterAt(letterIndex = waveZoneBestLetterIndex) : ""
    else
        bool liveIsRetraceSide = cycleZone != 0 and waveTrendDir != TrendDir.FLAT and not waveCycleIsImpulseSide and waveNextImpulseNumber > 1
        bool liveIsDeeper = liveIsRetraceSide and (waveTrendDir == TrendDir.UP ? cycleExtreme < waveZoneBestExtreme : cycleExtreme > waveZoneBestExtreme)
        bool zoneIsComplexNow = waveZoneRetraceCount + (liveIsRetraceSide ? 1 : 0) >= 2
        if liveIsDeeper
            waveOwnerText := zoneIsComplexNow and ownerLetterShowable ? f_waveLetterAt(letterIndex = waveZoneBestLetterIndex) : ""
        else
            waveOwnerText := f_waveRetraceText(retraceNumber = waveNextImpulseNumber - 1, letterIndex = ownerLetterShowable ? waveZoneBestLetterIndex : -1, zoneIsComplex = zoneIsComplexNow, isHighSide = waveTrendDir == TrendDir.DOWN)

color waveLabelColor = waveTrendDir == TrendDir.DOWN ? waveDownColor : waveUpColor
color waveLiveLabelColor = waveLiveTrendDir == TrendDir.DOWN ? waveDownColor : waveUpColor

// ═════════════════════════════════════════════════════════════════════════════
// 📊 PLOT
// Render layer — the SMA plot plus all label drawing. Series, state, texts,
// and ownership flags are computed in their owning sections above.
// ═════════════════════════════════════════════════════════════════════════════
plot(series = trendSma, title = "SMA", color = trendColor, linewidth = 3, offset = trendSmaOffset)

// Helper function to create a wave text label on first use or update it afterwards.
// High-side labels sit above the extreme, low-side labels below it.
f_upsertWaveLabel(label existingLabel, int labelBarIndex, float labelPrice, string labelText, color labelTextColor, bool isHighSide) =>
    label updatedLabel = existingLabel
    if na(updatedLabel)
        updatedLabel := label.new(x = labelBarIndex, y = labelPrice, text = labelText, xloc = xloc.bar_index, yloc = yloc.price,
             style = isHighSide ? label.style_label_down : label.style_label_up,
             color = color.new(color = color.gray, transp = 100), textcolor = labelTextColor, size = waveLabelSize)
    else
        label.set_xy(id = updatedLabel, x = labelBarIndex, y = labelPrice)
        label.set_text(id = updatedLabel, text = labelText)
        label.set_textcolor(id = updatedLabel, textcolor = labelTextColor)
    updatedLabel

// Wave label — live once the staleness gate below opens, pinned (or dropped)
// on the %D cross. The retrace-number owner's label ref is kept so a deeper retrace or
// a trend reset can downgrade it to its letter, and the authoritative owner
// text is re-applied every confirmed bar (provisional-retrace repaint
// semantics; impulse pins are final).
var label waveNumberLabel = na
var label waveZoneOwnerLabel = na
var label wavePendingALabel = na  // the held "a", drawn provisionally while the live "b" shows
// Live display gate: the live label shows only while the cycle's extreme sits
// on a CLOSED bar the current bar hasn't extended — the earliest evidence
// that the extreme is a turning point rather than the running edge of the
// move. It renders TICK-TIME in realtime (the block at the end of the file):
// the extreme bar being closed means the label's identity is computed from
// final OHLC and can't morph intrabar, so the label appears at the first tick
// that trades on a new bar with the extreme intact and hides the instant the
// forming bar takes it out (Pine rolls intrabar drawing changes back, so
// state stays consistent). The re-arm means a label can never sit on an
// extreme the market is actively breaking. Unconfirmed boundary ticks are the
// one exception: an intrabar %D cross reseeds the cycle and would flash the
// new cycle's label before the pin, so those ticks wait for the close.
bool waveLiveLabelDrawn = not na(cycleExtreme) and cycleExtremeBar != bar_index and waveLiveLabelText != "" and
     (barstate.isconfirmed or not cycleStartedThisBar)
// Close-only gate for everything else — pins, owner downgrades, and the held
// "a": an intrabar %D cross can recede before the close, so those label
// mutations wait for the bar's confirming tick, where the extreme tracking
// and boundary state above have already seen the bar's final values. Wave
// STATE is untouched — it still updates every tick and rolls back.
if barstate.isconfirmed
    if cycleStartedThisBar
        if waveEndedOwnerDelete and not na(waveZoneOwnerLabel)
            label.delete(id = waveZoneOwnerLabel)  // an owner "a" that never earned its "b"
            waveZoneOwnerLabel := na
        if waveEndedOwnerDowngradeText != "" and not na(waveZoneOwnerLabel)
            label.set_text(id = waveZoneOwnerLabel, text = waveEndedOwnerDowngradeText)
        if waveEndedLabelText != ""
            waveNumberLabel := f_upsertWaveLabel(existingLabel = waveNumberLabel, labelBarIndex = endedCycleExtremeBar,
                 labelPrice = endedCycleExtreme, labelText = waveEndedLabelText, labelTextColor = waveLabelColor, isHighSide = startedLowCycle)
            if waveEndedBecomesOwner
                waveZoneOwnerLabel := waveNumberLabel
        else if not na(waveNumberLabel)
            label.delete(id = waveNumberLabel)  // the ended cycle earned no pin (unqualified or trend reset)
        waveNumberLabel := na  // the next label belongs to the new half-cycle
        if waveOwnerClear
            waveZoneOwnerLabel := na  // zone closed or structure reset — the label stays, the ref is dropped
        if not na(wavePendingAReleasePrice)
            // The held "a" earned its "b" — make its preview permanent (or draw it
            // retroactively if the live "b" never showed). Dropping the ref keeps
            // the preview block below from deleting it.
            label releasedALabel = f_upsertWaveLabel(existingLabel = wavePendingALabel, labelBarIndex = wavePendingAReleaseBar,
                 labelPrice = wavePendingAReleasePrice, labelText = f_waveLetterAt(letterIndex = 0), labelTextColor = waveLabelColor, isHighSide = wavePendingAReleaseIsHighSide)
            wavePendingALabel := na
    // Held-"a" preview: a lone "a" is meaningless, but once the very next cycle's
    // live bare-letter "b" is drawing, the "a" has meaning — show it now instead
    // of waiting for the %D cross to pin the "b". Provisional like every live
    // label: it deletes if the open cycle upgrades to a number or failed wave
    // (the boundary then drops the held "a" for good).
    bool wavePendingAPreviewed = not na(wavePendingAPrice) and waveLiveLabelDrawn and waveLiveShowsLetter
    if wavePendingAPreviewed
        wavePendingALabel := f_upsertWaveLabel(existingLabel = wavePendingALabel, labelBarIndex = wavePendingABar,
             labelPrice = wavePendingAPrice, labelText = f_waveLetterAt(letterIndex = 0), labelTextColor = waveLabelColor, isHighSide = wavePendingAIsHighSide)
    else if not na(wavePendingALabel)
        label.delete(id = wavePendingALabel)
        wavePendingALabel := na
    // Empty owner text is applied too — it blanks an unconfirmed-"a" owner while
    // a live retrace is provisionally deeper (its number is being previewed there).
    if not na(waveZoneOwnerLabel) and waveOwnerHasZone
        label.set_text(id = waveZoneOwnerLabel, text = waveOwnerText)

// Live wave label — tick-time, per the display gate above. On the boundary
// bar's confirming tick this runs AFTER the pin block dropped the old ref, so
// the upsert starts a fresh label for the new half-cycle.
if waveLiveLabelDrawn
    waveNumberLabel := f_upsertWaveLabel(existingLabel = waveNumberLabel, labelBarIndex = cycleExtremeBar,
         labelPrice = cycleExtreme, labelText = waveLiveLabelText, labelTextColor = waveLiveLabelColor, isHighSide = cycleZone == 1)
else if not na(waveNumberLabel)
    label.delete(id = waveNumberLabel)
    waveNumberLabel := na
