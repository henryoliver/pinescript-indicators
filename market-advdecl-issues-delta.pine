//@version=6
indicator(title = "Market Advance-Decline Issues Delta", shorttitle = "📈 A/D Δ", overlay = false, max_lines_count = 400, calc_bars_count = 5000)

// 🧱 CONSTANTS
const string GROUP_MARKET = "🌐 Market"
const string GROUP_GENERAL = "⚙️ General"
const string GROUP_INTRADAY = "📍 Intraday Support/Resistance"

// Nord Theme Colors
const color NORD0 = #2E3440
const color NORD1 = #3B4252
const color NORD2 = #434C5E
const color NORD3 = #4C566A
const color NORD4 = #D8DEE9
const color NORD5 = #E5E9F0
const color NORD6 = #ECEFF4
const color NORD7 = #8FBCBB
const color NORD8 = #88C0D0
const color NORD9 = #81A1C1
const color NORD10 = #5E81AC
const color NORD11 = #BF616A
const color NORD12 = #D08770
const color NORD13 = #EBCB8B
const color NORD14 = #A3BE8C
const color NORD15 = #B48EAD

const int MAX_INTRADAY_LEVELS = 80
const int INTRADAY_LINE_WIDTH = 2

// 🧩 TYPE DEFINITIONS
type TrendSegment
    int x1
    float y1
    int x2
    float y2

// 🎛️ USER INPUT SETTINGS
string market = input.string(
     defval = "NASDAQ 100",
     title = "Market (Index)",
     options = ["NASDAQ 100", "S&P 500", "Dow Jones", "Russell 2000"],
     tooltip = "Selects the market-specific advance and decline issue symbols used to build the A/D delta index.",
     group = GROUP_MARKET
 )

bool showZeroLine = input.bool(defval = true, title = "Show Zero Line", tooltip = "Shows the zero reference line so you can quickly see whether advancing issues are dominating or lagging.", group = GROUP_GENERAL)
string displayMode = input.string(defval = "Line", title = "Plot Style", options = ["Candles", "Line"], tooltip = "Displays the A/D delta index as candles or as a single closing-value line.", group = GROUP_GENERAL)

bool showIntradayStructure = input.bool(defval = true, title = "Show Intraday Support/Resistance", tooltip = "Draws right-extended intraday support and resistance lines only for the latest regular trading session from confirmed body pivots that set new session highs or lows in the A/D delta index.", group = GROUP_INTRADAY)
int intradaySRPivotStrength = input.int(defval = 3, title = "S/R Pivot Strength", minval = 1, maxval = 10, tooltip = "Bars required on each side to confirm an intraday body pivot before a support or resistance level can be drawn.", group = GROUP_INTRADAY)
int intradaySRMaxLevels = input.int(defval = 20, title = "S/R Max Levels", minval = 5, maxval = MAX_INTRADAY_LEVELS, tooltip = "Maximum number of latest-session intraday support and resistance levels to keep on the chart.", group = GROUP_INTRADAY)
int intradaySRLineWidth = input.int(defval = INTRADAY_LINE_WIDTH, title = "S/R Line Width", minval = 1, maxval = 4, tooltip = "Line width for intraday support and resistance levels.", group = GROUP_INTRADAY)
int intradayVisibleLevelsPerSide = input.int(defval = 2, title = "Visible Levels Per Side", minval = 1, maxval = 6, tooltip = "Shows only the nearest intraday support levels below and resistance levels above the current delta value.", group = GROUP_INTRADAY)
int intradaySRExtensionBars = input.int(defval = 60, title = "S/R Extension (Bars)", minval = 1, maxval = 200, tooltip = "How many bars each intraday support/resistance line should extend forward from its pivot bar.", group = GROUP_INTRADAY)
int intradaySRProjectionBars = input.int(defval = 20, title = "S/R Forward Projection (Bars)", minval = 1, maxval = 200, tooltip = "Minimum number of bars each visible support/resistance line should extend beyond the current bar.", group = GROUP_INTRADAY)
bool showTrendLines = input.bool(defval = true, title = "Show Trend Lines", tooltip = "Draws intraday trend lines from confirmed higher lows and lower highs in the latest regular session.", group = GROUP_INTRADAY)
int trendLinePivotStrength = input.int(defval = 3, title = "Trend Pivot Strength", minval = 1, maxval = 10, tooltip = "Bars required on each side to confirm an intraday body pivot before it can be used to form a trend line.", group = GROUP_INTRADAY)
int trendLineWidth = input.int(defval = INTRADAY_LINE_WIDTH, title = "Trend Line Width", minval = 1, maxval = 4, tooltip = "Line width for the active intraday trend line.", group = GROUP_INTRADAY)
int trendLineLookbackBars = input.int(defval = 60, title = "Trend Line Lookback Bars", minval = 10, maxval = 200, tooltip = "How many recent bars of the active trend line should remain visible behind the current bar.", group = GROUP_INTRADAY)
int trendLineProjectionBars = input.int(defval = 60, title = "Trend Line Projection Bars", minval = 1, maxval = 200, tooltip = "How many bars the active trend line should project forward beyond the current bar.", group = GROUP_INTRADAY)
string trendLineStyleInput = input.string(defval = "Dotted", title = "Trend Line Style", options = ["Dotted", "Dashed", "Solid"], tooltip = "Display style for the active intraday trend line.", group = GROUP_INTRADAY)
color trendLineColor = input.color(defval = NORD3, title = "Trend Line Color", tooltip = "Color for the active intraday trend line.", group = GROUP_INTRADAY)

// 🧮 DATA & CALCULATIONS
f_clearLines(array<line> lines) =>
    int lineCount = array.size(id = lines)
    if lineCount > 0
        for lineIndex = 0 to lineCount - 1
            line.delete(id = array.get(id = lines, index = lineIndex))
    array.clear(id = lines)

f_isVisibleIntradayLevel(array<float> levels, float referencePrice, float candidateLevel, int visiblePerSide, bool isResistance) =>
    bool isOnCorrectSide = isResistance ? candidateLevel > referencePrice : candidateLevel < referencePrice
    int closerLevels = 0
    int levelCount = array.size(id = levels)
    if isOnCorrectSide and levelCount > 0
        for levelIndex = 0 to levelCount - 1
            float level = array.get(id = levels, index = levelIndex)
            bool countsAsCloser = isResistance ? level > referencePrice and level < candidateLevel : level < referencePrice and level > candidateLevel
            if countsAsCloser
                closerLevels += 1
    isOnCorrectSide and closerLevels < visiblePerSide

f_lineValueAtBar(int x1, float y1, int x2, float y2, int targetBar) =>
    x2 == x1 ? y2 : y1 + (y2 - y1) * (targetBar - x1) / (x2 - x1)

f_trendLineStyle(string styleInput) =>
    styleInput == "Solid" ? line.style_solid : styleInput == "Dashed" ? line.style_dashed : line.style_dotted

f_isTrendAnchor(TrendSegment trendSegment, int levelBar, float levelPrice) =>
    not na(trendSegment) and ((levelBar == trendSegment.x1 and levelPrice == trendSegment.y1) or (levelBar == trendSegment.x2 and levelPrice == trendSegment.y2))

f_isAnyTrendAnchor(TrendSegment upTrendSegment, TrendSegment downTrendSegment, int levelBar, float levelPrice) =>
    f_isTrendAnchor(trendSegment = upTrendSegment, levelBar = levelBar, levelPrice = levelPrice) or f_isTrendAnchor(trendSegment = downTrendSegment, levelBar = levelBar, levelPrice = levelPrice)

string marketSuffix = switch market
    "NASDAQ 100" => "NQ"
    "S&P 500" => "SP"
    "Dow Jones" => "DJ"
    "Russell 2000" => "RL"
    => "NQ"

string advSymbol = "USI:ADVN." + marketSuffix
string declSymbol = "USI:DECL." + marketSuffix

string advRegularSymbol = ticker.modify(advSymbol, session = session.regular)
string declRegularSymbol = ticker.modify(declSymbol, session = session.regular)

[advOpen, advClose] = request.security(symbol = advRegularSymbol, timeframe = timeframe.period, expression = [open, close], lookahead = barmerge.lookahead_off, gaps = barmerge.gaps_off, ignore_invalid_symbol = true)
[declOpen, declClose] = request.security(symbol = declRegularSymbol, timeframe = timeframe.period, expression = [open, close], lookahead = barmerge.lookahead_off, gaps = barmerge.gaps_off, ignore_invalid_symbol = true)

float deltaOpen = advOpen - declOpen
float deltaClose = advClose - declClose
// Use body extremes intentionally so intraday structure is based on confirmed closes/opens, not wick noise.
float deltaHigh = math.max(deltaOpen, deltaClose)
float deltaLow = math.min(deltaOpen, deltaClose)

bool inRegularSession = session.ismarket
int regularSessionDayKey = year * 10000 + month * 100 + dayofmonth
int currentTradingDayKey = year(timenow) * 10000 + month(timenow) * 100 + dayofmonth(timenow)
bool isCurrentTradingDay = regularSessionDayKey == currentTradingDayKey

float intradaySRPivotHigh = ta.pivothigh(source = deltaHigh, leftbars = intradaySRPivotStrength, rightbars = intradaySRPivotStrength)
float intradaySRPivotLow = ta.pivotlow(source = deltaLow, leftbars = intradaySRPivotStrength, rightbars = intradaySRPivotStrength)
int intradaySRPivotHighBar = not na(intradaySRPivotHigh) ? bar_index - intradaySRPivotStrength : na
int intradaySRPivotLowBar = not na(intradaySRPivotLow) ? bar_index - intradaySRPivotStrength : na
float trendPivotHigh = ta.pivothigh(source = deltaHigh, leftbars = trendLinePivotStrength, rightbars = trendLinePivotStrength)
float trendPivotLow = ta.pivotlow(source = deltaLow, leftbars = trendLinePivotStrength, rightbars = trendLinePivotStrength)
int trendPivotHighBar = not na(trendPivotHigh) ? bar_index - trendLinePivotStrength : na
int trendPivotLowBar = not na(trendPivotLow) ? bar_index - trendLinePivotStrength : na

var int sessionStartBarIndex = na
var int latestRegularSessionDayKey = na
var float previousTrendHighLevel = na
var int previousTrendHighBar = na
var float previousTrendLowLevel = na
var int previousTrendLowBar = na

var array<float> intradayResistanceLevels = array.new<float>()
var array<int> intradayResistanceBars = array.new<int>()
var array<float> intradaySupportLevels = array.new<float>()
var array<int> intradaySupportBars = array.new<int>()
var TrendSegment activeUpTrend = na
var TrendSegment activeDownTrend = na

var array<line> renderedLines = array.new<line>()

if inRegularSession and isCurrentTradingDay and (na(latestRegularSessionDayKey) or regularSessionDayKey != latestRegularSessionDayKey)
    latestRegularSessionDayKey := regularSessionDayKey
    sessionStartBarIndex := bar_index
    previousTrendHighLevel := na
    previousTrendHighBar := na
    previousTrendLowLevel := na
    previousTrendLowBar := na
    activeUpTrend := na
    activeDownTrend := na
    array.clear(id = intradayResistanceLevels)
    array.clear(id = intradayResistanceBars)
    array.clear(id = intradaySupportLevels)
    array.clear(id = intradaySupportBars)

if inRegularSession and isCurrentTradingDay and barstate.isconfirmed
    if showIntradayStructure and not na(intradaySRPivotHigh)
        if not na(sessionStartBarIndex) and intradaySRPivotHighBar >= sessionStartBarIndex
            array.push(id = intradayResistanceLevels, value = intradaySRPivotHigh)
            array.push(id = intradayResistanceBars, value = intradaySRPivotHighBar)
            while array.size(id = intradayResistanceLevels) > intradaySRMaxLevels
                array.shift(id = intradayResistanceLevels)
                array.shift(id = intradayResistanceBars)

    if showIntradayStructure and not na(intradaySRPivotLow)
        if not na(sessionStartBarIndex) and intradaySRPivotLowBar >= sessionStartBarIndex
            array.push(id = intradaySupportLevels, value = intradaySRPivotLow)
            array.push(id = intradaySupportBars, value = intradaySRPivotLowBar)
            while array.size(id = intradaySupportLevels) > intradaySRMaxLevels
                array.shift(id = intradaySupportLevels)
                array.shift(id = intradaySupportBars)

    if showTrendLines and not na(trendPivotHigh)
        if not na(sessionStartBarIndex) and trendPivotHighBar >= sessionStartBarIndex
            if not na(previousTrendHighLevel) and trendPivotHigh < previousTrendHighLevel
                activeDownTrend := TrendSegment.new(previousTrendHighBar, previousTrendHighLevel, trendPivotHighBar, trendPivotHigh)
            previousTrendHighLevel := trendPivotHigh
            previousTrendHighBar := trendPivotHighBar

    if showTrendLines and not na(trendPivotLow)
        if not na(sessionStartBarIndex) and trendPivotLowBar >= sessionStartBarIndex
            if not na(previousTrendLowLevel) and trendPivotLow > previousTrendLowLevel
                activeUpTrend := TrendSegment.new(previousTrendLowBar, previousTrendLowLevel, trendPivotLowBar, trendPivotLow)
            previousTrendLowLevel := trendPivotLow
            previousTrendLowBar := trendPivotLowBar

// 📊 VISUALIZATION
bool useCandles = displayMode == "Candles"
bool isUpCandle = deltaClose >= deltaOpen
// Hollow candles by design so the border and body direction stay readable without obscuring the intraday lines.
color candleBodyColor = isUpCandle ? color.new(color = NORD8, transp = 100) : color.new(color = NORD9, transp = 100)
color candleBorderColor = isUpCandle ? color.new(color = NORD8, transp = 20) : color.new(color = NORD9, transp = 60)
color lineColor = deltaClose >= nz(deltaClose[1], deltaClose) ? color.new(color = NORD8, transp = 20) : color.new(color = NORD9, transp = 60)
color intradayStructureColor = NORD3

plotcandle(
     open = useCandles ? deltaOpen : na,
     high = useCandles ? deltaHigh : na,
     low = useCandles ? deltaLow : na,
     close = useCandles ? deltaClose : na,
     title = "Advance-Decline Delta (Candles)",
     color = candleBodyColor,
     wickcolor = candleBodyColor,
     bordercolor = candleBorderColor,
     editable = true
 )

plot(
     useCandles ? na : deltaClose,
     title = "Advance-Decline Delta (Line)",
     color = lineColor,
     style = plot.style_line,
     linewidth = 3
 )

hline(price = 0, title = "Zero Line", color = showZeroLine ? NORD1 : na, linestyle = hline.style_solid, linewidth = 4, editable = true)

// 🖊️ RENDERING
if barstate.islastconfirmedhistory or barstate.islast
    f_clearLines(lines = renderedLines)
    int trendVisibleWindowStart = math.max(0, bar_index - trendLineLookbackBars + 1)
    bool showCurrentSessionIntraday = latestRegularSessionDayKey == currentTradingDayKey
    resolvedTrendStyle = f_trendLineStyle(styleInput = trendLineStyleInput)

    if showIntradayStructure and showCurrentSessionIntraday
        int resistanceLevelCount = array.size(id = intradayResistanceLevels)
        if resistanceLevelCount > 0
            for resistanceIndex = 0 to resistanceLevelCount - 1
                float resistanceLevel = array.get(id = intradayResistanceLevels, index = resistanceIndex)
                int resistanceBar = array.get(id = intradayResistanceBars, index = resistanceIndex)
                bool showResistanceLevel = f_isVisibleIntradayLevel(levels = intradayResistanceLevels, referencePrice = deltaClose, candidateLevel = resistanceLevel, visiblePerSide = intradayVisibleLevelsPerSide, isResistance = true)
                bool resistanceIsTrendAnchor = f_isAnyTrendAnchor(upTrendSegment = activeUpTrend, downTrendSegment = activeDownTrend, levelBar = resistanceBar, levelPrice = resistanceLevel)
                if showResistanceLevel and not resistanceIsTrendAnchor and resistanceBar >= sessionStartBarIndex
                    int resistanceEndBar = math.max(resistanceBar + intradaySRExtensionBars, bar_index + intradaySRProjectionBars)
                    line resistanceLine = line.new(x1 = resistanceBar, y1 = resistanceLevel, x2 = resistanceEndBar, y2 = resistanceLevel, xloc = xloc.bar_index, extend = extend.none, color = intradayStructureColor, width = intradaySRLineWidth, style = line.style_solid)
                    array.push(id = renderedLines, value = resistanceLine)
        int supportLevelCount = array.size(id = intradaySupportLevels)
        if supportLevelCount > 0
            for supportIndex = 0 to supportLevelCount - 1
                float supportLevel = array.get(id = intradaySupportLevels, index = supportIndex)
                int supportBar = array.get(id = intradaySupportBars, index = supportIndex)
                bool showSupportLevel = f_isVisibleIntradayLevel(levels = intradaySupportLevels, referencePrice = deltaClose, candidateLevel = supportLevel, visiblePerSide = intradayVisibleLevelsPerSide, isResistance = false)
                bool supportIsTrendAnchor = f_isAnyTrendAnchor(upTrendSegment = activeUpTrend, downTrendSegment = activeDownTrend, levelBar = supportBar, levelPrice = supportLevel)
                if showSupportLevel and not supportIsTrendAnchor and supportBar >= sessionStartBarIndex
                    int supportEndBar = math.max(supportBar + intradaySRExtensionBars, bar_index + intradaySRProjectionBars)
                    line supportLine = line.new(x1 = supportBar, y1 = supportLevel, x2 = supportEndBar, y2 = supportLevel, xloc = xloc.bar_index, extend = extend.none, color = intradayStructureColor, width = intradaySRLineWidth, style = line.style_solid)
                    array.push(id = renderedLines, value = supportLine)

    if showTrendLines and showCurrentSessionIntraday
        if not na(activeDownTrend)
            int downTrendStartBar = activeDownTrend.x1
            float downTrendStartLevel = activeDownTrend.y1
            int downTrendPivotBar = activeDownTrend.x2
            float downTrendPivotLevel = activeDownTrend.y2
            if downTrendStartBar >= sessionStartBarIndex
                int downTrendEndBar = bar_index + trendLineProjectionBars
                int downTrendVisibleStart = math.max(downTrendStartBar, trendVisibleWindowStart)
                if downTrendEndBar > downTrendVisibleStart
                    float downTrendVisibleStartY = f_lineValueAtBar(x1 = downTrendStartBar, y1 = downTrendStartLevel, x2 = downTrendPivotBar, y2 = downTrendPivotLevel, targetBar = downTrendVisibleStart)
                    float downTrendVisibleEndY = f_lineValueAtBar(x1 = downTrendStartBar, y1 = downTrendStartLevel, x2 = downTrendPivotBar, y2 = downTrendPivotLevel, targetBar = downTrendEndBar)
                    line activeDownTrendLine = line.new(x1 = downTrendVisibleStart, y1 = downTrendVisibleStartY, x2 = downTrendEndBar, y2 = downTrendVisibleEndY, xloc = xloc.bar_index, extend = extend.none, color = trendLineColor, width = trendLineWidth, style = resolvedTrendStyle)
                    array.push(id = renderedLines, value = activeDownTrendLine)
        if not na(activeUpTrend)
            int upTrendStartBar = activeUpTrend.x1
            float upTrendStartLevel = activeUpTrend.y1
            int upTrendPivotBar = activeUpTrend.x2
            float upTrendPivotLevel = activeUpTrend.y2
            if upTrendStartBar >= sessionStartBarIndex
                int upTrendEndBar = bar_index + trendLineProjectionBars
                int upTrendVisibleStart = math.max(upTrendStartBar, trendVisibleWindowStart)
                if upTrendEndBar > upTrendVisibleStart
                    float upTrendVisibleStartY = f_lineValueAtBar(x1 = upTrendStartBar, y1 = upTrendStartLevel, x2 = upTrendPivotBar, y2 = upTrendPivotLevel, targetBar = upTrendVisibleStart)
                    float upTrendVisibleEndY = f_lineValueAtBar(x1 = upTrendStartBar, y1 = upTrendStartLevel, x2 = upTrendPivotBar, y2 = upTrendPivotLevel, targetBar = upTrendEndBar)
                    line activeUpTrendLine = line.new(x1 = upTrendVisibleStart, y1 = upTrendVisibleStartY, x2 = upTrendEndBar, y2 = upTrendVisibleEndY, xloc = xloc.bar_index, extend = extend.none, color = trendLineColor, width = trendLineWidth, style = resolvedTrendStyle)
                    array.push(id = renderedLines, value = activeUpTrendLine)
